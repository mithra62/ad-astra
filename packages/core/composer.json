{
    "name": "adastra/core",
    "description": "AdAstra core framework package.",
    "type": "library",
    "license": "proprietary",
    "version": "0.0.1",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "darkaonline/l5-swagger": "^9.0",
        "doctrine/annotations": "^2.0",
        "laravel/fortify": "^1.31",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.24",
        "laravolt/avatar": "^6.3",
        "mews/purifier": "^3.4",
        "moneyphp/money": "^4.9",
        "rcrowe/twigbridge": "^0.14.6",
        "spatie/laravel-permission": "^6.21",
        "spatie/laravel-webhook-client": "^3.4",
        "twig/twig": "^3.22"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "AdAstra\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AdAstra\\Providers\\AppServiceProvider",
                "AdAstra\\Providers\\BotBlockServiceProvider",
                "AdAstra\\Providers\\ContentServiceProvider",
                "AdAstra\\Providers\\FortifyServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
