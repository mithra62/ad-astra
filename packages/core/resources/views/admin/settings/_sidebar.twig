{% import 'admin._inc._ui' as ui %}

{% set current_handle = current_handle ?? '' %}
{% set items = [] %}
{% for domain in all_domains %}
    {% set items = items|merge([{
        label: domain.name,
        href: route('settings.show', domain.handle),
        icon: 'menu',
        active: current_handle == domain.handle
    }]) %}
{% endfor %}

{{ ui.section_nav('Settings', items) }}
