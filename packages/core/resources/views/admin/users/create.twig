{% extends 'admin._inc._layout' %}
{% import 'admin._inc._schema-tab-elements' as tabs %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Create User' %}
{% set page_heading = 'Create User' %}
{% set active_nav = 'members' %}
{% set active_user_section = 'users' %}
{% set has_secondary_sidebar = true %}
{% set active_secondary_nav = 'create' %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Users', href: route('users.index')},
        {label: 'Create User'}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.users._sidebar') }}
{% endblock %}

{% block content %}
    {% embed 'admin._inc._page-header' with {title: 'Create User', subtitle: 'Add a new user and assign one or more roles.'} %}
        {% block actions %}{% import 'admin._inc._ui' as ui %}{{ ui.button('Back to Users', route('users.index'), 'secondary', icon='chevron-left') }}{% endblock %}
    {% endembed %}

    <div class="rounded-lg border border-amber-200 bg-amber-50 p-4">
        <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            <div><p class="text-sm font-semibold text-amber-800">Invitation email will be sent after save.</p>
                <p class="mt-1 text-sm text-amber-700">Users can set their own password from the secure invite link.</p>
            </div>
        </div>
    </div>

    <form method="POST" action="{{ route('users.store') }}"
          class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
        {{ csrf_field() }}
        <div class="flex min-w-0 flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Profile</h5>
                </div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="email">Email Address <span
                                class="text-red-500">*</span></label>
                        <input value="{{ old('email') }}"
                               class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                               id="email" name="email" type="email" placeholder="jane@example.com">
                        <p class="mt-1 text-xs text-faint">This is used for login and notifications.</p>
                        {% if errors.has('email') %}<p id="email-error"
                                                       class="mt-1 text-xs text-red-600">{{ errors.first('email') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="username">Username</label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center rounded-l-md border border-r-0 border-edge bg-subtle px-3 text-xs text-muted">@</span>
                            <input value="{{ old('name') }}"
                                   class="w-full rounded-r-md border border-edge px-3 py-2 text-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="name" name="name" type="text" placeholder="jane.smith">
                        </div>
                        {% if errors.has('name') %}<p id="name-error"
                                                      class="mt-1 text-xs text-red-600">{{ errors.first('name') }}</p>{% endif %}
                    </div>
                </div>
            </div>


            {% if layout %}
                {% for tab in layout.tabs %}
                    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                        <div class="border-b border-edge px-5 py-3"><h5
                                class="text-sm font-semibold text-content">{{ tab.name }}</h5></div>
                        <div class="space-y-4 px-5 py-5">

                            {{ tabs.tabFields(tab, {}) }}
                        </div>
                    </div>
                {% endfor %}

            {% endif %}


            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Password</h5>
                </div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="email">Password <span
                                class="text-red-500">*</span></label>
                        <input value=""
                               class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                               id="password" name="password" type="password">
                        <p class="mt-1 text-xs text-faint">This is used for login and notifications.</p>
                        {% if errors.has('password') %}<p id="password-error"
                                                          class="mt-1 text-xs text-red-600">{{ errors.first('password') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="username">Username</label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center rounded-l-md border border-r-0 border-edge bg-subtle px-3 text-xs text-muted">@</span>
                            <input value=""
                                   class="w-full rounded-r-md border border-edge px-3 py-2 text-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="password_confirmation" name="password_confirmation" type="password">
                        </div>
                        {% if errors.has('password_confirmation') %}<p id="password_confirmation-error"
                                                                       class="mt-1 text-xs text-red-600">{{ errors.first('password_confirmation') }}</p>{% endif %}
                    </div>
                </div>
            </div>


            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Roles</h5>
                </div>
                <div class="grid grid-cols-1 gap-3 px-5 py-5 sm:grid-cols-2 xl:grid-cols-3">
                    {% for role in roles %}
                        <label
                            class="flex cursor-pointer items-start gap-3 rounded-lg border border-edge bg-surface p-4 shadow-sm transition hover:border-emerald-300 hover:bg-accent-soft/30">
                            <input type="checkbox" name="roles[]" value="{{ role.name }}"
                                   class="mt-0.5 rounded border-edge text-emerald-600 focus:ring-emerald-500"
                                {% if old('roles') %}
                                    {% for key, field in old('roles') %}
                                        {% if old('roles.' ~ key) == role.name %}checked{% endif %}
                                    {% endfor %}
                                {% endif %}
                            >
                            <span>
                            <span class="block text-sm font-medium text-content">{{ role.name }}</span>
                            <span class="mt-0.5 block text-xs leading-5 text-muted">{{ role.description }} fdsa</span>
                        </span>
                        </label>
                    {% endfor %}
                    {% if errors.has('roles') %}<p id="name-error"
                                                   class="mt-1 text-xs text-red-600">{{ errors.first('roles') }}</p>{% endif %}
                </div>
            </div>
        </div>

        <div class="flex min-w-0 flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Account</h5>
                </div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="status">Status</label>
                        <select
                            class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                            id="status" name="status">
                            <option value="active" selected>Active</option>
                            <option value="invited">Invited</option>
                            <option value="suspended">Suspended</option>
                        </select>
                    </div>
                    <label class="flex cursor-pointer items-center gap-2.5 text-sm text-content">
                        <input type="checkbox" name="send_invite" checked
                               class="rounded border-edge text-emerald-600 focus:ring-emerald-500">
                        Send invite email
                    </label>
                    <label class="flex cursor-pointer items-center gap-2.5 text-sm text-content">
                        <input type="checkbox" name="require_2fa"
                               class="rounded border-edge text-emerald-600 focus:ring-emerald-500">
                        Require two-factor authentication
                    </label>
                </div>

                <div class="border-t border-edge px-5 py-4">
                    <h6 class="mb-3 text-xs font-semibold uppercase tracking-wider text-faint">Authoring</h6>
                    <label class="flex cursor-pointer items-center gap-2.5 text-sm text-content">
                        <input type="checkbox" name="is_author" value="1"
                               id="is_author"
                               class="rounded border-edge text-emerald-600 focus:ring-emerald-500"
                               onchange="document.getElementById('author-display-name-wrap').classList.toggle('hidden', !this.checked)"
                            {{ old('is_author') ? 'checked' : '' }}>
                        Eligible as content author
                    </label>
                    <div id="author-display-name-wrap" class="mt-3 {{ old('is_author') ? '' : 'hidden' }}">
                        <label class="mb-1.5 block text-sm font-medium text-content" for="author_display_name">Display
                            name <span class="text-faint font-normal">(optional)</span></label>
                        <input type="text" name="author_display_name" id="author_display_name"
                               value="{{ old('author_display_name') }}"
                               class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                               placeholder="Defaults to username">
                        <p class="mt-1 text-xs text-faint">Shown in entry author pickers. Defaults to username if
                            blank.</p>
                    </div>
                </div>

                <div class="space-y-2 border-t border-edge px-5 py-4">
                    <button type="submit"
                            class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                        Create User
                    </button>
                    <a href="{{ route('users.index') }}"
                       class="block w-full rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-medium text-muted shadow-sm hover:bg-subtle">Cancel</a>
                </div>
            </div>
        </div>
    </form>
{% endblock %}
