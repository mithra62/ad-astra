{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Edit Access Tokens' %}
{% set page_heading = 'Access Tokens' %}
{% set active_nav = 'members' %}
{% set active_user_section = 'users' %}
{% set has_secondary_sidebar = true %}
{% set active_secondary_nav = 'tokens' %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Users', href: route('users.index')},
        {label: user.name, href: route('users.show', user)},
        {label: 'Access Tokens', href: route('users.token.index', user)},
        {label: 'Edit Access Token'}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.users._sidebar', {'user': user}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar"
         class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form"
                class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save
            Now
        </button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        {% embed 'admin._inc._page-header' with {title: 'Edit Access Token', subtitle: 'Update this access token.'} %}
            {% block actions %}{% import 'admin._inc._ui' as ui %}{{ ui.button('Back to Access Tokens', route('users.token.index', user), 'secondary', icon='chevron-left') }}{% endblock %}
        {% endembed %}

        <form id="general-create-form" method="POST"
              action="{{ route('users.token.update', {id: user.id, token_id: token.id}) }}"
              class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="name">Name <span
                                class="text-red-500">*</span></label>
                        <input value="{{ old('name', token.name) }}"
                               class="w-full rounded-md border {% if errors.has('name') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 "
                               id="name" name="name" type="text" placeholder="">
                        {% if errors.has('name') %}<p id="name-error"
                                                      class="mt-1 text-xs text-red-600">{{ errors.first('name') }}</p>{% endif %}
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="expires_at">Expires</label>
                        <input id="expires_at" name="expires_at" type="text" value="{{ old('expires_at') }}"
                               class="w-full rounded-md border {% if errors.has('expires_at') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}">
                        <p class="mt-1 text-xs text-faint">Lowercase letters, numbers, and hyphens only.</p>
                        {% if errors.has('expires_at') %}<p id="handle-error"
                                                            class="mt-1 text-xs text-red-600">{{ errors.first('expires_at') }}</p>{% endif %}
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('users.token.index', user) }}"
                   class="rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-semibold text-content shadow-sm hover:bg-subtle">Cancel</a>
                <button type="submit"
                        class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                    Edit Access Token
                </button>
            </div>
        </form>
    </div>
{% endblock %}









