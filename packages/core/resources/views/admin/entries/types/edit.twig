{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Edit Entry Type' %}
{% set page_heading = 'Entry Types' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'entries' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Entry Types', href: route('entries.types')},
        {label: type.name}
    ]) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar"
         class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-edit-form"
                class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save
            Now
        </button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">{{ type.name }}</h1>
                <p class="mt-1 text-sm text-muted">
                    {% if type.entryGroup %}
                        Assigned to <strong>{{ type.entryGroup.name }}</strong>
                    {% else %}
                        <span class="text-amber-600">Unattached</span> — not assigned to any Entry Group
                    {% endif %}
                </p>
            </div>
            <div class="flex gap-2">
                <a href="{{ route('entries.types.confirm', type.id) }}"
                   class="inline-flex items-center gap-1.5 self-start rounded-md border border-red-300 bg-surface px-3 py-2 text-sm font-semibold text-red-700 shadow-sm hover:bg-red-50 sm:self-auto">
                    Delete
                </a>
                <a href="{{ route('entries.types') }}"
                   class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back to Entry Types
                </a>
            </div>
        </div>

        <form id="general-edit-form" method="POST" action="{{ route('entries.types.update', type.id) }}"
              class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    {{ forms.input(name='name', label='Name', required=true, value=type.name) }}
                    {{ forms.input('handle', 'Handle', required=true, value=type.handle, description="Lowercase letters, numbers, and hyphens only.") }}

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content"
                               for="entry_behavior_id">Behavior</label>
                        <select
                            class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm {% if errors.has('entry_behavior_id') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}"
                            id="entry_behavior_id" name="entry_behavior_id">
                            <option value="">— None (General) —</option>
                            {% for behavior in behaviors %}
                                <option value="{{ behavior.id }}"
                                        {% if old('entry_behavior_id', type.entry_behavior_id) == behavior.id %}selected{% endif %}>
                                    {{ behavior.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('entry_behavior_id') %}
                            <p id="entry_behavior_id-error"
                               class="mt-1 text-xs text-red-600">{{ errors.first('entry_behavior_id') }}</p>
                        {% endif %}
                        <p class="mt-1 text-xs text-faint">
                            Determines lifecycle hooks (e.g. reading time, stock status). Leave blank for
                            general-purpose behavior.
                        </p>
                    </div>

                    {{ forms.toggle(
                        name: 'has_entry_tree',
                        label: 'Allow Entry Tree',
                        value: type.has_entry_tree,
                        description: 'Allow Entries assigned to this Entry Type to have parent / child relationships.',
                        checked_value: '1',
                        id: 'has_entry_tree',
                        error_key: 'has_entry_tree',
                        copy_align: 'inline'
                    ) }}

                    {% set entry_tree_enabled = old('has_entry_tree', type.has_entry_tree) == '1' or type.has_entry_tree %}
                    <div id="entry-tree-settings"
                         class="{% if not entry_tree_enabled %}hidden {% endif %}rounded-lg border border-edge bg-subtle px-4 py-4">
                        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-content" for="max_depth">Max
                                    Depth</label>
                                <input
                                    class="w-full rounded-md border bg-surface px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:outline-none focus:ring-2 {% if errors.has('max_depth') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}border-edge focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}"
                                    id="max_depth" name="max_depth" type="number" min="0"
                                    value="{{ old('max_depth', type.max_depth) }}"
                                    {% if errors.has('max_depth') %}aria-invalid="true"
                                    aria-describedby="max_depth-error"{% endif %}>
                                {% if errors.has('max_depth') %}
                                    <p id="max_depth-error"
                                       class="mt-1 text-xs text-red-600">{{ errors.first('max_depth') }}</p>
                                {% endif %}
                            </div>

                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-content" for="default_template">Default
                                    Template</label>
                                <input
                                    class="w-full rounded-md border bg-surface px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:outline-none focus:ring-2 {% if errors.has('default_template') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}border-edge focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}"
                                    id="default_template" name="default_template" type="text"
                                    value="{{ old('default_template', type.default_template) }}"
                                    placeholder="entries/default"
                                    {% if errors.has('default_template') %}aria-invalid="true"
                                    aria-describedby="default_template-error"{% endif %}>
                                {% if errors.has('default_template') %}
                                    <p id="default_template-error"
                                       class="mt-1 text-xs text-red-600">{{ errors.first('default_template') }}</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="field_layout_id">Field
                            Layout</label>
                        <select
                            class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm {% if errors.has('field_layout_id') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}"
                            id="field_layout_id" name="field_layout_id">
                            <option value="">— None —</option>
                            {% for layout in field_layouts %}
                                <option value="{{ layout.id }}"
                                        {% if old('field_layout_id', type.field_layout_id) == layout.id %}selected{% endif %}>
                                    {{ layout.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('field_layout_id') %}
                            <p id="field_layout_id-error"
                               class="mt-1 text-xs text-red-600">{{ errors.first('field_layout_id') }}</p>
                        {% endif %}
                        <p class="mt-1 text-xs text-faint">
                            Fields from this layout are specific to this entry type. Group-level fields are always
                            included.
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('entries.types') }}"
                   class="rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-semibold text-content shadow-sm hover:bg-subtle">Cancel</a>
                <button type="submit"
                        class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var entryTreeToggle = document.getElementById('has_entry_tree');
            var entryTreeSettings = document.getElementById('entry-tree-settings');

            if (entryTreeToggle && entryTreeSettings) {
                var syncEntryTreeSettings = function () {
                    entryTreeSettings.classList.toggle('hidden', !entryTreeToggle.checked);
                };
                entryTreeToggle.addEventListener('change', syncEntryTreeSettings);
                syncEntryTreeSettings();
            }
        });
    </script>
{% endblock %}
