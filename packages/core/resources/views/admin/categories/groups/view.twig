{% extends 'admin._inc._layout' %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Category Groups' %}
{% set page_heading = 'Category Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'categories' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Category Groups', href: route('categories.groups')},
        {label: group.name}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.categories._sidebar', {active: group.id}) }}
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        {% embed 'admin._inc._page-header' with {title: group.name, subtitle: 'Manage the categories that belong to this group.'} %}
            {% block actions %}
                {% import 'admin._inc._ui' as ui %}
                {{ ui.button('Edit Group', route('categories.groups.edit', group.id), 'secondary', icon='pencil') }}
                {{ ui.button('Create Category', route('categories.create', {group_id: group.id}), icon='plus') }}
            {% endblock %}
        {% endembed %}

        {% embed 'admin._inc._card' with {title: 'Category List', subtitle: 'No Categories match the current view.'} %}
            {% block body %}
                {% import 'admin._inc._ui' as ui %}
                {% if categories.count >= 1 %}
                    {% embed 'admin._inc._table' with {columns: [
                        {label: 'Name'},
                        {label: 'Children', class: 'hidden sm:table-cell'},
                        {label: 'Last Modified'},
                        {label: 'Created', class: 'hidden md:table-cell'},
                        {label: 'Actions', class: 'text-right'}
                    ]} %}
                        {% block rows %}
                            {% import 'admin._inc._ui' as ui %}
                            {% for category in categories %}
                                <tr class="hover:bg-subtle">
                                    <td class="px-4 py-3.5">
                                        <p class="font-medium text-content">{{ category.name }}</p>
                                        <p class="mt-0.5 text-xs text-faint">{{ category.handle }}</p>
                                    </td>
                                    <td class="hidden px-4 py-3.5 text-muted sm:table-cell">{{ category.children.count() }}</td>
                                    <td class="px-4 py-3.5">{{ category.created_at.format('F j, Y') }}</td>
                                    <td class="hidden px-4 py-3.5 text-faint md:table-cell">{{ category.created_at.format('F j, Y') }}</td>
                                    <td class="px-4 py-3.5">
                                        <div class="flex items-center justify-end gap-1">
                                            <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:bg-subtle hover:text-content"
                                               href="{{ route('categories.show', category) }}"
                                               title="View">{{ ui.icon('eye') }}<span class="sr-only">View</span></a>
                                            <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:bg-subtle hover:text-content"
                                               href="{{ route('categories.edit', category) }}"
                                               title="Edit">{{ ui.icon('pencil') }}<span class="sr-only">Edit</span></a>
                                            <a class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600"
                                               href="{{ route('categories.confirm', category) }}"
                                               title="Delete">{{ ui.icon('trash') }}<span class="sr-only">Delete</span></a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    <div class="border-t border-edge px-5 py-3">{{ categories.links() }}</div>
                {% else %}
                    {{ ui.empty_state(
                        'No Categories found',
                        'Create your first category in this group.',
                        'documents',
                        {label: 'Create Category', href: route('categories.create', {group_id: group.id})}
                    ) }}
                {% endif %}
            {% endblock %}
        {% endembed %}
    </div>
{% endblock %}
