{% import 'admin._inc._ui' as ui %}

{% set items = [] %}
{% for group in groups %}
    {% set items = items|merge([{
        label: group.name ~ ' (' ~ group.categories.count() ~ ')',
        href: route('categories.groups.show', group),
        icon: 'menu',
        active: active == group.id
    }]) %}
{% endfor %}

{{ ui.section_nav('Category Groups', items) }}
