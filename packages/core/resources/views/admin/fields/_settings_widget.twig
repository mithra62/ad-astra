{% import 'admin::_inc/_form-fields' as f %}

{% if def.type == 'text' %}
    {{ f.input('settings[' ~ handle ~ ']', def.label, value, 'text', def.instructions|default('')) }}

{% elseif def.type == 'number' %}
    {{ f.input('settings[' ~ handle ~ ']', def.label, value, 'number', def.instructions|default('')) }}

{% elseif def.type == 'textarea' %}
    {{ f.textarea('settings[' ~ handle ~ ']', def.label, value, null, def.instructions|default('')) }}

{% elseif def.type == 'toggle' %}
    {{ f.toggle('settings[' ~ handle ~ ']', def.label, value, def.instructions|default('')) }}

{% elseif def.type == 'select' %}
    {{ f.select('settings[' ~ handle ~ ']', def.label, def.options|default([]), value, def.instructions|default('')) }}

{% elseif def.type == 'select_multiple' %}
    {{ f.select('settings[' ~ handle ~ '][]', def.label, def.options|default([]), value, def.instructions|default(''), null, null, true) }}

{% elseif def.type == 'slider' %}
    {{ f.slider('settings[' ~ handle ~ ']', def.label, value, def.min|default(0), def.max|default(100), def.step|default(1), def.instructions|default(''), null, def.suffix|default('')) }}

{% elseif def.type == 'color' %}
    {{ f.color('settings[' ~ handle ~ ']', def.label, value, def.instructions|default('')) }}

{% elseif def.type == 'key_value' %}
    {# Two-column repeater: key + label pairs. matrix.scripts() is NOT called here. #}
    {% import 'admin::_inc/_structured-rows' as matrix %}
    {{ matrix.field(
        'settings[' ~ handle ~ ']',
        def.label,
        [{handle: 'key', label: 'Key', type: 'text'}, {handle: 'label', label: 'Label', type: 'text'}],
        value,
        def.instructions|default(''),
        null, null,
        'Add option',
        0
    ) }}

{% elseif def.type == 'structured_rows_columns' %}
    {{ include('admin::fields/_settings_structured_rows_columns', {handle: handle, def: def, value: value}) }}

{% endif %}
