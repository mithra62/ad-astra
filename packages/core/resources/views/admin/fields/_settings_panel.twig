{% if settings_form is empty %}
    <p class="text-sm italic text-faint">This field type has no configurable settings.</p>
{% else %}
    <div class="space-y-4">
        {% for handle, def in settings_form %}
            {{ include('admin::blueprint/_blueprint_widget', {
                handle: handle,
                def: def,
                value: current_values[handle] is defined ? current_values[handle] : def.default,
                name_prefix: 'settings'
            }) }}
        {% endfor %}
    </div>
{% endif %}
