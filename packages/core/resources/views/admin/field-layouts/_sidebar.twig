<input id="secnav-toggle" type="checkbox">

<label for="secnav-toggle"
       class="flex cursor-pointer items-center justify-between border-b border-edge bg-surface px-4 py-2.5 text-sm font-medium text-muted hover:bg-subtle lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
    <span class="secnav-chevron text-faint">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
</label>

<div id="secondary-nav-panel" class="hidden border-b border-edge bg-surface px-4 py-3 lg:hidden">
    <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
        <a class="flex items-center gap-2 rounded-md bg-accent-soft px-3 py-2 text-sm font-medium text-accent"
           href="index.twig">All Articles</a>
        {% for group in groups %}
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle"
               href="create-article.twig">New Article</a>
        {% endfor %}
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle"
           href="categories.twig">Categories</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="#">Tags</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="#">Authors</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle"
           href="reorder-articles.twig">Reorder</a>
    </nav>
</div>

<aside class="hidden h-fit lg:block">
    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
        <div class="border-b border-edge px-4 py-3">
            <h5 class="text-sm font-semibold text-content">Field Layouts</h5>
        </div>
        <nav class="p-2">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle"
               href="{{ route('field-layouts') }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
                </svg>
                All Layouts
            </a>
            {% for layout in layouts %}
                <a href="{{ route('field-layouts.edit', layout) }}"
                   class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium {% if active == layout.id %}bg-accent-soft text-accent{% else %}text-muted hover:bg-subtle{% endif %}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
                    </svg>
                    {{ layout.name }}
                </a>
                {% if active == layout.id and layout.tabs is defined and layout.tabs|length > 0 %}
                    <div class="my-1 border-t border-edge"></div>
                    <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-faint">Tabs</p>
                    {% for tab in layout.tabs %}
                        <a href="{{ route('field-layouts.tabs.fields', {layout_id: layout.id, tab_id: tab.id}) }}"
                           class="ml-2 mt-0.5 flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium {% if active_tab is defined and active_tab == tab.id %}bg-accent-soft text-accent{% else %}text-muted hover:bg-subtle{% endif %}">
                            {{ tab.name }}
                        </a>
                    {% endfor %}
                    <div class="my-1 border-t border-edge"></div>
                {% endif %}
            {% endfor %}
        </nav>
    </div>
</aside>

