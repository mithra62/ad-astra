{{ include('admin._inc._header', {title: 'Remove Field from Tab'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Field Layouts</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts') }}">Field Layouts</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('field-layouts.edit', layout) }}">{{ layout.name }}</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}">{{ tab.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500"
                               href="{{ route('field-layouts.tabs.elements.confirm', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}">Remove
                                Field</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.field-layouts._sidebar', {active: layout.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <form method="POST"
                      action="{{ route('field-layouts.tabs.elements.destroy', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}"
                      class="row g-3 needs-validation" novalidate>
                    {{ csrf_field() }}
                    {{ method_field('DELETE') }}
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h5>Remove Field from Tab</h5>
                            </div>
                            <div class="card-body">
                                <h6>Remove <strong>{{ element.field.label ?: element.field.name }}</strong> from the
                                    <strong>{{ tab.name }}</strong> tab?</h6>
                                <p class="text-secondary">
                                    This removes the field from this tab's layout. The field itself will not be deleted
                                    and can be re-added at any time.
                                </p>
                            </div>
                            <div class="card-footer">
                                <div
                                    class="switch-border-primary switch-primary switch-unchecked-primary my-3 card-body main-switch main-switch-color">
                                    <input class="toggle switch-border-primary" name="confirm_removal"
                                           id="confirm_removal" type="checkbox">
                                    <label for="confirm_removal">Confirm Removal</label>
                                    {% if errors.has('confirm_removal') %}
                                        <p class="text-danger">{{ errors.first('confirm_removal') }}</p>
                                    {% endif %}
                                </div>
                                <div class="col-12 float-end">
                                    <a href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}"
                                       class="btn btn-secondary">Cancel</a>
                                    <button class="btn btn-danger ms-2" type="submit">Remove Field</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
