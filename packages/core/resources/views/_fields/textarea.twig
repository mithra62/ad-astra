<textarea
    class="w-full rounded-md border border-edge bg-surface text-content px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
    id="{{ id }}" name="fields[{{ field.handle }}]"
    placeholder="{{ field.instructions }}"
    rows="{{ field.settings.rows }}">{{ old('fields.' ~ field.handle, value) }}</textarea>
