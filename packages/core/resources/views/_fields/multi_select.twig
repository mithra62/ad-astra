{% set input_name = 'fields[' ~ field.handle ~ '][]' %}
{% set old_values = old('fields.' ~ field.handle) %}
{% set current_values = old_values is not null ? old_values : (value is iterable ? value : []) %}

{% if display == 'multiselect' %}
    <select id="{{ id }}" name="{{ input_name }}" multiple
            class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
        {% for option in options %}
            {% set option_value = option.value|default(option.key|default('')) %}
            {% set option_label = option.label|default(option_value) %}
            <option value="{{ option_value }}"
                    {% if option_value in current_values %}selected{% endif %}>{{ option_label }}</option>
        {% endfor %}
    </select>
{% else %}
    <div class="space-y-2">
        {% for option in options %}
            {% set option_value = option.value|default(option.key|default('')) %}
            {% set option_label = option.label|default(option_value) %}
            {% set checkbox_id = id ~ '_' ~ loop.index %}
            <label class="flex cursor-pointer items-center gap-2" for="{{ checkbox_id }}">
                <input id="{{ checkbox_id }}" type="checkbox" name="{{ input_name }}" value="{{ option_value }}"
                       class="rounded border-edge text-emerald-600 focus:ring-emerald-500"
                       {% if option_value in current_values %}checked{% endif %}>
                <span class="text-sm text-content">{{ option_label }}</span>
            </label>
        {% endfor %}
    </div>
{% endif %}
