{% set input_name = 'fields[' ~ field.handle ~ ']' %}
{% set current_value = old('fields.' ~ field.handle, value|default('')) %}
{% if has_subdivisions %}
    <select id="{{ id }}" name="{{ input_name }}"
        class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm transition focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
        {% if placeholder %}
            <option value="">{{ placeholder }}</option>
        {% endif %}
        {% for option in subdivision_options %}
            <option value="{{ option.code }}" {% if current_value == option.code %}selected{% endif %}>{{ option.name }}</option>
        {% endfor %}
    </select>
{% else %}
    <input value="{{ current_value }}" type="text" id="{{ id }}" name="{{ input_name }}" maxlength="100"
        class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm transition placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
        placeholder="Enter {{ country_name }} subdivision">
{% endif %}
