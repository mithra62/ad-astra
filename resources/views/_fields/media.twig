{% set field_id = (input_name|default('media'))|replace({'[': '_', ']': '', '.': '_'}) %}
{% set multiple = (max is null or max > 1) %}
{% set prepopulated = value is not empty ? value : [] %}
{% set library_payload = [] %}
{% for lib in libraries %}
    {% set library_payload = library_payload|merge([{
        'id': lib.id,
        'name': lib.name,
        'upload_url': route('media.libraries.upload', lib.id)
    }]) %}
{% endfor %}

<div data-media-field
     id="{{ field_id }}_wrapper"
     data-input-name="{{ input_name|default('') }}"
     data-max="{{ max is not null ? max : '' }}"
     data-multiple="{{ multiple ? 'true' : 'false' }}"
     data-picker-url="{{ picker_url }}"
     data-libraries='{{ library_payload|json_encode|e('html_attr') }}'>

    {# Selected chips — drag to reorder #}
    <div class="mb-3 flex flex-wrap gap-2" id="{{ field_id }}_chips" aria-label="Selected media">
        {% for media in prepopulated %}
            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"
                  draggable="true"
                  data-chip="{{ media.id }}"
                  data-name="{{ media.original_name }}">
                {{ media.original_name }}
                <button type="button"
                        class="ml-1 rounded-full text-slate-400 hover:text-red-500 focus:outline-none focus:ring-1 focus:ring-red-400"
                        aria-label="Remove {{ media.original_name }}">×</button>
                <input type="hidden" name="{{ input_name|default('') }}[]" value="{{ media.id }}">
            </span>
        {% endfor %}
    </div>

    {% if libraries|length > 0 %}
        <button type="button"
                id="{{ field_id }}_open"
                class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
            Browse / Upload
        </button>
    {% else %}
        <p class="mt-1 text-xs text-amber-600">No libraries configured — set at least one library in the field settings.</p>
    {% endif %}

    {# Modal #}
    <div id="{{ field_id }}_modal"
         class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4"
         role="dialog" aria-modal="true" aria-labelledby="{{ field_id }}_modal_title">
        <div class="flex max-h-[90vh] w-full max-w-4xl flex-col rounded-lg bg-white shadow-xl">
            <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
                <h3 id="{{ field_id }}_modal_title" class="text-sm font-semibold text-slate-800">Select Media</h3>
                <button type="button"
                        class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-700"
                        data-media-close aria-label="Close">×</button>
            </div>

            {# Tabs row: Browse / Upload + Library selector #}
            <div class="flex flex-wrap items-center gap-2 border-b border-slate-200 px-4 py-2">
                <div role="tablist" class="inline-flex rounded-md bg-slate-100 p-0.5 text-xs font-medium">
                    <button type="button" role="tab" data-media-tab="browse"
                            class="rounded px-3 py-1 text-slate-700 data-[active=true]:bg-white data-[active=true]:shadow-sm"
                            data-active="true">Browse</button>
                    <button type="button" role="tab" data-media-tab="upload"
                            class="rounded px-3 py-1 text-slate-700 data-[active=true]:bg-white data-[active=true]:shadow-sm">Upload</button>
                </div>

                <select data-media-library-select
                        class="ml-auto rounded-md border border-slate-300 bg-white px-2 py-1 text-xs text-slate-700 focus:border-emerald-500 focus:outline-none">
                    {% for lib in libraries %}
                        <option value="{{ lib.id }}">{{ lib.name }}</option>
                    {% endfor %}
                </select>

                <input type="search"
                       data-media-search
                       placeholder="Search…"
                       class="rounded-md border border-slate-300 px-2 py-1 text-xs focus:border-emerald-500 focus:outline-none">
            </div>

            {# Browse panel #}
            <div data-media-panel="browse" class="flex-1 overflow-auto p-4">
                <div data-media-grid class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6"></div>
                <div data-media-empty class="hidden py-8 text-center text-sm text-slate-400">No media in this library yet.</div>
                <div data-media-loading class="hidden py-8 text-center text-sm text-slate-400">Loading…</div>
                <div data-media-pagination class="mt-4 flex items-center justify-between text-xs text-slate-500"></div>
            </div>

            {# Upload panel #}
            <div data-media-panel="upload" class="hidden flex-1 overflow-auto p-4">
                <p class="mb-2 text-xs text-slate-500">Uploads go to the library selected above.</p>
                <input type="file" data-media-upload-input multiple
                       class="block w-full text-sm text-slate-700 file:mr-3 file:rounded-md file:border-0 file:bg-emerald-600 file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-white hover:file:bg-emerald-700">
                <div data-media-upload-status class="mt-3 space-y-1 text-xs"></div>
            </div>

            <div class="flex items-center justify-end gap-2 border-t border-slate-200 px-4 py-3">
                <span data-media-selected-count class="mr-auto text-xs text-slate-500">0 selected</span>
                <button type="button" data-media-close
                        class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
                <button type="button" data-media-confirm
                        class="rounded-md bg-emerald-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-700">Add selected</button>
            </div>
        </div>
    </div>

    <div id="{{ field_id }}_error_area" role="alert" class="mt-1 hidden text-xs text-red-600"></div>
</div>

<script>
(function () {
    var wrapper = document.getElementById('{{ field_id }}_wrapper');
    if (!wrapper || wrapper.dataset.mediaBound === '1') return;
    wrapper.dataset.mediaBound = '1';

    var inputName  = wrapper.dataset.inputName;
    var maxAttr    = wrapper.dataset.max;
    var max        = maxAttr !== '' ? parseInt(maxAttr, 10) : null;
    var pickerUrl  = wrapper.dataset.pickerUrl;
    var libraries  = JSON.parse(wrapper.dataset.libraries || '[]');
    var csrfToken  = '{{ csrf_token() }}';

    var chipsEl    = document.getElementById('{{ field_id }}_chips');
    var modal      = document.getElementById('{{ field_id }}_modal');
    var openBtn    = document.getElementById('{{ field_id }}_open');
    var errorArea  = document.getElementById('{{ field_id }}_error_area');

    if (!openBtn || !modal) return;

    var gridEl       = modal.querySelector('[data-media-grid]');
    var emptyEl      = modal.querySelector('[data-media-empty]');
    var loadingEl    = modal.querySelector('[data-media-loading]');
    var paginationEl = modal.querySelector('[data-media-pagination]');
    var librarySel   = modal.querySelector('[data-media-library-select]');
    var searchInput  = modal.querySelector('[data-media-search]');
    var confirmBtn   = modal.querySelector('[data-media-confirm]');
    var selectedCt   = modal.querySelector('[data-media-selected-count]');
    var browsePanel  = modal.querySelector('[data-media-panel="browse"]');
    var uploadPanel  = modal.querySelector('[data-media-panel="upload"]');
    var browseTab    = modal.querySelector('[data-media-tab="browse"]');
    var uploadTab    = modal.querySelector('[data-media-tab="upload"]');
    var uploadInput  = modal.querySelector('[data-media-upload-input]');
    var uploadStatus = modal.querySelector('[data-media-upload-status]');

    var modalSelection = new Map(); // id -> { id, name }
    var currentPage    = 1;
    var currentQuery   = '';
    var lastPage       = 1;
    var debounceTimer  = null;

    // ---------- Helpers ----------
    function chipIds() {
        return Array.from(chipsEl.querySelectorAll('[data-chip]'))
            .map(function (el) { return parseInt(el.dataset.chip, 10); });
    }

    function chipCount() {
        return chipsEl.querySelectorAll('[data-chip]').length;
    }

    function showError(msg) {
        errorArea.textContent = msg;
        errorArea.classList.remove('hidden');
        setTimeout(function () { errorArea.classList.add('hidden'); }, 6000);
    }

    function uploadStatusLine(text, ok) {
        var line = document.createElement('div');
        line.textContent = text;
        line.className = ok ? 'text-emerald-600' : 'text-red-600';
        uploadStatus.appendChild(line);
    }

    function addChip(id, name) {
        if (max === 1) { chipsEl.innerHTML = ''; }
        if (chipIds().indexOf(id) !== -1) { return; }

        var span = document.createElement('span');
        span.className = 'inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700';
        span.draggable = true;
        span.dataset.chip = id;
        span.dataset.name = name;
        span.appendChild(document.createTextNode(name + ' '));

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ml-1 rounded-full text-slate-400 hover:text-red-500 focus:outline-none focus:ring-1 focus:ring-red-400';
        btn.setAttribute('aria-label', 'Remove ' + name);
        btn.textContent = '×';
        btn.addEventListener('click', function () { span.remove(); });
        span.appendChild(btn);

        var hidden = document.createElement('input');
        hidden.type  = 'hidden';
        hidden.name  = inputName + '[]';
        hidden.value = id;
        span.appendChild(hidden);

        bindChipDrag(span);
        chipsEl.appendChild(span);
    }

    // ---------- Drag-to-reorder chips ----------
    var dragSrc = null;
    function bindChipDrag(el) {
        el.addEventListener('dragstart', function (e) {
            dragSrc = el;
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', el.dataset.chip);
        });
        el.addEventListener('dragover', function (e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; });
        el.addEventListener('drop', function (e) {
            e.preventDefault();
            if (!dragSrc || dragSrc === el) return;
            var rect = el.getBoundingClientRect();
            var after = (e.clientX - rect.left) > rect.width / 2;
            chipsEl.insertBefore(dragSrc, after ? el.nextSibling : el);
            dragSrc = null;
        });
    }
    chipsEl.querySelectorAll('[data-chip]').forEach(bindChipDrag);
    chipsEl.querySelectorAll('[data-chip] button').forEach(function (btn) {
        btn.addEventListener('click', function () { btn.closest('[data-chip]').remove(); });
    });

    // ---------- Modal open/close ----------
    function openModal() {
        modalSelection = new Map();
        currentPage = 1;
        currentQuery = '';
        if (searchInput) searchInput.value = '';
        showTab('browse');
        updateSelectedCount();
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        loadGrid();
    }
    function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        uploadStatus.innerHTML = '';
    }

    openBtn.addEventListener('click', openModal);
    modal.querySelectorAll('[data-media-close]').forEach(function (b) {
        b.addEventListener('click', closeModal);
    });
    modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
    });

    // ---------- Tabs ----------
    function showTab(name) {
        var browseActive = (name === 'browse');
        browseTab.dataset.active = browseActive ? 'true' : 'false';
        uploadTab.dataset.active = browseActive ? 'false' : 'true';
        browsePanel.classList.toggle('hidden', !browseActive);
        uploadPanel.classList.toggle('hidden',  browseActive);
    }
    browseTab.addEventListener('click', function () { showTab('browse'); });
    uploadTab.addEventListener('click', function () { showTab('upload'); });

    // ---------- Picker grid ----------
    function libraryId() { return parseInt(librarySel.value, 10); }

    function setLoading(on) {
        loadingEl.classList.toggle('hidden', !on);
        if (on) emptyEl.classList.add('hidden');
    }

    function loadGrid() {
        setLoading(true);
        var url = new URL(pickerUrl, window.location.origin);
        url.searchParams.set('library_id[]', String(libraryId()));
        url.searchParams.set('page', String(currentPage));
        if (currentQuery) url.searchParams.set('q', currentQuery);

        fetch(url.toString(), { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (json) {
                setLoading(false);
                renderGrid(json.data || []);
                renderPagination(json.meta || {});
            })
            .catch(function () {
                setLoading(false);
                emptyEl.textContent = 'Failed to load media.';
                emptyEl.classList.remove('hidden');
            });
    }

    function renderGrid(items) {
        gridEl.innerHTML = '';
        if (items.length === 0) {
            emptyEl.textContent = 'No media match.';
            emptyEl.classList.remove('hidden');
            return;
        }
        emptyEl.classList.add('hidden');

        items.forEach(function (item) {
            var card = document.createElement('button');
            card.type = 'button';
            card.className = 'group relative flex flex-col overflow-hidden rounded-md border border-slate-200 text-left transition hover:border-emerald-400 focus:border-emerald-500 focus:outline-none';
            card.dataset.mediaId = item.id;

            var thumb = document.createElement('div');
            thumb.className = 'aspect-square w-full bg-slate-100';
            if (item.thumbnail_url) {
                var img = document.createElement('img');
                img.src = item.thumbnail_url;
                img.alt = item.original_name || '';
                img.loading = 'lazy';
                img.className = 'h-full w-full object-cover';
                thumb.appendChild(img);
            } else {
                var icon = document.createElement('div');
                icon.className = 'flex h-full w-full items-center justify-center text-xs text-slate-400';
                icon.textContent = (item.mime_type || 'file').split('/').pop();
                thumb.appendChild(icon);
            }
            card.appendChild(thumb);

            var label = document.createElement('div');
            label.className = 'truncate px-2 py-1 text-xs text-slate-700';
            label.textContent = item.original_name || item.name;
            card.appendChild(label);

            updateCardState(card, item);

            card.addEventListener('click', function () {
                toggleSelect(item, card);
            });
            gridEl.appendChild(card);
        });
    }

    function updateCardState(card, item) {
        var selected = modalSelection.has(item.id) || chipIds().indexOf(item.id) !== -1;
        card.classList.toggle('ring-2',           selected);
        card.classList.toggle('ring-emerald-500', selected);
        card.setAttribute('aria-pressed', selected ? 'true' : 'false');
    }

    function toggleSelect(item, card) {
        if (modalSelection.has(item.id)) {
            modalSelection.delete(item.id);
        } else {
            // Disallow exceeding max (existing chips + modal selection)
            if (max !== null) {
                var projected = chipCount() + modalSelection.size + 1;
                // Don't double-count items already in chips
                if (chipIds().indexOf(item.id) === -1 && projected > max) {
                    showError('Maximum ' + max + ' item(s) reached.');
                    return;
                }
            }
            modalSelection.set(item.id, { id: item.id, name: item.original_name || item.name });
        }
        updateCardState(card, item);
        updateSelectedCount();
    }

    function updateSelectedCount() {
        var n = modalSelection.size;
        selectedCt.textContent = n + ' selected';
    }

    function renderPagination(meta) {
        paginationEl.innerHTML = '';
        var total    = meta.total | 0;
        var page     = meta.current_page || 1;
        lastPage     = meta.last_page || 1;

        var info = document.createElement('span');
        info.textContent = total + ' item' + (total === 1 ? '' : 's');
        paginationEl.appendChild(info);

        var nav = document.createElement('div');
        nav.className = 'flex items-center gap-1';

        var prev = document.createElement('button');
        prev.type = 'button';
        prev.textContent = '‹';
        prev.className = 'rounded border border-slate-300 px-2 py-0.5 disabled:opacity-40';
        prev.disabled = page <= 1;
        prev.addEventListener('click', function () { if (currentPage > 1) { currentPage--; loadGrid(); } });
        nav.appendChild(prev);

        var pageInfo = document.createElement('span');
        pageInfo.textContent = page + ' / ' + lastPage;
        pageInfo.className = 'px-1';
        nav.appendChild(pageInfo);

        var next = document.createElement('button');
        next.type = 'button';
        next.textContent = '›';
        next.className = 'rounded border border-slate-300 px-2 py-0.5 disabled:opacity-40';
        next.disabled = page >= lastPage;
        next.addEventListener('click', function () { if (currentPage < lastPage) { currentPage++; loadGrid(); } });
        nav.appendChild(next);

        paginationEl.appendChild(nav);
    }

    librarySel.addEventListener('change', function () {
        currentPage = 1;
        loadGrid();
    });

    if (searchInput) {
        searchInput.addEventListener('input', function () {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function () {
                currentQuery = searchInput.value.trim();
                currentPage  = 1;
                loadGrid();
            }, 300);
        });
    }

    // ---------- Confirm selection ----------
    confirmBtn.addEventListener('click', function () {
        modalSelection.forEach(function (item) { addChip(item.id, item.name); });
        closeModal();
    });

    // ---------- Upload ----------
    if (uploadInput) {
        uploadInput.addEventListener('change', function () {
            var files = Array.from(this.files);
            this.value = '';
            var targetLib = libraries.find(function (l) { return l.id === libraryId(); });
            if (!targetLib) { uploadStatusLine('No library selected.', false); return; }

            files.forEach(function (file) {
                var data = new FormData();
                data.append('file', file);
                data.append('_token', csrfToken);

                uploadStatusLine('Uploading ' + file.name + '…', true);

                fetch(targetLib.upload_url, {
                    method:  'POST',
                    headers: { 'Accept': 'application/json' },
                    body:    data,
                })
                .then(function (r) { return r.json(); })
                .then(function (json) {
                    if (json.id) {
                        // The user picked this exact file — commit it to the
                        // field immediately as a chip rather than parking it
                        // in modalSelection (which would require a separate
                        // "Add selected" click to take effect).
                        if (max !== null && max > 1 && chipCount() >= max && chipIds().indexOf(json.id) === -1) {
                            uploadStatusLine('✗ Maximum ' + max + ' item(s) reached.', false);
                            return;
                        }
                        uploadStatusLine('✓ ' + (json.name || file.name), true);
                        addChip(json.id, json.name || file.name);
                        // Refresh grid so the new media appears for any
                        // subsequent selection.
                        if (browsePanel.classList.contains('hidden') === false) {
                            currentPage = 1;
                            loadGrid();
                        }
                    } else {
                        uploadStatusLine('✗ ' + (json.error || 'Upload failed.'), false);
                    }
                })
                .catch(function () { uploadStatusLine('✗ Upload failed.', false); });
            });
        });
    }
})();
</script>
