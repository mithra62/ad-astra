<div class="input-group">
    <input type="color" class="form-control form-control-color" id="{{ id }}_picker"
           value="{{ old('fields.' ~ field.slug, value) ?? '#000000' }}"
           oninput="document.getElementById('{{ id }}').value = this.value">
    <input type="text" class="{{ class ?? 'form-control' }}" id="{{ id }}"
           name="fields[{{ field.slug }}]"
           value="{{ old('fields.' ~ field.slug, value) }}"
           placeholder="#000000"
           oninput="document.getElementById('{{ id }}_picker').value = this.value">
</div>
