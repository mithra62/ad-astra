<div id="tab-taxonomy" class="tab-panel" role="tabpanel" aria-labelledby="btn-taxonomy" data-tab-panel="taxonomy" hidden>

    <div class="divide-y divide-slate-100">

        <!-- Authors -->
        <div class="px-5 py-5">
            <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-faint">Authors</h5>
            <label class="mb-1.5 block text-sm font-medium text-content" for="authors">Assign Authors</label>
            {% if authors is not empty %}
                <select class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                        id="authors" name="authors[]" multiple size="5" data-tab-dirty="taxonomy">
                    {% for author in authors %}
                        <option value="{{ author.user_id }}"
                            {% if entry is defined %}
                                {% for assigned in entry.authors %}
                                    {% if assigned.user_id == author.user_id %}selected{% endif %}
                                {% endfor %}
                            {% elseif old('authors') %}
                                {% for key, val in old('authors') %}
                                    {% if val == author.user_id %}selected{% endif %}
                                {% endfor %}
                            {% endif %}
                        >{{ author.display_name }}</option>
                    {% endfor %}
                </select>
                <p class="mt-1 text-xs text-faint">Hold Ctrl / Cmd to select multiple authors.</p>
            {% else %}
                <p class="text-sm text-faint italic">No eligible authors yet. Mark users as authors from the <a href="{{ route('users.index') }}" class="text-emerald-600 hover:underline">Users</a> section.</p>
            {% endif %}
        </div>


        {% if group.categoryGroups().count >= 1 %}
            {% for group in group.categoryGroups %}
        <!-- Categories -->
        <div class="px-5 py-5">
            <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-faint">{{ group.name }}</h5>
            <div class="grid grid-cols-2 gap-x-6 gap-y-1 sm:grid-cols-3">
                {% for category in group.categories %}
                <label class="flex items-center gap-2.5 py-2 text-sm text-content">
                    <input class="rounded border-edge text-emerald-600 focus:ring-emerald-500"
                           name="categories[]" type="checkbox" value="{{ category.id }}"
                           data-tab-dirty="taxonomy" data-badge="taxonomy"
                        {% if old('categories') %}
                            {% for key, val in old('categories') %}
                                {% if old('categories.' ~ key) == category.id %}checked{% endif %}
                            {% endfor %}
                        {% else %}
                            {% for entryCat in entry.categories %}
                                {% if entryCat.id == category.id %}checked{% endif %}
                            {% endfor %}
                        {% endif %}
                    > {{ category.name }}
                </label>
                    {% endfor %}
            </div>
            {% if errors.has('categories') %}
                <p class="mt-1 text-xs text-red-600">{{ errors.first('categories') }}</p>
            {% endif %}
        </div>
            {% endfor %}
        {% endif %}

        {#
        <!-- Tags -->
        <div class="px-5 py-5">
            <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-faint">Tags</h5>
            <input id="tag-search"
                   class="w-full rounded-md border border-edge px-3 py-1.5 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   type="text" placeholder="Filter tags…" autocomplete="off">
            <div id="tag-cloud" class="mt-3 flex min-h-[2.5rem] flex-wrap gap-1.5"></div>
            <div id="tag-inputs"></div>
            <p class="mt-2 text-xs text-faint">Click a tag to select it. Selected tags are highlighted and submitted with the form.</p>
        </div>
        #}
    </div>

</div>
