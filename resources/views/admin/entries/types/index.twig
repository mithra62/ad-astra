{% extends 'admin._inc._layout' %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Entry Types' %}
{% set page_heading = 'Entry Types' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'entry_types' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([{label: 'Dashboard', href: route('dashboard'), icon: 'home'}, {label: page_title}]) }}
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        {% embed 'admin._inc._page-header' with {title: page_title, subtitle: 'Manage content schemas. Assign them to Entry Groups to activate them.'} %}
            {% block actions %}{% import 'admin._inc._ui' as ui %}{{ ui.button('New Entry Type', route('entries.types.create'), icon='plus') }}{% endblock %}
        {% endembed %}

        {% if types.count > 0 %}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-subtle">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Name</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Handle</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Behavior</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Entry Group</th>
                        <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-muted">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                    {% for type in types %}
                        <tr class="hover:bg-subtle">
                            <td class="px-5 py-3 font-medium text-content">
                                <a href="{{ route('entries.types.edit', type.id) }}" class="hover:text-accent">
                                    {{ type.name }}
                                </a>
                            </td>
                            <td class="px-5 py-3 text-muted"><code>{{ type.handle }}</code></td>
                            <td class="px-5 py-3 text-content">
                                {{ type.entryBehavior ? type.entryBehavior.name : '— General —' }}
                            </td>
                            <td class="px-5 py-3">
                                {% if type.entryGroup %}
                                    <a href="{{ route('entries.groups.show', type.entryGroup.id) }}"
                                       class="text-accent hover:underline">{{ type.entryGroup.name }}</a>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Unattached</span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-3 text-right">
                                <a href="{{ route('entries.types.edit', type.id) }}"
                                   class="text-sm font-medium text-muted hover:text-content">Edit</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div>{{ types.links() }}</div>
        {% else %}
            <div class="rounded-lg border border-edge bg-surface px-5 py-10 text-center shadow-sm">
                <p class="text-sm text-muted">No Entry Types yet. <a href="{{ route('entries.types.create') }}" class="font-medium text-emerald-600 hover:underline">Create the first one.</a></p>
            </div>
        {% endif %}
    </div>
{% endblock %}
