{{ include('admin._inc._header', {title: 'Create Entry'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Entry Groups</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('entries.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('entries.create', {group_id: group.id}) }}">Create
                                Entry</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.entries._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">

                <!-- Type selector (only when group has multiple types) -->
                {% if group.entryTypes.count > 1 %}
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5>Entry Type</h5>
                        </div>
                        <div class="card-body">
                            <form method="GET" action="{{ route('entries.create', {group_id: group.id}) }}">
                                <div class="row align-items-end g-3">
                                    <div class="col-md-8">
                                        <label class="form-label" for="type">Select Entry Type</label>
                                        <select class="form-select" id="type" name="type" onchange="this.form.submit()">
                                            {% for type in group.entryTypes %}
                                                <option value="{{ type.handle }}"
                                                        {% if type.id == entryType.id %}selected{% endif %}>
                                                    {{ type.name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                {% endif %}

                <!-- Entry Form -->
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Create Entry — {{ entryType.name }}</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('entries.store', {group_id: group.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            <input type="hidden" name="type_handle" value="{{ entryType.handle }}"/>

                            <!-- Core fields -->
                            <div class="col-md-12">
                                <label class="form-label" for="title">Title</label>
                                <input class="form-control" id="title" required type="text"
                                       value="{{ old('title') }}" name="title">
                                {% if errors.has('title') %}
                                    <p class="text-danger">{{ errors.first('title') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-8">
                                <label class="form-label" for="handle">Slug</label>
                                <input class="form-control" id="handle" type="text"
                                       value="{{ old('handle') }}" name="handle"
                                       placeholder="Leave blank to auto-generate from title">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>

                            <!-- Status -->
                            {% if group.statusGroup and group.statusGroup.statuses.count >= 1 %}
                                <div class="col-md-4">
                                    <label class="form-label" for="status">Status</label>
                                    <select class="form-select" id="status" name="status">
                                        <option value="">— Default —</option>
                                        {% for s in group.statusGroup.statuses %}
                                            <option value="{{ s.handle }}"
                                                    {% if old('status') == s.handle %}selected{% endif %}>
                                                {{ s.name }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <small class="text-secondary">Only statuses from the {{ group.statusGroup.name }}
                                        group are allowed.</small>
                                    {% if errors.has('status') %}
                                        <p class="text-danger">{{ errors.first('status') }}</p>
                                    {% endif %}
                                </div>
                            {% endif %}

                            <!-- Published At -->
                            <div class="col-md-6">
                                <label class="form-label" for="published_at">Publish Date</label>
                                <input class="form-control" id="published_at" type="datetime-local"
                                       value="{{ old('published_at') }}" name="published_at">
                                <small class="text-secondary">Leave blank to keep as draft.</small>
                                {% if errors.has('published_at') %}
                                    <p class="text-danger">{{ errors.first('published_at') }}</p>
                                {% endif %}
                            </div>

                            <!-- Field Layout (EntryType fields) -->
                            {% set layout = entryType.fieldLayout %}
                            {% if layout and layout.tabs.count >= 1 %}
                                {% for tab in layout.tabs %}
                                    <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label"
                                                   for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small
                                                    class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <!-- Group-level Field Layout (shared fields) -->
                            {% set groupLayout = group.fieldLayout %}
                            {% if groupLayout and groupLayout.tabs.count >= 1 %}
                                {% for tab in groupLayout.tabs %}
                                    <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label"
                                                   for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small
                                                    class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <!-- Authors -->
                            {% if users.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Authors</h5></div>
                                <div class="col-md-12">
                                    <label class="form-label" for="authors">Authors</label>
                                    <select class="select-basic-multiple-four w-100 select_primary" multiple="multiple"
                                            name="authors[]" id="authors">
                                        {% for user in users %}
                                            <option value="{{ user.id }}"
                                                {% if old('authors') %}
                                                {% for key, val in old('authors') %}
                                                    {% if old('authors.' ~ key) == user.id %}selected{% endif %}
                                                {% endfor %}
                                                {% endif %}>
                                                {{ user.name }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    {% if errors.has('authors') %}
                                        <p class="text-danger">{{ errors.first('authors') }}</p>
                                    {% endif %}
                                </div>
                            {% endif %}

                            <!-- Categories -->
                            {% if group.categoryGroups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Categories</h5></div>
                                {% for catGroup in group.categoryGroups %}
                                    {% if catGroup.categories.count >= 1 %}
                                        <div class="col-md-12">
                                            <label class="form-label">{{ catGroup.name }}</label>
                                            {% for category in catGroup.categories %}
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox"
                                                           name="categories[]" value="{{ category.id }}"
                                                           id="cat_{{ category.id }}"
                                                        {% if old('categories') %}
                                                        {% for key, val in old('categories') %}
                                                            {% if old('categories.' ~ key) == category.id %}checked{% endif %}
                                                        {% endfor %}
                                                        {% endif %}>
                                                    <label class="form-check-label" for="cat_{{ category.id }}">
                                                        {{ category.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}

                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Create Entry</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
