{% extends 'admin._inc._layout' %}

{% set page_title = 'Create Article' %}
{% set page_heading = 'Create Article' %}
{% set active_nav = 'articles' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="index.twig">Articles</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">New Article</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.entries.groups._sidebar', {active: group.id}) }}
{% endblock %}

{% block content %}
    <!-- ── Form content ─────────────────────────────────────────── -->
    <div class="flex min-w-0 flex-col gap-5">

        <!-- Page title + back link -->
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Article</h1>
                <p class="mt-1 text-sm text-slate-500">Fill in the details below and save when ready.</p>
            </div>
            <a class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto" href="#">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                Back to Articles
            </a>
        </div>

        <!-- Two-column form -->
        <form id="article-form" method="POST" action="#"
              class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

            <!-- ── Left: tabbed content area ───────────────────── -->
            <div class="flex flex-col gap-0 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">

                {{ csrf_field() }}
                <input type="hidden" name="type_handle" value="{{ entryType.handle }}"/>

                <!-- Core fields -->
                <div class="col-md-12">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" id="title" type="text"
                           value="{{ old('title') }}" name="title">
                    {% if errors.has('title') %}
                        <p class="text-danger">{{ errors.first('title') }}</p>
                    {% endif %}
                </div>
                <div class="col-md-8">
                    <label class="form-label" for="handle">Slug</label>
                    <input class="form-control" id="handle" type="text"
                           value="{{ old('handle') }}" name="handle"
                           placeholder="Leave blank to auto-generate from title">
                    {% if errors.has('handle') %}
                        <p class="text-danger">{{ errors.first('handle') }}</p>
                    {% endif %}
                </div>

                <!-- Status -->
                {% if group.statusGroup and group.statusGroup.statuses.count >= 1 %}
                    <div class="col-md-4">
                        <label class="form-label" for="status">Status</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">— Default —</option>
                            {% for s in group.statusGroup.statuses %}
                                <option value="{{ s.handle }}"
                                        {% if old('status') == s.handle %}selected{% endif %}>
                                    {{ s.name }}
                                </option>
                            {% endfor %}
                        </select>
                        <small class="text-secondary">Only statuses from the {{ group.statusGroup.name }}
                            group are allowed.</small>
                        {% if errors.has('status') %}
                            <p class="text-danger">{{ errors.first('status') }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                <!-- Published At -->
                <div class="col-md-6">
                    <label class="form-label" for="published_at">Publish Date</label>
                    <input class="form-control" id="published_at" type="datetime-local"
                           value="{{ old('published_at') }}" name="published_at">
                    <small class="text-secondary">Leave blank to keep as draft.</small>
                    {% if errors.has('published_at') %}
                        <p class="text-danger">{{ errors.first('published_at') }}</p>
                    {% endif %}
                </div>

                <!-- Field Layout (EntryType fields) -->
                {% set layout = entryType.fieldLayout %}
                {% if layout and layout.tabs.count >= 1 %}
                    {% for tab in layout.tabs %}
                        <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                        {% for element in tab.elements %}
                            {% set field = element.field %}
                            <div class="col-md-12">
                                <label class="form-label"
                                       for="field_{{ field.handle }}">{{ field.label }}</label>
                                {% if field.instructions %}
                                    <small
                                        class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                {% endif %}
                                <div class="input-group has-validation">
                                    {{ field.render({
                                        id: 'field_' ~ field.handle,
                                        class: 'form-control'
                                    })|raw }}
                                </div>
                                {% if errors.has('fields.' ~ field.handle) %}
                                    <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endfor %}
                {% endif %}

                <!-- Group-level Field Layout (shared fields) -->
                {% set groupLayout = group.fieldLayout %}
                {% if groupLayout and groupLayout.tabs.count >= 1 %}
                    {% for tab in groupLayout.tabs %}
                        <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                        {% for element in tab.elements %}
                            {% set field = element.field %}
                            <div class="col-md-12">
                                <label class="form-label"
                                       for="field_{{ field.handle }}">{{ field.label }}</label>
                                {% if field.instructions %}
                                    <small
                                        class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                {% endif %}
                                <div class="input-group has-validation">
                                    {{ field.render({
                                        id: 'field_' ~ field.handle,
                                        class: 'form-control'
                                    })|raw }}
                                </div>
                                {% if errors.has('fields.' ~ field.handle) %}
                                    <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endfor %}
                {% endif %}

                <!-- Authors -->
                {% if users.count >= 1 %}
                    <div class="col-12"><h5 class="border-bottom pb-2">Authors</h5></div>
                    <div class="col-md-12">
                        <label class="form-label" for="authors">Authors</label>
                        <select class="select-basic-multiple-four w-100 select_primary" multiple="multiple"
                                name="authors[]" id="authors">
                            {% for user in users %}
                                <option value="{{ user.id }}"
                                    {% if old('authors') %}
                                    {% for key, val in old('authors') %}
                                        {% if old('authors.' ~ key) == user.id %}selected{% endif %}
                                    {% endfor %}
                                    {% endif %}>
                                    {{ user.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('authors') %}
                            <p class="text-danger">{{ errors.first('authors') }}</p>
                        {% endif %}
                    </div>
                {% endif %}

                <!-- Categories -->
                {% if group.categoryGroups.count >= 1 %}
                    <div class="col-12"><h5 class="border-bottom pb-2">Categories</h5></div>
                    {% for catGroup in group.categoryGroups %}
                        {% if catGroup.categories.count >= 1 %}
                            <div class="col-md-12">
                                <label class="form-label">{{ catGroup.name }}</label>
                                {% for category in catGroup.categories %}
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="categories[]" value="{{ category.id }}"
                                               id="cat_{{ category.id }}"
                                            {% if old('categories') %}
                                            {% for key, val in old('categories') %}
                                                {% if old('categories.' ~ key) == category.id %}checked{% endif %}
                                            {% endfor %}
                                            {% endif %}>
                                        <label class="form-check-label" for="cat_{{ category.id }}">
                                            {{ category.name }}
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <div class="col-12">
                    <button class="btn btn-primary float-end" type="submit">Create Entry</button>
                </div>


            </div><!-- /tabbed card -->

            <!-- ── Right: persistent publishing panel ──────────── -->
            <div class="flex flex-col gap-4">

                <!-- Publish settings -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Publishing</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                            <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                    id="status" name="status">
                                <option value="draft" selected>Draft</option>
                                <option value="published">Published</option>
                                <option value="scheduled">Scheduled</option>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="published_at">Publish Date</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="published_at" name="published_at" type="datetime-local">
                            <p class="mt-1 text-xs text-slate-400">Leave blank to save as draft.</p>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="entry_type">Entry Type</label>
                            <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                    id="entry_type" name="entry_type">
                                <option>Standard Article</option>
                                <option>Feature Story</option>
                                <option>Press Release</option>
                                <option>Opinion Piece</option>
                            </select>
                        </div>
                    </div>
                    <div class="space-y-2 border-t border-slate-100 px-5 py-4">
                        <button class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
                                type="submit">
                            Save Article
                        </button>
                        <button type="button"
                                class="w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-600 shadow-sm hover:bg-slate-50">
                            Save as Draft
                        </button>
                    </div>
                </div>

                <!-- Unsaved changes notice (hidden by default) -->
                <div id="unsaved-notice"
                     class="hidden rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                    <div class="flex items-start gap-2.5">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                        <p class="text-xs text-amber-800">You have unsaved changes. Remember to save before leaving.</p>
                    </div>
                </div>

            </div>
            <!-- /right -->

        </form>

    </div>
    <!-- /form content -->
{% endblock %}
