{% import 'admin._inc._ui' as ui %}

{% set items = [{label: 'Entry Groups', href: route('entries.groups'), icon: 'menu', active: false}] %}
{% for group in groups %}
    {% set items = items|merge([{
        label: group.name ~ ' (' ~ group.entries_count ~ ')',
        href: route('entries.groups.show', group),
        icon: 'menu',
        active: active == group.id
    }]) %}
{% endfor %}

{{ ui.section_nav('Content', items) }}
