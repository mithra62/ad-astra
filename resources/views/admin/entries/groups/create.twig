{% extends 'admin._inc._layout' %}

{% set page_title = 'Create Entry Group' %}
{% set page_heading = 'Entry Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'entries' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('entries.groups') }}">
            Entry Groups
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Create Entry Group</span>
    </nav>
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Entry Group</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('entries.groups') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Entry Groups
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('entries.groups.store') }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                        <input value="{{ old('name') }}" class="w-full rounded-md border {% if errors.has('name') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 " id="name" name="name" type="text" placeholder="">
                        {% if errors.has('name') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('name') }}</p>{% endif %}
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Handle <span class="text-red-500">*</span></label>
                        <input class="w-full rounded-md border {% if errors.has('handle') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="handle" name="handle" type="text" value="{{ old('handle') }}" >
                        <p class="mt-1 text-xs text-slate-400">Lowercase letters, numbers, and hyphens only.</p>
                        {% if errors.has('handle') %}<p id="handle-error" class="mt-1 text-xs text-red-600">{{ errors.first('handle') }}</p>{% endif %}
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status_group_id">Status Group</label>
                        <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm {% if errors.has('status_group_id') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="status_group_id" name="status_group_id">
                            {% for sg in status_groups %}
                                <option value="{{ sg.id }}"
                                        {% if old('status_group_id') == sg.id %}selected{% endif %}>
                                    {{ sg.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('status_group_id') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('status_group_id') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="field_layout_id">Field Layout</label>
                        <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm {% if errors.has('field_layout_id') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="status_group_id" name="status_group_id">
                            {% for layout in field_layouts %}
                                <option value="{{ layout.id }}" {% if old('field_layout_id') == layout.id %}selected{% endif %}>
                                    {{ layout.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('status_group_id') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('status_group_id') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="description">Description</label>
                        <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="description" name="description" rows="4" placeholder="Optional internal description...">{{ old('description') }}</textarea>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            {% if category_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Category Groups</h5></div>
                                <div class="col-md-12">
                                    <small class="text-secondary d-block mb-2">Entries in this group can be assigned to
                                        categories from the selected category groups.</small>
                                    {% for cg in category_groups %}
                                        <div class="form-check">
                                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700" for="cg_{{ cg.id }}">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   type="checkbox"
                                                   name="category_groups[]" value="{{ cg.id }}"
                                                   id="cg_{{ cg.id }}"
                                                {% if old('category_groups') %}
                                                {% for key, val in old('category_groups') %}
                                                    {% if old('category_groups.' ~ key) == cg.id %}checked{% endif %}
                                                {% endfor %}
                                                {% endif %}>
                                           {{ cg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div>
                            {% if field_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Field Groups</h5></div>
                                <div class="col-md-12">
                                    {% for fg in field_groups %}
                                        <div class="form-check">
                                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700" for="fg_{{ fg.id }}">
                                            <input type="checkbox"
                                                   name="field_groups[]" value="{{ fg.id }}"
                                                   id="fg_{{ fg.id }}"
                                                   class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                {% if old('field_groups') %}
                                                {% for key, val in old('field_groups') %}
                                                    {% if old('field_groups.' ~ key) == fg.id %}checked{% endif %}
                                                {% endfor %}
                                                {% endif %}>
                                            {{ fg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {% if available_entry_types.count >= 1 %}
                    <div>
                        <h6 class="mb-2 text-sm font-semibold text-slate-700">Entry Types</h6>
                        <p class="mb-3 text-xs text-slate-400">Optionally assign existing Entry Types to this group now. Only unattached types are listed.</p>
                        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
                            {% for et in available_entry_types %}
                                <label class="flex cursor-pointer items-start gap-2.5 rounded-md border border-slate-200 bg-slate-50 px-3 py-2.5 hover:bg-slate-100" for="et_{{ et.id }}">
                                    <input class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                           type="checkbox"
                                           name="entry_type_ids[]"
                                           value="{{ et.id }}"
                                           id="et_{{ et.id }}"
                                        {% if old('entry_type_ids') %}
                                            {% for key, val in old('entry_type_ids') %}
                                                {% if old('entry_type_ids.' ~ key) == et.id %}checked{% endif %}
                                            {% endfor %}
                                        {% endif %}>
                                    <span>
                                        <span class="block text-sm font-medium text-slate-800">{{ et.name }}</span>
                                        <span class="block text-xs text-slate-400">{{ et.entryBehavior ? et.entryBehavior.name : 'General' }}</span>
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('entries.groups') }}" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Create Entry Group</button>
            </div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}
