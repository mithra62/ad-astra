{% extends 'admin._inc._layout' %}

{% set page_title = 'View Entry Group' %}
{% set page_heading = 'Entry Groups' %}
{% set active_nav = 'articles' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('entries.groups') }}">
            Entry Groups
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">{{ group.name }}</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.entries._sidebar', {active: group.id}) }}
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">{{ group.name }} Entries</h1>
                <p class="mt-1 text-sm text-slate-500">Manage drafts, scheduled posts, and published article content.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 self-start sm:self-auto">
                <a class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" href="{{ route('entries.groups.edit', group.id) }}">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit Group
                </a>
                <a class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" href="{{ route('entries.create', {group_id: group.id}) }}">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                    </svg>
                    Create Entry
                </a>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Overview</h5>
            </div>

            <div class="overflow-x-auto">
                <div class="flex w-full min-w-max divide-x divide-slate-200">
                    <div class="min-w-36 flex-1 p-4 sm:min-w-44 sm:p-5">
                        <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total</p>
                        <p class="mt-1.5 text-3xl font-semibold text-slate-900">{{ group.entries.count }}</p>
                    </div>
                    {% if group.statusGroup.statuses.count >= 1 %}
                        {% for status in group.statusGroup.statuses %}
                            <div class="min-w-36 flex-1 p-4 sm:min-w-44 sm:p-5">
                                <p class="truncate text-xs font-medium uppercase tracking-wide text-slate-500" title="{{ status.name }}">{{ status.name }}</p>
                                <p class="mt-1.5 text-3xl font-semibold text-slate-900">{{ group.entries().where('status_id', status.id).count() }}</p>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h5 class="text-sm font-semibold text-slate-700">Entry List</h5>
                        <p class="mt-0.5 text-xs text-slate-500">No entries match the current view.</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <select class="rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                            <option>All entry groups</option>
                            <option>Blog Posts</option>
                            <option>News</option>
                            <option>Press Releases</option>
                        </select>
                        <select class="rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                            <option>All statuses</option>
                            <option>Published</option>
                            <option>Draft</option>
                            <option>Scheduled</option>
                        </select>
                        <input class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-40" placeholder="Search articles" type="search">
                    </div>
                </div>
            </div>

            {% if entries.count >= 1 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                        <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-5 py-3" scope="col">Title</th>
                            <th class="hidden px-5 py-3 sm:table-cell" scope="col">Type</th>
                            <th class="px-5 py-3" scope="col">Status</th>
                            <th class="hidden px-5 py-3 md:table-cell" scope="col">Author</th>
                            <th class="hidden px-5 py-3 lg:table-cell" scope="col">Updated</th>
                            <th class="px-5 py-3 text-right" scope="col">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 bg-white">
                        {% for entry in entries %}
                            <tr class="hover:bg-slate-50">
                                <td class="px-5 py-3.5">
                                    <p class="font-medium text-slate-900">{{ entry.title }}</p>
                                    <p class="mt-0.5 text-xs text-slate-400">{{ entry.handle }}</p>
                                </td>
                                <td class="hidden px-5 py-3.5 text-slate-600 sm:table-cell">
                                    {{ entry.entryType.name ?? '—' }}
                                </td>
                                <td class="px-5 py-3.5">
                                    <span style="background-color:{{ entry.status.color }}" class="inline-flex rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">
                                        {{ entry.status.handle }}
                                    </span>
                                </td>
                                <td class="hidden px-5 py-3.5 text-slate-600 md:table-cell">
                                    {% if entry.authors.count >= 1 %}
                                        {% for author in entry.authors %}
                                            <span>{{ author.name }}</span>{% if not loop.last %}, {% endif %}
                                        {% endfor %}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="hidden px-5 py-3.5 text-slate-400 lg:table-cell">{{ entry.published_at.format('F j, Y') }}</td>
                                <td class="px-5 py-3.5">
                                    <div class="flex items-center justify-end gap-1">
                                        <a class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" href="{{ route('entries.edit', entry) }}" title="View">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                            <span class="sr-only">View</span>
                                        </a>
                                        <a class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" href="{{ route('entries.edit', entry) }}" title="Edit">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                            </svg>
                                            <span class="sr-only">Edit</span>
                                        </a>
                                        <a class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600" href="{{ route('entries.confirm', entry) }}" title="Delete">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                            <span class="sr-only">Delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
            <div class="flex min-h-80 items-center justify-center px-6 py-14">
                <div class="max-w-sm text-center">
                    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5A3.375 3.375 0 0010.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                        </svg>
                    </div>
                    <h2 class="mt-4 text-base font-semibold text-slate-900">No Entries found</h2>
                    <p class="mt-1 text-sm text-slate-500">Create your first entry or adjust the filters to broaden the list.</p>
                    <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                        <a class="inline-flex items-center justify-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" href="{{ route('entries.create', {group_id: group.id}) }}">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                            </svg>
                            Create Entry
                        </a>
                        <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="index.twig">Clear filters</a>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="border-t border-slate-200 px-5 py-3">
                <p class="text-xs text-slate-500">Showing 0 articles</p>
            </div>
        </div>
    </div>
{% endblock %}
