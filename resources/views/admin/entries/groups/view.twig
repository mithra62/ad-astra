{{ include('admin._inc._header', {title: 'View Entry Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h4 class="main-title">Entry Group</h4>
                <ul class="app-line-breadcrumbs mb-3">
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                            <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                        </a>
                    </li>
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                    </li>
                    <li class="active">
                        <a class="f-s-14 f-w-500" href="{{ route('entries.groups.show', group) }}">{{ group.name }}</a>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}
        <!-- setting-app start -->
        <div class="row">
            {{ include('admin.entries._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <div class="tab-content">
                    <div aria-labelledby="profile-tab" class="tab-pane fade active show"
                         id="profile-tab-pane"
                         role="tabpanel" tabindex="0">
                        <div class="card setting-profile-tab">
                            <div class="card-header">
                                <div class="row align-items-center">
                                    <div class="col">
                                        <h5 class="mb-0">Entries</h5>
                                    </div>
                                    <div class="col-auto">
                                        <a href="{{ route('entries.groups.edit', group) }}" class="btn btn-outline-secondary btn-sm me-2">
                                            <i class="ti ti-settings"></i> Group Settings
                                        </a>
                                        <a href="{{ route('entries.create', {group_id: group.id}) }}" class="btn btn-primary btn-sm">
                                            Create Entry
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="profile-tab profile-container">
                                    {% if entries.count >= 1 %}
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead>
                                                <tr>
                                                    <th scope="col">Title</th>
                                                    <th scope="col">Type</th>
                                                    <th scope="col">Status</th>
                                                    <th scope="col">Authors</th>
                                                    <th scope="col">Published</th>
                                                    <th scope="col">Last Modified</th>
                                                    <th scope="col"></th>
                                                </tr>
                                                </thead>
                                                <tbody>
                                                {% for entry in entries %}
                                                    <tr>
                                                        <td>
                                                            <strong>{{ entry.title }}</strong>
                                                            <br><small class="text-secondary">{{ entry.handle }}</small>
                                                        </td>
                                                        <td class="text-secondary f-w-500">
                                                            {{ entry.entryType.name ?? '—' }}
                                                        </td>
                                                        <td>
                                                            {% if entry.status %}
                                                                <span class="badge bg-secondary">{{ entry.status }}</span>
                                                            {% else %}
                                                                <span class="text-secondary">—</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="text-secondary">
                                                            {% if entry.authors.count >= 1 %}
                                                                {% for author in entry.authors %}
                                                                    <span>{{ author.name }}</span>{% if not loop.last %}, {% endif %}
                                                                {% endfor %}
                                                            {% else %}
                                                                —
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if entry.published_at %}
                                                                {{ entry.published_at.format('F j, Y') }}
                                                            {% else %}
                                                                <span class="text-secondary">Draft</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="text-secondary f-w-600">
                                                            {{ entry.updated_at.format('F j, Y') }}
                                                        </td>
                                                        <td>
                                                            <a class="btn btn-success icon-btn b-r-4"
                                                               href="{{ route('entries.edit', entry) }}">
                                                                <i class="ti ti-edit"></i>
                                                            </a>
                                                            <a class="btn btn-danger icon-btn b-r-4"
                                                               href="{{ route('entries.confirm', entry) }}">
                                                                <i class="ti ti-trash"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                        <div class="mt-3">
                                            {{ entries.links() }}
                                        </div>
                                    {% else %}
                                        <p class="text-center">
                                            No Entries Created. <br />
                                            <a href="{{ route('entries.create', {group_id: group.id}) }}" class="btn btn-outline-primary">Create Entry</a>
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--setting app end -->
    </div>
</main>
{{ include('admin._inc._footer') }}
