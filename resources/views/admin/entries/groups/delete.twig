{{ include('admin._inc._header', {title: 'Delete Entry Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Entry Groups</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups.confirm', group) }}">Delete Entry Group</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.entries._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <form method="POST" action="{{ route('entries.groups.destroy', group) }}" class="row g-3 needs-validation" novalidate>
                    {{ csrf_field() }}
                    {{ method_field('DELETE') }}
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h5>Delete Entry Group</h5>
                            </div>
                            <div class="card-body">
                                <h6>Are you sure you want to remove <strong>{{ group.name }}</strong>?</h6>
                                <p class="text-secondary">
                                    This will permanently delete the entry group and all associated entry types.
                                    Entries within this group will also be removed. This action cannot be undone.
                                </p>
                                {% if group.entries_count > 0 %}
                                    <div class="alert alert-warning">
                                        <strong>Warning:</strong> This group contains {{ group.entries_count }} {{ group.entries_count == 1 ? 'entry' : 'entries' }} that will also be deleted.
                                    </div>
                                {% endif %}
                            </div>
                            <div class="card-footer">
                                <div class="switch-border-primary switch-primary switch-unchecked-primary my-3 card-body main-switch main-switch-color">
                                    <input class="toggle switch-border-primary" name="confirm_removal" id="confirm_removal" type="checkbox">
                                    <label for="confirm_removal">Confirm Removal</label>
                                    {% if errors.has('confirm_removal') %}
                                        <p class="text-danger">{{ errors.first('confirm_removal') }}</p>
                                    {% endif %}
                                </div>
                                <div class="col-12 float-end">
                                    <a href="{{ route('entries.groups') }}" class="btn btn-secondary">Cancel</a>
                                    <button class="btn btn-danger ms-2" type="submit">Delete Entry Group</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
