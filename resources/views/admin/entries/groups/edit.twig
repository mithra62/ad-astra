{% extends 'admin._inc._layout' %}

{% set page_title = 'Edit Entry Group' %}
{% set page_heading = 'Entry Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'entries' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('entries.groups') }}">
            Entry Groups
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('entries.groups.show', group) }}">
            {{ group.name }}
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Edit Entry Group</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.entries.groups._sidebar', {active: group.id}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Edit Entry Group</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('entries.groups') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Entry Groups
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('entries.groups.update', group) }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Entry Group Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                        <input value="{{ old('name', group.name) }}" class="w-full rounded-md border {% if errors.has('name') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 " id="name" name="name" type="text" placeholder="">
                        {% if errors.has('name') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('name') }}</p>{% endif %}
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Handle <span class="text-red-500">*</span></label>
                        <input class="w-full rounded-md border {% if errors.has('handle') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="handle" name="handle" type="text" value="{{ old('handle', group.handle) }}" >
                        <p class="mt-1 text-xs text-slate-400">Lowercase letters, numbers, and hyphens only.</p>
                        {% if errors.has('handle') %}<p id="handle-error" class="mt-1 text-xs text-red-600">{{ errors.first('handle') }}</p>{% endif %}
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status_group_id">Status Group</label>
                        <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm {% if errors.has('status_group_id') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="status_group_id" name="status_group_id">
                            {% for sg in status_groups %}
                                <option value="{{ sg.id }}"
                                        {% if old('status_group_id', group.statusGroup.id ?? '') == sg.id %}selected{% endif %}>
                                    {{ sg.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('status_group_id') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('status_group_id') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="field_layout_id">Field Layout</label>
                        <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm {% if errors.has('field_layout_id') %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="field_layout_id" name="field_layout_id">
                            {% for layout in field_layouts %}
                                <option value="{{ layout.id }}" {% if old('field_layout_id', group.field_layout_id) == layout.id %}selected{% endif %}>
                                    {{ layout.name }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('field_layout_id') %}<p id="name-error" class="mt-1 text-xs text-red-600">{{ errors.first('field_layout_id') }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="description">Description</label>
                        <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="description" name="description" rows="4" placeholder="Optional internal description...">{{ old('description', group.description) }}</textarea>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            {% if category_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Category Groups</h5></div>
                                <div class="col-md-12">
                                    <small class="text-secondary d-block mb-2">Entries in this group can be assigned to
                                        categories from the selected category groups.</small>
                                    {% for cg in category_groups %}
                                        <div class="form-check">
                                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700" for="cg_{{ cg.id }}">
                                                <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                       type="checkbox"
                                                       name="category_groups[]" value="{{ cg.id }}"
                                                       id="cg_{{ cg.id }}"
                                                    {% if old('category_groups') %}
                                                    {% for key, val in old('category_groups') %}
                                                        {% if old('category_groups.' ~ key) == cg.id %}checked{% endif %}
                                                    {% endfor %}
                                                {% else %}
                                                    {% for attached in group.categoryGroups %}
                                                        {% if attached.id == cg.id %}checked{% endif %}
                                                    {% endfor %}
                                                    {% endif %}>
                                                {{ cg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div>
                            {% if field_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Field Groups</h5></div>
                                <div class="col-md-12">
                                    {% for fg in field_groups %}
                                        <div class="form-check">
                                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700" for="fg_{{ fg.id }}">
                                                <input type="checkbox"
                                                       name="field_groups[]" value="{{ fg.id }}"
                                                       id="fg_{{ fg.id }}"
                                                       class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                    {% if old('field_groups') %}
                                                    {% for key, val in old('field_groups') %}
                                                        {% if old('field_groups.' ~ key) == fg.id %}checked{% endif %}
                                                    {% endfor %}
                                                {% else %}
                                                    {% for attached in group.fieldGroups %}
                                                        {% if attached.id == fg.id %}checked{% endif %}
                                                    {% endfor %}
                                                    {% endif %}>
                                                {{ fg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                        <a href="{{ route('entries.groups.show', group) }}" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                        <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Edit Entry Group</button>
                    </div>
                </div>

            </div>
        </form>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Entry Types</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('entries.groups.types.create', group) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                Add Entry Type
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                <tr>
                    <th class="w-10 px-4 py-3">
                        <input id="select-all" type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                    </th>
                    <th class="px-4 py-3 font-semibold">Name</th>
                    <th class="px-4 py-3 font-semibold">Class</th>
                    <th class="px-4 py-3 font-semibold">Field Layout</th>
                    <th class="px-4 py-3 font-semibold"></th>
                </tr>
                </thead>
                <tbody id="item-tbody" class="divide-y divide-slate-100 bg-white">
                {% if group.entryTypes.count >= 1 %}
                    {% for type in group.entryTypes %}
                    <tr class="hover:bg-slate-50/60" data-name="{{ group.name|lower }} {{ group.handle|lower }}">
                        <td class="px-4 py-3">
                            <input type="checkbox" name="ids[]" value="{{ group.handle }}" class="row-cb rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div>
                                    <a class="font-medium text-slate-900 hover:text-emerald-700" href="{{ route('entries.groups.show', group) }}">{{ type.name }} <span class="mt-0.5 font-mono text-xs text-slate-400">{{ type.handle }}</span></a>
                                    <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                        <a href="{{ route('entries.groups.types.edit', {group_id: group.id, type_id: type.id}) }}" class="text-emerald-600 hover:underline">Edit</a>
                                        <span class="text-slate-300">|</span>
                                        <a href="{{ route('entries.groups.types.confirm', {group_id: group.id, type_id: type.id}) }}" class="text-red-500 hover:underline">Delete</a>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3 capitalize text-slate-600"><code>{{ type.class }}</code></td>
                        <td class="px-4 py-3">{{ type.fieldLayout.name ?? '—' }}</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-1.5">
                                <a href="{{ route('entries.groups.types.edit', {group_id: group.id, type_id: type.id}) }}" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="Edit">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <a href="{{ route('entries.groups.types.confirm', {group_id: group.id, type_id: type.id}) }}" class="rounded p-1 text-slate-400 hover:bg-red-50 hover:text-red-600" title="Delete">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="6">
                            <p class="text-center mb-0">
                                No entry types configured. <a
                                    href="{{ route('entries.groups.types.create', group) }}">Add one
                                    now.</a>
                            </p>
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>


    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}
