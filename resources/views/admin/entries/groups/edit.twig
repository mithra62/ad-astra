{{ include('admin._inc._header', {title: 'Edit Entry Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Entry Groups</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('entries.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups.edit', group) }}">Edit Entry
                                Group</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.entries._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">

                <!-- Group Settings Form -->
                <div class="card mb-4">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Group Settings</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('entries.groups.update', group) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            {{ method_field('PUT') }}
                            <input type="hidden" name="id" value="{{ group.id }}"/>

                            <!-- Details -->
                            <div class="col-12"><h5 class="border-bottom pb-2">Details</h5></div>
                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text"
                                       value="{{ old('name', group.name) }}" name="name">
                                {% if errors.has('name') %}<p
                                    class="text-danger">{{ errors.first('name') }}</p>{% endif %}
                            </div>
                            <div class="col-md-8">
                                <label class="form-label" for="handle">Handle</label>
                                <input class="form-control" id="handle" required type="text"
                                       value="{{ old('handle', group.handle) }}" name="handle">
                                {% if errors.has('handle') %}<p
                                    class="text-danger">{{ errors.first('handle') }}</p>{% endif %}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="sort_order">Sort Order</label>
                                <input class="form-control" id="sort_order" type="number"
                                       value="{{ old('sort_order', group.sort_order) }}" name="sort_order" min="0">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="description">Description</label>
                                <textarea class="form-control" id="description" name="description"
                                          rows="3">{{ old('description', group.description) }}</textarea>
                            </div>

                            <!-- Status Group -->
                            <div class="col-12"><h5 class="border-bottom pb-2">Status Group</h5></div>
                            <div class="col-md-12">
                                <label class="form-label" for="status_group_id">Status Group</label>
                                <small class="text-secondary d-block mb-1">The status group determines which statuses
                                    are available on entries in this group.</small>
                                <select class="form-select" id="status_group_id" name="status_group_id">
                                    <option value="">— None —</option>
                                    {% for sg in status_groups %}
                                        <option value="{{ sg.id }}"
                                                {% if old('status_group_id', group.statusGroup.id ?? '') == sg.id %}selected{% endif %}>
                                            {{ sg.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('status_group_id') %}<p
                                    class="text-danger">{{ errors.first('status_group_id') }}</p>{% endif %}
                            </div>

                            <!-- Field Layout -->
                            <div class="col-12"><h5 class="border-bottom pb-2">Shared Field Layout</h5></div>
                            <div class="col-md-12">
                                <label class="form-label" for="field_layout_id">Field Layout</label>
                                <small class="text-secondary d-block mb-1">Fields from this layout are shared across all
                                    entry types in this group.</small>
                                <select class="form-select" id="field_layout_id" name="field_layout_id">
                                    <option value="">— None —</option>
                                    {% for layout in field_layouts %}
                                        <option value="{{ layout.id }}"
                                                {% if old('field_layout_id', group.fieldLayout.id ?? '') == layout.id %}selected{% endif %}>
                                            {{ layout.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('field_layout_id') %}<p
                                    class="text-danger">{{ errors.first('field_layout_id') }}</p>{% endif %}
                            </div>

                            <!-- Category Groups -->
                            {% if category_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Category Groups</h5></div>
                                <div class="col-md-12">
                                    <small class="text-secondary d-block mb-2">Entries in this group can be assigned to
                                        categories from the selected category groups.</small>
                                    {% for cg in category_groups %}
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="category_groups[]" value="{{ cg.id }}"
                                                   id="cg_{{ cg.id }}"
                                                {% if old('category_groups') %}
                                                {% for key, val in old('category_groups') %}
                                                    {% if old('category_groups.' ~ key) == cg.id %}checked{% endif %}
                                                {% endfor %}
                                            {% else %}
                                                {% for attached in group.categoryGroups %}
                                                    {% if attached.id == cg.id %}checked{% endif %}
                                                {% endfor %}
                                                {% endif %}>
                                            <label class="form-check-label" for="cg_{{ cg.id }}">{{ cg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            <!-- Field Groups -->
                            {% if field_groups.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Field Groups</h5></div>
                                <div class="col-md-12">
                                    {% for fg in field_groups %}
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="field_groups[]" value="{{ fg.id }}"
                                                   id="fg_{{ fg.id }}"
                                                {% if old('field_groups') %}
                                                {% for key, val in old('field_groups') %}
                                                    {% if old('field_groups.' ~ key) == fg.id %}checked{% endif %}
                                                {% endfor %}
                                            {% else %}
                                                {% for attached in group.fieldGroups %}
                                                    {% if attached.id == fg.id %}checked{% endif %}
                                                {% endfor %}
                                                {% endif %}>
                                            <label class="form-check-label" for="fg_{{ fg.id }}">{{ fg.name }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Save Entry Group</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Entry Types Management -->
                <div class="card">
                    <div class="card-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="mb-0">Entry Types</h5>
                                <small class="text-secondary">Entry types define the available content structures within
                                    this group.</small>
                            </div>
                            <div class="col-auto">
                                <a href="{{ route('entries.groups.types.create', group) }}"
                                   class="btn btn-primary btn-sm">
                                    Add Entry Type
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Handle</th>
                                    <th scope="col">Class</th>
                                    <th scope="col">Field Layout</th>
                                    <th scope="col">Sort</th>
                                    <th scope="col"></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if group.entryTypes.count >= 1 %}
                                    {% for type in group.entryTypes %}
                                        <tr>
                                            <td><strong>{{ type.name }}</strong></td>
                                            <td class="text-secondary">{{ type.handle }}</td>
                                            <td class="text-secondary f-s-12">
                                                <code>{{ type.class }}</code>
                                            </td>
                                            <td class="text-secondary">
                                                {{ type.fieldLayout.name ?? '—' }}
                                            </td>
                                            <td class="text-secondary">{{ type.sort_order }}</td>
                                            <td>
                                                <a class="btn btn-success icon-btn b-r-4"
                                                   href="{{ route('entries.groups.types.edit', {group_id: group.id, type_id: type.id}) }}">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <a class="btn btn-danger icon-btn b-r-4"
                                                   href="{{ route('entries.groups.types.confirm', {group_id: group.id, type_id: type.id}) }}">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="6">
                                            <p class="text-center mb-0">
                                                No entry types configured. <a
                                                    href="{{ route('entries.groups.types.create', group) }}">Add one
                                                    now.</a>
                                            </p>
                                        </td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
