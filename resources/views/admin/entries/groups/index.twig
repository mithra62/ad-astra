{{ include('admin._inc._header', {title: 'Entry Groups'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Entry Groups</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row table-section">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-6">
                                <h5>Manage Entry Groups</h5>
                                <p>Select an entry group to view and manage its entries.</p>
                            </div>
                            <div class="col-6">
                                <p class="float-right text-end">
                                    <a href="{{ route('entries.groups.create') }}" class="btn btn-primary">Add Entry Group</a>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Handle</th>
                                    <th scope="col">Types</th>
                                    <th scope="col">Entries</th>
                                    <th scope="col">Status Group</th>
                                    <th scope="col"></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if groups.count >= 1 %}
                                    {% for group in groups %}
                                        <tr>
                                            <td>{{ group.name }}</td>
                                            <td class="text-secondary">{{ group.handle }}</td>
                                            <td class="f-w-500">{{ group.entry_types_count ?? '—' }}</td>
                                            <td class="f-w-500">{{ group.entries_count }}</td>
                                            <td class="text-secondary">{{ group.statusGroup.name ?? '—' }}</td>
                                            <td>
                                                <a class="btn btn-primary icon-btn b-r-4"
                                                   href="{{ route('entries.groups.show', group) }}">
                                                    <i class="ti ti-eye"></i>
                                                </a>
                                                <a class="btn btn-success icon-btn b-r-4"
                                                   href="{{ route('entries.groups.edit', group) }}">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <a class="btn btn-danger icon-btn b-r-4"
                                                   href="{{ route('entries.groups.confirm', group) }}">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="6">
                                            <p class="text-center">
                                                No Entry Groups found. <a href="{{ route('entries.groups.create') }}">Create one now.</a>
                                            </p>
                                        </td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                {{ groups.links() }}
            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
