{% extends 'admin._inc._layout' %}

{% set page_title = 'Entry Group' %}
{% set page_heading = 'Entry Group' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'entries' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Entry Group</span>
    </nav>
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Entry Group</h1>
                <p class="mt-1 text-sm text-slate-500">Select an entry group to view and manage its entries.</p>
            </div>
            <a class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 sm:self-auto" href="{{ route('entries.groups.create') }}">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Create Entry Group
            </a>
        </div>

        <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-emerald-800">Item saved successfully.</p>
                    <p class="mt-1 text-sm text-emerald-700">This is an example success alert for list actions.</p>
                </div>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <h5 class="text-sm font-semibold text-slate-700">All Items</h5>
                    <div class="flex flex-wrap items-center gap-2">
                        <select id="type-filter" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                            <option value="">All types</option>
                            <option value="status">Status</option>
                            <option value="field">Field</option>
                            <option value="option">Option</option>
                        </select>
                        <input id="item-search" class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-52" placeholder="Search items..." type="search">
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="w-10 px-4 py-3">
                            <input id="select-all" type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                        </th>
                        <th class="px-4 py-3 font-semibold">Name</th>
                        <th class="px-4 py-3 font-semibold">Types</th>
                        <th class="px-4 py-3 font-semibold">Entries</th>
                        <th class="px-4 py-3 text-center font-semibold">Status Group</th>
                        <th class="px-4 py-3 font-semibold"></th>
                    </tr>
                    </thead>
                    <tbody id="item-tbody" class="divide-y divide-slate-100 bg-white">
                    {% for group in groups %}
                        <tr class="hover:bg-slate-50/60" data-name="{{ group.name|lower }} {{ group.handle|lower }}">
                            <td class="px-4 py-3">
                                <input type="checkbox" name="ids[]" value="{{ group.handle }}" class="row-cb rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div>
                                        <a class="font-medium text-slate-900 hover:text-emerald-700" href="{{ route('entries.groups.show', group) }}">{{ group.name }} <span class="mt-0.5 font-mono text-xs text-slate-400">{{ group.handle }}</span></a>
                                        <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                            <a href="{{ route('entries.groups.show', group) }}" class="text-emerald-600 hover:underline">View</a>
                                            <span class="text-slate-300">|</span>
                                            <a href="{{ route('entries.groups.edit', group) }}" class="text-emerald-600 hover:underline">Edit</a>
                                            <span class="text-slate-300">|</span>
                                            <a href="{{ route('entries.groups.confirm', group) }}" class="text-red-500 hover:underline">Delete</a>
                                        </div>

                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 capitalize text-slate-600">{{ group.entry_types_count ?? '—' }}</td>
                            <td class="px-4 py-3">{{ group.entries_count }}</td>
                            <td class="px-4 py-3 text-center font-medium text-slate-800">{{ group.statusGroup.name ?? '—' }}</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-1.5">
                                    <a href="{{ route('entries.groups.show', group) }}" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="View">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </a>
                                    <a href="{{ route('entries.groups.edit', group) }}" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="Edit">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                    <a href="{{ route('entries.groups.confirm', group) }}" class="rounded p-1 text-slate-400 hover:bg-red-50 hover:text-red-600" title="Delete">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="flex flex-col gap-3 border-t border-slate-200 bg-slate-50 px-4 py-3 text-sm lg:flex-row lg:items-center lg:justify-between">
                <div class="flex flex-wrap items-center gap-2">
                    <select id="bulk-action" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option value="">Bulk action</option>
                        <option value="activate">Activate</option>
                        <option value="deactivate">Deactivate</option>
                        <option value="delete">Delete</option>
                    </select>
                    <button type="button" onclick="applyBulk()" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Apply</button>
                </div>
                {{ groups.links() }}
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                    <span class="text-xs text-slate-500">Showing 1-6 of 42 items</span>
                    <nav class="flex items-center gap-1" aria-label="Pagination">
                        <a href="#" class="inline-flex h-8 items-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-medium text-slate-500 shadow-sm hover:bg-slate-50" aria-label="Previous page">Previous</a>
                        <a href="#" class="inline-flex h-8 min-w-8 items-center justify-center rounded-md bg-emerald-600 px-2.5 text-xs font-semibold text-white shadow-sm" aria-current="page">1</a>
                        <a href="#" class="inline-flex h-8 min-w-8 items-center justify-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-medium text-slate-700 shadow-sm hover:bg-slate-50">2</a>
                        <a href="#" class="inline-flex h-8 min-w-8 items-center justify-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-medium text-slate-700 shadow-sm hover:bg-slate-50">3</a>
                        <span class="inline-flex h-8 items-center px-1.5 text-xs text-slate-400">...</span>
                        <a href="#" class="inline-flex h-8 min-w-8 items-center justify-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-medium text-slate-700 shadow-sm hover:bg-slate-50">7</a>
                        <a href="#" class="inline-flex h-8 items-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-medium text-slate-700 shadow-sm hover:bg-slate-50" aria-label="Next page">Next</a>
                    </nav>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

