{{ include('admin._inc._header', {title: 'Edit Entry'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h4 class="main-title">Entry</h4>
                <ul class="app-line-breadcrumbs mb-3">
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                            <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                        </a>
                    </li>
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('entries.groups') }}">Entry Groups</a>
                    </li>
                    <li>
                        <a class="f-s-14 f-w-500" href="{{ route('entries.groups.show', entry.entryGroup) }}">{{ entry.entryGroup.name }}</a>
                    </li>
                    <li class="active">
                        <a class="f-s-14 f-w-500" href="{{ route('entries.edit', entry) }}">Edit Entry</a>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.entries._sidebar', {active: entry.entry_group_id}) }}
            <div class="col-lg-8 col-xxl-9">

                <!-- Entry Form -->
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Edit Entry — {{ entry.entryType.name ?? 'Entry' }}</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('entries.update', entry) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            {{ method_field('PUT') }}
                            <input type="hidden" name="id" value="{{ entry.id }}" />

                            <!-- Core fields -->
                            <div class="col-md-12">
                                <label class="form-label" for="title">Title</label>
                                <input class="form-control" id="title" required type="text"
                                       value="{{ old('title', entry.title) }}" name="title">
                                {% if errors.has('title') %}
                                    <p class="text-danger">{{ errors.first('title') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-8">
                                <label class="form-label" for="handle">Slug</label>
                                <input class="form-control" id="handle" type="text"
                                       value="{{ old('handle', entry.handle) }}" name="handle">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>

                            <!-- Status -->
                            {% if entry.entryGroup.statusGroup and entry.entryGroup.statusGroup.statuses.count >= 1 %}
                            <div class="col-md-4">
                                <label class="form-label" for="status">Status</label>
                                <select class="form-select" id="status" name="status">
                                    {% for s in entry.entryGroup.statusGroup.statuses %}
                                        <option value="{{ s.handle }}"
                                            {% if old('status', entry.status) == s.handle %}selected{% endif %}>
                                            {{ s.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('status') %}
                                    <p class="text-danger">{{ errors.first('status') }}</p>
                                {% endif %}
                            </div>
                            {% endif %}

                            <!-- Published At -->
                            <div class="col-md-6">
                                <label class="form-label" for="published_at">Publish Date</label>
                                <input class="form-control" id="published_at" type="datetime-local"
                                       value="{{ old('published_at', entry.published_at ? entry.published_at.format('Y-m-d\\TH:i') : '') }}"
                                       name="published_at">
                                <small class="text-secondary">Leave blank to keep as draft.</small>
                                {% if errors.has('published_at') %}
                                    <p class="text-danger">{{ errors.first('published_at') }}</p>
                                {% endif %}
                            </div>

                            <!-- EntryType Field Layout -->
                            {% set typeLayout = entry.entryType.fieldLayout %}
                            {% if typeLayout and typeLayout.tabs.count >= 1 %}
                                {% for tab in typeLayout.tabs %}
                                    <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label" for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    value: field_values[field.handle],
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <!-- EntryGroup Field Layout (shared fields) -->
                            {% set groupLayout = entry.entryGroup.fieldLayout %}
                            {% if groupLayout and groupLayout.tabs.count >= 1 %}
                                <div class="col-12"><h5 class="border-bottom pb-2">Shared Fields</h5></div>
                                {% for tab in groupLayout.tabs %}
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label" for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    value: field_values[field.handle],
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <!-- Authors -->
                            {% if users.count >= 1 %}
                            <div class="col-12"><h5 class="border-bottom pb-2">Authors</h5></div>
                            <div class="col-md-12">
                                <label class="form-label" for="authors">Authors</label>
                                <select class="select-basic-multiple-four w-100 select_primary" multiple="multiple"
                                        name="authors[]" id="authors">
                                    {% for user in users %}
                                        <option value="{{ user.id }}"
                                            {% if old('authors') %}
                                                {% for key, val in old('authors') %}
                                                    {% if old('authors.' ~ key) == user.id %}selected{% endif %}
                                                {% endfor %}
                                            {% else %}
                                                {% for author in entry.authors %}
                                                    {% if author.id == user.id %}selected{% endif %}
                                                {% endfor %}
                                            {% endif %}>
                                            {{ user.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('authors') %}
                                    <p class="text-danger">{{ errors.first('authors') }}</p>
                                {% endif %}
                            </div>
                            {% endif %}

                            <!-- Categories -->
                            {% if entry.entryGroup.categoryGroups.count >= 1 %}
                            <div class="col-12"><h5 class="border-bottom pb-2">Categories</h5></div>
                            {% for catGroup in entry.entryGroup.categoryGroups %}
                                {% if catGroup.categories.count >= 1 %}
                                <div class="col-md-12">
                                    <label class="form-label">{{ catGroup.name }}</label>
                                    {% for category in catGroup.categories %}
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="categories[]" value="{{ category.id }}"
                                                   id="cat_{{ category.id }}"
                                                {% if old('categories') %}
                                                    {% for key, val in old('categories') %}
                                                        {% if old('categories.' ~ key) == category.id %}checked{% endif %}
                                                    {% endfor %}
                                                {% else %}
                                                    {% for entryCat in entry.categories %}
                                                        {% if entryCat.id == category.id %}checked{% endif %}
                                                    {% endfor %}
                                                {% endif %}>
                                            <label class="form-check-label" for="cat_{{ category.id }}">
                                                {{ category.name }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>
                                {% endif %}
                            {% endfor %}
                            {% endif %}

                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Save Entry</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Meta info card -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h5>Entry Details</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <th class="text-secondary" style="width: 30%">Entry Group</th>
                                    <td>{{ entry.entryGroup.name }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Entry Type</th>
                                    <td>{{ entry.entryType.name ?? '—' }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Created By</th>
                                    <td>{{ entry.creator.name ?? '—' }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Created</th>
                                    <td>{{ entry.created_at.format('F j, Y g:i A') }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Last Modified</th>
                                    <td>{{ entry.updated_at.format('F j, Y g:i A') }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
