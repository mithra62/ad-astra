{% import 'admin._inc._ui' as ui %}

{% set items = [{label: 'All Fields', href: route('fields.groups'), icon: 'menu', active: false}] %}
{% for group in groups %}
    {% set items = items|merge([{
        label: group.name ~ ' (' ~ group.fields.count() ~ ')',
        href: route('fields.groups.show', group),
        icon: 'menu',
        active: active == group.id
    }]) %}
{% endfor %}

{{ ui.section_nav('Field Groups', items) }}
