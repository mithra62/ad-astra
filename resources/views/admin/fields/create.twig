{{ include('admin._inc._header', {title: 'Create Field'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Field</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone  ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('fields.groups') }}">Field Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('fields.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('fields.groups.create') }}">Create Field</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <!-- Custom Styles start -->
        <div class="row">
            {{ include('admin.fields._sidebar', {active: group.id}) }}
            <div class="col-9">
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Create Field</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('fields.store', {group_id: group.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            <div class="mb-12">
                                <label class="form-label" for="type">Type</label>
                                <select class="form-select" id="type" name="type">
                                    {% for type, name in field_types %}
                                        <option value="{{ type }}"
                                                {% if old('type') == type %}selected{% elseif type == 'text' %}selected{% endif %}>{{ name }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('storage') %}
                                    <p class="text-danger">{{ errors.first('storage') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text" value="{{ old('name') }}"
                                       name="name">
                                {% if errors.has('name') %}
                                    <p class="text-danger">{{ errors.first('name') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="handle">Slug</label>
                                <input class="form-control" id="handle" required type="text" value="{{ old('handle') }}"
                                       name="handle">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>

                            <div class="col-md-12">
                                <label class="form-label" for="instructions">Instructions</label>
                                <textarea class="form-control" id="instructions" name="instructions"
                                          placeholder="Field instructions that appear in the publish form."
                                          rows="3"></textarea>
                                {% if errors.has('instructions') %}
                                    <p class="text-danger">{{ errors.first('instructions') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Create Field</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- Custom Styles end -->
        </div>
    </div>
</main>

{{ include('admin._inc._footer') }}
