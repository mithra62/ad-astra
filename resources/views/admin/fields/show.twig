{% extends 'admin._inc._layout' %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'View Field' %}
{% set page_heading = 'Field Groups' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'field_groups' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Field Groups', href: route('fields.groups')},
        {label: field.groups.first.name, href: route('fields.groups.show', field.groups.first)},
        {label: field.name}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.fields._sidebar', {active: field.groups.first.id}) }}
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-2.5">
                    <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">{{ field.name }}</h1>
                    <span class="inline-flex rounded-full bg-canvas px-2.5 py-0.5 text-xs font-medium text-content">{{ field.fieldType.name }}</span>
                    <span class="inline-flex rounded-full {{ field.hidden ? 'bg-amber-50 text-amber-700' : 'bg-accent-soft text-accent' }} px-2.5 py-0.5 text-xs font-medium">{{ field.hidden ? 'Hidden' : 'Visible' }}</span>
                </div>
                <p class="mt-1 text-sm text-muted">Field definition and placement within {{ layout.name }}.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 self-start">
                <a href="{{ route('fields.groups.show', field.groups.first) }}" class="inline-flex items-center gap-1.5 rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle">
                    Back to {{ field.groups.first.name }}
                </a>
                <a href="{{ route('fields.edit', field) }}" class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                    Edit Field
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Field Details</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-muted">Name</dt>
                            <dd class="font-medium text-content">{{ field.name }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-muted">Handle</dt>
                            <dd class="font-mono text-xs text-content">{{ field.handle }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-muted">Label</dt>
                            <dd class="text-content">{{ field.label|default(field.name) }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-muted">Instructions</dt>
                            <dd class="text-content">{{ field.instructions|default('None') }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-muted">Type</dt>
                            <dd class="break-all font-mono text-xs text-content">{{ field.fieldType.name }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Placement in {{ layout.name }}</h5>
                    </div>
                    <div class="divide-y divide-slate-100">
                        {% for tab in layout.tabs %}
                            <section id="tab-{{ tab.handle }}" class="px-5 py-4">
                                <div class="mb-3 flex items-center justify-between gap-3">
                                    <div>
                                        <h2 class="text-sm font-semibold text-content">{{ tab.name }}</h2>
                                        <p class="font-mono text-xs text-faint">{{ tab.handle }}</p>
                                    </div>
                                    <span class="rounded-full bg-canvas px-2.5 py-0.5 text-xs font-medium text-muted">{{ tab.elements|length }} fields</span>
                                </div>

                                <div class="space-y-2">
                                    {% for element in tab.elements %}
                                        {% set is_current = element.field.handle == field.handle %}
                                        <div class="rounded-md border {{ is_current ? 'border-emerald-200 bg-accent-soft' : 'border-edge bg-surface' }} px-4 py-3">
                                            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                                <div class="min-w-0">
                                                    <p class="truncate text-sm font-medium {{ is_current ? 'text-emerald-900' : 'text-content' }}">{{ element.field.name }}</p>
                                                    <p class="truncate font-mono text-xs {{ is_current ? 'text-accent' : 'text-faint' }}">{{ element.field.handle }}</p>
                                                </div>
                                                <div class="flex flex-wrap gap-1.5">
                                                    {% if element.required %}
                                                        <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Required</span>
                                                    {% endif %}
                                                    {% if element.hidden %}
                                                        <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Hidden</span>
                                                    {% endif %}
                                                    <span class="rounded-full bg-canvas px-2 py-0.5 text-xs font-medium text-muted">{{ element.width|default('full') }}</span>
                                                </div>
                                            </div>
                                            {% if is_current and element.instructions|default('') %}
                                                <p class="mt-2 text-xs text-emerald-800">{{ element.instructions }}</p>
                                            {% endif %}
                                        </div>
                                    {% else %}
                                        <p class="rounded-md border border-dashed border-edge px-4 py-6 text-center text-sm text-muted">No fields have been assigned to this tab.</p>
                                    {% endfor %}
                                </div>
                            </section>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Groups</h5>
                    </div>
                    <div class="space-y-2 px-5 py-4">
                        {% for group in field.groups %}
                            <a  href="{{ route('fields.groups.show', group) }}" class="flex items-center justify-between rounded-md border border-edge px-3 py-2 text-sm font-medium text-content hover:bg-subtle">
                                <span>{{ group.name }}</span>
                                <span class="font-mono text-xs text-faint">#{{ group.id }}</span>
                            </a>
                        {% else %}
                            <p class="text-sm text-muted">This field is not assigned to any field groups.</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Metadata</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-xs">
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-muted">ID</dt>
                            <dd class="font-medium text-content">{{ field.id }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-muted">Layout</dt>
                            <dd class="text-content">{{ layout.name }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-muted">Created</dt>
                            <dd class="text-content">{{ field.created_at|date('M j, Y') }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-muted">Updated</dt>
                            <dd class="text-content">{{ field.updated_at|date('M j, Y') }}</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
