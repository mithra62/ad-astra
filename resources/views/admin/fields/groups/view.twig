{% extends 'admin._inc._layout' %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Field Groups' %}
{% set page_heading = 'Field Groups' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'field_groups' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Field Groups', href: route('fields.groups')},
        {label: group.name}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.fields._sidebar', {active: group.id}) }}
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        {% embed 'admin._inc._page-header' with {title: group.name, subtitle: 'Manage the fields that belong to this group.'} %}
            {% block actions %}
                {% import 'admin._inc._ui' as ui %}
                {{ ui.button('Edit Group', route('fields.groups.edit', group.id), 'secondary', icon='pencil') }}
                {{ ui.button('Create Field', route('fields.create', {group_id: group.id}), icon='plus') }}
            {% endblock %}
        {% endembed %}

        <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
            <div class="border-b border-edge px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h5 class="text-sm font-semibold text-content">Field List</h5>
                        <p class="mt-0.5 text-xs text-muted">No Fields match the current view.</p>
                    </div>
                </div>
            </div>

            {% if fields.count >= 1 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                        <thead class="bg-subtle text-xs font-semibold uppercase tracking-wide text-muted">
                        <tr>
                            <th class="px-5 py-3" scope="col">Name</th>
                            <th class="hidden px-5 py-3 sm:table-cell" scope="col">Type</th>
                            <th class="px-5 py-3 text-right" scope="col">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 bg-surface">
                        {% for field in fields %}
                            <tr class="hover:bg-subtle">
                                <td class="px-5 py-3.5">
                                    <p class="font-medium text-content">{{ field.name }}</p>
                                    <p class="mt-0.5 text-xs text-faint">{{ field.handle }}</p>
                                </td>
                                <td class="hidden px-5 py-3.5 text-muted sm:table-cell">
                                    {{ field.fieldType.name }}
                                </td>
                                <td class="px-5 py-3.5">
                                    <div class="flex items-center justify-end gap-1">
                                        <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" href="{{ route('fields.show', field) }}" title="View">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                            <span class="sr-only">View</span>
                                        </a>
                                        <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" href="{{ route('fields.edit', field) }}" title="Edit">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                            </svg>
                                            <span class="sr-only">Edit</span>
                                        </a>
                                        <a class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600" href="{{ route('fields.confirm', field) }}" title="Delete">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                            <span class="sr-only">Delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="flex min-h-80 items-center justify-center px-6 py-14">
                    <div class="max-w-sm text-center">
                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas text-faint">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5A3.375 3.375 0 0010.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                            </svg>
                        </div>
                        <h2 class="mt-4 text-base font-semibold text-content">No Fields found</h2>
                        <p class="mt-1 text-sm text-muted">Create your first entry or adjust the filters to broaden the list.</p>
                        <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                            <a href="{{ route('fields.create', {group_id: group.id}) }}" class="inline-flex items-center justify-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" >
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                </svg>
                                Create Field
                            </a>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="border-t border-edge px-5 py-3">
                <p class="text-xs text-muted">Showing {{ fields.count}} fields</p>
            </div>
        </div>
    </div>
{% endblock %}
