{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Category Groups' %}
{% set page_heading = 'Category Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'categories' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('categories.groups') }}">
            Category Groups
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('categories.groups', category.group) }}">
            {{ category.group.name }}
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">{{ category.name }}</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.categories._sidebar', {active: category.group.id}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Edit Category</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('categories.groups.show', category.group) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to {{ category.group.name }}
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('categories.update', category) }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">

                    {{ forms.input(name='name', label='Name', required=true, placeholder="", value=category.name) }}
                    {{ forms.input('handle', 'Handle', required=true, description="Lowercase letters, numbers, and hyphens only.", value=category.handle) }}
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Parent Category</label>
                        <select class="w-full rounded-md border bg-white px-3 py-2 text-sm shadow-sm transition focus:outline-none focus:ring-2 {% if errors.has('parent_id') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}border-slate-300 focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="parent_id" name="parent_id">
                            <option value="">— No Parent (top-level) —</option>
                            {% for cat in parent_categories %}
                                <option value="{{ cat.id }}"
                                    {{ old('parent_id', category.parent_id) == cat.id ? 'selected' : '' }}>
                                    {{ cat.label }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.has('parent_id') %}<p id="handle-error" class="mt-1 text-xs text-red-600">{{ errors.first('parent_id') }}</p>{% endif %}
                    </div>

                </div>
            </div>

            {% set layout = category.group.fieldLayout %}
            {% if layout and layout.tabs.count >= 1 %}
                {% for tab in layout.tabs %}
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">{{ tab.name }}</h5>
                    </div>
                    <div class="space-y-5 px-5 py-5">
                        {% for element in tab.elements %}
                            {% set field = element.field %}
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700"
                                       for="field_{{ field.handle }}">{{ field.label }}</label>
                                {% if field.instructions %}
                                    <small
                                        class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                {% endif %}
                                {{ field.render({
                                    value: field_values[field.handle],
                                    id: 'field_' ~ field.handle,
                                    class: 'w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20'
                                })|raw }}
                                {% if errors.has('fields.' ~ field.handle) %}
                                    <p class="mt-1 text-xs text-red-600">{{ errors.first('fields.' ~ field.handle) }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% endfor %}
                {% endif %}

            </div>
            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('categories.show', category) }}" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Edit Category</button>
            </div>
        </form>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Children</h5>
            </div>
            <div class="space-y-5 px-5 py-5">
                {% if category.children.count >= 1 %}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
                            <tr>
                                <th class="px-5 py-3" scope="col">Title</th>
                                <th class="hidden px-5 py-3 sm:table-cell" scope="col">Children</th>
                                <th class="hidden px-5 py-3 lg:table-cell" scope="col">Updated</th>
                                <th class="px-5 py-3" scope="col">Created</th>
                                <th class="px-5 py-3 text-right" scope="col">Actions</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 bg-white">
                            {% for child in category.children %}
                                <tr class="hover:bg-slate-50">
                                    <td class="px-5 py-3.5">
                                        <a class="font-medium text-slate-900 hover:text-emerald-700" href="{{ route('categories.show', child) }}">{{ child.name }} <span class="mt-0.5 font-mono text-xs text-slate-400">{{ child.handle }}</span></a>
                                        <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                            <a href="{{ route('categories.show', child) }}" class="text-emerald-600 hover:underline">View</a>
                                            <span class="text-slate-300">|</span>
                                            <a href="{{ route('categories.edit', child) }}" class="text-emerald-600 hover:underline">Edit</a>
                                            <span class="text-slate-300">|</span>
                                            <a href="{{ route('categories.confirm', child) }}" class="text-red-500 hover:underline">Delete</a>
                                        </div>
                                    </td>
                                    <td class="hidden px-5 py-3.5 text-slate-600 sm:table-cell">
                                        {{ child.children.count() }}
                                    </td>
                                    <td class="px-5 py-3.5">
                                        {{ child.updated_at.format('F j, Y') }}
                                    </td>
                                    <td class="hidden px-5 py-3.5 text-slate-400 lg:table-cell">{{ child.created_at.format('F j, Y') }}</td>
                                    <td class="px-5 py-3.5">
                                        <div class="flex items-center justify-end gap-1">
                                            <a href="{{ route('categories.create', {group_id: category.group.id, parent_id: child.id}) }}" class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" title="View">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                                </svg>
                                                <span class="sr-only">Create Child</span>
                                            </a>
                                            <a href="{{ route('categories.show', child) }}" class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" title="View">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                                </svg>
                                                <span class="sr-only">View</span>
                                            </a>
                                            <a href="{{ route('categories.edit', child) }}" class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" title="Edit">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                                <span class="sr-only">Edit</span>
                                            </a>
                                            <a href="{{ route('categories.confirm', child) }}" class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600" title="Delete">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                <span class="sr-only">Delete</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="flex min-h-80 items-center justify-center px-6 py-14">
                        <div class="max-w-sm text-center">
                            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5A3.375 3.375 0 0010.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                                </svg>
                            </div>
                            <h2 class="mt-4 text-base font-semibold text-slate-900">No Child Categories found</h2>
                            <p class="mt-1 text-sm text-slate-500">Create your first entry or adjust the filters to broaden the list.</p>
                            <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                                <a href="{{ route('categories.create', {group_id: category.group.id, parent_id: category.id}) }}" class="inline-flex items-center justify-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                    </svg>
                                    Create Child Category
                                </a>
                                <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="index.twig">Clear filters</a>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    {{ forms.color_scripts() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}









