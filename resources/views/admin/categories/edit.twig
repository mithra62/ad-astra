{{ include('admin._inc._header', {title: 'Edit Category'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h4 class="main-title">Category</h4>
                <ul class="app-line-breadcrumbs mb-3">
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                            <span>
                                <i class="ph-duotone ph-table f-s-16"></i> Dashboard
                            </span>
                        </a>
                    </li>
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('categories.groups') }}">Category Groups</a>
                    </li>
                    <li>
                        <a class="f-s-14 f-w-500"
                           href="{{ route('categories.groups.show', category.group) }}">{{ category.group.name }}</a>
                    </li>
                    <li class="active">
                        <a class="f-s-14 f-w-500" href="{{ route('categories.edit', category) }}">Edit Category</a>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.categories._sidebar', {active: category.group.id}) }}
            <div class="col-lg-8 col-xxl-9">

                <!-- Category Form -->
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Edit Category</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('categories.update', category.id) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            {{ method_field('PUT') }}

                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text"
                                       value="{{ old('name', category.name) }}" name="name">
                                {% if errors.has('name') %}
                                    <p class="text-danger">{{ errors.first('name') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="handle">Slug</label>
                                <input class="form-control" id="handle" type="text"
                                       value="{{ old('handle', category.handle) }}" name="handle">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>

                            <!-- Group Field Layout -->
                            {% set layout = category.group.fieldLayout %}
                            {% if layout and layout.tabs.count >= 1 %}
                                {% for tab in layout.tabs %}
                                    <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label" for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    value: field_values[field.handle],
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Save Category</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Children card -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h5>Children</h5>
                    </div>
                    <div class="card-body">
                        {% if category.children.count >= 1 %}
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead>
                                    <tr>
                                        <th scope="col">Name</th>
                                        <th scope="col">Slug</th>
                                        <th scope="col">Children</th>
                                        <th scope="col">Last Modified</th>
                                        <th scope="col">Created</th>
                                        <th scope="col"></th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for child in category.children %}
                                        <tr>
                                            <td>{{ child.name }}</td>
                                            <td class="f-w-500">
                                                {{ child.handle }}
                                            </td>
                                            <td class="text-secondary f-w-600">
                                                {{ child.children.count() }}
                                            </td>
                                            <td>
                                                {{ child.created_at.format('F j, Y') }}
                                            </td>
                                            <td>
                                                {{ child.created_at.format('F j, Y') }}
                                            </td>
                                            <td>
                                                <a class="btn btn-primary icon-btn b-r-4"
                                                   href="{{ route('categories.show', child) }}">
                                                    <i class="ti ti-eye"></i>
                                                </a>
                                                <a class="btn btn-success icon-btn b-r-4"
                                                   href="{{ route('categories.edit', child) }}">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <a class="btn btn-danger icon-btn b-r-4"
                                                   href="{{ route('categories.confirm', child) }}">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <p class="text-center">
                                No Child Categories Created. <br />
                                <a href="{{ route('categories.create', {group_id: category.group.id}) }}" class="btn btn-outline-primary">Create Child Category</a>
                            </p>
                        {% endif %}
                    </div>
                </div>

                <!-- Meta info card -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h5>Category Details</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <th class="text-secondary" style="width: 30%">Group</th>
                                    <td>{{ category.group.name }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Created</th>
                                    <td>{{ category.created_at.format('F j, Y g:i A') }}</td>
                                </tr>
                                <tr>
                                    <th class="text-secondary">Last Modified</th>
                                    <td>{{ category.updated_at.format('F j, Y g:i A') }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
