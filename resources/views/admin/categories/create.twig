{{ include('admin._inc._header', {title: 'Create Category'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Category Groups</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('categories.groups') }}">Category Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('categories.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('categories.create', group) }}">Create Category</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            {{ include('admin.categories._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Create Category</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('categories.store', {group_id: group.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}

                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text"
                                       value="{{ old('name') }}" name="name">
                                {% if errors.has('name') %}
                                    <p class="text-danger">{{ errors.first('name') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="handle">Slug</label>
                                <input class="form-control" id="handle" type="text"
                                       value="{{ old('handle') }}" name="handle"
                                       placeholder="Leave blank to auto-generate from name">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="parent_id">Parent Category</label>
                                <select class="form-select" id="parent_id" name="parent_id">
                                    <option value="">— No Parent (top-level) —</option>
                                    {% for cat in parent_categories %}
                                        <option value="{{ cat.id }}"
                                            {{ old('parent_id', selected_parent_id) == cat.id ? 'selected' : '' }}>
                                            {{ cat.label }}
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('parent_id') %}
                                    <p class="text-danger">{{ errors.first('parent_id') }}</p>
                                {% endif %}
                            </div>

                            <!-- Group Field Layout -->
                            {% set layout = group.fieldLayout %}
                            {% if layout and layout.tabs.count >= 1 %}
                                {% for tab in layout.tabs %}
                                    <div class="col-12"><h5 class="border-bottom pb-2">{{ tab.name }}</h5></div>
                                    {% for element in tab.elements %}
                                        {% set field = element.field %}
                                        <div class="col-md-12">
                                            <label class="form-label"
                                                   for="field_{{ field.handle }}">{{ field.label }}</label>
                                            {% if field.instructions %}
                                                <small
                                                    class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                            {% endif %}
                                            <div class="input-group has-validation">
                                                {{ field.render({
                                                    id: 'field_' ~ field.handle,
                                                    class: 'form-control'
                                                })|raw }}
                                            </div>
                                            {% if errors.has('fields.' ~ field.handle) %}
                                                <p class="text-danger">{{ errors.first('fields.' ~ field.handle) }}</p>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}

                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Create Category</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
