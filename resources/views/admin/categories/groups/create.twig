{{ include('admin._inc._header', {title: 'Create Category Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Category Groups</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone  ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('categories.groups') }}">Category Groups</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('categories.groups.create') }}">Create Category Group</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <!-- Custom Styles start -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex flex-column gap-2">
                    <h5>Create Category Group</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ route('categories.groups.store') }}" class="row g-3 needs-validation" novalidate>
                        {{ csrf_field() }}
                        <div class="col-md-12">
                            <label class="form-label" for="name">Name</label>
                            <input class="form-control" id="name" required type="text" value="{{ old('name') }}" name="name">
                            {% if errors.has('name') %}
                                <p class="text-danger">{{ errors.first('name') }}</p>
                            {% endif %}
                        </div>
                        <div class="col-md-12">
                            <label class="form-label" for="slug">Slug</label>
                            <input class="form-control" id="slug" required type="text" value="{{ old('slug') }}" name="slug">
                            {% if errors.has('slug') %}
                                <p class="text-danger">{{ errors.first('slug') }}</p>
                            {% endif %}
                        </div>

                        {% if field_groups.count >= 1 %}

                            <div class="mb-12">
                                <label class="form-label" for="category_groups">Field Groups</label>
                                {% for group in field_groups %}
                                    <div class="form-check d-flex">
                                        <input class="form-check-input mg-2"
                                               id="library.{{ group.slug }}"
                                               type="checkbox"
                                               name="field_groups[]"
                                               value="{{ group.id }}"
                                            {% if old('field_groups') %}
                                                {% for key, field in old('field_groups') %}
                                                    {% if old('field_groups.' ~ key) == group.id %}checked{% endif %}
                                                {% endfor %}

                                            {% else %}
                                                {% for key, field in library.field_groups %}
                                                    {% if field.id == group.id %}checked{% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        >
                                        <label class="form-check-label ms-2" for="library.{{ group.slug }}">
                                            {{ group.name }}
                                        </label>
                                    </div>
                                {% endfor %}
                                {% if errors.has('category_groups') %}
                                    <p class="text-danger">{{ errors.first('category_groups') }}</p>
                                {% endif %}
                            </div>
                        {% else %}

                        {% endif %}

                        <div class="col-12">
                            <button class="btn btn-primary float-end" type="submit">Create Category Group</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- Custom Styles end -->
    </div>
</main>

{{ include('admin._inc._footer') }}
