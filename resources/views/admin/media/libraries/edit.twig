{% extends 'admin._inc._layout' %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Edit Media Library' %}
{% set page_heading = 'Edit Media Library' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Media Libraries', href: route('media.libraries')},
        {label: library.name, href: route('media.libraries.show', library)},
        {label: 'Edit'}
    ]) }}
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-edge bg-surface px-4 py-2.5 text-sm font-medium text-muted hover:bg-subtle lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-faint">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-edge bg-surface px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('media.libraries') }}">Libraries</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('media.libraries.show', library) }}">View Library</a>
            <a class="flex items-center gap-2 rounded-md bg-accent-soft px-3 py-2 text-sm font-medium text-accent" href="{{ route('media.libraries.edit', library) }}">Edit Library</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
            <div class="border-b border-edge px-4 py-3">
                <h5 class="text-sm font-semibold text-content">{{ library.name }}</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('media.libraries') }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                    </svg>
                    All Libraries
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('media.libraries.show', library) }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    View Library
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-accent-soft px-3 py-2 text-sm font-medium text-accent" href="{{ route('media.libraries.edit', library) }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit Library
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50" href="{{ route('media.libraries.confirm', library) }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Delete Library
                </a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Edit: {{ library.name }}</h1>
                <p class="mt-1 text-sm text-muted">Update storage configuration and upload rules for this library.</p>
            </div>
            <a href="{{ route('media.libraries.show', library) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Library
            </a>
        </div>

        <form method="POST" action="{{ route('media.libraries.update', library) }}" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
            {{ csrf_field() }}
            {{ method_field('PUT') }}

            <div class="flex min-w-0 flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Basic Details</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-content" for="name">Name <span class="text-red-500">*</span></label>
                            <input class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('name') %} border-red-400{% endif %}"
                                   id="name" name="name" type="text" value="{{ old('name', library.name) }}" placeholder="Marketing Assets">
                            {% if errors.has('name') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('name') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-content" for="handle">Handle <span class="text-red-500">*</span></label>
                            <div class="flex rounded-md shadow-sm">
                                <span class="inline-flex items-center rounded-l-md border border-r-0 border-edge bg-subtle px-3 text-xs text-muted">media/</span>
                                <input class="w-full rounded-r-md border border-edge px-3 py-2 font-mono text-sm placeholder:font-sans placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('handle') %} border-red-400{% endif %}"
                                       id="handle" name="handle" type="text" value="{{ old('handle', library.handle) }}" placeholder="marketing-assets">
                            </div>
                            {% if errors.has('handle') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('handle') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-content" for="status_group_id">Status Group</label>
                            <select class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('status_group_id') %} border-red-400{% endif %}"
                                    id="status_group_id" name="status_group_id">
                                <option value="">— None (ungoverned) —</option>
                                {% for sg in status_groups %}
                                    <option value="{{ sg.id }}" {% if old('status_group_id', library.status_group_id) == sg.id %}selected{% endif %}>{{ sg.name }}</option>
                                {% endfor %}
                            </select>
                            <p class="mt-1 text-xs text-faint">Changing or clearing this group does not retroactively migrate existing media — their saved status handle stays put.</p>
                            {% if errors.has('status_group_id') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('status_group_id') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Storage</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-content" for="adapter">Storage Disk <span class="text-red-500">*</span></label>
                                <select class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="adapter" name="adapter">
                                    {% for key, disk in disks %}
                                        <option value="{{ key }}" {% if old('adapter', library.adapter) == key %}selected{% endif %}>{{ key|capitalize }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('adapter') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter') }}</p>
                                {% endif %}
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-content" for="max_size">Max File Size</label>
                                <div class="flex rounded-md shadow-sm">
                                    <input class="w-full rounded-l-md border border-edge px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="max_size" name="max_size" type="number" min="0" value="{{ old('max_size', library.max_size) }}">
                                    <span class="inline-flex items-center rounded-r-md border border-l-0 border-edge bg-subtle px-3 text-xs text-muted">MB</span>
                                </div>
                                <p class="mt-1 text-xs text-faint">Set to 0 for unlimited.</p>
                                {% if errors.has('max_size') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('max_size') }}</p>
                                {% endif %}
                            </div>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-content" for="adapter_url">Base URL</label>
                            <input class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="adapter_url" name="adapter_settings[local][url]" type="text"
                                   value="{{ old('adapter_settings.local.url', library.adapter_settings.local.url ?? '') }}"
                                   placeholder="https://example.com/storage">
                            {% if errors.has('adapter_settings.local.url') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter_settings.local.url') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Upload Rules</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-content">Allowed File Types</label>
                            <p class="mb-2 text-xs text-faint">Leave all unchecked to accept any file type.</p>
                            <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                                {% for handle, mime in allowed_types %}
                                    {% if old('allowed_types') is not null %}
                                        {% set is_checked = mime in old('allowed_types', []) %}
                                    {% else %}
                                        {% set is_checked = library.allowed_types and mime in library.allowed_types %}
                                    {% endif %}
                                    <label class="flex cursor-pointer items-start gap-2.5 rounded-md border border-edge bg-subtle px-3 py-2.5 text-sm text-content">
                                        <input type="checkbox" name="allowed_types[]" value="{{ mime }}" class="mt-0.5 rounded border-edge text-emerald-600 focus:ring-emerald-500"
                                               {% if is_checked %}checked{% endif %}>
                                        <span class="capitalize">{{ handle }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            {% if errors.has('allowed_types') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('allowed_types') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if category_groups.count >= 1 %}
                    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                        <div class="border-b border-edge px-5 py-3">
                            <h5 class="text-sm font-semibold text-content">Category Groups</h5>
                        </div>
                        <div class="divide-y divide-slate-100 px-5 py-1">
                            {% for group in category_groups %}
                                {% if old('category_groups') is not null %}
                                    {% set is_checked = group.id in old('category_groups', []) %}
                                {% else %}
                                    {% set is_checked = false %}
                                    {% for cg in library.categoryGroups %}
                                        {% if cg.id == group.id %}{% set is_checked = true %}{% endif %}
                                    {% endfor %}
                                {% endif %}
                                <label class="flex cursor-pointer items-center gap-2.5 py-2.5 text-sm text-content">
                                    <input class="rounded border-edge text-emerald-600 focus:ring-emerald-500"
                                           name="category_groups[]" type="checkbox" value="{{ group.id }}"
                                           {% if is_checked %}checked{% endif %}>
                                    {{ group.name }}
                                </label>
                            {% endfor %}
                        </div>
                        {% if errors.has('category_groups') %}
                            <p class="px-5 pb-3 text-sm text-red-600">{{ errors.first('category_groups') }}</p>
                        {% endif %}
                    </div>
                {% endif %}

            </div>

            <div class="flex flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Save</h5>
                    </div>
                    <div class="space-y-2 px-5 py-4">
                        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                            Save Changes
                        </button>
                        <a href="{{ route('media.libraries.show', library) }}" class="block w-full rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-medium text-muted shadow-sm hover:bg-subtle">
                            Cancel
                        </a>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-red-200 bg-surface shadow-sm">
                    <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                        <h5 class="text-sm font-semibold text-red-800">Danger Zone</h5>
                    </div>
                    <div class="px-5 py-4">
                        <p class="mb-3 text-xs text-muted">Deleting this library will queue all its media files for removal.</p>
                        <a href="{{ route('media.libraries.confirm', library) }}" class="block w-full rounded-md border border-red-300 bg-surface px-4 py-2 text-center text-sm font-medium text-red-600 shadow-sm hover:bg-red-50">
                            Delete Library
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
{% endblock %}
