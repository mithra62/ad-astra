{% extends 'admin._inc._layout' %}

{% set page_title = 'Create Media Library' %}
{% set page_heading = 'Create Media Library' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('media.libraries') }}">Media Libraries</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Create Media Library</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('media.libraries') }}">Libraries</a>
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="{{ route('media.libraries.create') }}">New Library</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Media</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('media.libraries') }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                    </svg>
                    Libraries
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="{{ route('media.libraries.create') }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                    </svg>
                    New Library
                </a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Media Library</h1>
                <p class="mt-1 text-sm text-slate-500">Configure storage, upload rules, and access defaults for a new media library.</p>
            </div>
            <a href="{{ route('media.libraries') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Libraries
            </a>
        </div>

        <form method="POST" action="{{ route('media.libraries.store') }}" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
            {{ csrf_field() }}

            <div class="flex min-w-0 flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Basic Details</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('name') %} border-red-400{% endif %}"
                                   id="name" name="name" type="text" value="{{ old('name') }}" placeholder="Marketing Assets">
                            <p class="mt-1 text-xs text-slate-400">Shown in media navigation and upload destination lists.</p>
                            {% if errors.has('name') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('name') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Handle <span class="text-red-500">*</span></label>
                            <div class="flex rounded-md shadow-sm">
                                <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">media/</span>
                                <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 font-mono text-sm placeholder:font-sans placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('handle') %} border-red-400{% endif %}"
                                       id="handle" name="handle" type="text" value="{{ old('handle') }}" placeholder="marketing-assets">
                            </div>
                            <p class="mt-1 text-xs text-slate-400">Lowercase letters, numbers, and hyphens only.</p>
                            {% if errors.has('handle') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('handle') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status_group_id">Status Group</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('status_group_id') %} border-red-400{% endif %}"
                                    id="status_group_id" name="status_group_id">
                                <option value="">— None (ungoverned) —</option>
                                {% for sg in status_groups %}
                                    <option value="{{ sg.id }}" {% if old('status_group_id') == sg.id %}selected{% endif %}>{{ sg.name }}</option>
                                {% endfor %}
                            </select>
                            <p class="mt-1 text-xs text-slate-400">Optional. When set, uploaded files take the group's default status and can be moved between statuses on edit.</p>
                            {% if errors.has('status_group_id') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('status_group_id') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Storage</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="adapter">Storage Disk <span class="text-red-500">*</span></label>
                                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="adapter" name="adapter">
                                    {% for key, disk in disks %}
                                        <option value="{{ key }}" {% if old('adapter', 'local') == key %}selected{% endif %}>{{ key|capitalize }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('adapter') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter') }}</p>
                                {% endif %}
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="max_size">Max File Size</label>
                                <div class="flex rounded-md shadow-sm">
                                    <input class="w-full rounded-l-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="max_size" name="max_size" type="number" min="0" value="{{ old('max_size', 10) }}">
                                    <span class="inline-flex items-center rounded-r-md border border-l-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">MB</span>
                                </div>
                                <p class="mt-1 text-xs text-slate-400">Set to 0 for unlimited.</p>
                                {% if errors.has('max_size') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('max_size') }}</p>
                                {% endif %}
                            </div>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="adapter_url">Base URL</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="adapter_url" name="adapter_settings[local][url]" type="text" value="{{ old('adapter_settings.local.url') }}" placeholder="https://example.com/storage/marketing">
                            {% if errors.has('adapter_settings.local.url') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter_settings.local.url') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Upload Rules</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700">Allowed File Types</label>
                            <p class="mb-2 text-xs text-slate-400">Leave all unchecked to accept any file type.</p>
                            <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                                {% for handle, mime in allowed_types %}
                                    <label class="flex cursor-pointer items-start gap-2.5 rounded-md border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm text-slate-700">
                                        <input type="checkbox" name="allowed_types[]" value="{{ mime }}" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                               {% if old('allowed_types') is not null and mime in old('allowed_types', []) %}checked{% endif %}>
                                        <span class="capitalize">{{ handle }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            {% if errors.has('allowed_types') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('allowed_types') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if category_groups.count >= 1 %}
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3">
                            <h5 class="text-sm font-semibold text-slate-700">Category Groups</h5>
                        </div>
                        <div class="divide-y divide-slate-100 px-5 py-1">
                            {% for group in category_groups %}
                                <label class="flex cursor-pointer items-center gap-2.5 py-2.5 text-sm text-slate-700">
                                    <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                           name="category_groups[]" type="checkbox" value="{{ group.id }}"
                                           {% if old('category_groups') is not null and group.id in old('category_groups', []) %}checked{% endif %}>
                                    {{ group.name }}
                                </label>
                            {% endfor %}
                        </div>
                        {% if errors.has('category_groups') %}
                            <p class="px-5 pb-3 text-sm text-red-600">{{ errors.first('category_groups') }}</p>
                        {% endif %}
                    </div>
                {% endif %}

            </div>

            <div class="flex flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Save</h5>
                    </div>
                    <div class="space-y-2 px-5 py-4">
                        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                            Create Media Library
                        </button>
                        <a href="{{ route('media.libraries') }}" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-600 shadow-sm hover:bg-slate-50">
                            Cancel
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
{% endblock %}
