{% extends 'admin._inc._layout' %}

{% set page_title = 'All Media' %}
{% set page_heading = 'All Media' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="{{ route('dashboard') }}">Dashboard</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('media.libraries') }}">Media Libraries</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-content">All Files</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.media._sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">All Media Files</h1>
                <p class="mt-1 text-sm text-muted">Browse all uploaded files across every library.</p>
            </div>
            <a href="{{ route('media.libraries') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                View Libraries
            </a>
        </div>

        <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
            <div class="border-b border-edge px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <h5 class="text-sm font-semibold text-content">Files</h5>
                    <span class="rounded-full bg-canvas px-2 py-0.5 text-xs font-medium text-muted">
                        {{ media.total() }} total
                    </span>
                </div>
            </div>

            {% if media.count() >= 1 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                        <thead class="bg-subtle text-xs font-semibold uppercase tracking-wide text-muted">
                        <tr>
                            <th class="px-4 py-3" scope="col">File</th>
                            <th class="px-4 py-3" scope="col">Type</th>
                            <th class="px-4 py-3" scope="col">Size</th>
                            <th class="px-4 py-3" scope="col">Library</th>
                            <th class="px-4 py-3" scope="col">Uploaded</th>
                            <th class="px-4 py-3 text-right" scope="col">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 bg-surface">
                        {% for item in media %}
                            <tr class="hover:bg-subtle">
                                <td class="px-4 py-3.5">
                                    <div class="flex items-center gap-3">
                                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-canvas text-faint">
                                            {% if item.mime_type and ('image' in item.mime_type) %}
                                                <svg class="h-4 w-4 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                                </svg>
                                            {% elseif item.mime_type and ('video' in item.mime_type) %}
                                                <svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
                                                </svg>
                                            {% else %}
                                                <svg class="h-4 w-4 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                                </svg>
                                            {% endif %}
                                        </div>
                                        <div class="min-w-0">
                                            <a class="font-medium text-content hover:text-accent" href="{{ route('media.show', item) }}">{{ item.name ?: item.file_name }}</a>
                                            <p class="mt-0.5 font-mono text-xs text-faint truncate max-w-[200px]">{{ item.file_name }}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3.5 text-muted">{{ item.mime_type ?: '—' }}</td>
                                <td class="px-4 py-3.5 text-muted">
                                    {% if item.size > 1048576 %}
                                        {{ (item.size / 1048576)|number_format(1) }} MB
                                    {% elseif item.size > 1024 %}
                                        {{ (item.size / 1024)|number_format(1) }} KB
                                    {% else %}
                                        {{ item.size }} B
                                    {% endif %}
                                </td>
                                <td class="px-4 py-3.5 text-muted">
                                    {% if item.library %}
                                        <a class="text-emerald-600 hover:underline" href="{{ route('media.libraries.show', item.library) }}">{{ item.library.name }}</a>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-4 py-3.5 text-muted">{{ item.created_at|date('M j, Y') }}</td>
                                <td class="px-4 py-3.5">
                                    <div class="flex items-center justify-end gap-1">
                                        <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" href="{{ route('media.show', item) }}" title="View">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                        </a>
                                        <a class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" href="{{ route('media.edit', item) }}" title="Edit">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if media.lastPage() > 1 %}
                    <div class="flex flex-col gap-3 border-t border-edge px-5 py-3 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-xs text-muted">
                            Showing {{ media.firstItem() }}–{{ media.lastItem() }} of {{ media.total() }} files
                        </p>
                        <div>{{ media.links()|raw }}</div>
                    </div>
                {% endif %}

            {% else %}
                <div class="flex min-h-64 items-center justify-center px-6 py-14">
                    <div class="max-w-sm text-center">
                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas text-faint">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="mt-4 text-base font-semibold text-content">No media files yet</h2>
                        <p class="mt-1 text-sm text-muted">Create a library and upload files to get started.</p>
                        <div class="mt-5">
                            <a href="{{ route('media.libraries') }}" class="inline-flex items-center justify-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                                View Libraries
                            </a>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
