{% extends 'admin._inc._layout' %}

{% set page_title = 'Delete File' %}
{% set page_heading = 'Delete File' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('media.libraries') }}">Media Libraries</a>
        {% if media.library %}
            <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <a class="hover:text-slate-800" href="{{ route('media.libraries.show', media.library) }}">{{ media.library.name }}</a>
        {% endif %}
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('media.show', media) }}">{{ media.name ?: media.file_name }}</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.media._sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete File</h1>
                <p class="mt-1 text-sm text-slate-500">This file will be soft-deleted and purged after the grace period.</p>
            </div>
            <a href="{{ route('media.show', media) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">Cancel</a>
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-red-800">The physical file will be removed after a 30-day grace period.</p>
                    <p class="mt-1 text-sm text-red-700">The database record for <strong>{{ media.name ?: media.file_name }}</strong> will be soft-deleted immediately. The file on disk is purged automatically after the grace period.</p>
                </div>
            </div>
        </div>

        <form method="POST" action="{{ route('media.destroy', media) }}">
            {{ csrf_field() }}
            {{ method_field('DELETE') }}

            <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">File Being Deleted</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Name</dt>
                            <dd class="font-semibold text-slate-900">{{ media.name ?: media.file_name }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Type</dt>
                            <dd class="text-slate-700">{{ media.mime_type ?: '—' }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Size</dt>
                            <dd class="text-slate-700">
                                {% if media.size > 1048576 %}
                                    {{ (media.size / 1048576)|number_format(1) }} MB
                                {% elseif media.size > 1024 %}
                                    {{ (media.size / 1024)|number_format(1) }} KB
                                {% else %}
                                    {{ media.size }} B
                                {% endif %}
                            </dd>
                        </div>
                        {% if media.library %}
                            <div class="flex items-center justify-between py-2.5">
                                <dt class="text-slate-500">Library</dt>
                                <dd class="text-slate-700">{{ media.library.name }}</dd>
                            </div>
                        {% endif %}
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Uploaded</dt>
                            <dd class="text-slate-700">{{ media.created_at|date('M j, Y') }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="flex flex-col gap-5">
                    <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                        <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                            <h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5>
                        </div>
                        <div class="px-5 py-4">
                            <p class="mb-4 text-sm text-slate-600">Confirm you want to delete <strong>{{ media.name ?: media.file_name }}</strong>. This cannot be undone.</p>
                            <button type="submit" class="w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                                Delete File
                            </button>
                            <a href="{{ route('media.show', media) }}" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
                                Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
{% endblock %}
