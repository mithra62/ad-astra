{% extends 'admin._inc._layout' %}

{% set page_title = media.name ?: media.file_name %}
{% set page_heading = media.name ?: media.file_name %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('media.libraries') }}">Media Libraries</a>
        {% if media.library %}
            <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <a class="hover:text-slate-800" href="{{ route('media.libraries.show', media.library) }}">{{ media.library.name }}</a>
        {% endif %}
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">{{ media.name ?: media.file_name }}</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.media._sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">{{ media.name ?: media.file_name }}</h1>
                {% if media.library %}
                    <p class="mt-1 text-sm text-slate-500">In <a class="text-emerald-600 hover:underline" href="{{ route('media.libraries.show', media.library) }}">{{ media.library.name }}</a></p>
                {% endif %}
            </div>
            <div class="flex gap-2">
                <a href="{{ route('media.edit', media) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit
                </a>
                <a href="{{ route('media.download', media) }}" class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 sm:self-auto">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    Download
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 lg:grid-cols-[1fr_20rem]">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Preview</h5>
                </div>
                <div class="flex min-h-64 items-center justify-center p-5">
                    {% set is_image = media.mime_type and ('image' in media.mime_type) %}
                    {% if is_image %}
                        <img src="{{ route('media.download', media) }}" alt="{{ media.alt_text ?: (media.name ?: media.file_name) }}"
                             class="max-h-96 max-w-full rounded-md object-contain shadow-sm">
                    {% else %}
                        {% set is_video = media.mime_type and ('video' in media.mime_type) %}
                        {% if is_video %}
                            <video controls class="max-h-64 max-w-full rounded-md">
                                <source src="{{ route('media.download', media) }}" type="{{ media.mime_type }}">
                            </video>
                        {% else %}
                            <div class="flex flex-col items-center gap-3 text-slate-400">
                                <svg class="h-16 w-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                                <p class="text-sm">No preview available for this file type.</p>
                                <a href="{{ route('media.download', media) }}" class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                                    Download File
                                </a>
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">File Info</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Name</dt>
                            <dd class="font-medium text-slate-900">{{ media.name ?: '—' }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Filename</dt>
                            <dd class="font-mono text-xs text-slate-700 truncate max-w-[140px]" title="{{ media.file_name }}">{{ media.file_name }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Original</dt>
                            <dd class="text-xs text-slate-500 truncate max-w-[140px]" title="{{ media.original_name }}">{{ media.original_name }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">MIME type</dt>
                            <dd class="text-slate-700">{{ media.mime_type ?: '—' }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Size</dt>
                            <dd class="text-slate-700">
                                {% if media.size > 1048576 %}
                                    {{ (media.size / 1048576)|number_format(1) }} MB
                                {% elseif media.size > 1024 %}
                                    {{ (media.size / 1024)|number_format(1) }} KB
                                {% else %}
                                    {{ media.size }} B
                                {% endif %}
                            </dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Disk</dt>
                            <dd class="text-slate-700">{{ media.disk }}</dd>
                        </div>
                        {% if media.status_handle %}
                            <div class="flex items-center justify-between py-2.5">
                                <dt class="text-slate-500">Status</dt>
                                <dd>
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium {% if media.status_is_public %}bg-emerald-50 text-emerald-700{% else %}bg-slate-100 text-slate-600{% endif %}"
                                          {% if media.status and media.status.color %}style="background-color: {{ media.status.color }}20; color: {{ media.status.color }};"{% endif %}>
                                        {{ media.status ? media.status.name : media.status_handle }}
                                    </span>
                                </dd>
                            </div>
                        {% endif %}
                        {% if media.alt_text %}
                            <div class="flex items-center justify-between py-2.5">
                                <dt class="text-slate-500">Alt text</dt>
                                <dd class="text-slate-700">{{ media.alt_text }}</dd>
                            </div>
                        {% endif %}
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Uploaded</dt>
                            <dd class="text-slate-700">{{ media.created_at|date('M j, Y') }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Actions</h5>
                    </div>
                    <div class="space-y-2 px-5 py-4">
                        <a href="{{ route('media.edit', media) }}" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
                            Edit Details
                        </a>
                        <a href="{{ route('media.download', media) }}" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
                            Download
                        </a>
                        <a href="{{ route('media.confirm', media) }}" class="block w-full rounded-md border border-red-300 bg-white px-4 py-2 text-center text-sm font-medium text-red-600 shadow-sm hover:bg-red-50">
                            Delete File
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
