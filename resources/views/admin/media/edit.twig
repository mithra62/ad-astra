{% extends 'admin._inc._layout' %}
{% import 'admin._inc._schema-tab-elements' as tabs %}

{% set page_title = 'Edit Media' %}
{% set page_heading = 'Edit Media' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="{{ route('dashboard') }}">Dashboard</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('media.libraries') }}">Media Libraries</a>
        {% if media.library %}
            <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <a class="hover:text-content" href="{{ route('media.libraries.show', media.library) }}">{{ media.library.name }}</a>
        {% endif %}
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('media.show', media) }}">{{ media.name ?: media.file_name }}</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-content">Edit</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.media._sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Edit: {{ media.name ?: media.file_name }}</h1>
                <p class="mt-1 text-sm text-muted">Update display name, alt text, and title for this file.</p>
            </div>
            <a href="{{ route('media.show', media) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to File
            </a>
        </div>

        <form method="POST" action="{{ route('media.update', media) }}" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
            {{ csrf_field() }}
            {{ method_field('PUT') }}

            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">File Details</h5>
                </div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-content" for="name">Display Name</label>
                        <input class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('name') %} border-red-400{% endif %}"
                               id="name" name="name" type="text" value="{{ old('name', media.name) }}" placeholder="{{ media.file_name }}">
                        <p class="mt-1 text-xs text-faint">Human-readable label. Defaults to the filename if left blank.</p>
                        {% if errors.has('name') %}
                            <p class="mt-1 text-sm text-red-600">{{ errors.first('name') }}</p>
                        {% endif %}
                    </div>
                </div>


                {% set layout = media.library.fieldLayout %}
                {% if layout and layout.tabs.count >= 1 %}
                    {% set field_values = media.fieldArray() %}
                    {% for tab in layout.tabs %}
                        <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                            <div class="border-b border-edge px-5 py-3">
                                <h5 class="text-sm font-semibold text-content">{{ tab.name }}</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                {{ tabs.tabFields(tab, field_values) }}
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}



            </div>

            <div class="flex flex-col gap-4">
                {% if media.library and media.library.statusGroup and media.library.statusGroup.statuses.count >= 1 %}
                    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                        <div class="border-b border-edge px-5 py-3">
                            <h5 class="text-sm font-semibold text-content">Publishing</h5>
                        </div>
                        <div class="space-y-4 px-5 py-5">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-content" for="status">Status</label>
                                <select id="status" name="status" class="w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20{% if errors.has('status') %} border-red-400{% endif %}">
                                    <option value="">— Default —</option>
                                    {% for s in media.library.statusGroup.statuses %}
                                        <option value="{{ s.handle }}" {% if old('status', media.status_handle) == s.handle %}selected{% endif %}>{{ s.name }}</option>
                                    {% endfor %}
                                </select>
                                <p class="mt-1 text-xs text-faint">Only statuses from the {{ media.library.statusGroup.name }} group are allowed.</p>
                                {% if errors.has('status') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('status') }}</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">Save</h5>
                    </div>
                    <div class="space-y-2 px-5 py-4">
                        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                            Save Changes
                        </button>
                        <a href="{{ route('media.show', media) }}" class="block w-full rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-medium text-muted shadow-sm hover:bg-subtle">
                            Cancel
                        </a>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                    <div class="border-b border-edge px-5 py-3">
                        <h5 class="text-sm font-semibold text-content">File Info</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="flex items-center justify-between py-2">
                            <dt class="text-muted">Filename</dt>
                            <dd class="font-mono text-xs text-content truncate max-w-[120px]" title="{{ media.file_name }}">{{ media.file_name }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <dt class="text-muted">Type</dt>
                            <dd class="text-content">{{ media.mime_type ?: '—' }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <dt class="text-muted">Size</dt>
                            <dd class="text-content">
                                {% if media.size > 1048576 %}
                                    {{ (media.size / 1048576)|number_format(1) }} MB
                                {% elseif media.size > 1024 %}
                                    {{ (media.size / 1024)|number_format(1) }} KB
                                {% else %}
                                    {{ media.size }} B
                                {% endif %}
                            </dd>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <dt class="text-muted">Disk</dt>
                            <dd class="text-content">{{ media.disk }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-red-200 bg-surface shadow-sm">
                    <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                        <h5 class="text-sm font-semibold text-red-800">Danger Zone</h5>
                    </div>
                    <div class="px-5 py-4">
                        <a href="{{ route('media.confirm', media) }}" class="block w-full rounded-md border border-red-300 bg-surface px-4 py-2 text-center text-sm font-medium text-red-600 shadow-sm hover:bg-red-50">
                            Delete File
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
{% endblock %}
