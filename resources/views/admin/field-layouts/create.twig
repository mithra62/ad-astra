{{ include('admin._inc._header', {title: 'Create Field Layout'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Field Layouts</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts') }}">Field Layouts</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts.create') }}">Create Field Layout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            <div class="col-lg-8 col-xxl-6">
                <div class="card">
                    <div class="card-header">
                        <h5>Create Field Layout</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('field-layouts.store') }}" class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}

                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text" value="{{ old('name') }}" name="name"
                                       placeholder="e.g. Blog Post Layout">
                                {% if errors.has('name') %}<p class="text-danger">{{ errors.first('name') }}</p>{% endif %}
                            </div>

                            <div class="col-12">
                                <a href="{{ route('field-layouts') }}" class="btn btn-secondary">Cancel</a>
                                <button class="btn btn-primary float-end" type="submit">Create Field Layout</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
