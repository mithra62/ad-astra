{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Field Layouts' %}
{% set page_heading = 'Field Layouts' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'field_layouts' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('categories.groups') }}">
            Field Layouts
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('field-layouts.edit', layout) }}">
            {{ layout.name }}
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Edit Tab</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.field-layouts._sidebar', {active: category.group.id}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Edit Tab</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ route('field-layouts.tabs.fields', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    Fields
                </a>
                <a href="{{ route('field-layouts.edit', layout) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back to {{ layout.name }}
                </a>
            </div>
        </div>

        <div class="rounded-lg border border-sky-200 bg-sky-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-sky-800">Create a new reusable item.</p>
                    <p class="mt-1 text-sm text-sky-700">Handles should be stable once this item is used by content or templates.</p>
                </div>
            </div>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('field-layouts.tabs.update', {layout_id: layout.id, tab_id: tab.id}) }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    {{ forms.input(name='name', label='Name', required=true, placeholder="e.g. Content, SEO, Settings", value=tab.name) }}
                    {{ forms.input('handle', 'Handle', required=true, description="Lowercase letters, numbers, and hyphens only.", value=tab.handle) }}
                    {{ forms.input('sort_order', 'Sort Order', required=true, type="number", value=tab.sort_order) }}
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('field-layouts') }}" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Edit Tab</button>
            </div>
        </form>



        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Fields</h5>
            </div>
            <div class="space-y-5 px-5 py-5">
                {% if tab.elements.count >= 1 %}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
                            <tr>
                                <th class="px-5 py-3" scope="col">Field</th>
                                <th class="hidden px-5 py-3 sm:table-cell" scope="col">Type</th>
                                <th class="hidden px-5 py-3 lg:table-cell" scope="col">Required</th>
                                <th class="hidden px-5 py-3 lg:table-cell" scope="col">Sort Order</th>
                                <th class="px-5 py-3 text-right" scope="col">Actions</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 bg-white">
                            {% for element in tab.elements %}
                                <tr class="hover:bg-slate-50">
                                    <td class="px-5 py-3.5">
                                        {{ element.field.label ?: element.field.name }} <span class="mt-0.5 font-mono text-xs text-slate-400">{{ element.field.handle }}</span>
                                    </td>
                                    <td class="hidden px-5 py-3.5 text-slate-600 sm:table-cell">
                                        {{ element.field.fieldType.name ?? '—' }}
                                    </td>
                                    <td class="px-5 py-3.5">
                                        <form method="POST"
                                              action="{{ route('field-layouts.tabs.elements.update', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}"
                                              class="d-inline">
                                            {{ csrf_field() }}
                                            {{ method_field('PUT') }}
                                            <input type="hidden" name="sort_order"
                                                   value="{{ element.sort_order }}">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" name="required"
                                                       value="1" id="req_{{ element.id }}"
                                                       {% if element.required %}checked{% endif %}
                                                       onchange="this.form.submit()">
                                                <label class="form-check-label"
                                                       for="req_{{ element.id }}"></label>
                                            </div>
                                        </form>
                                    </td>
                                    <td>
                                        <form method="POST"
                                              action="{{ route('field-layouts.tabs.elements.update', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}"
                                              class="d-inline">
                                            {{ csrf_field() }}
                                            {{ method_field('PUT') }}
                                            <input type="hidden" name="required"
                                                   value="{{ element.required ? '1' : '0' }}">
                                            <input class="w-full rounded-md border focus:border-emerald-500 focus:ring-emerald-500/20" style="width:80px;"
                                                   type="number"
                                                   name="sort_order" value="{{ element.sort_order }}" min="0"
                                                   onchange="this.form.submit()">
                                        </form>
                                    </td>
                                    <td class="px-5 py-3.5">
                                        <div class="flex items-center justify-end gap-1">
                                            <a href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" title="Edit">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                                <span class="sr-only">Edit</span>
                                            </a>
                                            <a href="{{ route('field-layouts.tabs.confirm', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600" title="Delete">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                <span class="sr-only">Delete</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="flex min-h-80 items-center justify-center px-6 py-14">
                        <div class="max-w-sm text-center">
                            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5A3.375 3.375 0 0010.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                                </svg>
                            </div>
                            <h2 class="mt-4 text-base font-semibold text-slate-900">No Fields found</h2>
                            <p class="mt-1 text-sm text-slate-500">Create your first entry or adjust the filters to broaden the list.</p>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Add Field</h5>
            </div>
            <div class="space-y-5 px-5 py-5">
                {% if available_fields.count >= 1 %}
                    <form method="POST"
                          action="{{ route('field-layouts.tabs.elements.store', {layout_id: layout.id, tab_id: tab.id}) }}"
                          class="flex w-full min-w-0 flex-col gap-5">
                        {{ csrf_field() }}

                        <div class="col-md-6">
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="field_id">Field</label>
                            <select class="w-full rounded-md border bg-white px-3 py-2 text-sm shadow-sm transition focus:outline-none focus:ring-2 {% if errors.has('parent_id') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}border-slate-300 focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="field_id" name="field_id" required>
                                <option value="">— Select a field —</option>
                                {% for field in available_fields %}
                                    <option value="{{ field.id }}"
                                            {% if old('field_id') == field.id %}selected{% endif %}>
                                        {{ field.label ?: field.name }}
                                        ({{ field.fieldType.name ?? field.handle }})
                                    </option>
                                {% endfor %}
                            </select>
                            {% if errors.has('field_id') %}<p
                                class="text-danger">{{ errors.first('field_id') }}</p>{% endif %}
                        </div>
                        <div class="col-md-3">
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="sort_order">Sort Order</label>
                            <input class="w-full rounded-md border focus:border-emerald-500 focus:ring-emerald-500/20" id="sort_order" type="number"
                                   value="{{ old('sort_order', 0) }}" name="sort_order" min="0">
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="required" value="1"
                                       id="add_required" {% if old('required') %}checked{% endif %}>
                                <label class="form-check-label" for="add_required">Required</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Add Field to Tab</button>
                        </div>
                    </form>
                {% else %}
                    <p class="text-secondary mb-0">No fields available. <a href="{{ route('fields.groups') }}">Create
                            fields</a> first.</p>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}
