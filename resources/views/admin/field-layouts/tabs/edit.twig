{{ include('admin._inc._header', {title: 'Edit Tab'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>Field Layouts</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts') }}">Field Layouts</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts.edit', layout) }}">{{ layout.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}">{{ tab.name }}</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <div class="row">
            <div class="col-lg-10 col-xxl-9">

                <!-- Tab Settings Form -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Tab Settings</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('field-layouts.tabs.update', {layout_id: layout.id, tab_id: tab.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            {{ method_field('PUT') }}

                            <div class="col-md-8">
                                <label class="form-label" for="name">Tab Name</label>
                                <input class="form-control" id="name" required type="text"
                                       value="{{ old('name', tab.name) }}" name="name">
                                {% if errors.has('name') %}<p class="text-danger">{{ errors.first('name') }}</p>{% endif %}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="sort_order">Sort Order</label>
                                <input class="form-control" id="sort_order" type="number"
                                       value="{{ old('sort_order', tab.sort_order) }}" name="sort_order" min="0">
                            </div>

                            <div class="col-12">
                                <a href="{{ route('field-layouts.edit', layout) }}" class="btn btn-secondary">Back to Layout</a>
                                <button class="btn btn-primary float-end" type="submit">Save Tab</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Fields in this Tab -->
                <div class="card mb-4">
                    <div class="card-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="mb-0">Fields</h5>
                                <small class="text-secondary">Fields assigned to this tab. They will appear in this order when editing an entry.</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                <tr>
                                    <th scope="col">Field</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Required</th>
                                    <th scope="col">Sort Order</th>
                                    <th scope="col"></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if tab.elements.count >= 1 %}
                                    {% for element in tab.elements %}
                                        <tr>
                                            <td>
                                                <strong>{{ element.field.label ?: element.field.name }}</strong>
                                                <small class="text-secondary d-block">{{ element.field.slug }}</small>
                                            </td>
                                            <td class="text-secondary">
                                                {{ element.field.fieldType.name ?? '—' }}
                                            </td>
                                            <td>
                                                <form method="POST"
                                                      action="{{ route('field-layouts.tabs.elements.update', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}"
                                                      class="d-inline">
                                                    {{ csrf_field() }}
                                                    {{ method_field('PUT') }}
                                                    <input type="hidden" name="sort_order" value="{{ element.sort_order }}">
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" name="required"
                                                               value="1" id="req_{{ element.id }}"
                                                               {% if element.required %}checked{% endif %}
                                                               onchange="this.form.submit()">
                                                        <label class="form-check-label" for="req_{{ element.id }}"></label>
                                                    </div>
                                                </form>
                                            </td>
                                            <td>
                                                <form method="POST"
                                                      action="{{ route('field-layouts.tabs.elements.update', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}"
                                                      class="d-inline">
                                                    {{ csrf_field() }}
                                                    {{ method_field('PUT') }}
                                                    <input type="hidden" name="required" value="{{ element.required ? '1' : '0' }}">
                                                    <input class="form-control form-control-sm" style="width:80px;" type="number"
                                                           name="sort_order" value="{{ element.sort_order }}" min="0"
                                                           onchange="this.form.submit()">
                                                </form>
                                            </td>
                                            <td>
                                                <a class="btn btn-danger icon-btn b-r-4"
                                                   href="{{ route('field-layouts.tabs.elements.confirm', {layout_id: layout.id, tab_id: tab.id, element_id: element.id}) }}">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="5">
                                            <p class="text-center mb-0">No fields added to this tab yet.</p>
                                        </td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Add Field to Tab -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Add Field</h5>
                    </div>
                    <div class="card-body">
                        {% if available_fields.count >= 1 %}
                        <form method="POST" action="{{ route('field-layouts.tabs.elements.store', {layout_id: layout.id, tab_id: tab.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}

                            <div class="col-md-6">
                                <label class="form-label" for="field_id">Field</label>
                                <select class="form-select" id="field_id" name="field_id" required>
                                    <option value="">— Select a field —</option>
                                    {% for field in available_fields %}
                                        <option value="{{ field.id }}" {% if old('field_id') == field.id %}selected{% endif %}>
                                            {{ field.label ?: field.name }}
                                            ({{ field.fieldType.name ?? field.slug }})
                                        </option>
                                    {% endfor %}
                                </select>
                                {% if errors.has('field_id') %}<p class="text-danger">{{ errors.first('field_id') }}</p>{% endif %}
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" for="sort_order">Sort Order</label>
                                <input class="form-control" id="sort_order" type="number"
                                       value="{{ old('sort_order', 0) }}" name="sort_order" min="0">
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="required" value="1"
                                           id="add_required" {% if old('required') %}checked{% endif %}>
                                    <label class="form-check-label" for="add_required">Required</label>
                                </div>
                            </div>

                            <div class="col-12">
                                <button class="btn btn-primary" type="submit">Add Field to Tab</button>
                            </div>
                        </form>
                        {% else %}
                            <p class="text-secondary mb-0">No fields available. <a href="{{ route('fields.groups') }}">Create fields</a> first.</p>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{{ include('admin._inc._footer') }}
