{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Field Layouts' %}
{% set page_heading = 'Field Layouts' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'field_layouts' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('field-layouts') }}">
            Field Layouts
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-content">{{ layout.name }}</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.field-layouts._sidebar', {active: layout.id}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Edit Field Layout</h1>
                <p class="mt-1 text-sm text-muted">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('field-layouts') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Field Layouts
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('field-layouts.update', layout) }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    {{ forms.input(name='name', label='Name', required=true, value=layout.name) }}
                    {{ forms.input('handle', 'Handle', required=true, value=layout.handle) }}
                </div>
            </div>

            {% if field_groups.count >= 1 %}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <div class="flex items-baseline justify-between gap-3">
                        <div>
                            <h5 class="text-sm font-semibold text-content">Field Groups</h5>
                            <p class="mt-0.5 text-xs text-muted">Choose which field groups supply the available field palette for this layout.</p>
                        </div>
                        {% set selectedFieldGroupIds = layout.fieldGroups|map(fg => fg.id) %}
                        <span class="shrink-0 rounded-full bg-canvas px-2.5 py-0.5 text-xs font-medium text-muted">{{ selectedFieldGroupIds|length }} / {{ field_groups.count }}</span>
                    </div>
                </div>
                <div class="px-5 py-5">
                    {% set selectedFieldGroupIds = layout.fieldGroups|map(fg => fg.id) %}
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
                        {% for fg in field_groups %}
                            {{ forms.checkbox_card('field_groups[]', fg.id, fg.name, fg.description, fg.id in selectedFieldGroupIds, 'fg_' ~ fg.id) }}
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('field-layouts') }}" class="rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-semibold text-content shadow-sm hover:bg-subtle">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Edit Field Layout</button>
            </div>
        </form>

        {% set usedByGroups = layout.entryGroups %}
        {% set usedByTypes  = layout.entryTypes %}
        {% if usedByGroups.count >= 1 or usedByTypes.count >= 1 %}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Used By</h5>
                    <small class="text-secondary">Entry groups and types that use this field layout.</small>
                </div>
                <div class="card-body">
                    {% if usedByGroups.count >= 1 %}
                        <p class="mb-1"><strong>Entry Groups (shared layout):</strong></p>
                        <ul class="mb-3">
                            {% for eg in usedByGroups %}
                                <li>
                                    <a href="{{ route('entries.groups.edit', eg) }}">{{ eg.name }}</a>
                                    <small class="text-secondary">({{ eg.handle }})</small>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                    {% if usedByTypes.count >= 1 %}
                        <p class="mb-1"><strong>Entry Types (type-specific layout):</strong></p>
                        <ul class="mb-0">
                            {% for et in usedByTypes %}
                                <li>
                                    <a href="{{ route('entries.groups.types.edit', {group_id: et.entryGroup.id, type_id: et.id}) }}">{{ et.name }}</a>
                                    <small class="text-secondary">in {{ et.entryGroup.name ?? '?' }}</small>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning mb-4">
                <strong>This layout is not assigned anywhere.</strong>
                Assign it to an <a href="{{ route('entries.groups') }}">entry group</a> or entry type to use it
                on entry forms.
            </div>
        {% endif %}

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>

            </div>
            <a href="{{ route('field-layouts.tabs.create', layout) }}" class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Create Tab
            </a>
        </div>
        <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
            <div class="border-b border-edge px-5 py-3">
                <h5 class="text-sm font-semibold text-content">Tabs</h5>
            </div>
            <div class="space-y-5 px-5 py-5">
                {% if layout.tabs.count >= 1 %}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                            <thead class="bg-subtle text-xs font-semibold uppercase tracking-wide text-muted">
                            <tr>
                                <th class="px-5 py-3" scope="col">Name</th>
                                <th class="hidden px-5 py-3 sm:table-cell" scope="col">Fields</th>
                                <th class="hidden px-5 py-3 lg:table-cell" scope="col">Sort Order</th>
                                <th class="px-5 py-3 text-right" scope="col">Actions</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 bg-surface">
                            {% for tab in layout.tabs %}
                                <tr class="hover:bg-subtle">
                                    <td class="px-5 py-3.5">
                                        <a class="font-medium text-content hover:text-accent" href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}">{{ tab.name }} <span class="mt-0.5 font-mono text-xs text-faint">{{ tab.handle }}</span></a>
                                        <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                            <a href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}" class="text-emerald-600 hover:underline">Edit</a>
                                            <span class="text-faint">|</span>
                                            <a href="{{ route('field-layouts.tabs.fields', {layout_id: layout.id, tab_id: tab.id}) }}" class="text-emerald-600 hover:underline">Fields</a>
                                            <span class="text-faint">|</span>
                                            <a href="{{ route('field-layouts.tabs.confirm', {layout_id: layout.id, tab_id: tab.id}) }}" class="text-red-500 hover:underline">Delete</a>
                                        </div>
                                    </td>
                                    <td class="hidden px-5 py-3.5 text-muted sm:table-cell">
                                        {{ tab.elements.count }}
                                    </td>
                                    <td class="px-5 py-3.5">
                                        {{ tab.sort_order }}
                                    </td>
                                    <td class="px-5 py-3.5">
                                        <div class="flex items-center justify-end gap-1">
                                            <a href="{{ route('field-layouts.tabs.fields', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" title="Fields">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                                </svg>
                                                <span class="sr-only">Fields</span>
                                            </a>
                                            <a href="{{ route('field-layouts.tabs.edit', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center justify-center rounded-md border border-edge p-1.5 text-faint hover:border-edge hover:bg-subtle hover:text-content" title="Edit">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                                <span class="sr-only">Edit</span>
                                            </a>
                                            <a href="{{ route('field-layouts.tabs.confirm', {layout_id: layout.id, tab_id: tab.id}) }}" class="inline-flex items-center justify-center rounded-md border border-red-100 p-1.5 text-red-400 hover:border-red-300 hover:bg-red-50 hover:text-red-600" title="Delete">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                <span class="sr-only">Delete</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="flex min-h-80 items-center justify-center px-6 py-14">
                        <div class="max-w-sm text-center">
                            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas text-faint">
                                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5A3.375 3.375 0 0010.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                                </svg>
                            </div>
                            <h2 class="mt-4 text-base font-semibold text-content">No Tabs found</h2>
                            <p class="mt-1 text-sm text-muted">Create your first entry or adjust the filters to broaden the list.</p>
                            <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                                <a href="" class="inline-flex items-center justify-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                    </svg>
                                    Create Tab
                                </a>
                                <a class="inline-flex items-center justify-center rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle" href="index.twig">Clear filters</a>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}









