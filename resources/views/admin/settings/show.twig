{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Settings' %}
{% set page_heading = 'Settings' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'system' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Settings</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.settings._sidebar', {all_domains: domains, current_handle: domain.handle}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Settings</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
        </div>

        <div class="rounded-lg border border-sky-200 bg-sky-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-sky-800">Create a new reusable item.</p>
                    <p class="mt-1 text-sm text-sky-700">Handles should be stable once this item is used by content or templates.</p>
                </div>
            </div>
        </div>

        {% if grouped_fields|length > 0 %}
            <form id="general-create-form" method="POST" action="{{ route('settings.update', domain.handle) }}" class="flex w-full min-w-0 flex-col gap-5">
                {{ csrf_field() }}
                {{ method_field('PUT') }}






                {% for groupName, fields in grouped_fields %}
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">
                            {% if groupName %}
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 text-muted text-uppercase f-s-12 f-w-600">
                                        {{ groupName }}
                                    </h6>
                                </div>
                            {% endif %}
                        </h5>
                    </div>
                    <div class="space-y-5 px-5 py-5">

                    {% for field in fields %}
                        <div class="col-md-12">
                            <label class="form-label" for="field_{{ field.handle }}">
                                {{ field.label }}
                                {% if field.user_overridable %}
                                    <span class="badge bg-light-primary text-primary ms-1 f-s-11">  user overridable</span>
                                {% endif %}
                            </label>
                            {% if field.instructions %}
                                <small
                                    class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                            {% endif %}

                            {% set val = field_values[field.handle] is defined ? field_values[field.handle] : (field.default ?? '') %}

                            {% if field.type == 'boolean' %}
                                <div class="form-check form-switch">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="{{ field.handle }}"
                                           id="field_{{ field.handle }}"
                                           value="1"
                                        {{ old(field.handle, val) ? 'checked' : '' }}>
                                    <label class="form-check-label" for="field_{{ field.handle }}">
                                        Enable
                                    </label>
                                </div>
                            {% elseif field.type == 'integer' or field.type == 'float' %}
                                <input type="number"
                                       class="w-full rounded-md border {% if errors.has(field.handle) %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 "
                                       name="{{ field.handle }}"
                                       id="field_{{ field.handle }}"
                                       value="{{ old(field.handle, val) }}"
                                    {{ field.type == 'float' ? 'step="any"' : 'step="1"' }}>
                            {% elseif field.type == 'textarea' %}
                                <textarea class="w-full rounded-md border {% if errors.has(field.handle) %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 "
                                          name="{{ field.handle }}"
                                          id="field_{{ field.handle }}"
                                          rows="4">{{ old(field.handle, val) }}</textarea>
                            {% else %}
                                <input type="{{ field.type == 'email' ? 'email' : 'text' }}"
                                       class="w-full rounded-md border {% if errors.has(field.handle) %}border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:ring-red-500/20{% else %}focus:border-emerald-500 focus:ring-emerald-500/20{% endif %} focus:outline-none focus:ring-2 "
                                       name="{{ field.handle }}"
                                       id="field_{{ field.handle }}"
                                       value="{{ old(field.handle, val) }}">
                            {% endif %}

                            {% if errors.has(field.handle) %}
                                <p class="mt-1 text-xs text-red-600">{{ errors.first(field.handle) }}</p>
                            {% endif %}
                        </div>
                    {% endfor %}
                    </div>
                </div>
                {% endfor %}





                <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                    <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Save Settings</button>
                </div>
            </form>
        {% endif %}
    </div>
{% endblock %}
