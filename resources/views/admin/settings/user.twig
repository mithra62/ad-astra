{{ include('admin::_inc._header', {title: 'My Preferences'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb -->
        <div class="row m-1">
            <div class="col-12">
                <h4 class="main-title">Settings</h4>
                <ul class="app-line-breadcrumbs mb-3">
                    <li>
                        <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                            <span><i class="ph-duotone ph-table f-s-16"></i> Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a class="f-s-14 f-w-500" href="{{ route('settings') }}">Settings</a>
                    </li>
                    <li class="active">
                        <a class="f-s-14 f-w-500" href="{{ route('settings.user') }}">My Preferences</a>
                    </li>
                </ul>
            </div>
        </div>

        {{ include('admin::_inc._message') }}

        <div class="row">
            {{ include('admin::settings._sidebar', {all_domains: all_domains, current_handle: 'user'}) }}

            <div class="col-lg-8 col-xxl-9">
                <div class="card mb-3">
                    <div class="card-header d-flex align-items-center gap-2">
                        <i class="ti ti-user-cog f-s-20 text-success"></i>
                        <h5 class="mb-0">My Preferences</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-0">
                            These settings apply only to your account and override the system defaults.
                            Leave a field unchanged to inherit the system value.
                        </p>
                    </div>
                </div>

                {% if domains|length > 0 %}
                    <form method="POST" action="{{ route('settings.user.update') }}"
                          class="row g-3 needs-validation" novalidate>
                        {{ csrf_field() }}
                        {{ method_field('PUT') }}

                        {% for domainData in domains %}
                            {% set domain = domainData.domain %}
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header d-flex align-items-center gap-2">
                                        {% if domain.icon %}
                                            <i class="ti {{ domain.icon }} text-primary"></i>
                                        {% endif %}
                                        <h6 class="mb-0">{{ domain.name }}</h6>
                                    </div>
                                    <div class="card-body row g-3">
                                        {% for field in domainData.fields %}
                                            {% set val = domainData.field_values[field.handle] is defined ? domainData.field_values[field.handle] : (field.default ?? '') %}
                                            {% set hasOverride = field.handle in domainData.override_handles %}

                                            <div class="col-md-12">
                                                <label class="form-label" for="field_{{ field.handle }}">
                                                    {{ field.label }}
                                                </label>
                                                {% if field.instructions %}
                                                    <small class="text-secondary d-block mb-1">{{ field.instructions }}</small>
                                                {% endif %}

                                                {% if hasOverride %}
                                                    <small class="text-success d-block mb-1">
                                                        <span class="badge bg-light-success">your override is active</span>
                                                    </small>
                                                {% else %}
                                                    <small class="text-muted d-block mb-1">
                                                        <span class="badge bg-light-secondary">system default</span>
                                                        currently: <em>{{ val != '' ? val : '—' }}</em>
                                                    </small>
                                                {% endif %}

                                                {% if field.type == 'boolean' %}
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               name="{{ field.handle }}"
                                                               id="field_{{ field.handle }}"
                                                               value="1"
                                                               {{ old(field.handle, val) ? 'checked' : '' }}>
                                                        <label class="form-check-label" for="field_{{ field.handle }}">
                                                            Enable
                                                        </label>
                                                    </div>
                                                {% elseif field.type == 'integer' or field.type == 'float' %}
                                                    <input type="number"
                                                           class="form-control"
                                                           name="{{ field.handle }}"
                                                           id="field_{{ field.handle }}"
                                                           value="{{ old(field.handle, val) }}"
                                                           {{ field.type == 'float' ? 'step="any"' : 'step="1"' }}>
                                                {% elseif field.type == 'textarea' %}
                                                    <textarea class="form-control"
                                                              name="{{ field.handle }}"
                                                              id="field_{{ field.handle }}"
                                                              rows="4">{{ old(field.handle, val) }}</textarea>
                                                {% else %}
                                                    <input type="{{ field.type == 'email' ? 'email' : 'text' }}"
                                                           class="form-control"
                                                           name="{{ field.handle }}"
                                                           id="field_{{ field.handle }}"
                                                           value="{{ old(field.handle, val) }}">
                                                {% endif %}

                                                {% if errors.has(field.handle) %}
                                                    <p class="text-danger mt-1">{{ errors.first(field.handle) }}</p>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}

                        <div class="col-12 d-flex justify-content-end gap-2 pt-2">
                            <a href="{{ route('settings') }}" class="btn btn-outline-secondary">Cancel</a>
                            <button class="btn btn-primary" type="submit">
                                <i class="ti ti-device-floppy me-1"></i> Save My Preferences
                            </button>
                        </div>
                    </form>
                {% else %}
                    <div class="card">
                        <div class="card-body text-center py-5 text-muted">
                            <i class="ti ti-settings f-s-40 d-block mb-2"></i>
                            No user-overridable settings have been configured yet.
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</main>
{{ include('admin::_inc._footer') }}
