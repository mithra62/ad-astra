{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'My Preferences' %}
{% set page_heading = 'My Preferences' %}
{% set active_nav = 'settings' %}
{% set active_secondary_nav = 'user' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('settings.show', all_domains.first.handle) }}">Settings</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">My Preferences</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.settings._sidebar', {all_domains: all_domains, current_handle: 'user'}) }}
{% endblock %}

{% block content %}
    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">My Preferences</h1>
                <p class="mt-1 text-sm text-slate-500">These settings apply only to your account and override the system defaults. Leave a field unchanged to inherit the system value.</p>
            </div>
        </div>

        {% if domains|length > 0 %}
            <form method="POST" action="{{ route('account.edit_settings') }}" class="flex w-full min-w-0 flex-col gap-5">
                {{ csrf_field() }}
                {{ method_field('PUT') }}

                {% for domainData in domains %}
                    {% set domain = domainData.domain %}
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3">
                            <h5 class="text-sm font-semibold text-slate-700">{{ domain.name }}</h5>
                        </div>
                        <div class="space-y-5 px-5 py-5">
                            {% for field in domainData.fields %}
                                {% set val = domainData.field_values[field.handle] is defined ? domainData.field_values[field.handle] : (field.default ?? '') %}
                                {% set hasOverride = field.handle in domainData.override_handles %}

                                {% if hasOverride %}
                                    <p class="text-xs">
                                        <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-700/10">your override is active</span>
                                    </p>
                                {% else %}
                                    <p class="text-xs text-slate-500">
                                        <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">system default</span>
                                        currently: <em>{{ val != '' ? val : '—' }}</em>
                                    </p>
                                {% endif %}

                                {% set field_description = field.instructions %}

                                {% if field.type == 'boolean' %}
                                    {{ forms.toggle(field.handle, field.label, val, field_description) }}
                                {% elseif field.type == 'textarea' %}
                                    {{ forms.textarea(field.handle, field.label, val, 4, field_description) }}
                                {% elseif field.type == 'select' or (field.options is defined and field.options|length) %}
                                    {{ forms.select(field.handle, field.label, field.options|default([]), val, field_description) }}
                                {% elseif field.type == 'integer' %}
                                    {{ forms.input(field.handle, field.label, val, 'number', field_description, '', '', field.handle, false, 'step="1"') }}
                                {% elseif field.type == 'float' %}
                                    {{ forms.input(field.handle, field.label, val, 'number', field_description, '', '', field.handle, false, 'step="any"') }}
                                {% else %}
                                    {{ forms.input(field.handle, field.label, val, field.type == 'email' ? 'email' : 'text', field_description) }}
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}

                <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                    <a href="{{ route('settings.show', all_domains.first.handle) }}" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2">Cancel</a>
                    <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Save My Preferences</button>
                </div>
            </form>
        {% else %}
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="px-5 py-10 text-center text-sm text-slate-500">
                    No user-overridable settings have been configured yet.
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
