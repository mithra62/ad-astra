{% extends 'admin._inc._layout' %}

{% import 'admin._inc._form-fields' as forms %}
{% import 'admin._inc._ui' as ui %}

{% set page_title = 'Status Groups' %}
{% set page_heading = 'Status Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'statuses' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    {{ ui.breadcrumbs([
        {label: 'Dashboard', href: route('dashboard'), icon: 'home'},
        {label: 'Status Groups', href: route('statuses.groups')},
        {label: 'Create Status Group'}
    ]) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Create Status Group</h1>
                <p class="mt-1 text-sm text-muted">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('statuses.groups') }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Status Groups
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('statuses.groups.store') }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    {{ forms.input(name='name', label='Name', required=true) }}
                    {{ forms.input('handle', 'Handle', required=true) }}
                    {{ forms.input('sort_order', 'Sort Order', type="number", required=true, value=0) }}
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="general-index-no-sidebar.twig" class="rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-semibold text-content shadow-sm hover:bg-subtle">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Create Status Group</button>
            </div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}











