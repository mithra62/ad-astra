{{ include('admin._inc._header', {title: 'View Status Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h4 class="main-title">Status Group</h4>
                <ul class="app-line-breadcrumbs mb-3">
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone  ph-table f-s-16"></i> Dashboard
                                </span>
                        </a>
                    </li>
                    <li class="">
                        <a class="f-s-14 f-w-500" href="{{ route('statuses.groups') }}">Status Groups</a>
                    </li>
                    <li class="active">
                        <a class="f-s-14 f-w-500" href="{{ route('statuses.groups.show', group) }}">{{ group.name }}</a>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}
        <!-- setting-app start -->
        <div class="row">
            {{ include('admin.statuses._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <div class="tab-content">
                    <div aria-labelledby="profile-tab" class="tab-pane fade active show"
                         id="profile-tab-pane"
                         role="tabpanel" tabindex="0">
                        <div class="card setting-profile-tab">
                            <div class="card-header">
                                <h5>Statuses</h5>
                                <div class="col-12">
                                    <p class="float-right text-end">
                                        <a href="{{ route('statuses.create', {group_id: group.id}) }}"
                                           class="btn btn-primary">Create Status</a>
                                    </p>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="profile-tab profile-container">
                                    {% if statuses.count >= 1 %}
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead>
                                                <tr>
                                                    <th scope="col">Name</th>
                                                    <th scope="col">Handle</th>
                                                    <th scope="col">Color</th>
                                                    <th scope="col">Default</th>
                                                    <th scope="col">Sort Order</th>
                                                    <th scope="col"></th>
                                                </tr>
                                                </thead>
                                                <tbody>
                                                {% for status in statuses %}
                                                    <tr>
                                                        <td>{{ status.name }}</td>
                                                        <td class="text-secondary f-w-500">{{ status.handle }}</td>
                                                        <td>
                                                            {% if status.color %}
                                                                <span class="badge"
                                                                      style="background-color: {{ status.color }}">{{ status.color }}</span>
                                                            {% else %}
                                                                <span class="text-secondary">—</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if status.is_default %}
                                                                <span class="badge bg-success">Yes</span>
                                                            {% else %}
                                                                <span class="badge bg-secondary">No</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="text-secondary">{{ status.sort_order }}</td>
                                                        <td>
                                                            <a class="btn btn-success icon-btn b-r-4"
                                                               href="{{ route('statuses.edit', status) }}">
                                                                <i class="ti ti-edit"></i>
                                                            </a>
                                                            <a class="btn btn-danger icon-btn b-r-4"
                                                               href="{{ route('statuses.confirm', status) }}">
                                                                <i class="ti ti-trash"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                    {% else %}
                                        <p class="text-center">
                                            No Statuses Created. <br/>
                                            <a href="{{ route('statuses.create', {group_id: group.id}) }}"
                                               class="btn btn-outline-primary">Create Status</a>
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--setting app end -->
    </div>
</main>
{{ include('admin._inc._footer') }}
