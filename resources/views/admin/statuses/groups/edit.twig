{{ include('admin._inc._header', {title: 'Edit Status Group'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Status Groups</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone  ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('statuses.groups') }}">Status Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500" href="{{ route('statuses.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('statuses.groups.edit', group) }}">Edit Status Group</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <!-- Custom Styles start -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex flex-column gap-2">
                    <h5>Edit Status Group</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ route('statuses.groups.update', group) }}" class="row g-3 needs-validation" novalidate>
                        {{ csrf_field() }}
                        <input type="hidden" name="id" value="{{ group.id }}" />
                        {{ method_field('PUT') }}
                        <div class="col-md-12">
                            <label class="form-label" for="name">Name</label>
                            <input class="form-control" id="name" required type="text" value="{{ old('name', group.name) }}" name="name">
                            {% if errors.has('name') %}
                                <p class="text-danger">{{ errors.first('name') }}</p>
                            {% endif %}
                        </div>
                        <div class="col-md-12">
                            <label class="form-label" for="handle">Handle</label>
                            <input class="form-control" id="handle" required type="text" value="{{ old('handle', group.handle) }}" name="handle">
                            {% if errors.has('handle') %}
                                <p class="text-danger">{{ errors.first('handle') }}</p>
                            {% endif %}
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="sort_order">Sort Order</label>
                            <input class="form-control" id="sort_order" type="number" value="{{ old('sort_order', group.sort_order) }}" name="sort_order" min="0">
                            {% if errors.has('sort_order') %}
                                <p class="text-danger">{{ errors.first('sort_order') }}</p>
                            {% endif %}
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary float-end" type="submit">Save Status Group</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- Custom Styles end -->
    </div>
</main>

{{ include('admin._inc._footer') }}
