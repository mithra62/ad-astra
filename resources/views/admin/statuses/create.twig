{{ include('admin._inc._header', {title: 'Create Status'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12 ">
                <h5>Status Groups</h5>
                <div class="col-6 ">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone  ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('statuses.groups') }}">Status Groups</a>
                        </li>
                        <li>
                            <a class="f-s-14 f-w-500"
                               href="{{ route('statuses.groups.show', group) }}">{{ group.name }}</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('statuses.create', group) }}">Create Status</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <!-- Custom Styles start -->
        <div class="row">
            {{ include('admin.statuses._sidebar', {active: group.id}) }}
            <div class="col-lg-8 col-xxl-9">
                <div class="card">
                    <div class="card-header d-flex flex-column gap-2">
                        <h5>Create Status</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ route('statuses.store', {group_id: group.id}) }}"
                              class="row g-3 needs-validation" novalidate>
                            {{ csrf_field() }}
                            <input type="hidden" name="status_group_id" value="{{ group.id }}" />
                            <div class="col-md-12">
                                <label class="form-label" for="name">Name</label>
                                <input class="form-control" id="name" required type="text" value="{{ old('name') }}"
                                       name="name">
                                {% if errors.has('name') %}
                                    <p class="text-danger">{{ errors.first('name') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="handle">Handle</label>
                                <input class="form-control" id="handle" required type="text" value="{{ old('handle') }}"
                                       name="handle">
                                {% if errors.has('handle') %}
                                    <p class="text-danger">{{ errors.first('handle') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="color">Color</label>
                                <div class="input-group">
                                    <input class="form-control" id="color" type="color"
                                           value="{{ old('color', '#6c757d') }}" name="color" style="max-width: 60px;">
                                    <input class="form-control" id="color_hex" type="text"
                                           value="{{ old('color', '#6c757d') }}" placeholder="#6c757d"
                                           oninput="document.getElementById('color').value = this.value">
                                </div>
                                {% if errors.has('color') %}
                                    <p class="text-danger">{{ errors.first('color') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="sort_order">Sort Order</label>
                                <input class="form-control" id="sort_order" type="number"
                                       value="{{ old('sort_order', 0) }}" name="sort_order" min="0">
                                {% if errors.has('sort_order') %}
                                    <p class="text-danger">{{ errors.first('sort_order') }}</p>
                                {% endif %}
                            </div>
                            <div class="col-md-12">
                                <div class="switch-border-primary switch-primary switch-unchecked-primary my-3 card-body main-switch main-switch-color">
                                    <input class="toggle switch-border-primary" name="is_default" id="is_default"
                                           type="checkbox" value="1" {% if old('is_default') %}checked{% endif %}>
                                    <label for="is_default">Set as Default Status</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary float-end" type="submit">Create Status</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!-- Custom Styles end -->
    </div>
</main>

{{ include('admin._inc._footer') }}
