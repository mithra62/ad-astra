{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Edit Status' %}
{% set page_heading = 'Status Groups' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'statuses' %}
{% set has_secondary_sidebar = true %}
{% set active_secondary_nav = 'edit_status' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('statuses.groups') }}">
            Status Groups
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('statuses.groups.show', status.group) }}">
            {{ status.group.name }}
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('statuses.edit', status) }}">
            {{ status.name }}
        </a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-content">Edit Status</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.statuses._sidebar', {active: status.group.id}) }}
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Edit Status</h1>
                <p class="mt-1 text-sm text-muted">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="{{ route('statuses.groups.show', status.group) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to {{ status.group.name }}
            </a>
        </div>

        <form id="general-create-form" method="POST" action="{{ route('statuses.update', status.id) }}" class="flex w-full min-w-0 flex-col gap-5">
            {{ csrf_field() }}
            {{ method_field('PUT') }}
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3">
                    <h5 class="text-sm font-semibold text-content">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">

                    {{ forms.input(name='name', label='Name', required=true, value=status.name, placeholder="e.g. Open, Closed, etc...") }}
                    {{ forms.input('handle', 'Handle', required=true, value=status.handle, description="Lowercase letters, numbers, and hyphens only.") }}

                        {{ forms.color(
                            name: 'color',
                            label: 'Color',
                            value: status.color,
                            description: 'Used for this user avatar, labels, and personalized admin highlights.',
                            id: 'accent_color'
                        ) }}
                        {{ forms.toggle(
                            name: 'is_default',
                            label: 'Set as Default Status',
                            value: status.is_default,
                            description: 'The status the field will be set as if not set',
                            checked_value: '1',
                            id: 'is_default',
                            error_key: 'is_default',
                            copy_align: 'inline'
                        ) }}
                        {{ forms.toggle(
                            name: 'is_public',
                            label: 'Publicly Visible',
                            value: status.is_public,
                            description: 'Entries with this status will appear in public-facing queries.',
                            checked_value: '1',
                            id: 'is_public',
                            error_key: 'is_public',
                            copy_align: 'inline'
                        ) }}
                    {{ forms.input('sort_order', 'Sort Order', type="number", required=true, value=status.sort_order) }}
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="{{ route('statuses.groups.show', status.group) }}" class="rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-semibold text-content shadow-sm hover:bg-subtle">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Edit Status</button>
            </div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
    {{ forms.color_scripts() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}









