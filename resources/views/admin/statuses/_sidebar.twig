<input id="secnav-toggle" type="checkbox">

<label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-edge bg-surface px-4 py-2.5 text-sm font-medium text-muted hover:bg-subtle lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
    <span class="secnav-chevron text-faint">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
</label>

<div id="secondary-nav-panel" class="hidden border-b border-edge bg-surface px-4 py-3 lg:hidden">
    <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
        <a class="flex items-center gap-2 rounded-md bg-accent-soft px-3 py-2 text-sm font-medium text-accent" href="{{ route('statuses.groups') }}">All Status Groups</a>
        {% for group in groups %}
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('statuses.groups.show', group) }}">{{ group.name }} ({{ group.statuses.count() }})</a>
        {% endfor %}
    </nav>
</div>

<aside class="hidden h-fit lg:block">
    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
        <div class="border-b border-edge px-4 py-3">
            <h5 class="text-sm font-semibold text-content">Status Groups</h5>
        </div>
        <nav class="p-2">
            <a class="flex items-center gap-2 rounded-md  px-3 py-2 text-sm font-medium " href="{{ route('statuses.groups') }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
                </svg>
                All Status Groups
            </a>
            <a href="{{ route('statuses.groups.create') }}" class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle {% if active_secondary_nav == 'create' %} text-accent bg-accent-soft {% endif %}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>Create Status Group</a>
            {% for group in groups %}
                <a class="{% if active == group.id %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="{{ route('statuses.groups.show', group) }}">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
                    </svg>
                    {{ group.name }} ({{ group.statuses.count() }})
                </a>
            {% endfor %}

            {% if status %}
                <div class="my-2 border-t border-edge"></div>
                <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-faint">Manage Status</p>
                <a href="{{ route('statuses.edit', status) }}" class="{% if active_secondary_nav == 'edit_status' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Edit Status
                </a>
                <a href="{{ route('statuses.confirm', status) }}" class="{% if active_secondary_nav == 'delete_status' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Delete Status
                </a>
            {% endif %}
        </nav>
    </div>
</aside>
