{% import 'admin._inc._ui' as ui %}

{% set items = [
    {label: 'All Status Groups', href: route('statuses.groups'), icon: 'menu', active: false},
    {label: 'Create Status Group', href: route('statuses.groups.create'), icon: 'plus', active: active_secondary_nav == 'create'}
] %}
{% for group in groups %}
    {% set items = items|merge([{
        label: group.name ~ ' (' ~ group.statuses.count() ~ ')',
        href: route('statuses.groups.show', group),
        icon: 'menu',
        active: active == group.id
    }]) %}
{% endfor %}

{% if status is defined and status %}
    {% set items = items|merge([
        {divider: true},
        {heading: 'Manage Status'},
        {label: 'Edit Status', href: route('statuses.edit', status), icon: 'pencil', active: active_secondary_nav == 'edit_status'},
        {label: 'Delete Status', href: route('statuses.confirm', status), icon: 'trash', active: active_secondary_nav == 'delete_status'}
    ]) %}
{% endif %}

{{ ui.section_nav('Status Groups', items) }}
