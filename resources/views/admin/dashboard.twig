{% extends 'admin._inc._layout' %}

{% set page_title = 'Home' %}
{% set page_heading = 'Dashboard' %}
{% set active_nav = 'dashboard' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Home</span>
    </nav>
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">System Overview</h1>
            <p class="mt-1 text-sm text-slate-500">Monitor application health, content volume, and operational
                activity.</p>
        </div>
        <div class="flex flex-wrap items-center gap-2 self-start">
            <button type="button"
                    class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Refresh
            </button>
            <a href="#"
               class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                New Article
            </a>
        </div>
    </div>

    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4">
        <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <div>
                <p class="text-sm font-semibold text-emerald-800">All core services are operational.</p>
                <p class="mt-1 text-sm text-emerald-700">Last health check completed 2 minutes ago with no failed
                    checks.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="px-5 py-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Uptime</p>
                    <span
                        class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Healthy</span>
                </div>
                <p class="mt-2 text-3xl font-semibold text-slate-900">99.98%</p>
                <p class="mt-1 text-xs text-slate-400">30-day service availability</p>
            </div>
        </div>
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="px-5 py-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Response Time</p>
                    <span class="rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-700">Stable</span>
                </div>
                <p class="mt-2 text-3xl font-semibold text-slate-900">142 ms</p>
                <p class="mt-1 text-xs text-slate-400">Median API latency today</p>
            </div>
        </div>
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="px-5 py-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Queue Depth</p>
                    <span
                        class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Watching</span>
                </div>
                <p class="mt-2 text-3xl font-semibold text-slate-900">284</p>
                <p class="mt-1 text-xs text-slate-400">Jobs waiting to process</p>
            </div>
        </div>
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="px-5 py-4">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Storage</p>
                    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">64%</span>
                </div>
                <p class="mt-2 text-3xl font-semibold text-slate-900">428 GB</p>
                <p class="mt-1 text-xs text-slate-400">Used of 670 GB available</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h5 class="text-sm font-semibold text-slate-700">Request Volume</h5>
                        <p class="mt-0.5 text-xs text-slate-500">Requests per hour over the last 12 hours.</p>
                    </div>
                    <select
                        class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option selected>Last 12 hours</option>
                        <option>Last 24 hours</option>
                        <option>Last 7 days</option>
                    </select>
                </div>
            </div>
            <div class="px-5 py-5">
                <div class="h-72 w-full">
                    <svg class="h-full w-full" viewBox="0 0 720 260" role="img"
                         aria-label="Line chart showing request volume trending upward">
                        <defs>
                            <linearGradient id="chart-fill" x1="0" x2="0" y1="0" y2="1">
                                <stop offset="0%" stop-color="#10b981" stop-opacity="0.25"/>
                                <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
                            </linearGradient>
                        </defs>
                        <g stroke="#e2e8f0" stroke-width="1">
                            <line x1="42" x2="700" y1="32" y2="32"/>
                            <line x1="42" x2="700" y1="82" y2="82"/>
                            <line x1="42" x2="700" y1="132" y2="132"/>
                            <line x1="42" x2="700" y1="182" y2="182"/>
                            <line x1="42" x2="700" y1="232" y2="232"/>
                        </g>
                        <g class="text-[10px]" fill="#94a3b8">
                            <text x="8" y="36">12k</text>
                            <text x="8" y="86">9k</text>
                            <text x="8" y="136">6k</text>
                            <text x="8" y="186">3k</text>
                            <text x="12" y="236">0</text>
                        </g>
                        <path
                            d="M42 218 L100 198 L158 174 L216 182 L274 139 L332 152 L390 112 L448 92 L506 103 L564 66 L622 74 L700 44 L700 232 L42 232 Z"
                            fill="url(#chart-fill)"/>
                        <path
                            d="M42 218 L100 198 L158 174 L216 182 L274 139 L332 152 L390 112 L448 92 L506 103 L564 66 L622 74 L700 44"
                            fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round"
                            stroke-linejoin="round"/>
                        <g fill="#10b981" stroke="#ffffff" stroke-width="2">
                            <circle cx="42" cy="218" r="4"/>
                            <circle cx="100" cy="198" r="4"/>
                            <circle cx="158" cy="174" r="4"/>
                            <circle cx="216" cy="182" r="4"/>
                            <circle cx="274" cy="139" r="4"/>
                            <circle cx="332" cy="152" r="4"/>
                            <circle cx="390" cy="112" r="4"/>
                            <circle cx="448" cy="92" r="4"/>
                            <circle cx="506" cy="103" r="4"/>
                            <circle cx="564" cy="66" r="4"/>
                            <circle cx="622" cy="74" r="4"/>
                            <circle cx="700" cy="44" r="4"/>
                        </g>
                        <g class="text-[10px]" fill="#94a3b8">
                            <text x="36" y="252">06:00</text>
                            <text x="209" y="252">09:00</text>
                            <text x="383" y="252">12:00</text>
                            <text x="557" y="252">15:00</text>
                            <text x="676" y="252">Now</text>
                        </g>
                    </svg>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">System Load</h5>
                </div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-700">CPU</span>
                            <span class="text-slate-500">42%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full w-[42%] rounded-full bg-emerald-500"></div>
                        </div>
                    </div>
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-700">Memory</span>
                            <span class="text-slate-500">68%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full w-[68%] rounded-full bg-sky-500"></div>
                        </div>
                    </div>
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-700">Database</span>
                            <span class="text-slate-500">31%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full w-[31%] rounded-full bg-violet-500"></div>
                        </div>
                    </div>
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-700">Queue</span>
                            <span class="text-slate-500">74%</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full w-[74%] rounded-full bg-amber-500"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Content Summary</h5>
                </div>
                <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                    <div class="flex items-center justify-between py-2.5">
                        <dt class="text-slate-500">Published articles</dt>
                        <dd class="font-semibold text-slate-900">186</dd>
                    </div>
                    <div class="flex items-center justify-between py-2.5">
                        <dt class="text-slate-500">Drafts</dt>
                        <dd class="font-semibold text-slate-900">24</dd>
                    </div>
                    <div class="flex items-center justify-between py-2.5">
                        <dt class="text-slate-500">Media files</dt>
                        <dd class="font-semibold text-slate-900">1,284</dd>
                    </div>
                    <div class="flex items-center justify-between py-2.5">
                        <dt class="text-slate-500">Active users</dt>
                        <dd class="font-semibold text-slate-900">42</dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-2">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Recent Activity</h5>
            </div>
            <div class="divide-y divide-slate-100">
                <div class="flex items-center gap-3 px-5 py-3.5">
                    <div
                        class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-emerald-50 text-emerald-600">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-sm font-medium text-slate-800">Backup completed successfully</p>
                        <p class="text-xs text-slate-400">2 minutes ago</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 px-5 py-3.5">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-sky-50 text-sky-600">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-sm font-medium text-slate-800">36 media files processed</p>
                        <p class="text-xs text-slate-400">18 minutes ago</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 px-5 py-3.5">
                    <div
                        class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-amber-50 text-amber-600">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-sm font-medium text-slate-800">Queue depth exceeded normal threshold</p>
                        <p class="text-xs text-slate-400">41 minutes ago</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Scheduled Jobs</h5>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="px-4 py-3 font-semibold">Job</th>
                        <th class="px-4 py-3 font-semibold">Status</th>
                        <th class="px-4 py-3 font-semibold">Next Run</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                    <tr>
                        <td class="px-4 py-3 font-medium text-slate-900">Search index</td>
                        <td class="px-4 py-3"><span
                                class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Ready</span>
                        </td>
                        <td class="px-4 py-3 text-slate-500">5 min</td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3 font-medium text-slate-900">Image cleanup</td>
                        <td class="px-4 py-3"><span
                                class="rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-700">Queued</span>
                        </td>
                        <td class="px-4 py-3 text-slate-500">22 min</td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3 font-medium text-slate-900">Daily backup</td>
                        <td class="px-4 py-3"><span
                                class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">Idle</span>
                        </td>
                        <td class="px-4 py-3 text-slate-500">9 hr</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <table class="w-100 display apikey-data-table table-bottom-border"
           id="apikeydtatable">
        <thead>
        <tr>
            <th>User</th>
            <th>Route</th>
            <th>Status</th>
            <th>Method</th>
            <th>Date</th>
        </tr>
        </thead>
        <tbody id="api_key_body">
        {% for log in api_logs %}
            <tr>
                <td>
                    <div class="d-flex align-items-center">
                        <div
                            class="h-30 w-30 d-flex-center b-r-50 overflow-hidden text-bg-primary me-2">
                            <img alt="" class="img-fluid"
                                 src="{{ log.user.avatar() }}">
                        </div>
                        {{ log.user.name }}
                    </div>
                </td>
                <td>{{ log.request_route }}</td>
                <td data-order="{{ log.response_status_code }}">
                    {% if log.response_status_code == 200 %}
                        <span
                            class="badge text-bg-success">{{ log.response_status_code }} </span>
                    {% elseif log.response_status_code == 404 %}
                        <span
                            class="badge text-bg-warning">{{ log.response_status_code }}</span>
                    {% else %}
                        <span class="badge text-bg-danger">{{ log.response_status_code }}</span>
                    {% endif %}
                </td>
                <td>{{ log.method }}</td>
                <td data-order="{{ log.created_at }}">{{ log.created_at.format('M j, Y h:i:s A') }}</td>
            </tr>
        {% endfor %}

        </tbody>

    </table>
{% endblock %}


