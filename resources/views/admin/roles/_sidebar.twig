{% import 'admin._inc._ui' as ui %}

{% set items = [
    {label: 'All Roles', href: route('roles.index'), icon: 'users', active: false},
    {label: 'Create Role', href: route('roles.create'), icon: 'plus', active: active_secondary_nav == 'create_role'}
] %}

{% if role is defined and role %}
    {% set items = items|merge([
        {divider: true},
        {heading: 'Manage Role'},
        {label: 'Edit Role', href: route('roles.edit', role), icon: 'pencil', active: active_secondary_nav == 'edit_role'},
        {label: 'Delete Role', href: route('roles.confirm', role), icon: 'trash', active: active_secondary_nav == 'delete_role'}
    ]) %}
{% endif %}

{{ ui.section_nav('User Roles', items) }}
