{{ include('admin._inc._header', {title: 'View User'}) }}
<main>
    <div class="container-fluid">
        <!-- Breadcrumb start -->
        <div class="row m-1">
            <div class="col-12">
                <h5>View User</h5>
                <div class="col-6">
                    <ul class="app-line-breadcrumbs mb-3">
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('dashboard') }}">
                                <span>
                                    <i class="ph-duotone ph-table f-s-16"></i> Dashboard
                                </span>
                            </a>
                        </li>
                        <li class="">
                            <a class="f-s-14 f-w-500" href="{{ route('users.index') }}">Users</a>
                        </li>
                        <li class="active">
                            <a class="f-s-14 f-w-500" href="{{ route('users.show', user) }}">{{ user.name }}</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- Breadcrumb end -->
        {{ include('admin._inc._message') }}

        <!-- Action bar -->
        <div class="row mb-3">
            <div class="col-12 d-flex gap-2 justify-content-end">
                <a href="{{ route('users.edit', user) }}" class="btn btn-primary">
                    <i class="ti ti-edit me-1"></i> Edit User
                </a>
                <a href="{{ route('users.confirm', user) }}" class="btn btn-danger">
                    <i class="ti ti-trash me-1"></i> Delete User
                </a>
            </div>
        </div>

        <!-- Profile card start -->
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>Profile</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <p class="text-muted f-s-12 mb-1">Name</p>
                            <p class="f-w-500">{{ user.name }}</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted f-s-12 mb-1">Email</p>
                            <p class="f-w-500">
                                <a href="mailto:{{ user.email }}">{{ user.email }}</a>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted f-s-12 mb-1">Member Since</p>
                            <p class="f-w-500">{{ user.created_at.format('F j, Y') }}</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted f-s-12 mb-1">Last Updated</p>
                            <p class="f-w-500">{{ user.updated_at.format('F j, Y') }}</p>
                        </div>
                        <div class="col-md-12">
                            <p class="text-muted f-s-12 mb-1">Roles</p>
                            <div class="d-flex flex-wrap gap-1">
                                {% if user.roles.count >= 1 %}
                                    {% for role in user.roles %}
                                        <span class="badge bg-primary-light text-primary">{{ role.name }}</span>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-secondary">No roles assigned</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Profile card end -->

        <!-- Custom fields start -->
        {% if field_values is not empty %}
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5>Custom Fields</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            {% for handle, value in field_values %}
                                <div class="col-md-6">
                                    <p class="text-muted f-s-12 mb-1">{{ handle }}</p>
                                    <p class="f-w-500">{{ value is not empty ? value : '—' }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        <!-- Custom fields end -->

        <!-- Access tokens start -->
        {% if user.can('api') %}
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="mb-0">Access Tokens</h5>
                            </div>
                            <div class="col-auto">
                                <a href="{{ route('users.token.create', user) }}" class="btn btn-primary btn-sm">
                                    <i class="ti ti-plus me-1"></i> Create Token
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col">Name</th>
                                        <th scope="col">Expires</th>
                                        <th scope="col">Last Used</th>
                                        <th scope="col">Created</th>
                                        <th scope="col"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% if user.tokens.count >= 1 %}
                                    {% for token in user.tokens %}
                                        <tr>
                                            <td class="f-w-500">{{ token.name }}</td>
                                            <td>
                                                {% if token.expires_at %}
                                                    {{ token.expires_at.format('F j, Y') }}
                                                {% else %}
                                                    <span class="text-secondary">Never</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if token.last_used_at %}
                                                    {{ token.last_used_at.format('F j, Y') }}
                                                {% else %}
                                                    <span class="text-secondary">Never</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ token.created_at.format('F j, Y') }}</td>
                                            <td class="text-end">
                                                <a class="btn btn-success icon-btn b-r-4"
                                                   href="{{ route('users.token.edit', {id: user.id, token_id: token.id}) }}"
                                                   title="Edit token">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <a class="btn btn-danger icon-btn b-r-4"
                                                   href="{{ route('users.token.confirm', {id: user.id, token_id: token.id}) }}"
                                                   title="Revoke token">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-secondary py-3">
                                            No tokens created.
                                        </td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        <!-- Access tokens end -->

    </div>
</main>
{{ include('admin._inc._footer') }}
