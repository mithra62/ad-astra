{% import 'admin._inc._ui' as ui %}

{% set items = [
    {label: 'All Users',   href: route('users.index'),  icon: 'users', active: active_secondary_nav == 'all'},
    {label: 'Create User', href: route('users.create'), icon: 'plus',  active: active_secondary_nav == 'create'}
] %}

{% if user is defined and user %}
    {% set items = items|merge([
        {divider: true},
        {heading: 'Manage User'},
        {label: 'Edit User',       href: route('users.edit', user),            icon: 'pencil', active: active_secondary_nav == 'edit'},
        {label: 'View User',       href: route('users.show', user),            icon: 'eye',    active: active_secondary_nav == 'view'},
        {label: 'Change Password', href: route('users.change_password', user), icon: 'key',    active: active_secondary_nav == 'password'},
        {label: 'Access Tokens',   href: route('users.token.index', user),     icon: 'key',    active: active_secondary_nav == 'tokens'},
        {label: 'Delete User',     href: route('users.confirm', user),         icon: 'trash',  active: active_secondary_nav == 'delete'}
    ]) %}
{% endif %}

{{ ui.section_nav('Users', items) }}
