<input id="secnav-toggle" type="checkbox">

<label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-edge bg-surface px-4 py-2.5 text-sm font-medium text-muted hover:bg-subtle lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
    <span class="secnav-chevron text-faint">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
</label>

<div id="secondary-nav-panel" class="hidden border-b border-edge bg-surface px-4 py-3 lg:hidden">
    <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
        <a class="flex items-center gap-2 rounded-md bg-accent-soft px-3 py-2 text-sm font-medium text-accent" href="index.twig">All Articles</a>
        {% for group in groups %}
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="create-article.twig">New Article</a>
        {% endfor %}
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="categories.twig">Categories</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="#">Tags</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="#">Authors</a>
        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle" href="reorder-articles.twig">Reorder</a>
    </nav>
</div>

<aside class="hidden h-fit lg:block">
    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
        <div class="border-b border-edge px-4 py-3">
            <h5 class="text-sm font-semibold text-content">Status Groups</h5>
        </div>
        <nav class="p-2">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium {% if active_secondary_nav == 'all' %} text-accent bg-accent-soft {% endif %}" href="{{ route('users.index') }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>All Users
            </a>
            <a href="{{ route('users.create') }}" class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle {% if active_secondary_nav == 'create' %} text-accent bg-accent-soft {% endif %}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>Create User</a>
            {% if user %}
            <div class="my-2 border-t border-edge"></div>
            <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-faint">Manage User</p>
            <a href="{{ route('users.edit', user) }}" class="{% if active_secondary_nav == 'edit' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Edit User
            </a>
            <a href="{{ route('users.confirm', user) }}" class="{% if active_secondary_nav == 'delete' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Delete User
            </a>
            <a href="{{ route('users.show', user) }}" class="{% if active_secondary_nav == 'view' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> View User
            </a>
                <a href="{{ route('users.change_password', user) }}" class="{% if active_secondary_nav == 'password' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Change Password
                </a>
                <a href="{{ route('users.token.index', user) }}" class="{% if active_secondary_nav == 'tokens' %} text-accent bg-accent-soft {% endif %} mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted hover:bg-subtle">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Access Tokens
                </a>
                {% if can('manage user status') %}

                {% endif %}
            {% endif %}
        </nav>
    </div>
</aside>
