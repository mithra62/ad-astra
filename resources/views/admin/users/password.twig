{% extends 'admin._inc._layout' %}
{% import 'admin._inc._form-fields' as forms %}

{% set page_title = 'Change Password' %}
{% set page_heading = 'Change Password' %}
{% set active_nav = 'members' %}
{% set active_user_section = 'users' %}
{% set has_secondary_sidebar = true %}
{% set active_secondary_nav = 'password' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="{{ route('dashboard') }}"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-content" href="{{ route('users.index') }}">Users</a>

        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-content" href="{{ route('users.show', user) }}">
            {{ user.name }}
        </a>

        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-content">Change Password</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.users._sidebar', {'user': user}) }}
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Change Password</h1>
            <p class="mt-1 text-sm text-muted">Add a new user and assign one or more roles.</p>
        </div>
        <a href="{{ route('users.show', user) }}" class="inline-flex items-center gap-1.5 self-start rounded-md border border-edge bg-surface px-3 py-2 text-sm font-semibold text-content shadow-sm hover:bg-subtle sm:self-auto"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>Back to {{ user.name }}</a>
    </div>

    <form method="POST" action="{{ route('users.password', user) }}" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
        {{ csrf_field() }}
        {{ method_field('PUT') }}
        <div class="flex min-w-0 flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Password Management</h5></div>
                <div class="space-y-4 px-5 py-5">
                    <div>
                        {{ forms.password(
                            'password',
                            'New Password',
                            '',
                            'Leave blank to keep the current password.',
                            'Enter a new password',
                            'password'
                        ) }}
                    </div>
                    <div>
                        {{ forms.password(
                            'password_confirmation',
                            'Confirm Password',
                            '',
                            'Leave blank to keep the current password.',
                            'Enter a new password',
                            'password_confirmation'
                        ) }}
                    </div>
                </div>
            </div>


        </div>

        <div class="flex min-w-0 flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
                <div class="border-b border-edge px-5 py-3"><h5 class="text-sm font-semibold text-content">Change Password</h5></div>
                <div class="space-y-2 border-t border-edge px-5 py-4">
                    <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Change Password</button>
                    <a href="{{ route('users.show', user) }}" class="block w-full rounded-md border border-edge bg-surface px-4 py-2 text-center text-sm font-medium text-muted shadow-sm hover:bg-subtle">Cancel</a>
                </div>
            </div>
        </div>
    </form>
    {{ forms.password_scripts() }}
{% endblock %}
