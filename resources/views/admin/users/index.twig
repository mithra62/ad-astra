{% extends 'admin._inc._layout' %}

{% set page_title = 'Users' %}
{% set page_heading = 'Users' %}
{% set active_nav = 'members' %}
{% set active_user_section = 'users' %}
{% set has_secondary_sidebar = true %}
{% set active_secondary_nav = 'all' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-muted sm:text-sm">
        <a class="hover:text-content" href="home.twig"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
        <svg class="h-3 w-3 text-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-content">Users</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('admin.users._sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">Users</h1>
            <p class="mt-1 text-sm text-muted">Manage admin accounts, access status, and assigned roles.</p>
        </div>
        <a href="{{ route('users.create') }}" class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 sm:self-auto"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>Add User</a>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="overflow-hidden rounded-lg border border-edge bg-surface p-5 shadow-sm"><p class="text-xs font-medium uppercase tracking-wide text-muted">Total Users</p><p class="mt-2 text-3xl font-semibold text-content">128</p></div>
        <div class="overflow-hidden rounded-lg border border-edge bg-surface p-5 shadow-sm"><p class="text-xs font-medium uppercase tracking-wide text-muted">Active</p><p class="mt-2 text-3xl font-semibold text-content">112</p></div>
        <div class="overflow-hidden rounded-lg border border-edge bg-surface p-5 shadow-sm"><p class="text-xs font-medium uppercase tracking-wide text-muted">Pending Invites</p><p class="mt-2 text-3xl font-semibold text-content">9</p></div>
        <div class="overflow-hidden rounded-lg border border-edge bg-surface p-5 shadow-sm"><p class="text-xs font-medium uppercase tracking-wide text-muted">Admins</p><p class="mt-2 text-3xl font-semibold text-content">6</p></div>
    </div>

    <div class="overflow-hidden rounded-lg border border-edge bg-surface shadow-sm">
        <div class="border-b border-edge px-5 py-3">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <h5 class="text-sm font-semibold text-content">All Users</h5>
                <div class="flex flex-wrap items-center gap-2">
                    <select id="role-filter" class="rounded-md border border-edge bg-surface px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option value="">All roles</option>
                        <option value="administrator">Administrator</option>
                        <option value="editor">Editor</option>
                        <option value="author">Author</option>
                    </select>
                    <input id="user-search" class="w-full rounded-md border border-edge px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-52" placeholder="Search users..." type="search">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                <thead class="bg-subtle text-xs uppercase tracking-wide text-muted">
                <tr>
                    <th class="px-4 py-3"><input id="select-all" type="checkbox" class="rounded border-edge text-emerald-600 focus:ring-emerald-500"></th>
                    <th class="px-4 py-3 font-semibold">User</th>
                    <th class="px-4 py-3 font-semibold">Roles</th>
                    <th class="px-4 py-3 font-semibold">Status</th>
                    <th class="px-4 py-3 font-semibold">Last Login</th>
                    <th class="px-4 py-3 font-semibold">Actions</th>
                </tr>
                </thead>
                <tbody id="user-tbody" class="divide-y divide-slate-100 bg-surface">
                {% for user in users %}
                    <tr class="hover:bg-subtle/60" data-name="{{ user.name|lower }} {{ user.email|lower }}" data-role="{{ user.role_key }}">
                        <td class="px-4 py-3"><input type="checkbox" name="ids[]" value="{{ user.email }}" class="row-cb rounded border-edge text-emerald-600 focus:ring-emerald-500"></td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-sm font-semibold text-white">{{ user.initials }}</div>
                                <div class="min-w-0">
                                    <a href="{{ route('users.show', user) }}" class="font-medium text-content hover:text-accent">{{ user.name }}</a>
                                    <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                        <a href="{{ route('users.show', user) }}" class="text-emerald-600 hover:underline">View</a><span class="text-faint">|</span>
                                        <a href="{{ route('users.edit', user) }}" class="text-emerald-600 hover:underline">Edit</a><span class="text-faint">|</span>
                                        <a href="{{ route('users.confirm', user) }}" class="text-red-500 hover:underline">Delete</a>
                                    </div>
                                    <p class="mt-0.5 truncate text-xs text-faint">{{ user.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex flex-wrap gap-1.5">
                                {% for role in user.roles %}
                                    <span class="rounded-full bg-canvas px-2 py-0.5 text-xs font-medium text-content">{{ role.name }}</span>
                                {% endfor %}
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            {% if user.status == 'active' %}
                                <span class="rounded-full bg-accent-soft px-2 py-0.5 text-xs font-medium text-accent">{{ user.status }}</span>
                            {% else %}
                                <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">{{ user.status }}</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-muted">{{ user.updated_at.format('F j, Y') }}</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-1.5">
                                <a href="{{ route('users.show', user) }}" class="rounded p-1 text-faint hover:bg-subtle hover:text-emerald-600" title="View"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></a>
                                <a href="{{ route('users.edit', user) }}" class="rounded p-1 text-faint hover:bg-subtle hover:text-emerald-600" title="Edit"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></a>
                                <a href="{{ route('users.confirm', user) }}" class="rounded p-1 text-faint hover:bg-red-50 hover:text-red-600" title="Delete"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="flex flex-col gap-3 border-t border-edge bg-subtle px-4 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-wrap items-center gap-2">
                <select id="bulk-action" class="rounded-md border border-edge bg-surface px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                    <option value="">Bulk action</option>
                    <option value="activate">Activate</option>
                    <option value="suspend">Suspend</option>
                    <option value="delete">Delete</option>
                </select>
                <button type="button" onclick="applyBulk()" class="rounded-md border border-edge bg-surface px-3 py-1.5 text-sm font-medium text-content shadow-sm hover:bg-subtle">Apply</button>
            </div>

            {{ users.links() }}
        </div>
    </div>
{% endblock %}
