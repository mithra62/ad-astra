<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>{% block title %}{{ page_title|default('Admin') }}{% endblock %} - {{ config('app.name', 'Laravel') }}</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
    {% block vendor_scripts %}{% endblock %}

    {% block head %}{% endblock %}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">
{% set primary_nav_sticky = primary_nav_sticky|default(true) %}
{% set active_nav = active_nav|default('dashboard') %}
{% set secondary_sidebar_template = secondary_sidebar_template|default(null) %}
{% set has_secondary_sidebar = has_secondary_sidebar|default(secondary_sidebar_template is not empty) %}
{% set current_user = auth_user() %}
{% set account_menu_links = account_menu_links|default([
    {label: 'Profile', url: route('account.details')},
    {label: 'Preferences', url: route('account.settings')},
    {label: 'API Tokens', url: route('account.tokens.index')},
    {label: 'Logout', url: route('logout'), logout: true}
]) %}

<input id="sidebar-toggle" type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">
    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200 lg:relative lg:inset-auto lg:z-40 lg:w-auto lg:translate-x-0 lg:overflow-visible lg:transition-none {{ primary_nav_sticky ? 'lg:sticky lg:top-0 lg:h-screen' : '' }}">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="{{ route('dashboard') }}">{{ app_name|default('Admin') }}</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>

        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            {% block primary_navigation %}
                <a class="block rounded-md px-3 py-2 {{ active_nav == 'dashboard' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('dashboard') }}">Dashboard</a>

                <div class="nav-group">
                    <input id="nav-content" type="checkbox" {{ active_nav == 'content' ? 'checked' : '' }}>
                    <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 {{ active_nav in ['content', 'articles', 'categories', 'field-layouts'] ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}">
                        <span>Content</span>
                        <span class="nav-chevron">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </label>

                    <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'entries' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('entries.groups') }}">Entries</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'categories' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('categories.groups') }}">Categories</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'statuses' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('statuses.groups') }}">Statuses</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'media' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('media.libraries') }}">Media</a></li>

                        {# <li class="nav-group nav-tertiary-group">
                            <input id="nav-entries-tertiary" type="checkbox" {{ active_nav in ['entries', 'entries-published', 'entries-drafts', 'entries-archived'] ? 'checked' : '' }}>
                            <label for="nav-entries-tertiary" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-1.5 {{ active_nav in ['entries', 'entries-published', 'entries-drafts', 'entries-archived'] ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}">
                                <span>Entries</span>
                                <span class="nav-chevron">
                                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                                </span>
                            </label>
                            <ul class="nav-subitems mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'entries-published' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ entries_published_url|default('#') }}">Published</a></li>
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'entries-drafts' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ entries_drafts_url|default('#') }}">Drafts</a></li>
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'entries-archived' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ entries_archived_url|default('#') }}">Archived</a></li>
                            </ul>
                        </li>

                        <li class="nav-popout-group relative">
                            <a class="flex items-center justify-between rounded-md px-3 py-1.5 {{ active_nav in ['collections', 'collections-news', 'collections-guides', 'collections-releases'] ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ collections_url|default('#') }}">
                                <span>Collections</span>
                                <svg class="hidden h-3.5 w-3.5 text-slate-400 lg:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                            </a>
                            <ul class="nav-popout-menu mt-1 space-y-0.5 border-l border-slate-200 pl-3 lg:absolute lg:left-full lg:top-0 lg:z-40 lg:ml-2 lg:mt-0 lg:hidden lg:min-w-44 lg:rounded-md lg:border lg:border-slate-200 lg:bg-white lg:p-2 lg:shadow-lg">
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'collections-news' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ collections_news_url|default('#') }}">Newsroom</a></li>
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'collections-guides' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ collections_guides_url|default('#') }}">Guides</a></li>
                                <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'collections-releases' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-700' }}" href="{{ collections_releases_url|default('#') }}">Releases</a></li>
                            </ul>
                        </li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_nav == 'field-layouts' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ field_layouts_url|default('edit-field-layout.twig') }}">Field Layouts</a></li>
                        #}
                    </ul>
                </div>

                <div class="nav-group">
                    <input id="nav-media" type="checkbox" {{ active_nav in ['members'] ? 'checked' : '' }}>
                    <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 {{ active_nav in ['media', 'media-libraries'] ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}">
                        <span>Members</span>
                        <span class="nav-chevron">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </label>
                    <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_user_section == 'users' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('users.index') }}">Users</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_user_section == 'media' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('roles.index') }}">Roles</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_user_section == 'media' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('users.layouts.show') }}">Field Layout</a></li>
                    </ul>
                </div>

                <div class="nav-group">
                    <input id="nav-users" type="checkbox" {{ active_nav in ['account'] ? 'checked' : '' }}>
                    <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 {{ active_nav in ['users', 'roles'] ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}">
                        <span>Account</span>
                        <span class="nav-chevron">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </label>
                    <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'settings' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('account.details') }}">Details</a></li>
                        <li><a class="block rounded-md px-3 py-1.5"  href="{{ route('logout') }}"
                               onclick="event.preventDefault(); document.getElementById('logout-form').submit();">Logout</a></li>
                    </ul>
                </div>

                <div class="nav-group">
                    <input id="nav-settings" type="checkbox" {{ active_nav in ['settings'] ? 'checked' : '' }}>
                    <label for="nav-settings" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 {{ active_nav in ['settings'] ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}">
                        <span>Settings</span>
                        <span class="nav-chevron">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </label>
                    <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'system' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('settings.show', 'general') }}">System Settings</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'field_groups' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('fields.groups') }}">Field Groups</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'roles' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="">Entry Types</a></li>
                        <li><a class="block rounded-md px-3 py-1.5 {{ active_secondary_nav == 'field_layouts' ? 'bg-emerald-50 font-semibold text-emerald-700' : 'text-slate-600 hover:bg-slate-100' }}" href="{{ route('field-layouts') }}">Field Layouts</a></li>
                    </ul>
                </div>
                <form id="logout-form" action="{{ route('logout') }}" method="POST">
                    {{ csrf_field() }}
                </form>
            {% endblock %}
        </nav>
    </aside>

    <div class="flex min-w-0 flex-col">
        <header class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            {% block header %}
                <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                    <div class="flex min-w-0 items-center gap-3">
                        <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                        </label>
                        <div class="min-w-0">
                            <h4 class="text-sm font-semibold text-slate-800 sm:text-base">{{ page_heading|default(page_title|default('Dashboard')) }}</h4>
                            {% block breadcrumbs %}{% endblock %}
                        </div>
                    </div>

                    <div class="flex min-w-0 items-center gap-2 sm:gap-3 lg:ml-auto">
                        <form action="{{ admin_search_url|default('#') }}" method="GET" class="relative min-w-0 flex-1 sm:w-72 sm:flex-none" role="search">
                            <label class="sr-only" for="admin-global-search">Search</label>
                            <svg class="pointer-events-none absolute right-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.1-5.4a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z"/>
                            </svg>
                            <input id="admin-global-search"
                                   name="{{ admin_search_parameter|default('q') }}"
                                   type="input"
                                   value="{{ app.request.query.get(admin_search_parameter|default('q')) }}"
                                   placeholder="Search"
                                   class="h-10 w-full rounded-md border border-slate-200 bg-slate-50 pl-3 pr-14 text-sm text-slate-700 shadow-inner placeholder:text-slate-400 focus:border-emerald-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        </form>

                        <div class="relative shrink-0" data-account-menu>
                            <button type="button"
                                    class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border border-slate-200 bg-white text-sm font-semibold text-emerald-700 shadow-sm ring-offset-2 hover:border-emerald-200 hover:bg-emerald-50 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                                    aria-haspopup="true"
                                    aria-expanded="false"
                                    aria-label="Open account menu"
                                    data-account-menu-button>
                                {% if current_user.avatar() %}
                                    <img class="h-full w-full object-cover" src="{{ current_user.avatar() }}" alt="">
                                {% else %}
                                    {{ current_user.name|default('U')|slice(0, 2)|upper }}
                                {% endif %}
                            </button>

                            <div class="absolute right-0 z-40 mt-2 hidden w-72 overflow-hidden rounded-md border border-slate-200 bg-white text-left shadow-lg"
                                 role="menu"
                                 data-account-menu-panel>
                                <div class="border-b border-slate-100 px-4 py-3">
                                    <div class="flex items-center gap-3">
                                        <div class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-full bg-emerald-600 text-sm font-semibold text-white">
                                            {% if current_user.avatar() %}
                                                <img class="h-full w-full object-cover" src="{{ current_user.avatar() }}" alt="">
                                            {% else %}
                                                {{ current_user.name|default('U')|slice(0, 2)|upper }}
                                            {% endif %}
                                        </div>
                                        <div class="min-w-0">
                                            <p class="truncate text-sm font-semibold text-slate-900">{{ current_user.name }}</p>
                                            <p class="truncate text-xs text-slate-500">{{ current_user.email }}</p>
                                            {% if current_user.title %}
                                                <p class="mt-0.5 truncate text-xs text-slate-400">{{ current_user.title }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>

                                <div class="py-1">
                                    {% for link in account_menu_links %}
                                        <a href="{{ link.url }}"
                                           class="block px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 hover:text-slate-900 focus:bg-slate-50 focus:outline-none"
                                           role="menuitem"
                                           {% if link.logout|default(false) %}onclick="event.preventDefault(); document.getElementById('logout-form').submit();"{% endif %}>
                                            {{ link.label }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endblock %}
        </header>

        <main class="flex flex-1 p-4 sm:p-6">
            {% if has_secondary_sidebar %}
                <div class="grid min-w-0 flex-1 gap-6 lg:grid-cols-[14rem_1fr]">
                    {% if secondary_sidebar_template %}
                        {% include secondary_sidebar_template ignore missing %}
                    {% else %}
                        {% block secondary_sidebar %}{% endblock %}
                    {% endif %}

                    <div class="flex min-w-0 flex-col gap-5">
                        {{ include('admin._inc._message') }}
                        {% block content %}{% endblock %}
                    </div>
                </div>
            {% else %}
                <div class="flex min-w-0 flex-1 flex-col gap-5">
                    {{ include('admin._inc._message') }}
                    {{ block('content') }}
                </div>
            {% endif %}
        </main>

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            {% block footer %}
                <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-xs text-slate-400">&copy; {{ year|default('2026') }} {{ app_name|default('Admin') }} &mdash; All rights reserved.</p>
                    <nav class="flex items-center gap-4 text-xs text-slate-400">
                        <a class="hover:text-slate-600" href="{{ docs_url|default('#') }}">Documentation</a>
                        <a class="hover:text-slate-600" href="{{ support_url|default('#') }}">Support</a>
                        <a class="hover:text-slate-600" href="{{ privacy_url|default('#') }}">Privacy</a>
                        <span class="text-slate-300">|</span>
                        <span>{{ app_version|default('v0.0.12') }}</span>
                    </nav>
                </div>
            {% endblock %}
        </footer>
    </div>
</div>


<script>
    document.addEventListener('DOMContentLoaded', function () {
        var accountMenus = Array.prototype.slice.call(document.querySelectorAll('[data-account-menu]'));

        function closeAccountMenu(menu) {
            var button = menu.querySelector('[data-account-menu-button]');
            var panel = menu.querySelector('[data-account-menu-panel]');

            if (!button || !panel) {
                return;
            }

            panel.classList.add('hidden');
            button.setAttribute('aria-expanded', 'false');
        }

        accountMenus.forEach(function (menu) {
            var button = menu.querySelector('[data-account-menu-button]');
            var panel = menu.querySelector('[data-account-menu-panel]');

            if (!button || !panel) {
                return;
            }

            button.addEventListener('click', function () {
                var isOpen = !panel.classList.contains('hidden');

                accountMenus.forEach(function (otherMenu) {
                    if (otherMenu !== menu) {
                        closeAccountMenu(otherMenu);
                    }
                });

                panel.classList.toggle('hidden', isOpen);
                button.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
            });
        });

        document.addEventListener('click', function (event) {
            accountMenus.forEach(function (menu) {
                if (!menu.contains(event.target)) {
                    closeAccountMenu(menu);
                }
            });
        });

        document.addEventListener('keydown', function (event) {
            if (event.key !== 'Escape') {
                return;
            }

            accountMenus.forEach(closeAccountMenu);
        });
    });
</script>
{% block scripts %}{% endblock %}
</body>
</html>
