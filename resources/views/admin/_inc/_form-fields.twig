            <input id="{{ field_id }}" class="sr-only" type="file" name="{{ name }}" {% if accept %}accept="{{ accept }}"{% endif %} {% if multiple %}multiple{% endif %} {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
