    <div>
        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="{{ field_id }}">{{ label }}</label>
        <label class="flex cursor-pointer flex-col items-center justify-center rounded-lg border border-dashed px-5 py-6 text-center transition {% if has_error %}border-red-300 bg-red-50 hover:border-red-400 hover:bg-red-50{% else %}border-slate-300 bg-slate-50 hover:border-emerald-400 hover:bg-emerald-50/40{% endif %}" for="{{ field_id }}">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-slate-400 shadow-sm ring-1 ring-slate-200">
