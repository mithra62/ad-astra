{% macro slider(name, label, value, min, max, step, description, id, suffix, error_key) %}
    {% set field_id = id|default(name|replace({'[': '_', ']': '', '.': '_'})) %}
    {% set field_error_key = error_key|default(name|replace({'[]': '', '[': '.', ']': ''})) %}
    {% set field_value = old(field_error_key, value|default(min|default(0))) %}
    {% set field_min = min|default(0) %}
    {% set field_max = max|default(100) %}
    {% set field_step = step|default(1) %}
    {% set has_error = errors is defined and errors.has(field_error_key) %}
    <div data-range-field>
        <div class="mb-1.5 flex items-center justify-between gap-3">
            <label class="block text-sm font-medium text-slate-700" for="{{ field_id }}">{{ label }}</label>
            <span class="rounded-md bg-slate-100 px-2 py-1 font-mono text-xs font-medium text-slate-600" data-range-value>{{ field_value }}{{ suffix|default('') }}</span>
        </div>
        <div class="group relative pt-7">
            <output class="pointer-events-none absolute top-0 -translate-x-1/2 rounded-md bg-slate-900 px-2 py-1 font-mono text-xs font-medium text-white opacity-0 shadow-sm transition group-hover:opacity-100 group-focus-within:opacity-100 after:absolute after:left-1/2 after:top-full after:-translate-x-1/2 after:border-4 after:border-transparent after:border-t-slate-900 after:content-['']" for="{{ field_id }}" data-range-output style="left: 0;">{{ field_value }}{{ suffix|default('') }}</output>
            <input id="{{ field_id }}" name="{{ name }}" type="range" value="{{ field_value }}" min="{{ field_min }}" max="{{ field_max }}" step="{{ field_step }}" data-range-input data-range-suffix="{{ suffix|default('') }}" class="h-2 w-full cursor-pointer appearance-none rounded-full bg-slate-200 accent-emerald-600 focus:outline-none focus:ring-2 {% if has_error %}focus:ring-red-500/20{% else %}focus:ring-emerald-500/20{% endif %}" {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
        </div>
        <div class="mt-1 flex items-center justify-between font-mono text-[11px] text-slate-400">
            <span>{{ field_min }}{{ suffix|default('') }}</span>
            <span>{{ field_max }}{{ suffix|default('') }}</span>
        </div>
        {% if description %}
            <p class="mt-1 text-xs leading-5 text-slate-400">{{ description }}</p>
        {% endif %}
        {% if has_error %}
            <p id="{{ field_id }}_error" class="mt-1 text-xs text-red-600">{{ errors.first(field_error_key) }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% macro slider_scripts() %}
    <script>
        (function () {
            function initRangeSliders() {
                document.querySelectorAll('[data-range-field]').forEach(function (field) {
                    if (field.dataset.rangeReady === 'true') {
                        return;
                    }

                    var input = field.querySelector('[data-range-input]');
                    var output = field.querySelector('[data-range-output]');
                    var valueBadge = field.querySelector('[data-range-value]');

                    if (!input || !output) {
                        return;
                    }

                    var update = function () {
                        var min = Number(input.min || 0);
                        var max = Number(input.max || 100);
                        var value = Number(input.value || min);
                        var percent = max === min ? 0 : ((value - min) / (max - min)) * 100;
                        var thumbOffset = 8 - (percent * 0.16);
                        var displayValue = input.value + (input.dataset.rangeSuffix || '');

                        output.value = displayValue;
                        output.textContent = displayValue;
                        output.style.left = 'calc(' + percent + '% + ' + thumbOffset + 'px)';

                        if (valueBadge) {
                            valueBadge.textContent = displayValue;
                        }
                    };

                    input.addEventListener('input', update);
                    input.addEventListener('change', update);
                    input.addEventListener('pointermove', update);
                    window.addEventListener('resize', update);
                    field.dataset.rangeReady = 'true';
                    update();
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initRangeSliders);
            } else {
                initRangeSliders();
            }
        })();
    </script>
{% endmacro %}

{% macro toggle(name, label, checked, description, value, id, error_key) %}
    {% set field_id = id|default(name|replace({'[': '_', ']': '', '.': '_'})) %}
    {% set field_error_key = error_key|default(name|replace({'[]': '', '[': '.', ']': ''})) %}
    {% set field_value = value|default('1') %}
    {% set checked_state = old(field_error_key) is not null ? old(field_error_key) : checked %}
    {% set has_error = errors is defined and errors.has(field_error_key) %}
    <div>
        <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border px-4 py-3 transition {% if has_error %}border-red-300 bg-red-50 hover:border-red-400{% else %}border-slate-200 bg-slate-50 hover:border-emerald-300 hover:bg-emerald-50/30{% endif %}" for="{{ field_id }}">
            <span class="min-w-0">
                <span class="block text-sm font-medium text-slate-700">{{ label }}</span>
                {% if description %}
                    <span class="mt-0.5 block text-xs leading-5 text-slate-500">{{ description }}</span>
                {% endif %}
            </span>
            <span class="shrink-0">
                <input type="hidden" name="{{ name }}" value="0">
                <input id="{{ field_id }}" class="peer sr-only" type="checkbox" name="{{ name }}" value="{{ field_value }}" {% if checked_state %}checked{% endif %} {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
                <span class="relative block h-6 w-11 rounded-full bg-slate-300 transition after:absolute after:left-1 after:top-1 after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-emerald-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-emerald-500"></span>
            </span>
        </label>
        {% if has_error %}
            <p id="{{ field_id }}_error" class="mt-1 text-xs text-red-600">{{ errors.first(field_error_key) }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% macro checkbox_card(name, value, label, description, checked, id, error_key) %}
    {% set field_id = id|default((name ~ '_' ~ value)|replace({'[': '_', ']': '', '.': '_', ' ': '_'})) %}
    {% set field_error_key = error_key|default(name|replace({'[]': '', '[': '.', ']': ''})) %}
    {% set old_values = old(field_error_key) %}
    {% set checked_state = old_values is not null ? value in old_values : checked %}
    {% set has_error = errors is defined and errors.has(field_error_key) %}
    <div>
        <label class="group flex cursor-pointer items-start gap-3 rounded-lg border bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:bg-emerald-50/30 has-[:checked]:border-emerald-400 has-[:checked]:bg-emerald-50/60 {% if has_error %}border-red-300{% else %}border-slate-200{% endif %}" for="{{ field_id }}">
            <input id="{{ field_id }}" type="checkbox" name="{{ name }}" value="{{ value }}" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" {% if checked_state %}checked{% endif %} {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
            <span class="min-w-0">
                <span class="block text-sm font-medium text-slate-800">{{ label }}</span>
                {% if description %}
                    <span class="mt-0.5 block text-xs leading-5 text-slate-500">{{ description }}</span>
                {% endif %}
            </span>
        </label>
        {% if has_error %}
            <p id="{{ field_id }}_error" class="mt-1 text-xs text-red-600">{{ errors.first(field_error_key) }}</p>
        {% endif %}
    </div>
{% endmacro %}
