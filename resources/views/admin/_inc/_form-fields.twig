{% macro input(name, label, value, type, description, placeholder, id, error_key) %}
    {% set field_id = id|default(name|replace({'[': '_', ']': '', '.': '_'})) %}
    {% set field_error_key = error_key|default(name|replace({'[]': '', '[': '.', ']': ''})) %}
    {% set field_type = type|default('text') %}
    {% set field_value = old(field_error_key, value) %}
    {% set has_error = errors is defined and errors.has(field_error_key) %}
    <div>
        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="{{ field_id }}">{{ label }}</label>
        <input class="w-full rounded-md border bg-white px-3 py-2 text-sm shadow-sm transition placeholder:text-slate-400 focus:outline-none focus:ring-2 {% if has_error %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %}border-slate-300 focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}" id="{{ field_id }}" name="{{ name }}" type="{{ field_type }}" value="{{ field_value }}" placeholder="{{ placeholder|default('') }}" {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
        {% if description %}
            <p class="mt-1 text-xs leading-5 text-slate-400">{{ description }}</p>
        {% endif %}
        {% if has_error %}
            <p id="{{ field_id }}_error" class="mt-1 text-xs text-red-600">{{ errors.first(field_error_key) }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% macro password(name, label, value, description, placeholder, id, error_key) %}
    {% set field_id = id|default(name|replace({'[': '_', ']': '', '.': '_'})) %}
    {% set field_error_key = error_key|default(name|replace({'[]': '', '[': '.', ']': ''})) %}
    {% set has_error = errors is defined and errors.has(field_error_key) %}
    <div data-password-field>
        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="{{ field_id }}">{{ label }}</label>
        <div class="flex items-center rounded-md border bg-white shadow-sm transition focus-within:ring-2 {% if has_error %}border-red-300 focus-within:border-red-500 focus-within:ring-red-500/20{% else %}border-slate-300 focus-within:border-emerald-500 focus-within:ring-emerald-500/20{% endif %}">
            <input class="min-w-0 flex-1 border-0 bg-transparent px-3 py-2 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-0" id="{{ field_id }}" name="{{ name }}" type="password" value="{{ value|default('') }}" placeholder="{{ placeholder|default('') }}" data-password-input {% if has_error %}aria-invalid="true" aria-describedby="{{ field_id }}_error"{% endif %}>
            <button class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-r-md text-slate-400 hover:bg-slate-50 hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" type="button" data-password-toggle aria-controls="{{ field_id }}" aria-label="Show password">
                <svg class="h-4 w-4" data-password-show-icon fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg class="hidden h-4 w-4" data-password-hide-icon fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18"/><path stroke-linecap="round" stroke-linejoin="round" d="M10.585 10.587a2 2 0 102.828 2.826"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.88 4.24A10.95 10.95 0 0112 4c4.478 0 8.268 2.943 9.542 7a10.52 10.52 0 01-3.188 4.568M6.228 6.228A10.46 10.46 0 002.458 12c1.274 4.057 5.064 7 9.542 7 1.528 0 2.967-.343 4.248-.957"/></svg>
            </button>
        </div>
        {% if description %}
            <p class="mt-1 text-xs leading-5 text-slate-400">{{ description }}</p>
        {% endif %}
        {% if has_error %}
            <p id="{{ field_id }}_error" class="mt-1 text-xs text-red-600">{{ errors.first(field_error_key) }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% macro password_scripts() %}
    <script>
        (function () {
            function initPasswordFields() {
                document.querySelectorAll('[data-password-field]').forEach(function (field) {
                    if (field.dataset.passwordReady === 'true') {
                        return;
                    }

                    var input = field.querySelector('[data-password-input]');
                    var toggle = field.querySelector('[data-password-toggle]');
                    var showIcon = field.querySelector('[data-password-show-icon]');
                    var hideIcon = field.querySelector('[data-password-hide-icon]');

                    if (!input || !toggle) {
                        return;
                    }

                    toggle.addEventListener('click', function () {
                        var isMasked = input.type === 'password';
                        input.type = isMasked ? 'text' : 'password';
                        toggle.setAttribute('aria-label', isMasked ? 'Hide password' : 'Show password');

                        if (showIcon) {
                            showIcon.classList.toggle('hidden', isMasked);
                        }

                        if (hideIcon) {
                            hideIcon.classList.toggle('hidden', !isMasked);
                        }
                    });

                    field.dataset.passwordReady = 'true';
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initPasswordFields);
            } else {
                initPasswordFields();
            }
        })();
    </script>
{% endmacro %}

{% macro file(name, label, description, accept, multiple, id, error_key) %}
