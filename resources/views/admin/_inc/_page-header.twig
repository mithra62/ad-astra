{# ============================================================================
   Page header — title + subtitle + optional action buttons.

   {% embed 'admin._inc._page-header' with {title: 'Users', subtitle: '...'} %}
       {% block actions %}{{ ui.button('Add User', route('users.create'), icon='plus') }}{% endblock %}
   {% endembed %}

   Vars: title (required), subtitle (optional). Block: actions (optional).
   ============================================================================ #}
{% set _actions %}{% block actions %}{% endblock %}{% endset %}
<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-xl font-semibold tracking-tight text-content sm:text-2xl">{{ title }}</h1>
        {% if subtitle is defined and subtitle %}<p class="mt-1 text-sm text-muted">{{ subtitle }}</p>{% endif %}
    </div>
    {% if _actions|trim %}<div class="flex flex-wrap items-center gap-2 self-start sm:self-auto">{{ _actions|raw }}</div>{% endif %}
</div>
