{% extends 'auth._layout' %}

{% set page_title = 'Forgot Password' %}

{% block heading %}Reset your password{% endblock %}
{% block subheading %}Enter your email and we will send reset instructions.{% endblock %}

{% block content %}

    <form method="POST" action="{{ route('password.request') }}" class="space-y-5 px-5 py-6 sm:px-6">
        {{ csrf_field() }}
        <div class="rounded-md border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-800">
            If an account exists for this email, a reset link will be sent.
        </div>

        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-slate-700">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 {% if errors.has('email') %}border-red-300 focus:border-red-500 focus:ring-red-500/20{% else %} focus:border-emerald-500 focus:ring-emerald-500/20{% endif %}"
                   placeholder="you@example.com">

            {% if errors.has('email') %}
                <p id="email-error" class="mt-1.5 text-xs font-medium text-red-600">{{ errors.first('email') }}</p>
            {% endif %}
        </div>

        {{ include('_inc._bb') }}
        <button type="submit"
                class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
            Send reset link
        </button>
    </form>

    <div class="border-t border-slate-200 bg-slate-50 px-5 py-4 text-center text-sm text-slate-500 sm:px-6">
        Remembered your password?
        <a href="{{ route('login') }}" class="font-medium text-emerald-700 hover:text-emerald-800">Back to sign in</a>
    </div>
{% endblock %}
