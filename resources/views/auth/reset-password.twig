{% extends 'auth._layout' %}

{% set page_title = 'Reset Password' %}

{% block heading %}Choose a new password{% endblock %}
{% block subheading %}Create a secure password for your account.{% endblock %}

{% block content %}
    <form method="POST" action="{{ route('password.update') }}" class="space-y-5 px-5 py-6 sm:px-6">
        {{ csrf_field() }}
        {% if session('status') %}
            <div class="rounded-md border border-emerald-200 bg-accent-soft px-4 py-3 text-sm text-emerald-800">
                {{ session('status') }}
            </div>
        {% endif %}

        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-content">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email"
                   class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   value="{{ old('email', request.email) }}"
                   placeholder="you@example.com">
            {% if errors.has('email') %}
                <p id="email-error" class="mt-1.5 text-xs font-medium text-red-600">{{ errors.first('email') }}</p>
            {% endif %}
        </div>

        <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-content">New password</label>
            <div class="relative">
                <input id="password" name="password" type="password" autocomplete="new-password" minlength="8"
                       class="w-full rounded-md border border-edge px-3 py-2 pr-10 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                       placeholder="Minimum 8 characters">
                <button type="button" class="auth-password-toggle absolute inset-y-0 right-0 inline-flex items-center px-3 text-faint hover:text-muted" data-auth-password-toggle="password" aria-label="Show password">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </button>
                {% if errors.has('password') %}
                    <p id="password-error" class="mt-1.5 text-xs font-medium text-red-600">{{ errors.first('password') }}</p>
                {% endif %}
            </div>
        </div>

        <div>
            <label for="password_confirmation" class="mb-1.5 block text-sm font-medium text-content">Confirm new password</label>
            <input id="password_confirmation" name="password_confirmation" type="password" autocomplete="new-password" minlength="8"
                   class="w-full rounded-md border border-edge px-3 py-2 text-sm shadow-sm placeholder:text-faint focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   placeholder="Repeat password">
            <button type="button" class="auth-password-toggle absolute inset-y-0 right-0 inline-flex items-center px-3 text-faint hover:text-muted" data-auth-password_confirmation-toggle="password_confirmation" aria-label="Show password">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </button>
            {% if errors.has('password_confirmation') %}
                <p id="password_confirmation-error" class="mt-1.5 text-xs font-medium text-red-600">{{ errors.first('password_confirmation') }}</p>
            {% endif %}
        </div>
        {{ include('_inc._bb') }}
        <input type="hidden" value="{{ request.route('token') }}" name="token">
        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Reset password</button>
    </form>

    <div class="border-t border-edge bg-subtle px-5 py-4 text-center text-sm text-muted sm:px-6">
        <a href="login.twig" class="font-medium text-accent hover:text-emerald-800">Return to sign in</a>
    </div>

{% endblock %}

