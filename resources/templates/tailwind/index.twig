<!DOCTYPE html>
<html lang="{{ app().getLocale()|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Tailwind Twig Vite</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
<main class="mx-auto flex min-h-screen w-full max-w-5xl flex-col justify-center px-6 py-12">
    <section class="grid gap-6 md:grid-cols-[1.25fr_0.75fr]">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-8 shadow-xl shadow-black/20">
            <p class="text-sm font-semibold uppercase tracking-wide text-cyan-300">Twig + Tailwind + Vite</p>
            <h1 class="mt-4 text-4xl font-bold text-white">Tailwind is rendering from a Twig template.</h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-zinc-300">
                This page is served from <span class="font-mono text-cyan-200">resources/templates/tailwind/index.twig</span>
                and loads the Laravel Vite bundle through TwigBridge.
            </p>

            <div
                class="mt-8 rounded-lg border border-cyan-400/30 bg-cyan-400/10 p-5 transition-colors duration-200"
                data-vite-action="panel"
            >
                <p class="text-sm font-medium text-cyan-100">Vite action one</p>
                <p class="mt-2 text-zinc-200">Click the button to toggle this panel between active states.</p>
            </div>

            <button
                class="mt-5 rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-900"
                data-vite-action="toggle-panel"
                type="button"
            >
                Toggle panel
            </button>
        </div>

        <aside class="rounded-lg border border-zinc-800 bg-white p-8 text-zinc-950 shadow-xl shadow-black/20">
            <p class="text-sm font-semibold uppercase tracking-wide text-zinc-500">Vite action two</p>
            <div class="mt-6 flex items-end gap-3">
                <span class="text-6xl font-bold tabular-nums" data-vite-action="counter">0</span>
                <span class="pb-2 text-sm font-medium text-zinc-500">clicks</span>
            </div>
            <button
                class="mt-8 rounded-md bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-zinc-950 focus:ring-offset-2"
                data-vite-action="increment-counter"
                type="button"
            >
                Increment
            </button>
        </aside>
    </section>
</main>
</body>
</html>
