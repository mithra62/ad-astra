<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Categories</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .nav-group input[type="checkbox"] { display: none; }
        .nav-group input[type="checkbox"]:checked ~ .nav-subitems { display: block; }
        .nav-group input[type="checkbox"]:checked ~ label .nav-chevron { transform: rotate(90deg); }
        .nav-subitems { display: none; }
        .nav-chevron { transition: transform 0.15s ease; display: inline-block; }
        #sidebar-toggle { display: none; }
        #sidebar-toggle:checked ~ .app-shell #primary-sidebar { transform: translateX(0); }
        #sidebar-toggle:checked ~ .sidebar-overlay { display: block; }
        #secnav-toggle { display: none; }
        #secnav-toggle:checked ~ .app-shell #secondary-nav-panel { display: block; }
        #secnav-toggle:checked ~ .app-shell .secnav-chevron { transform: rotate(180deg); }
        .secnav-chevron { transition: transform 0.15s ease; display: inline-block; }
        .child-row td:first-child { padding-left: 2.5rem; }
        tr.selected { background-color: #f0fdf4; }
        .row-actions { opacity: 0; transition: opacity 0.1s; }
        tr:hover .row-actions { opacity: 1; }
    </style>
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <!-- Primary Sidebar -->
    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <div class="nav-group">
                <input id="nav-content" type="checkbox" checked>
                <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700">
                    <span>Content</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 font-semibold text-emerald-700" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-media" type="checkbox">
                <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Media</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Upload</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-users" type="checkbox">
                <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <!-- Main column -->
    <div class="flex min-w-0 flex-col">

        <!-- Topbar -->
        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Categories</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Articles</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Categories</span>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Mobile secnav toggle -->
        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>

        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">All Articles</a>
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">Categories</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Tags</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Authors</a>
            </nav>
        </div>

        <!-- Body -->
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <!-- Secondary nav card -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Articles</h5></div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> All Articles
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> New Article
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10M7 11h6m-9 8h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg> Categories
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg> Tags
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg> Authors
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Tools</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg> Import
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Export
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Content -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Page header -->
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Categories</h1>
                        <p class="mt-1 text-sm text-slate-500">Organise your content with categories. Categories can be nested.</p>
                    </div>
                    <a href="create-category.twig" class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 sm:self-auto">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                        Add New Category
                    </a>
                </div>

                <!-- Split layout: quick-add left, table right -->
                <div class="flex flex-col gap-5 lg:grid lg:grid-cols-[22rem_1fr] lg:items-start">

                    <!-- ── Quick Add card ──────────────────────────────── -->
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-4">
                            <h3 class="text-sm font-semibold text-slate-800">Add New Category</h3>
                            <p class="mt-0.5 text-xs text-slate-500">Quick-add a category without leaving this page.</p>
                        </div>
                        <form id="quick-add-form" method="POST" action="#" class="divide-y divide-slate-100">
                            <div class="px-5 py-4">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="cat_name">Name <span class="text-red-500">*</span></label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       id="cat_name" name="name" type="text" placeholder="e.g. Engineering" required>
                                <p class="mt-1 text-xs text-slate-400">The name is how it appears on your site.</p>
                            </div>
                            <div class="px-5 py-4">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="cat_slug">Slug</label>
                                <div class="flex rounded-md shadow-sm">
                                    <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/category/</span>
                                    <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="cat_slug" name="slug" type="text" placeholder="engineering">
                                </div>
                                <p class="mt-1 text-xs text-slate-400">Auto-generated from name. Lowercase, hyphens only.</p>
                            </div>
                            <div class="px-5 py-4">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="cat_parent">Parent Category</label>
                                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                        id="cat_parent" name="parent_id">
                                    <option value="">— None (top-level) —</option>
                                    <option value="1">Engineering</option>
                                    <option value="2">Product</option>
                                    <option value="3">Company</option>
                                    <option value="4">Operations</option>
                                    <option value="5">Security</option>
                                    <option value="6">Tutorials</option>
                                </select>
                                <p class="mt-1 text-xs text-slate-400">Unlike tags, categories can have a hierarchy.</p>
                            </div>
                            <div class="px-5 py-4">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="cat_desc">Description</label>
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="cat_desc" name="description" rows="3"
                                          placeholder="Optional description for this category…"></textarea>
                                <p class="mt-1 text-xs text-slate-400">The description is not prominent by default, but some themes may display it.</p>
                            </div>
                            <div class="bg-slate-50 px-5 py-4">
                                <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                                    Add New Category
                                </button>
                                <p class="mt-2 text-center text-xs text-slate-400">
                                    Need more options? <a href="create-category.twig" class="text-emerald-600 hover:underline">Use the full form →</a>
                                </p>
                            </div>
                        </form>
                    </div>

                    <!-- ── Category table ─────────────────────────────── -->
                    <div class="flex flex-col gap-3">

                        <!-- Table toolbar -->
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                            <div class="flex items-center gap-2">
                                <!-- Bulk action -->
                                <select id="bulk-action" class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none">
                                    <option value="">Bulk Actions</option>
                                    <option value="delete">Delete</option>
                                    <option value="export">Export</option>
                                </select>
                                <button type="button" onclick="applyBulk()" class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Apply</button>
                                <span id="selected-count" class="text-xs text-slate-500 hidden"><span id="selected-num">0</span> selected</span>
                            </div>
                            <div class="relative">
                                <svg class="pointer-events-none absolute left-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                                <input id="cat-search" type="text" placeholder="Search categories…"
                                       class="rounded-md border border-slate-300 bg-white py-2 pl-8 pr-3 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 w-full sm:w-56">
                            </div>
                        </div>

                        <!-- Table card -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm" id="cat-table">
                                    <thead>
                                        <tr class="border-b border-slate-200 bg-slate-50 text-left">
                                            <th class="w-8 px-4 py-3">
                                                <input type="checkbox" id="select-all" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                            </th>
                                            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">
                                                <button type="button" class="flex items-center gap-1 hover:text-slate-800" onclick="sortTable('name')">
                                                    Name <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
                                                </button>
                                            </th>
                                            <th class="hidden px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500 sm:table-cell">Description</th>
                                            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Slug</th>
                                            <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-500">
                                                <button type="button" class="flex items-center gap-1 hover:text-slate-800 mx-auto" onclick="sortTable('count')">
                                                    Articles <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
                                                </button>
                                            </th>
                                            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100" id="cat-tbody">

                                        <!-- Engineering (parent) -->
                                        <tr class="hover:bg-slate-50/60" data-name="engineering" data-id="1">
                                            <td class="px-4 py-3"><input type="checkbox" name="ids[]" value="1" class="row-cb rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                            <td class="px-4 py-3 font-medium text-slate-900">
                                                <a href="edit-category.twig" class="hover:text-emerald-700">Engineering</a>
                                                <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                                    <a href="edit-category.twig" class="text-emerald-600 hover:underline">Edit</a>
                                                    <span class="text-slate-300">|</span>
                                                    <a href="delete-category.twig" class="text-red-500 hover:underline">Delete</a>
                                                    <span class="text-slate-300">|</span>
                                                    <a href="#" class="text-slate-500 hover:underline">View</a>
                                                </div>
                                            </td>
                                            <td class="hidden px-4 py-3 text-slate-500 sm:table-cell">All things engineering &amp; software development</td>
                                            <td class="px-4 py-3 font-mono text-xs text-slate-500">engineering</td>
                                            <td class="px-4 py-3 text-center text-slate-700">47</td>
                                            <td class="px-4 py-3">
