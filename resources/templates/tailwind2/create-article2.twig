<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Create Article</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* ── Primary sidebar (CSS accordion) ─────────────────────── */
        .nav-group input[type="checkbox"] { display: none; }
        .nav-group input[type="checkbox"]:checked ~ .nav-subitems { display: block; }
        .nav-group input[type="checkbox"]:checked ~ label .nav-chevron { transform: rotate(90deg); }
        .nav-subitems { display: none; }
        .nav-chevron { transition: transform 0.15s ease; display: inline-block; }

        /* ── Mobile: primary sidebar slide-in ────────────────────── */
        #sidebar-toggle { display: none; }
        #sidebar-toggle:checked ~ .app-shell #primary-sidebar { transform: translateX(0); }
        #sidebar-toggle:checked ~ .sidebar-overlay { display: block; }

        /* ── Mobile: secondary nav accordion ─────────────────────── */
        #secnav-toggle { display: none; }
        #secnav-toggle:checked ~ .app-shell #secondary-nav-panel { display: block; }
        #secnav-toggle:checked ~ .app-shell .secnav-chevron { transform: rotate(180deg); }
        .secnav-chevron { transition: transform 0.15s ease; display: inline-block; }

        /* ── Tab system ───────────────────────────────────────────── */
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        .tab-btn {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.625rem 1rem;
            font-size: 0.8125rem;
            font-weight: 500;
            color: #64748b;
            border-bottom: 2px solid transparent;
            white-space: nowrap;
            transition: color 0.12s, border-color 0.12s;
            cursor: pointer;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
            outline: none;
        }
        .tab-btn:hover { color: #1e293b; }
        .tab-btn.active {
            color: #059669;
            border-bottom-color: #059669;
            font-weight: 600;
        }
        .tab-btn .tab-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 1.125rem;
            min-width: 1.125rem;
            padding: 0 0.3rem;
            border-radius: 9999px;
            font-size: 0.6875rem;
            font-weight: 600;
            background: #f1f5f9;
            color: #64748b;
        }
        .tab-btn.active .tab-badge {
            background: #d1fae5;
            color: #065f46;
        }

        /* ── Unsaved indicator dot ─────────────────────────────────── */
        .unsaved-dot {
            display: none;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: #f59e0b;
            position: absolute;
            top: 6px; right: 4px;
        }
        .tab-btn.dirty .unsaved-dot { display: block; }
    </style>
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle"
       class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40"
       aria-hidden="true"></label>

<!-- ═══ App shell ════════════════════════════════════════════════════ -->
<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <!-- ── Primary sidebar ──────────────────────────────────────────── -->
    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">

        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle"
                   class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden"
                   aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </label>
        </div>

        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>

            <div class="nav-group">
                <input id="nav-content" type="checkbox" checked>
                <label for="nav-content"
                       class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700">
                    <span>Content</span>
                    <span class="nav-chevron">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 text-emerald-700" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>

            <div class="nav-group">
                <input id="nav-media" type="checkbox">
                <label for="nav-media"
                       class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Media</span>
                    <span class="nav-chevron">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Upload</a></li>
                </ul>
            </div>

            <div class="nav-group">
                <input id="nav-users" type="checkbox">
                <label for="nav-users"
                       class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>

            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <!-- ── Page area ─────────────────────────────────────────────────── -->
    <div class="flex min-w-0 flex-col">

        <!-- Topbar -->
        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle"
                       class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden"
                       aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </label>
                <div class="flex-1">
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Create Article</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#">
                            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
                            </svg>
                            Dashboard
                        </a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Articles</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">New Article</span>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Mobile secondary nav toggle -->
        <label for="secnav-toggle"
               class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2">
                <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
                </svg>
                Section Navigation
            </span>
            <span class="secnav-chevron text-slate-400">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </span>
        </label>

        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg>
                    All Articles
                </a>
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    New Article
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10M7 11h6m-9 8h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    Categories
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                    Tags
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Authors
                </a>
            </nav>
        </div>

        <!-- ── Main body ─────────────────────────────────────────────── -->
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <!-- Desktop secondary nav card -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Articles</h5>
                    </div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg>
                            All Articles
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            New Article
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10M7 11h6m-9 8h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Categories
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                            Tags
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Authors
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Settings</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Edit Entry Group
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            Edit Entry Type
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- ── Form content ─────────────────────────────────────────── -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Page title + back link -->
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Article</h1>
                        <p class="mt-1 text-sm text-slate-500">Fill in the details below and save when ready.</p>
                    </div>
                    <a class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto" href="#">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                        Back to Articles
                    </a>
                </div>

                <!-- Two-column form -->
                <form id="article-form" method="POST" action="#"
                      class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

                    <!-- ── Left: tabbed content area ───────────────────── -->
                    <div class="flex flex-col gap-0 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">

                        <!-- Tab bar -->
                        <div class="border-b border-slate-200 bg-slate-50">
                            <div class="flex overflow-x-auto" role="tablist" aria-label="Article sections">

                                <button type="button" role="tab" aria-selected="true"
                                        class="tab-btn active" data-target="tab-content"
                                        id="btn-content" aria-controls="tab-content">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    Content
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-target="tab-structure"
                                        id="btn-structure" aria-controls="tab-structure">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                                    Structure
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-target="tab-taxonomy"
                                        id="btn-taxonomy" aria-controls="tab-taxonomy">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                                    Taxonomy
                                    <span class="tab-badge" id="badge-taxonomy">0</span>
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-target="tab-seo"
                                        id="btn-seo" aria-controls="tab-seo">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                                    SEO
                                    <span class="unsaved-dot"></span>
                                </button>

                            </div>
                        </div><!-- /tab bar -->

                        <!-- ░░ TAB: Content ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
                        <div id="tab-content" class="tab-panel active" role="tabpanel" aria-labelledby="btn-content">

                            <!-- Title + slug -->
                            <div class="border-b border-slate-100 px-5 py-5">
                                <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Basic Details</h5>
                                <div class="space-y-4">
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="title">
                                            Title <span class="text-red-500">*</span>
                                        </label>
                                        <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="title" name="title" type="text"
                                               placeholder="Enter article title" required
                                               data-tab-dirty="content">
                                    </div>
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Slug</label>
                                        <div class="flex rounded-md shadow-sm">
                                            <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/articles/</span>
                                            <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="handle" name="handle" type="text"
                                                   placeholder="auto-generated-from-title"
                                                   data-tab-dirty="content">
                                        </div>
                                        <p class="mt-1 text-xs text-slate-400">Leave blank to auto-generate from title.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="border-b border-slate-100 px-5 py-5">
                                <h5 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Body</h5>
