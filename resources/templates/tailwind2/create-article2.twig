{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Create Article' %}
{% set page_heading = 'Create Article' %}
{% set active_nav = 'articles' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="index.twig">Articles</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">New Article</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
            <!-- Desktop secondary nav card -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Articles</h5>
                    </div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg>
                            All Articles
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            New Article
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10M7 11h6m-9 8h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Categories
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                            Tags
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Authors
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Settings</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Edit Entry Group
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            Edit Entry Type
                        </a>
                    </nav>
                </div>
            </aside>
{% endblock %}

{% block content %}
            <!-- ── Form content ─────────────────────────────────────────── -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Page title + back link -->
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Article</h1>
                        <p class="mt-1 text-sm text-slate-500">Fill in the details below and save when ready.</p>
                    </div>
                    <a class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto" href="#">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                        Back to Articles
                    </a>
                </div>

                <!-- Two-column form -->
                <form id="article-form" method="POST" action="#"
                      class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

                    <!-- ── Left: tabbed content area ───────────────────── -->
                    <div class="flex flex-col gap-0 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm" data-tabs>

                        <!-- Tab bar -->
                        <div class="border-b border-slate-200 bg-slate-50">
                            <div class="flex overflow-x-auto" role="tablist" aria-label="Article sections">

                                <button type="button" role="tab" aria-selected="true"
                                        class="tab-btn active" data-tab-target="content"
                                        id="btn-content" aria-controls="tab-content">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    Content
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-tab-target="structure"
                                        id="btn-structure" aria-controls="tab-structure">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                                    Structure
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-tab-target="taxonomy"
                                        id="btn-taxonomy" aria-controls="tab-taxonomy">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                                    Taxonomy
                                    <span class="tab-badge" id="badge-taxonomy">0</span>
                                    <span class="unsaved-dot"></span>
                                </button>

                                <button type="button" role="tab" aria-selected="false"
                                        class="tab-btn" data-tab-target="seo"
                                        id="btn-seo" aria-controls="tab-seo">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                                    SEO
                                    <span class="unsaved-dot"></span>
                                </button>

                            </div>
                        </div><!-- /tab bar -->

                        <!-- ░░ TAB: Content ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
                        <div id="tab-content" class="tab-panel active" role="tabpanel" aria-labelledby="btn-content" data-tab-panel="content">

                            <!-- Title + slug -->
                            <div class="border-b border-slate-100 px-5 py-5">
                                <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Basic Details</h5>
                                <div class="space-y-4">
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="title">
                                            Title <span class="text-red-500">*</span>
                                        </label>
                                        <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="title" name="title" type="text"
                                               placeholder="Enter article title" required
                                               data-tab-dirty="content">
                                    </div>
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Slug</label>
                                        <div class="flex rounded-md shadow-sm">
                                            <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/articles/</span>
                                            <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="handle" name="handle" type="text"
                                                   placeholder="auto-generated-from-title"
                                                   data-tab-dirty="content">
                                        </div>
                                        <p class="mt-1 text-xs text-slate-400">Leave blank to auto-generate from title.</p>
                                    </div>
                                </div>
                            </div>

                            {% import 'templates::tailwind2._matrix-field' as matrix %}

                            {% set attributes = [
                                { key: 'Color', value: 'Blue', visible: true },
                                { key: 'Material', value: 'Cotton', visible: true },
                                { key: 'Care', value: 'Machine washable', visible: false }
                            ] %}
                            {% set add_attribute_button = {
                                label: add_attribute_button_label|default('Add attribute'),
                                attributes: {
                                    'data-tab-dirty': 'content'
                                }
                            } %}

                            <!-- Excerpt -->
                            <div class="px-5 py-5">
                                <h5 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Excerpt</h5>
                                {{ matrix.field('attributes', 'Attributes', [
                                    { handle: 'key', label: 'Key', placeholder: 'Color' },
                                    { handle: 'value', label: 'Value', type: 'textarea', placeholder: 'Blue' },
                                    { handle: 'visible', label: 'Visible', type: 'checkbox' }
                                ], attributes, 'Add curated rows as needed.', null, null, null, 1, add_attribute_button) }}

                                {{ matrix.scripts() }}
                            </div>

                        </div><!-- /tab-content -->

                        <!-- ░░ TAB: Structure ░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
                        <div id="tab-structure" class="tab-panel" role="tabpanel" aria-labelledby="btn-structure" data-tab-panel="structure" hidden>

                            <div class="divide-y divide-slate-100">

                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Hierarchy</h5>
                                    <div class="space-y-4">
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="parent_entry">Parent Entry</label>
                                            <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                    id="parent_entry" name="parent_entry" data-tab-dirty="structure">
                                                <option value="">— None (top-level) —</option>
                                                <option value="1">Getting Started</option>
                                                <option value="2">Product Updates</option>
                                                <option value="3">Engineering Blog</option>
                                                <option value="4">Company News</option>
                                            </select>
                                            <p class="mt-1 text-xs text-slate-400">Leave blank to place at the top level.</p>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="sort_order">Sort Order</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:max-w-[8rem]"
                                                   id="sort_order" name="sort_order" type="number" min="0" placeholder="0"
                                                   data-tab-dirty="structure">
                                            <p class="mt-1 text-xs text-slate-400">Lower numbers appear first in ordered lists.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Routing</h5>
                                    <div class="space-y-4">
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="entry_url">URL Override</label>
                                            <div class="flex rounded-md shadow-sm">
                                                <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">https://example.com/</span>
                                                <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                       id="entry_url" name="entry_url" type="text"
                                                       placeholder="articles/my-article"
                                                       data-tab-dirty="structure">
                                            </div>
                                            <p class="mt-1 text-xs text-slate-400">Leave blank to auto-build from slug and parent.</p>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="redirect_url">Redirect URL</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="redirect_url" name="redirect_url" type="url"
                                                   placeholder="https://example.com/new-location"
                                                   data-tab-dirty="structure">
                                            <p class="mt-1 text-xs text-slate-400">Optional. If set, visiting this entry's URL will redirect here.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Template</h5>
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="template">Template Path</label>
                                        <input class="w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm shadow-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="template" name="template" type="text"
                                               placeholder="e.g. articles/default"
                                               data-tab-dirty="structure">
                                        <p class="mt-1 text-xs text-slate-400">Template path relative to the views root. Leave blank to use the entry type's default.</p>
                                    </div>
                                </div>

                            </div>

                        </div><!-- /tab-structure -->

                        <!-- ░░ TAB: Taxonomy ░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
                        <div id="tab-taxonomy" class="tab-panel" role="tabpanel" aria-labelledby="btn-taxonomy" data-tab-panel="taxonomy" hidden>

                            <div class="divide-y divide-slate-100">

                                <!-- Authors -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Authors</h5>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="authors">Assign Authors</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="authors" name="authors[]" multiple size="5" data-tab-dirty="taxonomy">
                                        <option>Avery Stone</option>
                                        <option>Morgan Lee</option>
                                        <option>Riley Chen</option>
                                        <option>Jordan Kim</option>
                                        <option>Sam Patel</option>
                                    </select>
                                    <p class="mt-1 text-xs text-slate-400">Hold Ctrl / Cmd to select multiple authors.</p>
                                </div>

                                <!-- Categories -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Categories</h5>
                                    <div class="grid grid-cols-2 gap-x-6 gap-y-1 sm:grid-cols-3">
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="engineering"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Engineering
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="product"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Product
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="operations"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Operations
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="support"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Support
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="company"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Company
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="tutorial"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Tutorial
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="announcements"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Announcements
                                        </label>
                                        <label class="flex items-center gap-2.5 py-2 text-sm text-slate-700">
                                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                   name="categories[]" type="checkbox" value="security"
                                                   data-tab-dirty="taxonomy" data-badge="taxonomy"> Security
                                        </label>
                                    </div>
                                </div>

                                <!-- Tags -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Tags</h5>
                                    <input id="tag-search"
                                           class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           type="text" placeholder="Filter tags…" autocomplete="off">
                                    <div id="tag-cloud" class="mt-3 flex min-h-[2.5rem] flex-wrap gap-1.5"></div>
                                    <div id="tag-inputs"></div>
                                    <p class="mt-2 text-xs text-slate-400">Click a tag to select it. Selected tags are highlighted and submitted with the form.</p>
                                </div>

                            </div>

                        </div><!-- /tab-taxonomy -->

                        <!-- ░░ TAB: SEO ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
                        <div id="tab-seo" class="tab-panel" role="tabpanel" aria-labelledby="btn-seo" data-tab-panel="seo" hidden>

                            <div class="divide-y divide-slate-100">

                                <!-- Meta basics -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-400">Search Engine</h5>
                                    <div class="space-y-4">
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_title">Meta Title</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="meta_title" name="meta_title" type="text"
                                                   placeholder="Defaults to article title if blank"
                                                   maxlength="70"
                                                   data-tab-dirty="seo" data-charcount="70">
                                            <p class="mt-1 flex justify-between text-xs text-slate-400">
                                                <span>Recommended: 50–60 characters.</span>
                                                <span id="meta-title-count" class="tabular-nums">0 / 70</span>
                                            </p>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_description">Meta Description</label>
                                            <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                      id="meta_description" name="meta_description" rows="3"
                                                      placeholder="A concise summary for search engines…"
                                                      maxlength="160"
                                                      data-tab-dirty="seo" data-charcount="160"></textarea>
                                            <p class="mt-1 flex justify-between text-xs text-slate-400">
                                                <span>Recommended: 120–158 characters.</span>
                                                <span id="meta-desc-count" class="tabular-nums">0 / 160</span>
                                            </p>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="canonical_url">Canonical URL</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="canonical_url" name="canonical_url" type="url"
                                                   placeholder="https://example.com/original-article"
                                                   data-tab-dirty="seo">
                                            <p class="mt-1 text-xs text-slate-400">Use if this content is a copy of or heavily derived from another URL.</p>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700">Robots</label>
                                            <div class="flex flex-wrap gap-4">
                                                <label class="flex items-center gap-2 text-sm text-slate-700">
                                                    <input type="checkbox" name="robots_index" checked
                                                           class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                           data-tab-dirty="seo"> Allow indexing
                                                </label>
                                                <label class="flex items-center gap-2 text-sm text-slate-700">
                                                    <input type="checkbox" name="robots_follow" checked
                                                           class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                                           data-tab-dirty="seo"> Follow links
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Open Graph -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-1 text-xs font-semibold uppercase tracking-wider text-slate-400">Open Graph / Social</h5>
                                    <p class="mb-4 text-xs text-slate-400">Controls how this article appears when shared on social networks.</p>
                                    <div class="space-y-4">
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="og_title">OG Title</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="og_title" name="og_title" type="text"
                                                   placeholder="Defaults to meta title"
                                                   data-tab-dirty="seo">
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="og_description">OG Description</label>
                                            <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                      id="og_description" name="og_description" rows="2"
                                                      placeholder="Defaults to meta description"
                                                      data-tab-dirty="seo"></textarea>
                                        </div>
                                        <div>
                                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="og_image">OG Image URL</label>
                                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                                   id="og_image" name="og_image" type="url"
                                                   placeholder="https://example.com/images/share.jpg"
                                                   data-tab-dirty="seo">
                                            <p class="mt-1 text-xs text-slate-400">Recommended size: 1200 × 630 px.</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- SERP preview -->
                                <div class="px-5 py-5">
                                    <h5 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">SERP Preview</h5>
                                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                                        <p id="serp-title" class="truncate text-base font-medium text-blue-700">Your article title will appear here</p>
                                        <p id="serp-url" class="mt-0.5 truncate text-xs text-green-700">https://example.com/articles/your-slug</p>
                                        <p id="serp-desc" class="mt-1 text-sm text-slate-500 line-clamp-2">Your meta description will appear here. Make it descriptive and inviting — this is what users see in search results.</p>
                                    </div>
                                </div>

                            </div>

                        </div><!-- /tab-seo -->

                        <!-- Tab footer: prev/next navigation -->
                        <div class="flex items-center justify-between border-t border-slate-100 bg-slate-50 px-5 py-3">
                            <button type="button" id="tab-prev"
                                    data-tab-prev
                                    class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 shadow-sm hover:bg-slate-50 disabled:pointer-events-none disabled:opacity-40">
                                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                                Previous
                            </button>
                            <span id="tab-position" data-tab-position class="text-xs text-slate-400">1 / 4</span>
                            <button type="button" id="tab-next"
                                    data-tab-next
                                    class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 shadow-sm hover:bg-slate-50 disabled:pointer-events-none disabled:opacity-40">
                                Next
                                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                            </button>
                        </div>

                    </div><!-- /tabbed card -->

                    <!-- ── Right: persistent publishing panel ──────────── -->
                    <div class="flex flex-col gap-4">

                        <!-- Publish settings -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Publishing</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="status" name="status">
                                        <option value="draft" selected>Draft</option>
                                        <option value="published">Published</option>
                                        <option value="scheduled">Scheduled</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="published_at">Publish Date</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="published_at" name="published_at" type="datetime-local">
                                    <p class="mt-1 text-xs text-slate-400">Leave blank to save as draft.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="entry_type">Entry Type</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="entry_type" name="entry_type">
                                        <option>Standard Article</option>
                                        <option>Feature Story</option>
                                        <option>Press Release</option>
                                        <option>Opinion Piece</option>
                                    </select>
                                </div>
                            </div>
                            <div class="space-y-2 border-t border-slate-100 px-5 py-4">
                                <button class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
                                        type="submit">
                                    Save Article
                                </button>
                                <button type="button"
                                        class="w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-600 shadow-sm hover:bg-slate-50">
                                    Save as Draft
                                </button>
                            </div>
                        </div>

                        <!-- Unsaved changes notice (hidden by default) -->
                        <div id="unsaved-notice"
                             class="hidden rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                            <div class="flex items-start gap-2.5">
                                <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                                <p class="text-xs text-amber-800">You have unsaved changes. Remember to save before leaving.</p>
                            </div>
                        </div>

                        <!-- Featured image -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Featured Image</h5>
                            </div>
                            <div class="px-5 py-4">
                                <label class="block cursor-pointer rounded-lg border-2 border-dashed border-slate-300 p-6 text-center hover:border-emerald-400 hover:bg-emerald-50/40 transition-colors" for="featured_image">
                                    <svg class="mx-auto h-8 w-8 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    <p class="mt-2 text-xs font-medium text-slate-500">Click to upload</p>
                                    <p class="mt-0.5 text-xs text-slate-400">PNG, JPG, WebP up to 10 MB</p>
                                    <input id="featured_image" name="featured_image" type="file" accept="image/*" class="sr-only">
                                </label>
                            </div>
                        </div>

                    </div>
                    <!-- /right -->

                </form>

            </div>
            <!-- /form content -->
{% endblock %}
