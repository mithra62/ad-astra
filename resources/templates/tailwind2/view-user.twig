{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'View User' %}
{% set page_heading = 'View User' %}
{% set active_nav = 'users' %}
{% set active_user_section = 'index' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-slate-800" href="users.twig">Users</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-800">Jane Smith</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    {{ include('templates::tailwind2._user_sidebar') }}
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-center gap-4">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-lg font-semibold text-white">JS</div>
            <div><h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Jane Smith</h1><p class="mt-1 text-sm text-slate-500">jane@example.com</p><div class="mt-2 flex flex-wrap gap-1.5"><span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Active</span><span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Administrator</span><span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Editor</span></div></div>
        </div>
        <div class="flex flex-wrap items-center gap-2 self-start"><a href="edit-user.twig" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">Edit User</a><a href="delete-user.twig" class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-red-100">Delete</a></div>
    </div>
    <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"><div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Profile</h5></div><dl class="divide-y divide-slate-100 px-5 py-2 text-sm"><div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]"><dt class="text-slate-500">Name</dt><dd class="font-medium text-slate-900">Jane Smith</dd></div><div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]"><dt class="text-slate-500">Email</dt><dd class="text-slate-700">jane@example.com</dd></div><div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]"><dt class="text-slate-500">Bio</dt><dd class="text-slate-700">Senior editor with a focus on technology and culture.</dd></div><div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]"><dt class="text-slate-500">Timezone</dt><dd class="text-slate-700">America/New_York</dd></div></dl></div>
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"><div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Recent Activity</h5></div><div class="divide-y divide-slate-100"><div class="px-5 py-3 text-sm"><p class="font-medium text-slate-800">Published "Quarterly Product Notes"</p><p class="text-xs text-slate-400">2 hours ago</p></div><div class="px-5 py-3 text-sm"><p class="font-medium text-slate-800">Updated media library permissions</p><p class="text-xs text-slate-400">Yesterday</p></div><div class="px-5 py-3 text-sm"><p class="font-medium text-slate-800">Approved 4 comments</p><p class="text-xs text-slate-400">Apr 26, 2026</p></div></div></div>
        </div>
        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"><div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Metadata</h5></div><dl class="divide-y divide-slate-100 px-5 py-2 text-xs"><div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">ID</dt><dd class="font-medium text-slate-700">42</dd></div><div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Created</dt><dd class="text-slate-700">Jan 12, 2023</dd></div><div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Last login</dt><dd class="text-slate-700">2 hours ago</dd></div><div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">2FA</dt><dd class="text-emerald-700">Enabled</dd></div></dl></div>
        </div>
    </div>
{% endblock %}
