{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Create General Item' %}
{% set page_heading = 'Create General Item' %}
{% set active_nav = 'content' %}
{% set has_secondary_sidebar = false %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="general-index-no-sidebar.twig">General Items</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Create</span>
    </nav>
{% endblock %}

{% block content %}
    <div id="unsaved-bar" class="unsaved-bar items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-2">
        <span class="flex items-center gap-2 text-sm text-amber-800">
            <svg class="h-4 w-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            You have unsaved changes.
        </span>
        <button type="submit" form="general-create-form" class="rounded-md bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700">Save Now</button>
    </div>

    <div class="flex w-full min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create General Item</h1>
                <p class="mt-1 text-sm text-slate-500">Create a reusable status, field, label, or option for content workflows.</p>
            </div>
            <a href="general-index-no-sidebar.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Items
            </a>
        </div>

        <div class="rounded-lg border border-sky-200 bg-sky-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-sky-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-sky-800">Create a new reusable item.</p>
                    <p class="mt-1 text-sm text-sky-700">Handles should be stable once this item is used by content or templates.</p>
                </div>
            </div>
        </div>

        <form id="general-create-form" method="POST" action="#" class="flex w-full min-w-0 flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Item Details</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                        <input class="w-full rounded-md border border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20" id="name" name="name" type="text" value="" placeholder="e.g. Published" required aria-invalid="true" aria-describedby="name-error">
                        <p id="name-error" class="mt-1 text-xs text-red-600">Name is required.</p>
                        <p class="mt-1 text-xs text-slate-400">Use a short, human-readable label.</p>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Handle <span class="text-red-500">*</span></label>
                        <div class="flex rounded-md shadow-sm">
                            <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">general/</span>
                            <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 font-mono text-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="handle" name="handle" type="text" value="" placeholder="published" required>
                        </div>
                        <p class="mt-1 text-xs text-slate-400">Lowercase letters, numbers, and hyphens only.</p>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="type">Type</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="type" name="type">
                                <option value="status" selected>Status</option>
                                <option value="field">Field</option>
                                <option value="option">Option</option>
                                <option value="label">Label</option>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="status" name="status">
                                <option value="active" selected>Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="value">Value</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm shadow-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="value" name="value" type="text" value="" placeholder="published">
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="sort_order">Sort Order</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="sort_order" name="sort_order" type="number" min="0" value="10">
                        </div>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="description">Description</label>
                        <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="description" name="description" rows="4" placeholder="Optional internal description..."></textarea>
                    </div>
                </div>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3">
                    <h5 class="text-sm font-semibold text-slate-700">Display</h5>
                </div>
                <div class="space-y-5 px-5 py-5">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Color</label>
                        <div class="flex flex-wrap gap-2">
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="slate">
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-slate-500"></span>Slate
                                </span>
                            </label>
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="red">
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-red-500"></span>Red
                                </span>
                            </label>
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="amber">
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-amber-500"></span>Amber
                                </span>
                            </label>
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="emerald" checked>
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-emerald-500"></span>Emerald
                                </span>
                            </label>
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="sky">
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-sky-500"></span>Sky
                                </span>
                            </label>
                            <label class="cursor-pointer">
                                <input class="peer sr-only" type="radio" name="color" value="violet">
                                <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm capitalize text-slate-700 shadow-sm peer-checked:border-emerald-500 peer-checked:ring-2 peer-checked:ring-emerald-500/20">
                                    <span class="h-3 w-3 rounded-full bg-violet-500"></span>Violet
                                </span>
                            </label>
                        </div>
                    </div>

                    <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                        <input type="checkbox" name="is_default" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                        Use as default item for this type
                    </label>
                    <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                        <input type="checkbox" name="is_locked" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                        Lock item from accidental deletion
                    </label>
                </div>
            </div>

            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-end">
                <a href="general-index-no-sidebar.twig" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Create Item</button>
            </div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.attachHandleGenerator) {
                window.attachHandleGenerator('name', 'handle');
            }
        });
    </script>
{% endblock %}
