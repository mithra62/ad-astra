<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Media Library</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <div class="nav-group">
                <input id="nav-content" type="checkbox">
                <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Content</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-media" type="checkbox" checked>
                <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700">
                    <span>Media</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 text-emerald-700" href="#">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Upload</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-users" type="checkbox">
                <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <div class="flex min-w-0 flex-col">

        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Media Library</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Media</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Library</span>
                    </nav>
                </div>
            </div>
        </div>

        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>

        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    Library
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                    Upload
                </a>
            </nav>
        </div>

        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Media</h5>
                    </div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Library
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                            Upload
                        </a>
                    </nav>
                </div>
            </aside>

            <div class="flex min-w-0 flex-col gap-5">

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Media Library</h1>
                        <p class="mt-1 text-sm text-slate-500">Browse, manage, and organise uploaded files.</p>
                    </div>
                    <a class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" href="#">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        Upload Files
                    </a>
                </div>

                <!-- Stats -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Overview</h5></div>
                    <div class="grid grid-cols-2 divide-x divide-y divide-slate-200 sm:grid-cols-4 sm:divide-y-0">
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total Files</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">342</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Images</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">284</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Documents</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">41</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Video</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">17</p></div>
                    </div>
                </div>

                <!-- Library card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                            <h5 class="text-sm font-semibold text-slate-700">All Files</h5>
                            <div class="flex flex-wrap items-center gap-2">
                                <select class="rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                                    <option>All types</option>
                                    <option>Images</option>
                                    <option>Documents</option>
                                    <option>Video</option>
                                    <option>Audio</option>
                                </select>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-44" placeholder="Search files…" type="search">
                                <div class="flex rounded-md border border-slate-300 bg-white shadow-sm">
                                    <button type="button" class="rounded-l-md px-2.5 py-1.5 text-slate-600 hover:bg-slate-50" title="Grid view">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                                    </button>
                                    <button type="button" class="rounded-r-md border-l border-slate-300 px-2.5 py-1.5 text-slate-600 hover:bg-slate-50" title="List view">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Media grid -->
                    <div class="p-5">
                        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5">

                            {% set items = [
                                {name: 'hero-banner.jpg',   size: '842 KB', type: 'image',    bg: 'bg-sky-100',    icon_color: 'text-sky-400'},
                                {name: 'product-shot.png',  size: '1.2 MB', type: 'image',    bg: 'bg-violet-100', icon_color: 'text-violet-400'},
                                {name: 'team-photo.jpg',    size: '3.1 MB', type: 'image',    bg: 'bg-pink-100',   icon_color: 'text-pink-400'},
                                {name: 'logo-dark.svg',     size: '14 KB',  type: 'image',    bg: 'bg-slate-100',  icon_color: 'text-slate-400'},
                                {name: 'press-kit.pdf',     size: '5.4 MB', type: 'document', bg: 'bg-red-100',    icon_color: 'text-red-400'},
                                {name: 'roadmap-q2.pdf',    size: '2.2 MB', type: 'document', bg: 'bg-amber-100',  icon_color: 'text-amber-400'},
                                {name: 'demo-reel.mp4',     size: '48 MB',  type: 'video',    bg: 'bg-emerald-100',icon_color: 'text-emerald-400'},
                                {name: 'brand-guide.pdf',   size: '8.7 MB', type: 'document', bg: 'bg-orange-100', icon_color: 'text-orange-400'},
                                {name: 'thumbnail-01.jpg',  size: '198 KB', type: 'image',    bg: 'bg-teal-100',   icon_color: 'text-teal-400'},
                                {name: 'thumbnail-02.jpg',  size: '214 KB', type: 'image',    bg: 'bg-indigo-100', icon_color: 'text-indigo-400'},
                            ] %}

                            {% for item in items %}
                            <div class="group relative overflow-hidden rounded-lg border border-slate-200 bg-slate-50 hover:border-emerald-300 hover:shadow-sm transition-all">
                                <div class="flex aspect-square items-center justify-center {{ item.bg }}">
                                    {% if item.type == 'image' %}
                                    <svg class="h-10 w-10 {{ item.icon_color }}" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    {% elseif item.type == 'video' %}
                                    <svg class="h-10 w-10 {{ item.icon_color }}" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/></svg>
                                    {% else %}
                                    <svg class="h-10 w-10 {{ item.icon_color }}" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    {% endif %}
                                </div>
                                <div class="px-2.5 py-2">
                                    <p class="truncate text-xs font-medium text-slate-800">{{ item.name }}</p>
                                    <p class="text-xs text-slate-400">{{ item.size }}</p>
                                </div>
                                <div class="absolute right-1.5 top-1.5 hidden gap-1 group-hover:flex">
                                    <a href="#" class="inline-flex items-center justify-center rounded-md bg-white/90 p-1 shadow-sm hover:bg-white" title="View">
                                        <svg class="h-3.5 w-3.5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    <a href="#" class="inline-flex items-center justify-center rounded-md bg-red-600/90 p-1 shadow-sm hover:bg-red-600" title="Delete">
                                        <svg class="h-3.5 w-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </a>
                                </div>
                            </div>
                            {% endfor %}

                        </div>
                    </div>

                    <div class="flex flex-col gap-3 border-t border-slate-200 px-5 py-3 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-xs text-slate-500">Showing 1–10 of 342 files</p>
                        <nav class="flex items-center gap-1" aria-label="Pagination">
                            <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-2 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-50" href="#" aria-label="Previous page"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></a>
                            <a class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-emerald-600 text-sm font-semibold text-white shadow-sm" href="#" aria-current="page">1</a>
                            <a class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50" href="#">2</a>
                            <a class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50" href="#">3</a>
                            <span class="inline-flex h-8 w-8 items-center justify-center text-sm text-slate-400">…</span>
                            <a class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50" href="#">35</a>
                            <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-2 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" href="#" aria-label="Next page"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
                        </nav>
                    </div>
                </div>

            </div>
        </div>

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p>
                <nav class="flex items-center gap-4 text-xs text-slate-400">
                    <a class="hover:text-slate-600" href="#">Documentation</a>
                    <a class="hover:text-slate-600" href="#">Support</a>
                    <a class="hover:text-slate-600" href="#">Privacy</a>
                    <span class="text-slate-300">|</span>
                    <span>v1.0.0</span>
                </nav>
            </div>
        </footer>

    </div>
</div>

</body>
</html>
