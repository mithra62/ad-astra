<!DOCTYPE html>
<html lang="{{ app().getLocale()|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Edit Article</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">
<div class="min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">
    <aside class="border-r border-slate-200 bg-white px-5 py-6">
        <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
        <nav class="mt-8 space-y-1 text-sm font-medium">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <a class="block rounded-md bg-emerald-50 px-3 py-2 text-emerald-700" href="#">Articles</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Media</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <main class="px-4 py-6 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
            <div class="flex flex-col gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <nav class="flex gap-2 text-sm text-slate-500">
                        <a class="hover:text-slate-900" href="#">Dashboard</a>
                        <span>/</span>
                        <a class="hover:text-slate-900" href="#">Articles</a>
                        <span>/</span>
                        <span class="text-slate-900">Edit</span>
                    </nav>
                    <h1 class="mt-3 text-3xl font-semibold tracking-tight">Edit Article</h1>
                    <p class="mt-2 text-sm text-slate-500">Last updated {{ article.updated_at.format('F j, Y g:i A') }}</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="#">View</a>
                    <a class="inline-flex items-center justify-center rounded-md border border-red-200 bg-white px-4 py-2 text-sm font-semibold text-red-700 shadow-sm hover:bg-red-50" href="#">Remove</a>
                </div>
            </div>

            <form class="mt-8 grid gap-8 lg:grid-cols-[1fr_20rem]" method="POST" action="#">
                {{ csrf_field() }}
                {{ method_field('PUT') }}

                <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="grid gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700" for="title">Title</label>
                            <input class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="title" name="title" required type="text" value="{{ old('title', article.title) }}">
                            {% if errors.has('title') %}
                                <p class="mt-2 text-sm text-red-600">{{ errors.first('title') }}</p>
                            {% endif %}
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700" for="slug">Slug</label>
                            <input class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="slug" name="slug" type="text" value="{{ old('slug', article.slug) }}">
                            {% if errors.has('slug') %}
                                <p class="mt-2 text-sm text-red-600">{{ errors.first('slug') }}</p>
                            {% endif %}
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700" for="excerpt">Excerpt</label>
                            <textarea class="mt-2 block min-h-24 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="excerpt" name="excerpt">{{ old('excerpt', article.excerpt) }}</textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700" for="body">Body</label>
                            <textarea class="mt-2 block min-h-80 w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="body" name="body" required>{{ old('body', article.body) }}</textarea>
                            {% if errors.has('body') %}
                                <p class="mt-2 text-sm text-red-600">{{ errors.first('body') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </section>

                <aside class="space-y-6">
                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <h2 class="text-base font-semibold">Publishing</h2>
                        <div class="mt-5 grid gap-5">
                            <div>
                                <label class="block text-sm font-medium text-slate-700" for="status">Status</label>
                                <select class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="status" name="status">
                                    <option value="draft" {{ old('status', article.status) == 'draft' ? 'selected' : '' }}>Draft</option>
                                    <option value="review" {{ old('status', article.status) == 'review' ? 'selected' : '' }}>In Review</option>
                                    <option value="published" {{ old('status', article.status) == 'published' ? 'selected' : '' }}>Published</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700" for="published_at">Publish Date</label>
                                <input class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="published_at" name="published_at" type="datetime-local" value="{{ old('published_at', article.published_at ? article.published_at.format('Y-m-d\\TH:i') : '') }}">
                            </div>
                            <label class="flex items-center gap-3 text-sm font-medium text-slate-700">
                                <input class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="featured" type="checkbox" value="1" {{ old('featured', article.featured) ? 'checked' : '' }}>
                                Featured article
                            </label>
                        </div>
                    </section>

                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <h2 class="text-base font-semibold">Classification</h2>
                        <div class="mt-5 grid gap-5">
                            <div>
                                <label class="block text-sm font-medium text-slate-700" for="category_id">Category</label>
                                <select class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="category_id" name="category_id">
                                    {% for category in categories %}
                                        <option value="{{ category.id }}" {{ old('category_id', article.category_id) == category.id ? 'selected' : '' }}>{{ category.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700" for="author_id">Author</label>
                                <select class="mt-2 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="author_id" name="author_id">
                                    {% for author in authors %}
                                        <option value="{{ author.id }}" {{ old('author_id', article.author_id) == author.id ? 'selected' : '' }}>{{ author.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </section>

                    <div class="flex justify-end gap-3">
                        <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="#">Cancel</a>
                        <button class="inline-flex items-center justify-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" type="submit">Save Changes</button>
                    </div>
                </aside>
            </form>
        </div>
    </main>
</div>
</body>
</html>
