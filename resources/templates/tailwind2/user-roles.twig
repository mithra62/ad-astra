                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Create Role</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Users</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Roles</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Create Role</span>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Mobile secnav toggle -->
        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>

        <!-- Mobile secnav panel -->
        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    All Users
                </a>
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    Roles
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Invitations
                </a>
            </nav>
        </div>

        <!-- Body: secnav card + content -->
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <!-- Secondary nav card (desktop) -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Users</h5></div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            All Users
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            Roles
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            Invitations
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Content area -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Role name + description card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-6 py-4">
                        <h3 class="text-sm font-semibold text-slate-800">Role Details</h3>
                        <p class="mt-0.5 text-xs text-slate-500">Give this role a clear name and description so administrators know when to assign it.</p>
                    </div>
                    <div class="divide-y divide-slate-100">
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="role_name">Role Name <span class="text-red-500">*</span></label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 sm:max-w-md" id="role_name" name="role_name" type="text" placeholder="e.g. Editor, Contributor, Moderator">
                            <p class="mt-1 text-xs text-slate-500">Used as the display name throughout the admin. Must be unique.</p>
                        </div>
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="role_slug">Slug <span class="text-red-500">*</span></label>
                            <div class="flex max-w-md items-center rounded-md border border-slate-300 bg-slate-50 shadow-sm focus-within:border-emerald-500 focus-within:ring-1 focus-within:ring-emerald-500">
                                <span class="border-r border-slate-300 px-3 py-2 text-sm text-slate-500">role/</span>
                                <input class="flex-1 rounded-r-md bg-transparent px-3 py-2 text-sm focus:outline-none" id="role_slug" name="role_slug" type="text" placeholder="editor">
                            </div>
                            <p class="mt-1 text-xs text-slate-500">Lowercase letters, numbers, and hyphens only. Auto-generated from name.</p>
                        </div>
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="role_description">Description</label>
                            <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="role_description" name="role_description" rows="2" placeholder="Describe what this role can do and when it should be assigned…"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Permissions matrix card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-6 py-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-800">Permissions</h3>
                                <p class="mt-0.5 text-xs text-slate-500">Select the capabilities this role grants. Use the row checkboxes to toggle all actions for a resource.</p>
                            </div>
                            <button type="button" id="select-all-btn" onclick="toggleAllPermissions(this)" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Select All</button>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="perm-header border-b border-slate-200">
                                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">Resource</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">View</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">Create</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">Edit</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">Delete</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">Publish</th>
                                    <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-slate-600">All</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <!-- Articles -->
                                <tr class="perm-row">
                                    <td class="px-6 py-3 font-medium text-slate-800">
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                            Articles
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[articles][view]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[articles][create]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[articles][edit]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[articles][delete]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[articles][publish]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" data-row="articles" onchange="toggleRow(this,'articles')" class="h-4 w-4 rounded border-slate-300 text-slate-500 focus:ring-slate-400" title="Toggle all for Articles"></td>
                                </tr>
                                <!-- Pages -->
                                <tr class="perm-row">
                                    <td class="px-6 py-3 font-medium text-slate-800">
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                                            Pages
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[pages][view]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[pages][create]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[pages][edit]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[pages][delete]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[pages][publish]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" data-row="pages" onchange="toggleRow(this,'pages')" class="h-4 w-4 rounded border-slate-300 text-slate-500 focus:ring-slate-400" title="Toggle all for Pages"></td>
                                </tr>
                                <!-- Categories -->
                                <tr class="perm-row">
                                    <td class="px-6 py-3 font-medium text-slate-800">
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                                            Categories
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[categories][view]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[categories][create]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[categories][edit]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[categories][delete]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><span class="text-slate-300">—</span></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" data-row="categories" onchange="toggleRow(this,'categories')" class="h-4 w-4 rounded border-slate-300 text-slate-500 focus:ring-slate-400" title="Toggle all for Categories"></td>
                                </tr>
                                <!-- Tags -->
                                <tr class="perm-row">
                                    <td class="px-6 py-3 font-medium text-slate-800">
                                        <div class="flex items-center gap-2">
                                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                                            Tags
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[tags][view]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[tags][create]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[tags][edit]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" name="perm[tags][delete]" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3 text-center"><span class="text-slate-300">—</span></td>
                                    <td class="px-4 py-3 text-center"><input type="checkbox" data-row="tags" onchange="toggleRow(this,'tags')" class="h-4 w-4 rounded border-slate-300 text-slate-500 focus:ring-slate-400" title="Toggle all for Tags"></td>
                                </tr>
                                <!-- Media -->
                                <tr class="perm-row">
