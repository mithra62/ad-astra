                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Email</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Security</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Advanced</a>
            </nav>
        </div>

        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Settings</h5></div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            General
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                            SEO
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            Email
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            Security
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
                            Advanced
                        </a>
                    </nav>
                </div>
            </aside>

            <div class="flex min-w-0 flex-col gap-5">

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">General Settings</h1>
                        <p class="mt-1 text-sm text-slate-500">Configure core site identity, locale, and behaviour.</p>
                    </div>
                </div>

                <form method="POST" action="#" class="flex flex-col gap-5">

                    <!-- Site identity -->
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Site Identity</h5></div>
                        <div class="space-y-4 px-5 py-5">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="site-name">Site Name <span class="text-red-500">*</span></label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       id="site-name" type="text" value="Acme Corp Admin">
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="site-tagline">Tagline</label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       id="site-tagline" type="text" value="Just another great website">
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="site-url">Site URL <span class="text-red-500">*</span></label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       id="site-url" type="url" value="https://example.com">
                            </div>
                            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="timezone">Timezone</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="timezone">
                                        <option>UTC</option>
                                        <option selected>America/New_York</option>
                                        <option>America/Chicago</option>
                                        <option>America/Los_Angeles</option>
                                        <option>Europe/London</option>
                                        <option>Europe/Paris</option>
                                        <option>Asia/Tokyo</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="locale">Locale</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="locale">
                                        <option selected>en_US</option>
                                        <option>en_GB</option>
                                        <option>fr_FR</option>
                                        <option>de_DE</option>
                                        <option>ja_JP</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Content defaults -->
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Content Defaults</h5></div>
                        <div class="space-y-4 px-5 py-5">
                            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="posts-per-page">Items Per Page</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="posts-per-page" type="number" min="1" max="100" value="10">
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="date-format">Date Format</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="date-format">
                                        <option selected>M d, Y</option>
                                        <option>Y-m-d</option>
                                        <option>d/m/Y</option>
                                        <option>m/d/Y</option>
                                    </select>
                                </div>
                            </div>
                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                                <input type="checkbox" checked class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                Allow comments by default
                            </label>
                            <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                                <input type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                Moderate comments before publishing
                            </label>
                        </div>
                    </div>

                    <!-- Maintenance mode -->
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Maintenance Mode</h5></div>
                        <div class="space-y-4 px-5 py-5">
                            <div class="flex items-center justify-between rounded-lg bg-slate-50 px-4 py-3.5 ring-1 ring-slate-200">
                                <div>
                                    <p class="text-sm font-medium text-slate-800">Site Maintenance Mode</p>
                                    <p class="mt-0.5 text-xs text-slate-500">When enabled, visitors see the maintenance page instead of your content.</p>
                                </div>
                                <label class="relative inline-flex cursor-pointer items-center">
                                    <input type="checkbox" class="peer sr-only">
                                    <div class="peer h-6 w-11 rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow after:transition-all after:content-[''] peer-checked:bg-emerald-500 peer-checked:after:translate-x-5 peer-focus:ring-2 peer-focus:ring-emerald-500/30"></div>
                                </label>
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="maintenance-msg">Maintenance Message</label>
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="maintenance-msg" rows="3">We're performing scheduled maintenance. We'll be back shortly.</textarea>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3">
                        <button type="reset" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Reset</button>
                        <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Save Settings</button>
                    </div>

                </form>
            </div>
        </div>

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p>
                <nav class="flex items-center gap-4 text-xs text-slate-400">
                    <a class="hover:text-slate-600" href="#">Documentation</a>
                    <a class="hover:text-slate-600" href="#">Support</a>
                    <a class="hover:text-slate-600" href="#">Privacy</a>
                    <span class="text-slate-300">|</span>
                    <span>v1.0.0</span>
                </nav>
            </div>
        </footer>

    </div>
</div>

