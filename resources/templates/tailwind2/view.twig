<!DOCTYPE html>
<html lang="{{ app().getLocale()|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>View Article</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">
<div class="min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">
    <aside class="border-r border-slate-200 bg-white px-5 py-6">
        <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
        <nav class="mt-8 space-y-1 text-sm font-medium">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <a class="block rounded-md bg-emerald-50 px-3 py-2 text-emerald-700" href="#">Articles</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Media</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <main class="px-4 py-6 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
            <div class="flex flex-col gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <nav class="flex gap-2 text-sm text-slate-500">
                        <a class="hover:text-slate-900" href="#">Dashboard</a>
                        <span>/</span>
                        <a class="hover:text-slate-900" href="#">Articles</a>
                        <span>/</span>
                        <span class="text-slate-900">View</span>
                    </nav>
                    <h1 class="mt-3 text-3xl font-semibold tracking-tight">{{ article.title }}</h1>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="#">Edit</a>
                    <a class="inline-flex items-center justify-center rounded-md border border-red-200 bg-white px-4 py-2 text-sm font-semibold text-red-700 shadow-sm hover:bg-red-50" href="#">Remove</a>
                </div>
            </div>

            <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_20rem]">
                <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-wrap items-center gap-3 text-sm">
                        <span class="rounded-full bg-emerald-100 px-3 py-1 font-medium text-emerald-800">{{ article.status|title }}</span>
                        {% if article.featured %}
                            <span class="rounded-full bg-amber-100 px-3 py-1 font-medium text-amber-800">Featured</span>
                        {% endif %}
                        <span class="text-slate-500">{{ article.published_at ? article.published_at.format('F j, Y') : 'Not published' }}</span>
                    </div>

                    {% if article.excerpt %}
                        <p class="mt-6 text-lg leading-8 text-slate-700">{{ article.excerpt }}</p>
                    {% endif %}

                    <div class="prose prose-slate mt-8 max-w-none">
                        {{ article.body|raw }}
                    </div>
                </article>

                <aside class="space-y-6">
                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <h2 class="text-base font-semibold">Article Details</h2>
                        <dl class="mt-5 grid gap-4 text-sm">
                            <div>
                                <dt class="font-medium text-slate-500">Slug</dt>
                                <dd class="mt-1 text-slate-900">{{ article.slug }}</dd>
                            </div>
                            <div>
                                <dt class="font-medium text-slate-500">Author</dt>
                                <dd class="mt-1 text-slate-900">{{ article.author.name }}</dd>
                            </div>
                            <div>
                                <dt class="font-medium text-slate-500">Category</dt>
                                <dd class="mt-1 text-slate-900">{{ article.category.name }}</dd>
                            </div>
                            <div>
                                <dt class="font-medium text-slate-500">Created</dt>
                                <dd class="mt-1 text-slate-900">{{ article.created_at.format('F j, Y g:i A') }}</dd>
                            </div>
                            <div>
                                <dt class="font-medium text-slate-500">Updated</dt>
                                <dd class="mt-1 text-slate-900">{{ article.updated_at.format('F j, Y g:i A') }}</dd>
                            </div>
                        </dl>
                    </section>

                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <h2 class="text-base font-semibold">Workflow</h2>
                        <ol class="mt-5 space-y-4 text-sm">
                            <li class="flex gap-3">
                                <span class="mt-0.5 h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                                <span><span class="font-medium">Created</span><span class="block text-slate-500">{{ article.created_at.format('F j, Y') }}</span></span>
                            </li>
                            <li class="flex gap-3">
                                <span class="mt-0.5 h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                                <span><span class="font-medium">Last saved</span><span class="block text-slate-500">{{ article.updated_at.format('F j, Y') }}</span></span>
                            </li>
                            <li class="flex gap-3">
                                <span class="mt-0.5 h-2.5 w-2.5 rounded-full {{ article.published_at ? 'bg-emerald-500' : 'bg-slate-300' }}"></span>
                                <span><span class="font-medium">Published</span><span class="block text-slate-500">{{ article.published_at ? article.published_at.format('F j, Y') : 'Pending' }}</span></span>
                            </li>
                        </ol>
                    </section>
                </aside>
            </div>
        </div>
    </main>
</div>
</body>
</html>
