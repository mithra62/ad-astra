{% extends 'admin._inc._layout' %}

{% set page_title = 'View Role' %}
{% set page_heading = 'View Role' %}
{% set active_nav = 'members' %}
{% set active_user_section = 'roles' %}
{% set has_secondary_sidebar = true %}

{% set role = {
    id: 2,
    name: 'admin',
    label: 'Admin',
    guard: 'web',
    description: 'Receives every seeded permission directly and can manage the full administration panel.',
    highlight: '#059669',
    users: 6,
    permissions: 43,
    created: 'Jan 14, 2026',
    updated: 'May 6, 2026',
    updated_by: 'Avery Stone'
} %}

{% set permission_groups = [
    {name: 'Platform', assigned: 2, total: 2, permissions: ['api', 'access admin']},
    {name: 'Users', assigned: 5, total: 5, permissions: ['view user', 'create user', 'edit user', 'delete user', 'manage user status']},
    {name: 'User Tokens', assigned: 4, total: 4, permissions: ['view user token', 'create user token', 'edit user token', 'delete user token']},
    {name: 'Roles', assigned: 3, total: 3, permissions: ['create role', 'edit role', 'delete role']},
    {name: 'Content', assigned: 17, total: 17, permissions: ['create entry group', 'edit entry group', 'delete entry group', 'create entry type', 'edit entry type', 'delete entry type', 'create entry', 'edit entry', 'delete entry', 'create category group', 'edit category group', 'delete category group', 'reorder category group', 'create category', 'edit category', 'delete category', 'reorder category']},
    {name: 'Fields', assigned: 9, total: 9, permissions: ['create field group', 'edit field group', 'delete field group', 'create field', 'edit field', 'delete field', 'create field layout', 'edit field layout', 'delete field layout']},
    {name: 'Media', assigned: 4, total: 4, permissions: ['create media library', 'edit media library', 'delete media library', 'reorder media library']},
    {name: 'Statuses', assigned: 3, total: 3, permissions: ['create status', 'edit status', 'delete status']},
    {name: 'Settings', assigned: 1, total: 1, permissions: ['edit setting']}
] %}

{% set assigned_users = [
    {name: 'Avery Stone', email: 'avery@example.com', status: 'Active', last_seen: 'Today'},
    {name: 'Jane Smith', email: 'jane@example.com', status: 'Active', last_seen: 'Yesterday'},
    {name: 'Marco Chen', email: 'marco@example.com', status: 'Active', last_seen: 'May 4, 2026'},
    {name: 'Priya Patel', email: 'priya@example.com', status: 'Invited', last_seen: 'Pending'}
] %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="{{ route('roles.index') }}">Roles</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">{{ role.label }}</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('users.index') }}">Users</a>
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="{{ route('roles.index') }}">Roles</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('users.layouts.show') }}">Field Layout</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Members</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('users.index') }}">Users</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="{{ route('roles.index') }}">Roles</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="{{ route('users.layouts.show') }}">Field Layout</a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex min-w-0 items-start gap-4">
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-md text-lg font-semibold text-white shadow-sm" style="background-color: {{ role.highlight }}">
                    {{ role.label|slice(0, 1) }}
                </div>
                <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">{{ role.label }}</h1>
                        <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-100">Active</span>
                    </div>
                    <p class="mt-1 max-w-3xl text-sm text-slate-500">{{ role.description }}</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-2 self-start">
                <a href="{{ route('roles.index') }}" class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back
                </a>
                <a href="{{ route('roles.edit', role.id) }}" class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit
                </a>
                <a href="roles-permissions.twig" class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    Permissions
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
            <div class="flex min-w-0 flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Role Details</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-slate-500">Name</dt>
                            <dd class="font-medium text-slate-900">{{ role.label }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-slate-500">Handle</dt>
                            <dd class="font-mono text-xs text-slate-700">{{ role.name }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-slate-500">Guard</dt>
                            <dd class="text-slate-700">{{ role.guard }}</dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-slate-500">Highlight</dt>
                            <dd>
                                <span class="inline-flex items-center gap-2 text-slate-700">
                                    <span class="h-3 w-3 rounded-full" style="background-color: {{ role.highlight }}"></span>
                                    {{ role.highlight }}
                                </span>
                            </dd>
                        </div>
                        <div class="grid gap-1 py-3 sm:grid-cols-[10rem_1fr]">
                            <dt class="text-slate-500">Description</dt>
                            <dd class="text-slate-700">{{ role.description }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                                <h5 class="text-sm font-semibold text-slate-700">Assigned Permissions</h5>
                                <p class="mt-0.5 text-xs text-slate-500">Read-only summary grouped by permission domain.</p>
                            </div>
                            <span class="text-xs font-medium text-slate-500">{{ role.permissions }} total permissions</span>
                        </div>
                    </div>
                    <div class="divide-y divide-slate-100">
                        {% for group in permission_groups %}
                            <section class="grid gap-3 px-5 py-4 lg:grid-cols-[12rem_1fr]">
                                <div>
                                    <h6 class="text-sm font-semibold text-slate-800">{{ group.name }}</h6>
                                    <p class="mt-1 text-xs text-slate-500">{{ group.assigned }} of {{ group.total }} assigned</p>
                                </div>
                                <div class="flex min-w-0 flex-wrap gap-2">
                                    {% for permission in group.permissions %}
                                        <span class="inline-flex max-w-full items-center rounded-md border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-700">
                                            <span class="truncate">{{ permission }}</span>
                                        </span>
                                    {% endfor %}
                                </div>
                            </section>
                        {% endfor %}
                    </div>
                    <div class="border-t border-slate-100 bg-slate-50 px-5 py-3">
                        <a class="text-sm font-semibold text-emerald-700 hover:text-emerald-800" href="roles-permissions.twig">Manage permission assignments</a>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                                <h5 class="text-sm font-semibold text-slate-700">Assigned Users</h5>
                                <p class="mt-0.5 text-xs text-slate-500">People currently receiving this role.</p>
                            </div>
                            <a class="text-sm font-semibold text-emerald-700 hover:text-emerald-800" href="{{ route('users.index') }}">View all users</a>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-100 text-sm">
                            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                <tr>
                                    <th class="px-5 py-3">User</th>
                                    <th class="px-5 py-3">Status</th>
                                    <th class="px-5 py-3">Last Seen</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                                {% for user in assigned_users %}
                                    <tr>
                                        <td class="px-5 py-3">
                                            <div class="font-medium text-slate-900">{{ user.name }}</div>
                                            <div class="text-xs text-slate-500">{{ user.email }}</div>
                                        </td>
                                        <td class="px-5 py-3">
                                            <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium {{ user.status == 'Active' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' }}">{{ user.status }}</span>
                                        </td>
                                        <td class="px-5 py-3 text-slate-600">{{ user.last_seen }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div class="border-t border-slate-100 bg-slate-50 px-5 py-3 text-xs text-slate-500">
                        Showing 4 of {{ role.users }} assigned users.
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Summary</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-xs">
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Users</dt>
                            <dd class="font-medium text-slate-700">{{ role.users }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Permissions</dt>
                            <dd class="font-medium text-slate-700">{{ role.permissions }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Guard</dt>
                            <dd class="font-medium text-slate-700">{{ role.guard }}</dd>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <dt class="text-slate-500">Role ID</dt>
                            <dd class="font-medium text-slate-700">#{{ role.id }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Metadata</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-xs">
                        <div class="flex items-center justify-between gap-3 py-2.5">
                            <dt class="text-slate-500">Created</dt>
                            <dd class="text-right text-slate-700">{{ role.created }}</dd>
                        </div>
                        <div class="flex items-center justify-between gap-3 py-2.5">
                            <dt class="text-slate-500">Updated</dt>
                            <dd class="text-right text-slate-700">{{ role.updated }}</dd>
                        </div>
                        <div class="flex items-center justify-between gap-3 py-2.5">
                            <dt class="text-slate-500">Updated by</dt>
                            <dd class="text-right text-slate-700">{{ role.updated_by }}</dd>
                        </div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Actions</h5>
                    </div>
                    <div class="space-y-2 p-5">
                        <a href="{{ route('roles.edit', role.id) }}" class="flex w-full items-center justify-center rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">Edit Role</a>
                        <a href="roles-permissions.twig" class="flex w-full items-center justify-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Manage Permissions</a>
                        <a href="{{ route('roles.confirm', role.id) }}" class="flex w-full items-center justify-center rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 shadow-sm hover:bg-red-100">Delete Role</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
