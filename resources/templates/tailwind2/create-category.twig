<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <!-- Primary Sidebar -->
    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <div class="nav-group">
                <input id="nav-content" type="checkbox" checked>
                <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700">
                    <span>Content</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 font-semibold text-emerald-700" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-media" type="checkbox">
                <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Media</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Upload</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-users" type="checkbox">
                <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <!-- Main column -->
    <div class="flex min-w-0 flex-col">

        <!-- Topbar -->
        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Create Category</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="categories.twig">Categories</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Create Category</span>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Mobile secnav toggle -->
        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>
        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="categories.twig">All Categories</a>
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">New Category</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Tags</a>
            </nav>
        </div>

        <!-- Body -->
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <!-- Secondary nav card -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Categories</h5></div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="categories.twig">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> All Categories
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> New Category
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Tools</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg> Import
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Export
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Form content -->
            <div class="flex min-w-0 flex-col gap-5">

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Category</h1>
                        <p class="mt-1 text-sm text-slate-500">Add a new category to organise your articles.</p>
                    </div>
                    <a href="categories.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                        Back to Categories
                    </a>
                </div>

                <form method="POST" action="#" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

                    <!-- Left: main fields -->
                    <div class="flex flex-col gap-4">

                        <!-- Basic Details -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Basic Details</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="name" name="name" type="text" placeholder="e.g. Engineering" required>
                                    <p class="mt-1 text-xs text-slate-400">The name is how it appears on your site.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="slug">Slug</label>
                                    <div class="flex rounded-md shadow-sm">
                                        <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/category/</span>
                                        <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="slug" name="slug" type="text" placeholder="engineering">
                                    </div>
                                    <p class="mt-1 text-xs text-slate-400">Auto-generated from name. Lowercase letters, numbers, and hyphens only.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="parent_id">Parent Category</label>
                                    <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="parent_id" name="parent_id">
                                        <option value="">— None (top-level) —</option>
                                        <option value="1">Engineering</option>
                                        <option value="2">&nbsp;&nbsp;&nbsp;└ Backend</option>
                                        <option value="3">&nbsp;&nbsp;&nbsp;└ Frontend</option>
                                        <option value="4">Product</option>
                                        <option value="5">&nbsp;&nbsp;&nbsp;└ Features</option>
                                        <option value="6">&nbsp;&nbsp;&nbsp;└ Roadmap</option>
                                        <option value="7">Company</option>
                                        <option value="8">&nbsp;&nbsp;&nbsp;└ Announcements</option>
                                        <option value="9">Operations</option>
                                        <option value="10">Security</option>
                                        <option value="11">Tutorials</option>
                                        <option value="12">&nbsp;&nbsp;&nbsp;└ Getting Started</option>
                                    </select>
                                    <p class="mt-1 text-xs text-slate-400">Categories can be nested. Leave blank to create a top-level category.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Description</h5>
                            </div>
                            <div class="px-5 py-5">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="description">Description</label>
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="description" name="description" rows="4"
                                          placeholder="A short description of this category…"></textarea>
                                <p class="mt-1 text-xs text-slate-400">The description is not prominent by default; some themes may display it.</p>
                            </div>
                        </div>

                        <!-- SEO -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">SEO</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_title">Meta Title</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="meta_title" name="meta_title" type="text" placeholder="Defaults to category name if blank" maxlength="70">
                                    <p class="mt-1 flex justify-between text-xs text-slate-400">
                                        <span>Recommended: 50–60 characters.</span>
                                        <span id="meta-title-count" class="tabular-nums">0 / 70</span>
                                    </p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_description">Meta Description</label>
                                    <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                              id="meta_description" name="meta_description" rows="3"
                                              placeholder="A concise summary for search engines…" maxlength="160"></textarea>
                                    <p class="mt-1 flex justify-between text-xs text-slate-400">
                                        <span>Recommended: 120–158 characters.</span>
                                        <span id="meta-desc-count" class="tabular-nums">0 / 160</span>
                                    </p>
                                </div>
                                <!-- SERP preview -->
                                <div>
                                    <p class="mb-2 text-xs font-medium text-slate-600">SERP Preview</p>
                                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                                        <p id="serp-title" class="truncate text-sm font-medium text-blue-700">Category name will appear here</p>
                                        <p id="serp-url" class="mt-0.5 truncate text-xs text-green-700">https://example.com/category/your-slug</p>
                                        <p id="serp-desc" class="mt-1 text-xs text-slate-500 line-clamp-2">Your meta description will appear here.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div><!-- /left -->

                    <!-- Right: options panel -->
                    <div class="flex flex-col gap-4">

                        <!-- Save card -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Save</h5>
                            </div>
                            <div class="space-y-3 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                                    <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="status" name="status">
                                        <option value="active" selected>Active</option>
                                        <option value="inactive">Inactive</option>
                                    </select>
                                    <p class="mt-1 text-xs text-slate-400">Inactive categories are hidden from the front-end.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="sort_order">Sort Order</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="sort_order" name="sort_order" type="number" min="0" placeholder="0">
                                    <p class="mt-1 text-xs text-slate-400">Lower numbers appear first.</p>
                                </div>
                            </div>
                            <div class="space-y-2 border-t border-slate-100 px-5 py-4">
                                <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                                    Create Category
                                </button>
                                <a href="categories.twig" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-600 shadow-sm hover:bg-slate-50">
                                    Cancel
                                </a>
                            </div>
                        </div>

                        <!-- Featured image -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Featured Image</h5>
                            </div>
                            <div class="px-5 py-4">
                                <label class="block cursor-pointer rounded-lg border-2 border-dashed border-slate-300 p-6 text-center hover:border-emerald-400 hover:bg-emerald-50/40 transition-colors" for="featured_image">
                                    <svg class="mx-auto h-8 w-8 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    <p class="mt-2 text-xs font-medium text-slate-500">Click to upload</p>
                                    <p class="mt-0.5 text-xs text-slate-400">PNG, JPG, WebP up to 10 MB</p>
                                    <input id="featured_image" name="featured_image" type="file" accept="image/*" class="sr-only">
                                </label>
                            </div>
                        </div>

                        <!-- Template override -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Advanced</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="template">Template Override</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm shadow-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="template" name="template" type="text" placeholder="categories/default">
                                    <p class="mt-1 text-xs text-slate-400">Path relative to the views root. Leave blank for the default.</p>
                                </div>
                                <div>
                                    <label class="flex items-start gap-2.5 text-sm text-slate-700">
                                        <input type="checkbox" name="show_in_nav" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                                        <span>Show in navigation</span>
                                    </label>
                                    <label class="mt-2 flex items-start gap-2.5 text-sm text-slate-700">
                                        <input type="checkbox" name="include_in_sitemap" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                                        <span>Include in sitemap</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div><!-- /right -->

                </form>

            </div><!-- /content -->
        </div><!-- /body -->

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p>
                <nav class="flex items-center gap-4 text-xs text-slate-400">
                    <a class="hover:text-slate-600" href="#">Documentation</a>
                    <a class="hover:text-slate-600" href="#">Support</a>
