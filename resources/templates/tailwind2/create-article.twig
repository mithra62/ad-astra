{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Create Article' %}
{% set page_heading = 'Create Article' %}
{% set active_nav = 'articles' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="#">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="index.twig">Articles</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Create Article</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
            <!-- Desktop secondary nav card -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Articles</h5>
                    </div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg>
                            All Articles
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            New Article
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10M7 11h6m-9 8h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Categories
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 014-4z"/></svg>
                            Tags
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Authors
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Settings</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            Edit Entry Group
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            Edit Entry Type
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Tools</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                            Import
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                            Export
                        </a>
                    </nav>
                </div>
            </aside>
{% endblock %}

{% block content %}
            <!-- ── Form content ──────────────────────────────────────── -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Page title row -->
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Article</h1>
                        <p class="mt-1 text-sm text-slate-500">Fill in the details below to publish a new article.</p>
                    </div>
                    <a class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto" href="#">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                        Back to Articles
                    </a>
                </div>

                <!-- Two-column form layout -->
                <form method="POST" action="#" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

                    <!-- ── Left: core fields ─────────────────────────── -->
                    <div class="flex flex-col gap-4">

                        <!-- Title + slug card -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Basic Details</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="title">Title <span class="text-red-500">*</span></label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="title" name="title" type="text" placeholder="Enter article title" required>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Slug</label>
                                    <div class="flex rounded-md shadow-sm">
                                        <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/articles/</span>
                                        <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="handle" name="handle" type="text" placeholder="auto-generated-from-title">
                                    </div>
                                    <p class="mt-1 text-xs text-slate-400">Leave blank to auto-generate from title.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Body / content card -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Content</h5>
                            </div>
                            <div class="px-5 py-5">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="body">Body</label>
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="body" name="body" rows="14" placeholder="Write your article content here…"></textarea>
                                <p class="mt-1 text-xs text-slate-400">Plain text or Markdown supported.</p>
                            </div>
                        </div>

                        <!-- Excerpt card -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Excerpt</h5>
                            </div>
                            <div class="px-5 py-5">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="excerpt">Summary</label>
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="excerpt" name="excerpt" rows="3" placeholder="A short description shown in article listings…"></textarea>
                            </div>
                        </div>

                    </div>
                    <!-- /left -->

                    <!-- ── Right: settings panel ─────────────────────── -->
                    <div class="flex flex-col gap-4">

                        <!-- Publish settings -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Publishing</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="status" name="status">
                                        <option value="draft" selected>Draft</option>
                                        <option value="published">Published</option>
                                        <option value="scheduled">Scheduled</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="published_at">Publish Date</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="published_at" name="published_at" type="datetime-local">
                                    <p class="mt-1 text-xs text-slate-400">Leave blank to save as draft.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="entry_type">Entry Type</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="entry_type" name="entry_type">
                                        <option>Standard Article</option>
                                        <option>Feature Story</option>
                                        <option>Press Release</option>
                                        <option>Opinion Piece</option>
                                    </select>
                                </div>
                            </div>
                            <!-- Save button -->
                            <div class="border-t border-slate-100 px-5 py-4">
                                <button class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
                                        type="submit">
                                    Save Article
                                </button>
                            </div>
                        </div>

                        <!-- Structure / hierarchy -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Structure</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="parent_entry">Parent Entry</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="parent_entry" name="parent_entry">
                                        <option value="">— None (top-level) —</option>
                                        <option value="1">Getting Started</option>
                                        <option value="2">Product Updates</option>
                                        <option value="3">Engineering Blog</option>
                                        <option value="4">Company News</option>
                                    </select>
                                    <p class="mt-1 text-xs text-slate-400">Leave blank to place at the top level.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="template">Template</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm shadow-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="template" name="template" type="text" placeholder="e.g. articles/default">
                                    <p class="mt-1 text-xs text-slate-400">Template path relative to the views root.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="entry_url">URL</label>
                                    <div class="flex rounded-md shadow-sm">
                                        <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">https://example.com/</span>
                                        <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="entry_url" name="entry_url" type="text" placeholder="articles/my-article">
                                    </div>
                                    <p class="mt-1 text-xs text-slate-400">Leave blank to auto-build from slug and parent.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Authors -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Authors</h5>
                            </div>
                            <div class="px-5 py-4">
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="authors">Assign Authors</label>
                                <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                        id="authors" name="authors[]" multiple size="4">
                                    <option>Avery Stone</option>
                                    <option>Morgan Lee</option>
                                    <option>Riley Chen</option>
                                    <option>Jordan Kim</option>
                                </select>
                                <p class="mt-1 text-xs text-slate-400">Hold Ctrl / Cmd to select multiple.</p>
                            </div>
                        </div>

                        <!-- Categories -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Categories</h5>
                            </div>
                            <div class="divide-y divide-slate-100 px-5 py-1">
                                <label class="flex items-center gap-2.5 py-2.5 text-sm text-slate-700">
                                    <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="categories[]" type="checkbox" value="engineering"> Engineering
                                </label>
                                <label class="flex items-center gap-2.5 py-2.5 text-sm text-slate-700">
                                    <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="categories[]" type="checkbox" value="product"> Product
                                </label>
                                <label class="flex items-center gap-2.5 py-2.5 text-sm text-slate-700">
                                    <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="categories[]" type="checkbox" value="operations"> Operations
                                </label>
                                <label class="flex items-center gap-2.5 py-2.5 text-sm text-slate-700">
                                    <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="categories[]" type="checkbox" value="support"> Support
                                </label>
                            </div>
                        </div>

                        <!-- Tags -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Tags</h5>
                            </div>
                            <div class="px-5 py-4">
                                <input id="tag-search-create"
                                       class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       type="text" placeholder="Filter tags…" autocomplete="off">
                                <div id="tag-cloud-create" class="mt-3 flex min-h-[2rem] flex-wrap gap-1.5"></div>
                                <div id="tag-inputs-create"></div>
                                <p class="mt-2 text-xs text-slate-400">Click a tag to select it. Selected tags are highlighted and submitted as hidden fields.</p>
                            </div>
                        </div>

                    </div>
                    <!-- /right -->

                </form>

            </div>
            <!-- /form content -->
{% endblock %}
