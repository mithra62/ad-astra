{% extends 'templates::tailwind2.auth-layout' %}

{% set page_title = 'Login' %}

{% block heading %}Sign in{% endblock %}
{% block subheading %}Use your account credentials to continue.{% endblock %}

{% block content %}
    <form method="POST" action="#" class="space-y-5 px-5 py-6 sm:px-6">
        <div class="rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
            Demo state: enter any valid email and password to preview form behavior.
        </div>

        <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">
            <p class="font-medium">Unable to sign in.</p>
            <p class="mt-1">Please review the highlighted fields and try again.</p>
        </div>

        <div class="rounded-md border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-800" role="status">
            <p class="font-medium">Security notice</p>
            <p class="mt-1">Use your administrator email address to access this workspace.</p>
        </div>

        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-slate-700">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email" required
                   class="w-full rounded-md border border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20"
                   aria-invalid="true" aria-describedby="email-error"
                   placeholder="you@example.com">
            <p id="email-error" class="mt-1.5 text-xs font-medium text-red-600">Enter a valid email address.</p>
        </div>

        <div>
            <div class="mb-1.5 flex items-center justify-between gap-3">
                <label for="password" class="block text-sm font-medium text-slate-700">Password</label>
                <a href="forgot-password.twig" class="text-xs font-medium text-emerald-700 hover:text-emerald-800">Forgot password?</a>
            </div>
            <div class="relative">
                <input id="password" name="password" type="password" autocomplete="current-password" required
                       class="w-full rounded-md border border-red-300 px-3 py-2 pr-10 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20"
                       aria-invalid="true" aria-describedby="password-error"
                       placeholder="Enter your password">
                <button type="button" class="auth-password-toggle absolute inset-y-0 right-0 inline-flex items-center px-3 text-slate-400 hover:text-slate-600" data-auth-password-toggle="password" aria-label="Show password">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </button>
            </div>
            <p id="password-error" class="mt-1.5 text-xs font-medium text-red-600">Password is required.</p>
        </div>

        <div class="flex items-center justify-between gap-3">
            <label class="flex items-center gap-2 text-sm text-slate-600">
                <input type="checkbox" name="remember" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                Remember me
            </label>
        </div>

        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Sign in</button>

        <div class="relative">
            <div class="absolute inset-0 flex items-center" aria-hidden="true">
                <div class="w-full border-t border-slate-200"></div>
            </div>
            <div class="relative flex justify-center">
                <span class="bg-white px-3 text-xs font-medium text-slate-500">Or continue with</span>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-3 sm:grid-cols-6">
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-sky-300 hover:bg-sky-50 hover:text-sky-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with Twitter">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.656l-5.214-6.817-5.966 6.817H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>
                </svg>
            </a>
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-sky-300 hover:bg-sky-50 hover:text-sky-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with Bluesky">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M5.716 3.194C8.262 5.107 11 8.99 12 11.07c1-2.08 3.738-5.963 6.284-7.876 1.837-1.38 4.816-2.447 4.816.95 0 .679-.389 5.707-.617 6.522-.793 2.835-3.684 3.558-6.258 3.119 4.493.766 5.636 3.305 3.169 5.844-4.686 4.822-6.735-1.21-7.261-2.756-.097-.284-.142-.416-.133-.303-.009-.113-.036.019-.133.303-.526 1.546-2.575 7.578-7.261 2.756-2.467-2.539-1.324-5.078 3.169-5.844-2.574.439-5.465-.284-6.258-3.119C1.289 9.851.9 4.823.9 4.144c0-3.397 2.979-2.33 4.816-.95Z"/>
                </svg>
            </a>
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-blue-300 hover:bg-blue-50 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with Facebook">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.026 4.388 11.02 10.125 11.927v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.971H15.83c-1.491 0-1.956.931-1.956 1.887v2.266h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.099 24 12.073Z"/>
                </svg>
            </a>
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-sky-300 hover:bg-sky-50 hover:text-sky-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with LinkedIn">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.119 20.452H3.554V9h3.565v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
                </svg>
            </a>
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-slate-400 hover:bg-slate-100 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with GitHub">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .297C5.373.297 0 5.67 0 12.297c0 5.303 3.438 9.8 8.207 11.387.6.111.82-.26.82-.577 0-.285-.011-1.23-.016-2.233-3.338.726-4.043-1.416-4.043-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.085 1.839 1.237 1.839 1.237 1.07 1.833 2.807 1.304 3.492.997.108-.775.419-1.305.762-1.605-2.665-.303-5.466-1.332-5.466-5.93 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23A11.49 11.49 0 0 1 12 6.099c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.873.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.806 5.624-5.479 5.921.43.371.814 1.103.814 2.222 0 1.605-.014 2.898-.014 3.294 0 .319.216.694.825.576C20.565 22.092 24 17.597 24 12.297c0-6.627-5.373-12-12-12Z"/>
                </svg>
            </a>
            <a href="#" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:border-red-300 hover:bg-red-50 hover:text-red-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" aria-label="Sign in with Google">
                <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="#4285F4" d="M23.49 12.275c0-.815-.073-1.596-.209-2.345H12v4.438h6.445a5.51 5.51 0 0 1-2.386 3.615v2.953h3.801c2.225-2.049 3.63-5.068 3.63-8.661Z"/>
                    <path fill="#34A853" d="M12 24c3.24 0 5.956-1.074 7.941-2.91l-3.801-2.953c-1.054.706-2.4 1.123-4.14 1.123-3.129 0-5.775-2.113-6.72-4.953H1.35v3.049A11.995 11.995 0 0 0 12 24Z"/>
                    <path fill="#FBBC05" d="M5.28 14.307A7.213 7.213 0 0 1 4.902 12c0-.8.137-1.577.378-2.307V6.644H1.35A11.995 11.995 0 0 0 0 12c0 1.933.463 3.762 1.35 5.356l3.93-3.049Z"/>
                    <path fill="#EA4335" d="M12 4.74c1.762 0 3.344.606 4.589 1.795l3.436-3.436C17.95 1.166 15.235 0 12 0A11.995 11.995 0 0 0 1.35 6.644l3.93 3.049C6.225 6.853 8.871 4.74 12 4.74Z"/>
                </svg>
            </a>
        </div>
    </form>

    <div class="border-t border-slate-200 bg-slate-50 px-5 py-4 text-center text-sm text-slate-500 sm:px-6">
        Need an account?
        <a href="register.twig" class="font-medium text-emerald-700 hover:text-emerald-800">Create one</a>
    </div>
{% endblock %}
