<!DOCTYPE html>
<html lang="{{ app().getLocale()|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Reorder Articles</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">
<div class="min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">
    <aside class="border-r border-slate-200 bg-white px-5 py-6">
        <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
        <nav class="mt-8 space-y-1 text-sm font-medium">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <a class="block rounded-md bg-emerald-50 px-3 py-2 text-emerald-700" href="#">Articles</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Media</a>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <main class="px-4 py-6 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <div class="flex flex-col gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <nav class="flex gap-2 text-sm text-slate-500">
                        <a class="hover:text-slate-900" href="#">Dashboard</a>
                        <span>/</span>
                        <a class="hover:text-slate-900" href="#">Articles</a>
                        <span>/</span>
                        <span class="text-slate-900">Reorder</span>
                    </nav>
                    <h1 class="mt-3 text-3xl font-semibold tracking-tight">Reorder Articles</h1>
                </div>
                <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="#">Back to Articles</a>
            </div>

            <form class="mt-8 rounded-lg border border-slate-200 bg-white shadow-sm" method="POST" action="#">
                {{ csrf_field() }}
                {{ method_field('PUT') }}

                <div class="border-b border-slate-200 px-6 py-5">
                    <h2 class="text-base font-semibold">Article Order</h2>
                    <p class="mt-1 text-sm text-slate-500">Use sort numbers to control the displayed order. Lower numbers appear first.</p>
                </div>

                <div class="divide-y divide-slate-200">
                    {% for article in articles %}
                        <div class="grid gap-4 px-6 py-4 sm:grid-cols-[4rem_1fr_8rem] sm:items-center">
                            <div class="flex items-center gap-3 text-slate-500">
                                <span class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-slate-50 text-sm font-semibold">{{ loop.index }}</span>
                                <span class="text-lg leading-none" aria-hidden="true">::</span>
                            </div>
                            <div>
                                <input name="articles[{{ loop.index0 }}][id]" type="hidden" value="{{ article.id }}">
                                <p class="font-medium text-slate-900">{{ article.title }}</p>
                                <p class="mt-1 text-sm text-slate-500">{{ article.slug }} - {{ article.status|title }}</p>
                            </div>
                            <div>
                                <label class="sr-only" for="sort_order_{{ article.id }}">Sort order for {{ article.title }}</label>
                                <input class="block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="sort_order_{{ article.id }}" min="1" name="articles[{{ loop.index0 }}][sort_order]" type="number" value="{{ old('articles.' ~ loop.index0 ~ '.sort_order', article.sort_order ?: loop.index) }}">
                            </div>
                        </div>
                    {% else %}
                        <div class="px-6 py-12 text-center">
                            <h2 class="text-base font-semibold">No articles to reorder</h2>
                            <p class="mt-2 text-sm text-slate-500">Create an article before managing display order.</p>
                            <a class="mt-5 inline-flex items-center justify-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" href="#">Create Article</a>
                        </div>
                    {% endfor %}
                </div>

                {% if articles.count >= 1 %}
                    <div class="flex flex-col-reverse gap-3 border-t border-slate-200 px-6 py-4 sm:flex-row sm:justify-end">
                        <a class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="#">Cancel</a>
                        <button class="inline-flex items-center justify-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" type="submit">Save Order</button>
                    </div>
                {% endif %}
            </form>
        </div>
    </main>
</div>
</body>
</html>
