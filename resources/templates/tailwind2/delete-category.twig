{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Delete Category: Engineering' %}
{% set page_heading = 'Delete Category' %}
{% set active_nav = 'categories' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-slate-800" href="categories.twig">Categories</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-slate-800" href="edit-category.twig">Engineering</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Categories</h5></div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="categories.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg>
                    All Categories
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-category.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    New Category
                </a>
                <div class="my-2 border-t border-slate-100"></div>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="edit-category.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Edit Engineering
                </a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete Category</h1>
            <p class="mt-1 text-sm text-slate-500">Review the impact before permanently deleting this category.</p>
        </div>
        <a href="categories.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Cancel
        </a>
    </div>

    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <div>
                <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                <p class="mt-1 text-sm text-red-700">Deleting <strong>Engineering</strong> will permanently remove the category and all its associations. Articles in this category will be uncategorised unless you reassign them below.</p>
            </div>
        </div>
    </div>

    <div class="flex flex-col gap-4 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
        <div class="flex flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Category Being Deleted</h5></div>
                <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Name</dt><dd class="font-semibold text-slate-900">Engineering</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Slug</dt><dd class="font-mono text-xs text-slate-700">engineering</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Status</dt><dd><span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">Active</span></dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Articles</dt><dd class="font-semibold text-slate-900">47</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Sub-categories</dt><dd class="font-semibold text-slate-900">2</dd></div>
                </dl>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Reassignment Options</h5></div>
                <div class="divide-y divide-slate-100">
                    <div class="px-5 py-5">
                        <p class="mb-3 text-sm font-medium text-slate-800">Articles (47)</p>
                        <div class="space-y-3">
                            <label class="flex items-start gap-3">
                                <input type="radio" name="article_action" value="uncategorise" checked class="mt-0.5 border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                <span class="text-sm text-slate-700"><span class="font-medium">Leave uncategorised</span><span class="mt-0.5 block text-xs text-slate-500">Articles remain but have no category assigned.</span></span>
                            </label>
                            <label class="flex items-start gap-3">
                                <input type="radio" name="article_action" value="reassign" class="mt-0.5 border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                <span class="text-sm text-slate-700"><span class="font-medium">Reassign to another category</span><span class="mt-0.5 block text-xs text-slate-500">Move all 47 articles to a different category.</span></span>
                            </label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" name="reassign_to">
                                <option value="">Select a category</option>
                                <option value="4">Product</option>
                                <option value="7">Company</option>
                                <option value="10">Security</option>
                            </select>
                        </div>
                    </div>
                    <div class="px-5 py-5">
                        <p class="mb-3 text-sm font-medium text-slate-800">Sub-categories</p>
                        <div class="space-y-3">
                            <label class="flex items-start gap-3">
                                <input type="radio" name="subcategory_action" value="promote" checked class="mt-0.5 border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                <span class="text-sm text-slate-700"><span class="font-medium">Promote to top-level</span><span class="mt-0.5 block text-xs text-slate-500">Backend and Frontend become independent categories.</span></span>
                            </label>
                            <label class="flex items-start gap-3">
                                <input type="radio" name="subcategory_action" value="delete" class="mt-0.5 border-slate-300 text-red-600 focus:ring-red-500">
                                <span class="text-sm text-slate-700"><span class="font-medium text-red-700">Delete sub-categories too</span><span class="mt-0.5 block text-xs text-slate-500">Backend and Frontend will also be permanently deleted.</span></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-4">
            <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                <div class="border-b border-red-100 bg-red-50 px-5 py-3"><h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5></div>
                <form id="delete-form" method="POST" action="#" class="px-5 py-5">
                    <input type="hidden" name="_method" value="DELETE">
                    <input type="hidden" name="category_id" value="1">
                    <div class="mb-4 rounded-md bg-slate-50 px-4 py-3 text-sm text-slate-700">You are about to permanently delete the <strong>Engineering</strong> category and remove it from <strong>47 articles</strong>.</div>
                    <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                        <span class="text-sm font-medium text-slate-700">I understand this category will be permanently deleted</span>
                        <input class="peer sr-only" type="checkbox" name="confirm_delete" required>
                        <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:mt-1 after:ml-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                    </label>
                    <button type="submit" id="delete-btn" class="mt-5 w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">Permanently Delete Category</button>
                    <a href="edit-category.twig" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Back to Edit</a>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
