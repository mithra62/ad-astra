                                        <p class="mt-1 text-xs text-slate-400">PNG, JPG, GIF, SVG, PDF, MP4, MP3 &mdash; max 50 MB per file</p>
                                    </div>
                                    <input id="file-input" type="file" multiple class="sr-only" accept="image/*,video/*,audio/*,.pdf,.doc,.docx">
                                </label>
                            </div>
                        </div>

                        <!-- Upload queue -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="flex items-center justify-between border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Upload Queue</h5>
                                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">3 files</span>
                            </div>
                            <ul class="divide-y divide-slate-100">

                                <!-- Completed -->
                                <li class="flex items-center gap-3 px-5 py-3.5">
                                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-sky-100">
                                        <svg class="h-5 w-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <p class="truncate text-sm font-medium text-slate-800">hero-banner.jpg</p>
                                        <div class="mt-1 flex items-center gap-2">
                                            <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-slate-100"><div class="h-full w-full rounded-full bg-emerald-500"></div></div>
                                            <span class="text-xs text-slate-400">842 KB</span>
                                        </div>
                                    </div>
                                    <svg class="h-5 w-5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </li>

                                <!-- In progress -->
                                <li class="flex items-center gap-3 px-5 py-3.5">
                                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-violet-100">
                                        <svg class="h-5 w-5 text-violet-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <p class="truncate text-sm font-medium text-slate-800">product-shot.png</p>
                                        <div class="mt-1 flex items-center gap-2">
                                            <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-slate-100"><div class="h-full w-3/5 rounded-full bg-blue-500"></div></div>
                                            <span class="text-xs text-slate-400">60%</span>
                                        </div>
                                    </div>
                                    <button type="button" class="shrink-0 text-slate-400 hover:text-slate-600">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                    </button>
                                </li>

                                <!-- Waiting -->
                                <li class="flex items-center gap-3 px-5 py-3.5">
                                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-red-100">
                                        <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <p class="truncate text-sm font-medium text-slate-800">press-kit.pdf</p>
                                        <div class="mt-1 flex items-center gap-2">
                                            <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-slate-100"><div class="h-full w-0 rounded-full bg-emerald-500"></div></div>
                                            <span class="text-xs text-slate-400">Waiting…</span>
                                        </div>
                                    </div>
                                    <button type="button" class="shrink-0 text-slate-400 hover:text-slate-600">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                    </button>
                                </li>

                            </ul>
                            <div class="flex justify-end gap-3 border-t border-slate-100 px-5 py-4">
                                <button type="button" class="rounded-md border border-slate-300 bg-white px-4 py-1.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Clear Done</button>
