                            <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Upload Options</h5></div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="upload-folder">Destination Folder</label>
                                    <select class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="upload-folder">
                                        <option>/ (root)</option>
                                        <option>blog/</option>
                                        <option>products/</option>
                                        <option>team/</option>
                                        <option>documents/</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="upload-alt">Default Alt Text</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="upload-alt" type="text" placeholder="Describe the image…">
                                    <p class="mt-1 text-xs text-slate-400">Applied to images that don't have specific alt text.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700">On Duplicate</label>
                                    <div class="space-y-2">
                                        <label class="flex items-center gap-2 text-sm text-slate-700">
                                            <input type="radio" name="on_duplicate" value="rename" checked class="text-emerald-600 focus:ring-emerald-500"> Rename automatically
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-slate-700">
                                            <input type="radio" name="on_duplicate" value="overwrite" class="text-emerald-600 focus:ring-emerald-500"> Overwrite existing
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-slate-700">
                                            <input type="radio" name="on_duplicate" value="skip" class="text-emerald-600 focus:ring-emerald-500"> Skip
                                        </label>
                                    </div>
                                </div>
                                <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                                    <input type="checkbox" checked class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                    Auto-generate thumbnails
                                </label>
                            </div>
                        </div>

                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Allowed Types</h5></div>
                            <ul class="divide-y divide-slate-100 px-5 py-1 text-sm text-slate-600">
                                <li class="flex items-center justify-between py-2"><span>Images</span><span class="text-xs text-slate-400">JPG, PNG, GIF, SVG, WebP</span></li>
                                <li class="flex items-center justify-between py-2"><span>Documents</span><span class="text-xs text-slate-400">PDF, DOC, DOCX, XLS</span></li>
                                <li class="flex items-center justify-between py-2"><span>Video</span><span class="text-xs text-slate-400">MP4, MOV, WebM</span></li>
                                <li class="flex items-center justify-between py-2"><span>Audio</span><span class="text-xs text-slate-400">MP3, WAV, OGG</span></li>
                                <li class="flex items-center justify-between py-2"><span>Max size</span><span class="text-xs font-medium text-slate-700">50 MB</span></li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p>
