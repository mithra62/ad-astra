{% extends 'admin._inc._layout' %}

{% set page_title = 'Create Media Library' %}
{% set page_heading = 'Create Media Library' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="media-libraries.twig">Media Libraries</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Create Media Library</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">Libraries</a>
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="create-media-library.twig">New Library</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">View Library</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Media</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                    </svg>
                    Libraries
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="create-media-library.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                    </svg>
                    New Library
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    View Library
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                    </svg>
                    Upload
                </a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Create Media Library</h1>
                <p class="mt-1 text-sm text-slate-500">Configure storage, upload rules, and access defaults for a new media library.</p>
            </div>
            <a href="media-libraries.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Libraries
            </a>
        </div>

        <form method="POST" action="{{ route('media.libraries.store') }}" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">
            {{ csrf_field() }}

            <div class="flex min-w-0 flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Basic Details</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="name" name="name" type="text" value="{{ old('name') }}" placeholder="Marketing Assets" required>
                            <p class="mt-1 text-xs text-slate-400">Shown in media navigation and upload destination lists.</p>
                            {% if errors.has('name') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('name') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="handle">Handle <span class="text-red-500">*</span></label>
                            <div class="flex rounded-md shadow-sm">
                                <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">media/</span>
                                <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 font-mono text-sm placeholder:font-sans placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                       id="handle" name="handle" type="text" value="{{ old('handle') }}" placeholder="marketing-assets" required>
                            </div>
                            <p class="mt-1 text-xs text-slate-400">Lowercase letters, numbers, and hyphens only.</p>
                            {% if errors.has('handle') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('handle') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="description">Description</label>
                            <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                      id="description" name="description" rows="3" placeholder="What should this library be used for?">{{ old('description') }}</textarea>
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Storage</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="storage">Storage Disk</label>
                                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="storage" name="storage">
                                    <option value="local" {% if old('storage', 'local') == 'local' %}selected{% endif %}>Local Disk</option>
                                    <option value="public" {% if old('storage') == 'public' %}selected{% endif %}>Public Disk</option>
                                    <option value="s3" {% if old('storage') == 's3' %}selected{% endif %}>Amazon S3</option>
                                </select>
                                {% if errors.has('storage') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('storage') }}</p>
                                {% endif %}
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-slate-700" for="max_size">Max File Size</label>
                                <div class="flex rounded-md shadow-sm">
                                    <input class="w-full rounded-l-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="max_size" name="max_size" type="number" min="1" value="{{ old('max_size', 20) }}">
                                    <span class="inline-flex items-center rounded-r-md border border-l-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">MB</span>
                                </div>
                                {% if errors.has('max_size') %}
                                    <p class="mt-1 text-sm text-red-600">{{ errors.first('max_size') }}</p>
                                {% endif %}
                            </div>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="adapter_url">Base URL</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="adapter_url" name="adapter_settings[local][url]" type="text" value="{{ old('adapter_settings.local.url') }}" placeholder="https://example.com/storage/marketing">
                            {% if errors.has('adapter_settings.local.url') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter_settings.local.url') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="adapter_path">Base Path</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm shadow-sm placeholder:font-sans placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                   id="adapter_path" name="adapter_settings[local][path]" type="text" value="{{ old('adapter_settings.local.path') }}" placeholder="uploads/marketing">
                            {% if errors.has('adapter_settings.local.path') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('adapter_settings.local.path') }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Upload Rules</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700">Allowed File Types</label>
                            <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                                {% for type in ['images', 'documents', 'video', 'audio', 'archives', 'svg'] %}
                                    <label class="flex cursor-pointer items-start gap-2.5 rounded-md border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm text-slate-700">
                                        <input type="checkbox" name="allowed_types[]" value="{{ type }}" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" {% if type in ['images', 'documents', 'video', 'audio'] %}checked{% endif %}>
                                        <span class="capitalize">{{ type }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            {% if errors.has('allowed_types') %}
                                <p class="mt-1 text-sm text-red-600">{{ errors.first('allowed_types') }}</p>
                            {% endif %}
                        </div>
                        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                            <label class="flex cursor-pointer items-start gap-2.5 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                                <input type="checkbox" name="generate_thumbnails" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                                <span><span class="font-medium text-slate-800">Generate thumbnails</span><span class="mt-0.5 block text-xs text-slate-500">Create standard image derivatives on upload.</span></span>
                            </label>
                            <label class="flex cursor-pointer items-start gap-2.5 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                                <input type="checkbox" name="preserve_originals" class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                                <span><span class="font-medium text-slate-800">Preserve originals</span><span class="mt-0.5 block text-xs text-slate-500">Keep source files after processing.</span></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Publishing</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="status">Status</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="status" name="status">
                                <option value="active" selected>Active</option>
                                <option value="restricted">Restricted</option>
                                <option value="archived">Archived</option>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-slate-700" for="visibility">Default Visibility</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" id="visibility" name="visibility">
                                <option value="public" selected>Public</option>
                                <option value="private">Private</option>
                                <option value="authenticated">Authenticated Users</option>
                            </select>
                        </div>
                    </div>
                    <div class="space-y-2 border-t border-slate-100 px-5 py-4">
                        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                            Create Media Library
                        </button>
                        <a href="media-libraries.twig" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-600 shadow-sm hover:bg-slate-50">
                            Cancel
                        </a>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Access</h5>
                    </div>
                    <div class="divide-y divide-slate-100 px-5 py-1">
                        <label class="flex cursor-pointer items-center gap-2.5 py-2.5 text-sm text-slate-700">
                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="roles[]" type="checkbox" value="admin" checked>
                            Administrators
                        </label>
                        <label class="flex cursor-pointer items-center gap-2.5 py-2.5 text-sm text-slate-700">
                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="roles[]" type="checkbox" value="editor" checked>
                            Editors
                        </label>
                        <label class="flex cursor-pointer items-center gap-2.5 py-2.5 text-sm text-slate-700">
                            <input class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" name="roles[]" type="checkbox" value="author">
                            Authors
                        </label>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Duplicate Handling</h5>
                    </div>
                    <div class="space-y-3 px-5 py-5">
                        <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                            <input type="radio" name="duplicate_strategy" value="rename" class="text-emerald-600 focus:ring-emerald-500" checked>
                            Rename automatically
                        </label>
                        <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                            <input type="radio" name="duplicate_strategy" value="overwrite" class="text-emerald-600 focus:ring-emerald-500">
                            Overwrite existing file
                        </label>
                        <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                            <input type="radio" name="duplicate_strategy" value="skip" class="text-emerald-600 focus:ring-emerald-500">
                            Skip upload
                        </label>
                    </div>
                </div>
            </div>
        </form>
    </div>
{% endblock %}
