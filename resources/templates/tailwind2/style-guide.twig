{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Tailwind2 Style Guide' %}
{% set page_heading = 'Style Guide' %}
{% set active_nav = 'settings' %}
{% set has_secondary_sidebar = true %}

{% set icon_classes = 'h-4 w-4 shrink-0' %}
{% set field_classes = 'w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Style Guide</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Guide</h5>
            </div>
            <nav class="p-2">
                {% set sections = [
                    { href: '#foundations', label: 'Foundations', icon: 'M4 6h16M4 12h16M4 18h7' },
                    { href: '#buttons', label: 'Buttons', icon: 'M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M5 8h8a2 2 0 012 2v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4a2 2 0 012-2z' },
                    { href: '#forms', label: 'Forms', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
                    { href: '#alerts', label: 'Alerts', icon: 'M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z' },
                    { href: '#tables', label: 'Tables', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
                    { href: '#icons', label: 'Icons', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.16c.969 0 1.371 1.24.588 1.81l-3.366 2.445a1 1 0 00-.364 1.118l1.286 3.957c.3.921-.755 1.688-1.538 1.118l-3.366-2.445a1 1 0 00-1.176 0l-3.366 2.445c-.783.57-1.838-.197-1.538-1.118l1.286-3.957a1 1 0 00-.364-1.118L4.063 9.384c-.783-.57-.38-1.81.588-1.81h4.16a1 1 0 00.95-.69l1.288-3.957z' }
                ] %}
                {% for section in sections %}
                    <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium {{ loop.first ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-50' }}" href="{{ section.href }}">
                        <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="{{ section.icon }}"/>
                        </svg>
                        {{ section.label }}
                    </a>
                {% endfor %}
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Tailwind2 Style Guide</h1>
                <p class="mt-1 text-sm text-slate-500">Reusable admin interface patterns for templates in this directory.</p>
            </div>
            <a class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto" href="settings.twig">
                <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Settings
            </a>
        </div>

        <section id="foundations" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h2 class="text-sm font-semibold text-slate-700">Foundations</h2>
            </div>
            <div class="grid gap-6 px-5 py-5 xl:grid-cols-[1.1fr_0.9fr]">
                <div>
                    <h3 class="text-base font-semibold text-slate-900">Page Structure</h3>
                    <p class="mt-1 text-sm text-slate-500">Use compact headers, white cards, slate borders, and emerald for primary actions and active states.</p>
                    <div class="mt-4 grid gap-3 sm:grid-cols-3">
                        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Page Title</p>
                            <p class="mt-1 text-xl font-semibold tracking-tight text-slate-900">Content</p>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Card Header</p>
                            <p class="mt-1 text-sm font-semibold text-slate-700">Section</p>
                        </div>
                        <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Active</p>
                            <p class="mt-1 text-sm font-semibold text-emerald-800">Selected</p>
                        </div>
                    </div>
                </div>
                <div>
                    <h3 class="text-base font-semibold text-slate-900">Color Tokens</h3>
                    <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3">
                        {% set swatches = [
                            { name: 'Slate', class: 'bg-slate-600', text: 'text-slate-700', note: 'Text, borders' },
                            { name: 'Emerald', class: 'bg-emerald-600', text: 'text-emerald-700', note: 'Primary' },
                            { name: 'Red', class: 'bg-red-600', text: 'text-red-700', note: 'Danger' },
                            { name: 'Amber', class: 'bg-amber-500', text: 'text-amber-700', note: 'Warning' },
                            { name: 'Sky', class: 'bg-sky-500', text: 'text-sky-700', note: 'Info' },
                            { name: 'Violet', class: 'bg-violet-500', text: 'text-violet-700', note: 'Metadata' }
                        ] %}
                        {% for swatch in swatches %}
                            <div class="rounded-md border border-slate-200 bg-white p-3">
                                <span class="block h-8 rounded {{ swatch.class }}"></span>
                                <p class="mt-2 text-sm font-semibold {{ swatch.text }}">{{ swatch.name }}</p>
                                <p class="text-xs text-slate-400">{{ swatch.note }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>

        <section id="buttons" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h2 class="text-sm font-semibold text-slate-700">Buttons</h2>
            </div>
            <div class="space-y-5 px-5 py-5">
                <div class="flex flex-wrap items-center gap-3">
                    <button type="button" class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                        <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                        Primary
                    </button>
                    <button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
                        <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                        Secondary
                    </button>
                    <button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 shadow-sm hover:bg-red-100">
                        <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Danger
                    </button>
                    <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-600 shadow-sm hover:bg-slate-50" title="Settings">
                        <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </button>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <button type="button" class="rounded-md bg-emerald-600 px-2.5 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700">Small</button>
                    <button type="button" class="rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-slate-700 shadow-sm hover:bg-slate-50">Small Secondary</button>
                    <button type="button" disabled class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white opacity-50">Disabled</button>
                    <a href="#" class="text-sm font-medium text-emerald-700 hover:text-emerald-800 hover:underline">Text Link</a>
                </div>
            </div>
        </section>

        <section id="forms" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h2 class="text-sm font-semibold text-slate-700">Form Fields</h2>
            </div>
            <div class="grid gap-6 px-5 py-5 xl:grid-cols-2">
                <div class="space-y-4">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="guide-title">Text Input <span class="text-red-500">*</span></label>
                        <input id="guide-title" name="guide_title" type="text" class="{{ field_classes }}" placeholder="Enter a title">
                        <p class="mt-1 text-xs text-slate-400">Use helper text for constraints and defaults.</p>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="guide-handle">Input Group</label>
                        <div class="flex rounded-md shadow-sm">
                            <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/articles/</span>
                            <input id="guide-handle" name="guide_handle" type="text" class="w-full rounded-r-md border border-slate-300 px-3 py-2 font-mono text-sm placeholder:text-slate-400 placeholder:font-sans focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="my-article">
                        </div>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="guide-description">Textarea</label>
                        <textarea id="guide-description" name="guide_description" rows="4" class="{{ field_classes }}" placeholder="Write a concise description..."></textarea>
                    </div>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="guide-select">Select</label>
                        <select id="guide-select" name="guide_select" class="{{ field_classes }}">
                            <option>Draft</option>
                            <option>Published</option>
                            <option>Archived</option>
                        </select>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700" for="guide-error">Validation State</label>
                        <input id="guide-error" name="guide_error" type="text" class="w-full rounded-md border border-red-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20" placeholder="Required value" aria-invalid="true" aria-describedby="guide-error-message">
                        <p id="guide-error-message" class="mt-1 text-xs text-red-600">This field is required.</p>
                    </div>
                    <div class="space-y-2">
                        <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                            <input type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                            Checkbox option
                        </label>
                        <label class="flex cursor-pointer items-center gap-2.5 text-sm text-slate-700">
                            <input type="radio" name="guide-radio" class="border-slate-300 text-emerald-600 focus:ring-emerald-500" checked>
                            Radio option
                        </label>
                    </div>
                    <div class="flex items-center justify-between rounded-lg bg-slate-50 px-4 py-3.5 ring-1 ring-slate-200">
                        <div>
                            <p class="text-sm font-medium text-slate-800">Toggle</p>
                            <p class="mt-0.5 text-xs text-slate-500">Use for binary settings.</p>
                        </div>
                        <label class="relative inline-flex cursor-pointer items-center">
                            <input type="checkbox" class="peer sr-only" checked>
                            <div class="peer h-6 w-11 rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow after:transition-all after:content-[''] peer-checked:bg-emerald-500 peer-checked:after:translate-x-5 peer-focus:ring-2 peer-focus:ring-emerald-500/30"></div>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section id="alerts" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h2 class="text-sm font-semibold text-slate-700">Alerts, Badges, And Status</h2>
            </div>
            <div class="space-y-4 px-5 py-5">
                {% set alerts = [
                    { name: 'Success', border: 'border-emerald-200', bg: 'bg-emerald-50', icon: 'text-emerald-500', title: 'text-emerald-800', body: 'text-emerald-700', path: 'M5 13l4 4L19 7', copy: 'Record saved successfully.' },
                    { name: 'Info', border: 'border-sky-200', bg: 'bg-sky-50', icon: 'text-sky-500', title: 'text-sky-800', body: 'text-sky-700', path: 'M13 16h-1v-4h-1m1-4h.01M12 18a6 6 0 100-12 6 6 0 000 12z', copy: 'A background process is running.' },
                    { name: 'Warning', border: 'border-amber-200', bg: 'bg-amber-50', icon: 'text-amber-500', title: 'text-amber-800', body: 'text-amber-700', path: 'M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z', copy: 'Unsaved changes may be lost.' },
                    { name: 'Danger', border: 'border-red-200', bg: 'bg-red-50', icon: 'text-red-500', title: 'text-red-800', body: 'text-red-700', path: 'M12 9v2m0 4h.01M4.93 4.93l14.14 14.14', copy: 'Delete actions should be confirmed.' }
                ] %}
                {% for alert in alerts %}
                    <div class="rounded-lg border {{ alert.border }} {{ alert.bg }} p-4">
                        <div class="flex items-start gap-3">
                            <svg class="mt-0.5 h-5 w-5 shrink-0 {{ alert.icon }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="{{ alert.path }}"/>
                            </svg>
                            <div>
                                <p class="text-sm font-semibold {{ alert.title }}">{{ alert.name }}</p>
                                <p class="mt-1 text-sm {{ alert.body }}">{{ alert.copy }}</p>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Active</span>
                    <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">Draft</span>
                    <span class="inline-flex rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Pending</span>
                    <span class="inline-flex rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Error</span>
                    <span class="inline-flex rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-700">Queued</span>
                </div>
            </div>
        </section>

        <section id="tables" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <h2 class="text-sm font-semibold text-slate-700">Tables And Lists</h2>
                    <div class="flex flex-wrap items-center gap-2">
                        <select class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                            <option>All statuses</option>
                            <option>Active</option>
                            <option>Draft</option>
                        </select>
                        <input class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-52" placeholder="Search..." type="search">
                    </div>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-4 py-3"><input type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></th>
                            <th class="px-4 py-3 font-semibold">Name</th>
                            <th class="px-4 py-3 font-semibold">Handle</th>
                            <th class="px-4 py-3 font-semibold">Status</th>
                            <th class="px-4 py-3 font-semibold">Updated</th>
                            <th class="px-4 py-3 font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        {% set rows = [
                            { name: 'Getting Started', handle: 'getting-started', status: 'Published', updated: 'May 5, 2026' },
                            { name: 'API Overview', handle: 'api-overview', status: 'Draft', updated: 'May 2, 2026' },
                            { name: 'Release Notes', handle: 'release-notes', status: 'Review', updated: 'Apr 28, 2026' }
                        ] %}
                        {% for row in rows %}
                            <tr class="hover:bg-slate-50/60">
                                <td class="px-4 py-3"><input type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                <td class="px-4 py-3">
                                    <a class="font-medium text-slate-900 hover:text-emerald-700" href="#">{{ row.name }}</a>
                                    <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                        <a href="#" class="text-emerald-600 hover:underline">View</a>
                                        <span class="text-slate-300">|</span>
                                        <a href="#" class="text-emerald-600 hover:underline">Edit</a>
                                        <span class="text-slate-300">|</span>
                                        <a href="#" class="text-red-500 hover:underline">Delete</a>
                                    </div>
                                </td>
                                <td class="px-4 py-3 font-mono text-xs text-slate-500">{{ row.handle }}</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex rounded-full {{ row.status == 'Published' ? 'bg-emerald-50 text-emerald-700' : (row.status == 'Review' ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-600') }} px-2 py-0.5 text-xs font-medium">{{ row.status }}</span>
                                </td>
                                <td class="px-4 py-3 text-slate-500">{{ row.updated }}</td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-1.5">
                                        <a href="#" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="View">
                                            <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                        </a>
                                        <a href="#" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="Edit">
                                            <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="flex flex-col gap-3 border-t border-slate-200 bg-slate-50 px-4 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                <span class="text-xs text-slate-500">Showing 1-3 of 24 records</span>
                <nav class="flex items-center gap-1" aria-label="Pagination">
                    <a class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-emerald-600 text-sm font-semibold text-white shadow-sm" href="#" aria-current="page">1</a>
                    <a class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50" href="#">2</a>
                    <a class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50" href="#">3</a>
                </nav>
            </div>
        </section>

        <section id="icons" class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h2 class="text-sm font-semibold text-slate-700">Icons And Glyphs</h2>
            </div>
            <div class="px-5 py-5">
                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                    {% set icons = [
                        { label: 'Create', path: 'M12 4v16m8-8H4', tone: 'text-emerald-600 bg-emerald-50' },
                        { label: 'Edit', path: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', tone: 'text-sky-600 bg-sky-50' },
                        { label: 'Delete', path: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', tone: 'text-red-600 bg-red-50' },
                        { label: 'Search', path: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', tone: 'text-slate-600 bg-slate-100' },
                        { label: 'Upload', path: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12', tone: 'text-violet-600 bg-violet-50' },
                        { label: 'Lock', path: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', tone: 'text-amber-600 bg-amber-50' },
                        { label: 'Media', path: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', tone: 'text-emerald-600 bg-emerald-50' },
                        { label: 'Settings', path: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', tone: 'text-slate-600 bg-slate-100' }
                    ] %}
                    {% for icon in icons %}
                        <div class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-3">
                            <span class="inline-flex h-9 w-9 items-center justify-center rounded-md {{ icon.tone }}">
                                <svg class="{{ icon_classes }}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ icon.path }}"/>
                                </svg>
                            </span>
                            <div>
                                <p class="text-sm font-semibold text-slate-800">{{ icon.label }}</p>
                                <p class="text-xs text-slate-400">Inline SVG</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="mt-5 rounded-lg border border-slate-200 bg-slate-50 p-4">
                    <p class="text-sm font-semibold text-slate-700">Glyph Pairings</p>
                    <div class="mt-3 flex flex-wrap gap-2 text-sm">
                        <span class="inline-flex items-center rounded-md bg-white px-2.5 py-1.5 font-mono text-slate-600 ring-1 ring-slate-200"># handle</span>
                        <span class="inline-flex items-center rounded-md bg-white px-2.5 py-1.5 font-mono text-slate-600 ring-1 ring-slate-200">* required</span>
                        <span class="inline-flex items-center rounded-md bg-white px-2.5 py-1.5 font-mono text-slate-600 ring-1 ring-slate-200">/ path</span>
                        <span class="inline-flex items-center rounded-md bg-white px-2.5 py-1.5 font-mono text-slate-600 ring-1 ring-slate-200">@ user</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
