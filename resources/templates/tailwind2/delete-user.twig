{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Delete User' %}
{% set page_heading = 'Delete User' %}
{% set active_nav = 'users' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-slate-800" href="users.twig">Users</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete User</h1>
            <p class="mt-1 text-sm text-slate-500">Review ownership and access before removing this account.</p>
        </div>
        <a href="users.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">Cancel</a>
    </div>

    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <div>
                <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                <p class="mt-1 text-sm text-red-700">Deleting Jane Smith removes login access and profile data. Reassign content before continuing.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">User Being Deleted</h5></div>
                <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Name</dt><dd class="font-semibold text-slate-900">Jane Smith</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Email</dt><dd class="text-slate-700">jane@example.com</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Roles</dt><dd class="text-slate-700">Administrator, Editor</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Articles</dt><dd class="font-semibold text-slate-900">36</dd></div>
                </dl>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Content Reassignment</h5></div>
                <div class="space-y-4 px-5 py-5">
                    <label class="flex items-start gap-3">
                        <input type="radio" name="content_action" value="reassign" checked class="mt-0.5 border-slate-300 text-emerald-600 focus:ring-emerald-500">
                        <span class="text-sm text-slate-700"><span class="font-medium">Reassign authored content</span><span class="mt-0.5 block text-xs text-slate-500">Move articles and drafts to another user.</span></span>
                    </label>
                    <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option>Morgan Lee</option>
                        <option>Avery Stone</option>
                        <option>Riley Chen</option>
                    </select>
                    <label class="flex items-start gap-3">
                        <input type="radio" name="content_action" value="delete" class="mt-0.5 border-slate-300 text-red-600 focus:ring-red-500">
                        <span class="text-sm text-slate-700"><span class="font-medium text-red-700">Delete user-owned drafts</span><span class="mt-0.5 block text-xs text-slate-500">Published content remains assigned to system.</span></span>
                    </label>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                <div class="border-b border-red-100 bg-red-50 px-5 py-3"><h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5></div>
                <form id="delete-form" method="POST" action="#" class="px-5 py-5">
                    <input type="hidden" name="_method" value="DELETE">
                    <div class="mb-4 rounded-md bg-slate-50 px-4 py-3 text-sm text-slate-700">Select the toggle to confirm deletion of <strong>Jane Smith</strong>.</div>
                    <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                        <span class="text-sm font-medium text-slate-700">I understand this user will be permanently deleted</span>
                        <input class="peer sr-only" type="checkbox" name="confirm_delete" required>
                        <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:mt-1 after:ml-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                    </label>
                    <button id="delete-btn" type="submit" class="mt-5 w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">Permanently Delete User</button>
                    <a href="edit-user.twig" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Back to Edit</a>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
