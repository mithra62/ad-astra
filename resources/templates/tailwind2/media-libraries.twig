<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Media Libraries</title>
    {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <div class="nav-group">
                <input id="nav-content" type="checkbox">
                <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Content</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-media" type="checkbox" checked>
                <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700">
                    <span>Media</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 text-emerald-700" href="media-libraries.twig">Libraries</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="media-library.twig">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="media-upload.twig">Upload</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-users" type="checkbox">
                <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <div class="flex min-w-0 flex-col">

        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Media Libraries</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Media</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Libraries</span>
                    </nav>
                </div>
            </div>
        </div>

        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>

        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-libraries.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
                    Libraries
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-media-library.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    New Library
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">View Library</a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
            </nav>
        </div>

        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Media</h5>
                    </div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-libraries.twig">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
                            Libraries
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-media-library.twig">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            New Library
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            View Library
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                            Upload
                        </a>
                    </nav>
                </div>
            </aside>

            <div class="flex min-w-0 flex-col gap-5">

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Media Libraries</h1>
                        <p class="mt-1 text-sm text-slate-500">Manage available media libraries and the storage rules for each one.</p>
                    </div>
                    <a class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:self-auto" href="create-media-library.twig">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                        Add Media Library
                    </a>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Overview</h5></div>
                    <div class="grid grid-cols-2 divide-x divide-y divide-slate-200 sm:grid-cols-4 sm:divide-y-0">
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Libraries</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">4</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total Files</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">1,284</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Storage Used</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">42 GB</p></div>
                        <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Pending Review</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">18</p></div>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                            <h5 class="text-sm font-semibold text-slate-700">All Libraries</h5>
                            <div class="flex flex-wrap items-center gap-2">
                                <select id="library-status" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                                    <option value="">All statuses</option>
                                    <option value="active">Active</option>
                                    <option value="restricted">Restricted</option>
                                    <option value="archived">Archived</option>
                                </select>
                                <input id="library-search" class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-52" placeholder="Search libraries..." type="search">
                            </div>
                        </div>
                    </div>

                    {% set libraries = [
                        {name: 'Marketing Assets', handle: 'marketing-assets', status: 'active', files: '342', storage: '8.4 GB', driver: 'Local Disk', visibility: 'Public', max_size: '50 MB', types: 'Images, documents, video', updated: 'Apr 26, 2026'},
                        {name: 'Product Media', handle: 'product-media', status: 'active', files: '516', storage: '18.7 GB', driver: 'Amazon S3', visibility: 'Public', max_size: '100 MB', types: 'Images, video', updated: 'Apr 24, 2026'},
                        {name: 'Private Documents', handle: 'private-documents', status: 'restricted', files: '211', storage: '5.2 GB', driver: 'Local Disk', visibility: 'Private', max_size: '25 MB', types: 'PDF, DOCX, XLSX', updated: 'Apr 21, 2026'},
                        {name: 'Brand Archive', handle: 'brand-archive', status: 'archived', files: '215', storage: '9.9 GB', driver: 'Backblaze B2', visibility: 'Private', max_size: '75 MB', types: 'Images, documents', updated: 'Mar 30, 2026'}
                    ] %}

                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                            <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                                <tr>
                                    <th class="px-4 py-3"><input id="select-all" type="checkbox" class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></th>
                                    <th class="px-4 py-3 font-semibold">Library</th>
                                    <th class="px-4 py-3 font-semibold">Storage</th>
                                    <th class="px-4 py-3 font-semibold">Rules</th>
                                    <th class="px-4 py-3 text-center font-semibold">Files</th>
                                    <th class="px-4 py-3 font-semibold">Updated</th>
                                    <th class="px-4 py-3 font-semibold">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="library-tbody" class="divide-y divide-slate-100 bg-white">
                                {% for library in libraries %}
                                <tr class="hover:bg-slate-50/60" data-name="{{ library.name|lower }} {{ library.handle|lower }}" data-status="{{ library.status }}">
                                    <td class="px-4 py-3"><input type="checkbox" name="ids[]" value="{{ library.handle }}" class="row-cb rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"></td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-emerald-50 text-emerald-600 ring-1 ring-emerald-100">
                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
                                            </div>
                                            <div class="min-w-0">
                                                <a class="font-medium text-slate-900 hover:text-emerald-700" href="media-library.twig">{{ library.name }}</a>
                                                <div class="row-actions mt-0.5 flex items-center gap-2 text-xs">
                                                    <a href="media-library.twig" class="text-emerald-600 hover:underline">View</a><span class="text-slate-300">|</span>
                                                    <a href="#" class="text-emerald-600 hover:underline">Edit Settings</a><span class="text-slate-300">|</span>
                                                    <a href="#" class="text-red-500 hover:underline">Delete</a>
                                                </div>
                                                <p class="mt-0.5 font-mono text-xs text-slate-400">{{ library.handle }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <p class="font-medium text-slate-700">{{ library.driver }}</p>
                                        <p class="text-xs text-slate-400">{{ library.storage }} used</p>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex flex-col gap-1">
                                            <span class="w-fit rounded-full px-2 py-0.5 text-xs font-medium {% if library.status == 'active' %}bg-emerald-50 text-emerald-700{% elseif library.status == 'restricted' %}bg-amber-50 text-amber-700{% else %}bg-slate-100 text-slate-600{% endif %}">{{ library.status|title }}</span>
                                            <span class="text-xs text-slate-500">{{ library.visibility }} / {{ library.max_size }}</span>
                                            <span class="text-xs text-slate-400">{{ library.types }}</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-center font-medium text-slate-800">{{ library.files }}</td>
                                    <td class="px-4 py-3 text-slate-500">{{ library.updated }}</td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-1.5">
                                            <a href="media-library.twig" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="View Library">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                            </a>
                                            <a href="#" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-emerald-600" title="Edit Settings">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                            </a>
                                            <a href="#" class="rounded p-1 text-slate-400 hover:bg-red-50 hover:text-red-600" title="Delete">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="flex flex-col gap-3 border-t border-slate-200 bg-slate-50 px-4 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                        <div class="flex flex-wrap items-center gap-2">
                            <select id="bulk-action" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                                <option value="">Bulk action</option>
                                <option value="activate">Activate</option>
                                <option value="archive">Archive</option>
                                <option value="delete">Delete</option>
                            </select>
                            <button type="button" onclick="applyBulk()" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Apply</button>
                            <span id="selected-count" class="hidden text-xs text-slate-500"><span id="selected-num">0</span> selected</span>
                        </div>
                        <span class="text-xs text-slate-500" id="row-count">Showing 4 libraries</span>
                    </div>
                </div>

            </div>
        </div>

        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p>
                <nav class="flex items-center gap-4 text-xs text-slate-400">
                    <a class="hover:text-slate-600" href="#">Documentation</a>
                    <a class="hover:text-slate-600" href="#">Support</a>
                    <a class="hover:text-slate-600" href="#">Privacy</a>
                    <span class="text-slate-300">|</span>
                    <span>v1.0.0</span>
                </nav>
            </div>
        </footer>

    </div>
</div>

</body>
</html>
