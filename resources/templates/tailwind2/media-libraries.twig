{% extends 'admin._inc._layout' %}

{% set page_title = 'Media Libraries' %}
{% set page_heading = 'Media Libraries' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-800">Media Libraries</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-libraries.twig">Libraries</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">View Library</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Media</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-libraries.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                    </svg>
                    Libraries
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-library.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    View Library
                </a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                    </svg>
                    Upload
                </a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    {% set libraries = [
        {name: 'Marketing Assets', handle: 'marketing-assets', status: 'active', files: '342', storage: '8.4 GB', driver: 'Local Disk', visibility: 'Public', max_size: '50 MB', types: 'Images, documents, video', updated: 'Apr 26, 2026'},
        {name: 'Product Media', handle: 'product-media', status: 'active', files: '516', storage: '18.7 GB', driver: 'Amazon S3', visibility: 'Public', max_size: '100 MB', types: 'Images, video', updated: 'Apr 24, 2026'},
        {name: 'Private Documents', handle: 'private-documents', status: 'restricted', files: '211', storage: '5.2 GB', driver: 'Local Disk', visibility: 'Private', max_size: '25 MB', types: 'PDF, DOCX, XLSX', updated: 'Apr 21, 2026'},
        {name: 'Brand Archive', handle: 'brand-archive', status: 'archived', files: '215', storage: '9.9 GB', driver: 'Backblaze B2', visibility: 'Private', max_size: '75 MB', types: 'Images, documents', updated: 'Mar 30, 2026'}
    ] %}

    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Media Libraries</h1>
                <p class="mt-1 text-sm text-slate-500">Manage media libraries and the storage rules for each one.</p>
            </div>
            <a class="inline-flex items-center gap-1.5 self-start rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 sm:self-auto" href="#">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add Media Library
            </a>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Overview</h5>
            </div>
            <div class="grid grid-cols-2 divide-x divide-y divide-slate-200 sm:grid-cols-4 sm:divide-y-0">
                <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Libraries</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">4</p></div>
                <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total Files</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">1,284</p></div>
                <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Storage Used</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">42 GB</p></div>
                <div class="p-4 sm:p-5"><p class="text-xs font-medium uppercase tracking-wide text-slate-500">Pending Review</p><p class="mt-1.5 text-3xl font-semibold text-slate-900">18</p></div>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <h5 class="text-sm font-semibold text-slate-700">All Libraries</h5>
                    <div class="flex flex-wrap items-center gap-2">
                        <select class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                            <option>All statuses</option>
                            <option>Active</option>
                            <option>Restricted</option>
                            <option>Archived</option>
                        </select>
                        <input class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 sm:w-52" placeholder="Search libraries" type="search">
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="px-4 py-3" scope="col">Library</th>
                        <th class="px-4 py-3" scope="col">Storage</th>
                        <th class="px-4 py-3" scope="col">Rules</th>
                        <th class="px-4 py-3 text-center" scope="col">Files</th>
                        <th class="px-4 py-3" scope="col">Updated</th>
                        <th class="px-4 py-3 text-right" scope="col">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                    {% for library in libraries %}
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-emerald-50 text-emerald-600 ring-1 ring-emerald-100">
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                                        </svg>
                                    </div>
                                    <div class="min-w-0">
                                        <a class="font-medium text-slate-900 hover:text-emerald-700" href="media-library.twig">{{ library.name }}</a>
                                        <p class="mt-0.5 font-mono text-xs text-slate-400">{{ library.handle }}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3.5">
                                <p class="font-medium text-slate-700">{{ library.driver }}</p>
                                <p class="text-xs text-slate-400">{{ library.storage }} used</p>
                            </td>
                            <td class="px-4 py-3.5">
                                <div class="flex flex-col gap-1">
                                    <span class="w-fit rounded-full px-2 py-0.5 text-xs font-medium {% if library.status == 'active' %}bg-emerald-50 text-emerald-700{% elseif library.status == 'restricted' %}bg-amber-50 text-amber-700{% else %}bg-slate-100 text-slate-600{% endif %}">{{ library.status|title }}</span>
                                    <span class="text-xs text-slate-500">{{ library.visibility }} / {{ library.max_size }}</span>
                                    <span class="text-xs text-slate-400">{{ library.types }}</span>
                                </div>
                            </td>
                            <td class="px-4 py-3.5 text-center font-medium text-slate-800">{{ library.files }}</td>
                            <td class="px-4 py-3.5 text-slate-500">{{ library.updated }}</td>
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-end gap-1">
                                    <a class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" href="media-library.twig" title="View">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </a>
                                    <a class="inline-flex items-center justify-center rounded-md border border-slate-200 p-1.5 text-slate-400 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700" href="#" title="Edit">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
