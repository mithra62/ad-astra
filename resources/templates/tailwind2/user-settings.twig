<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>User Settings</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .nav-group input[type="checkbox"] { display: none; }
        .nav-group input[type="checkbox"]:checked ~ .nav-subitems { display: block; }
        .nav-group input[type="checkbox"]:checked ~ label .nav-chevron { transform: rotate(90deg); }
        .nav-subitems { display: none; }
        .nav-chevron { transition: transform 0.15s ease; display: inline-block; }
        #sidebar-toggle { display: none; }
        #sidebar-toggle:checked ~ .app-shell #primary-sidebar { transform: translateX(0); }
        #sidebar-toggle:checked ~ .sidebar-overlay { display: block; }
        #secnav-toggle { display: none; }
        #secnav-toggle:checked ~ .app-shell #secondary-nav-panel { display: block; }
        #secnav-toggle:checked ~ .app-shell .secnav-chevron { transform: rotate(180deg); }
        .secnav-chevron { transition: transform 0.15s ease; display: inline-block; }
        .avatar-placeholder { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
    </style>
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">

<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle"  type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>

<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">

    <!-- Primary Sidebar -->
    <aside id="primary-sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto
                  border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200
                  lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block">
            <a class="text-lg font-semibold tracking-tight" href="#">Admin</a>
            <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </label>
        </div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8">
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Dashboard</a>
            <div class="nav-group">
                <input id="nav-content" type="checkbox">
                <label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Content</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Pages</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Categories</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Tags</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-media" type="checkbox">
                <label for="nav-media" class="flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">
                    <span>Media</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Library</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Upload</a></li>
                </ul>
            </div>
            <div class="nav-group">
                <input id="nav-users" type="checkbox" checked>
                <label for="nav-users" class="flex cursor-pointer items-center justify-between rounded-md bg-slate-100 px-3 py-2 text-slate-800 hover:bg-slate-100">
                    <span>Users</span>
                    <span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
                </label>
                <ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3">
                    <li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 font-semibold text-emerald-700" href="#">All Users</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Roles</a></li>
                    <li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Invitations</a></li>
                </ul>
            </div>
            <a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a>
        </nav>
    </aside>

    <!-- Main column -->
    <div class="flex min-w-0 flex-col">

        <!-- Topbar -->
        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6">
            <div class="flex items-center gap-3">
                <label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </label>
                <div>
                    <h4 class="text-sm font-semibold text-slate-800 sm:text-base">Edit User</h4>
                    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
                        <a class="hover:text-slate-800" href="#"><svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg> Dashboard</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <a class="hover:text-slate-800" href="#">Users</a>
                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-slate-800">Jane Smith</span>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Mobile secnav toggle -->
        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
            <span class="flex items-center gap-2"><svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/></svg> Section Navigation</span>
            <span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span>
        </label>

        <!-- Mobile secnav panel -->
        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
            <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
                <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    Password &amp; Security
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    Notifications
                </a>
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                    API Tokens
                </a>
            </nav>
        </div>

        <!-- Body: secnav card + content -->
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">

            <!-- Secondary nav card (desktop) -->
            <aside class="hidden h-fit lg:block">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Jane Smith</h5></div>
                    <nav class="p-2">
                        <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Profile
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            Password &amp; Security
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            Notifications
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                            API Tokens
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Content area -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Avatar + name header card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="flex flex-col items-center gap-4 px-6 py-6 sm:flex-row sm:items-start">
                        <!-- Avatar -->
                        <div class="relative shrink-0">
                            <div class="avatar-placeholder flex h-20 w-20 items-center justify-center rounded-full text-2xl font-bold text-white">JS</div>
                            <button type="button" class="absolute bottom-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white bg-slate-700 text-white shadow hover:bg-slate-600" title="Change avatar">
                                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </button>
                        </div>
                        <!-- Name / meta -->
                        <div class="text-center sm:text-left">
                            <h2 class="text-lg font-semibold text-slate-900">Jane Smith</h2>
                            <p class="text-sm text-slate-500">jane@example.com</p>
                            <div class="mt-1.5 flex flex-wrap items-center justify-center gap-2 sm:justify-start">
                                <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">Editor</span>
                                <span class="text-xs text-slate-400">Member since Jan 12, 2023</span>
                                <span class="text-xs text-slate-400">·</span>
                                <span class="text-xs text-slate-400">Last login 2 hours ago</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Profile form card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-6 py-4">
                        <h3 class="text-sm font-semibold text-slate-800">Profile Information</h3>
                        <p class="mt-0.5 text-xs text-slate-500">Update this user's name, email address, and public profile details.</p>
                    </div>
                    <form class="divide-y divide-slate-100">
                        <!-- Name row -->
                        <div class="grid gap-4 px-6 py-5 sm:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-xs font-medium text-slate-700" for="first_name">First Name</label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="first_name" name="first_name" type="text" value="Jane">
                            </div>
                            <div>
                                <label class="mb-1.5 block text-xs font-medium text-slate-700" for="last_name">Last Name</label>
                                <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="last_name" name="last_name" type="text" value="Smith">
                            </div>
                        </div>
                        <!-- Email row -->
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="email">Email Address</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 sm:max-w-md" id="email" name="email" type="email" value="jane@example.com">
                            <p class="mt-1 text-xs text-slate-500">Changing this will require email re-verification.</p>
                        </div>
                        <!-- Username -->
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="username">Username</label>
                            <div class="flex max-w-md items-center rounded-md border border-slate-300 bg-slate-50 shadow-sm focus-within:border-emerald-500 focus-within:ring-1 focus-within:ring-emerald-500">
                                <span class="border-r border-slate-300 px-3 py-2 text-sm text-slate-500">@</span>
                                <input class="flex-1 rounded-r-md bg-transparent px-3 py-2 text-sm focus:outline-none" id="username" name="username" type="text" value="janesmith">
                            </div>
                        </div>
                        <!-- Bio -->
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="bio">Bio</label>
                            <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="bio" name="bio" rows="3" placeholder="A short bio about this user…">Senior editor with a focus on technology and culture.</textarea>
                            <p class="mt-1 text-xs text-slate-500">Displayed publicly on the author page. Max 200 characters.</p>
                        </div>
                        <!-- Website -->
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="website">Website</label>
                            <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 sm:max-w-md" id="website" name="website" type="url" placeholder="https://example.com" value="https://janesmith.dev">
                        </div>
                        <!-- Actions -->
                        <div class="flex items-center gap-3 bg-slate-50 px-6 py-4">
                            <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Save Changes</button>
                            <button type="reset" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Reset</button>
                        </div>
                    </form>
                </div>

                <!-- Account Preferences card -->
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-6 py-4">
                        <h3 class="text-sm font-semibold text-slate-800">Account Preferences</h3>
                        <p class="mt-0.5 text-xs text-slate-500">Role, language, and display settings for this account.</p>
                    </div>
                    <form class="divide-y divide-slate-100">
                        <!-- Role -->
                        <div class="px-6 py-5">
                            <label class="mb-1.5 block text-xs font-medium text-slate-700" for="role">Role</label>
                            <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 sm:max-w-xs" id="role" name="role">
                                <option>Administrator</option>
                                <option selected>Editor</option>
                                <option>Author</option>
                                <option>Contributor</option>
                                <option>Subscriber</option>
                            </select>
                            <p class="mt-1 text-xs text-slate-500">Determines what this user can view and modify in the admin.</p>
                        </div>
                        <!-- Language -->
                        <div class="grid gap-4 px-6 py-5 sm:grid-cols-2">
                            <div>
                                <label class="mb-1.5 block text-xs font-medium text-slate-700" for="language">Language</label>
                                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="language" name="language">
                                    <option selected>English (US)</option>
                                    <option>English (UK)</option>
                                    <option>Español</option>
                                    <option>Français</option>
                                    <option>Deutsch</option>
                                    <option>日本語</option>
                                </select>
                            </div>
                            <div>
                                <label class="mb-1.5 block text-xs font-medium text-slate-700" for="timezone">Timezone</label>
                                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500" id="timezone" name="timezone">
                                    <option>UTC</option>
                                    <option selected>America/New_York</option>
                                    <option>America/Chicago</option>
                                    <option>America/Denver</option>
                                    <option>America/Los_Angeles</option>
                                    <option>Europe/London</option>
                                    <option>Europe/Paris</option>
                                    <option>Asia/Tokyo</option>
                                </select>
                            </div>
                        </div>
                        <!-- Notification toggles -->
                        <div class="px-6 py-5">
                            <p class="mb-3 text-xs font-medium text-slate-700">Email Notifications</p>
                            <div class="space-y-3">
                                <label class="flex items-start gap-3">
                                    <input type="checkbox" checked class="mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                    <span class="text-sm text-slate-700">New comments on my articles</span>
                                </label>
                                <label class="flex items-start gap-3">
                                    <input type="checkbox" checked class="mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                    <span class="text-sm text-slate-700">Articles published in my name</span>
                                </label>
                                <label class="flex items-start gap-3">
                                    <input type="checkbox" class="mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                    <span class="text-sm text-slate-700">Weekly digest</span>
                                </label>
                                <label class="flex items-start gap-3">
                                    <input type="checkbox" class="mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
                                    <span class="text-sm text-slate-700">System announcements</span>
                                </label>
                            </div>
                        </div>
                        <!-- Actions -->
                        <div class="flex items-center gap-3 bg-slate-50 px-6 py-4">
                            <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Save Preferences</button>
                            <button type="reset" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Reset</button>
                        </div>
                    </form>
                </div>

                <!-- Danger zone -->
                <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                    <div class="border-b border-red-200 bg-red-50 px-6 py-4">
                        <h3 class="text-sm font-semibold text-red-800">Danger Zone</h3>
                        <p class="mt-0.5 text-xs text-red-600">These actions are irreversible. Proceed with caution.</p>
                    </div>
                    <div class="divide-y divide-slate-100">
                        <div class="flex items-center justify-between px-6 py-4">
                            <div>
                                <p class="text-sm font-medium text-slate-800">Suspend Account</p>
                                <p class="text-xs text-slate-500">Prevent this user from logging in without deleting their content.</p>
                            </div>
                            <button type="button" class="rounded-md border border-amber-300 bg-amber-50 px-3 py-1.5 text-sm font-medium text-amber-800 hover:bg-amber-100">Suspend</button>
                        </div>
                        <div class="flex items-center justify-between px-6 py-4">
                            <div>
                                <p class="text-sm font-medium text-slate-800">Delete Account</p>
                                <p class="text-xs text-slate-500">Permanently delete this user and all associated data. Cannot be undone.</p>
                            </div>
                            <button type="button" class="rounded-md border border-red-300 bg-red-50 px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-100">Delete</button>
                        </div>
                    </div>
                </div>

            </div><!-- /content area -->
        </div><!-- /body grid -->

        <!-- Footer -->
        <footer class="mt-auto border-t border-slate-200 bg-white px-6 py-4 text-xs text-slate-400">
            <div class="flex flex-col items-center justify-between gap-2 sm:flex-row">
                <span>Admin &copy; 2024. All rights reserved.</span>
                <div class="flex gap-4">
                    <a class="hover:text-slate-600" href="#">Documentation</a>
                    <a class="hover:text-slate-600" href="#">Support</a>
                    <a class="hover:text-slate-600" href="#">Privacy</a>
                </div>
            </div>
        </footer>

    </div><!-- /main column -->
</div><!-- /app-shell -->

</body>
