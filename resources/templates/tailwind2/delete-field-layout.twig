{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Delete Field Layout' %}
{% set page_heading = 'Delete Field Layout' %}
{% set active_nav = 'field-layouts' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a class="hover:text-slate-800" href="edit-field-layout.twig">Article Layout</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block content %}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete Field Layout</h1>
            <p class="mt-1 text-sm text-slate-500">Review layout usage before deleting it.</p>
        </div>
        <a href="edit-field-layout.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">Cancel</a>
    </div>

    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <div>
                <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                <p class="mt-1 text-sm text-red-700">Deleting this layout removes its tabs and field placement rules. Existing content values are not deleted.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Layout Being Deleted</h5></div>
                <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Name</dt><dd class="font-semibold text-slate-900">Article Layout</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Handle</dt><dd class="font-mono text-xs text-slate-700">article-layout</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Tabs</dt><dd class="font-semibold text-slate-900">3</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Assigned fields</dt><dd class="font-semibold text-slate-900">13</dd></div>
                    <div class="flex items-center justify-between py-2.5"><dt class="text-slate-500">Used by</dt><dd class="text-slate-700">Articles, Pages</dd></div>
                </dl>
            </div>

            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-3"><h5 class="text-sm font-semibold text-slate-700">Replacement Layout</h5></div>
                <div class="space-y-4 px-5 py-5">
                    <p class="text-sm text-slate-600">Select a layout to use for records currently assigned to this one.</p>
                    <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                        <option>Default Content Layout</option>
                        <option>Minimal Article Layout</option>
                        <option>Longform Layout</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                <div class="border-b border-red-100 bg-red-50 px-5 py-3"><h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5></div>
                <form id="delete-form" method="POST" action="#" class="px-5 py-5">
                    <input type="hidden" name="_method" value="DELETE">
                    <div class="mb-4 rounded-md bg-slate-50 px-4 py-3 text-sm text-slate-700">Select the toggle to confirm deletion of <strong>Article Layout</strong>.</div>
                    <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                        <span class="text-sm font-medium text-slate-700">I understand this layout will be permanently deleted</span>
                        <input class="peer sr-only" type="checkbox" name="confirm_delete" required>
                        <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:mt-1 after:ml-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                    </label>
                    <button id="delete-btn" type="submit" class="mt-5 w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700">Permanently Delete Layout</button>
                    <a href="edit-field-layout.twig" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Back to Edit</a>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
