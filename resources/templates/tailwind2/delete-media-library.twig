{% extends 'admin._inc._layout' %}

{% set page_title = 'Delete Media Library' %}
{% set page_heading = 'Delete Media Library' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}
{% set library = {
    name: 'Marketing Assets',
    handle: 'marketing-assets',
    storage: 'Local Disk',
    visibility: 'Public',
    files: 342,
    size: '8.4 GB',
    updated: 'Apr 26, 2026'
} %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">
            <svg class="inline-block h-3 w-3 align-middle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/>
            </svg>
            Dashboard
        </a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="media-libraries.twig">Media Libraries</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="media-library.twig">{{ library.name }}</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">Libraries</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-media-library.twig">New Library</a>
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-library.twig">View Library</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Media</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">Libraries</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-media-library.twig">New Library</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-library.twig">View Library</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete Media Library</h1>
                <p class="mt-1 text-sm text-slate-500">Review storage and file impact before removing this library.</p>
            </div>
            <a href="media-library.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Library
            </a>
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                    <p class="mt-1 text-sm text-red-700">Deleting this library removes its metadata and may orphan file references in content that uses these assets.</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Library Being Deleted</h5>
                    </div>
                    <dl class="divide-y divide-slate-100 px-5 py-2 text-sm">
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Name</dt><dd class="font-semibold text-slate-900">{{ library.name }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Handle</dt><dd class="font-mono text-slate-700">{{ library.handle }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Storage</dt><dd class="text-slate-700">{{ library.storage }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Visibility</dt><dd class="text-slate-700">{{ library.visibility }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Files</dt><dd class="font-semibold text-slate-900">{{ library.files }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Storage Used</dt><dd class="font-semibold text-slate-900">{{ library.size }}</dd></div>
                        <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Updated</dt><dd class="text-slate-700">{{ library.updated }}</dd></div>
                    </dl>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">File Handling</h5>
                    </div>
                    <div class="space-y-4 px-5 py-5">
                        <label class="flex items-start gap-3">
                            <input type="radio" name="file_action" value="keep" checked class="mt-0.5 border-slate-300 text-emerald-600 focus:ring-emerald-500">
                            <span class="text-sm text-slate-700">
                                <span class="font-medium">Keep physical files</span>
                                <span class="mt-0.5 block text-xs text-slate-500">Remove the library record but leave files on the configured disk.</span>
                            </span>
                        </label>
                        <label class="flex items-start gap-3">
                            <input type="radio" name="file_action" value="delete" class="mt-0.5 border-slate-300 text-red-600 focus:ring-red-500">
                            <span class="text-sm text-slate-700">
                                <span class="font-medium text-red-700">Delete physical files</span>
                                <span class="mt-0.5 block text-xs text-slate-500">Remove library metadata and delete all files from storage.</span>
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                    <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                        <h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5>
                    </div>
                    <form id="delete-form" method="POST" action="#" class="px-5 py-5">
                        <input type="hidden" name="_method" value="DELETE">
                        <div class="mb-4 rounded-md bg-slate-50 px-4 py-3 text-sm text-slate-700">Select the toggle to confirm deletion of <strong>{{ library.name }}</strong>.</div>
                        <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                            <span class="text-sm font-medium text-slate-700">I understand this library will be permanently deleted</span>
                            <input class="peer sr-only" type="checkbox" name="confirm_removal" required>
                            <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:ml-1 after:mt-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                        </label>
                        <button type="submit" class="mt-5 w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">Delete Media Library</button>
                        <a href="media-library.twig" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
