                            Back
                        </a>
                    </div>
                </div>

                <form id="edit-form" method="POST" action="#" class="flex flex-col gap-5 lg:grid lg:grid-cols-[1fr_18rem] lg:items-start">

                    <!-- Left: main fields -->
                    <div class="flex flex-col gap-4">

                        <!-- Basic Details -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Basic Details</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="name">Name <span class="text-red-500">*</span></label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="name" name="name" type="text" value="Engineering" required>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="slug">Slug</label>
                                    <div class="flex rounded-md shadow-sm">
                                        <span class="inline-flex items-center rounded-l-md border border-r-0 border-slate-300 bg-slate-50 px-3 text-xs text-slate-500">/category/</span>
                                        <input class="w-full rounded-r-md border border-slate-300 px-3 py-2 text-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                               id="slug" name="slug" type="text" value="engineering">
                                    </div>
                                    <p class="mt-1 text-xs text-slate-400">Changing the slug will break existing links to this category.</p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="parent_id">Parent Category</label>
                                    <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                            id="parent_id" name="parent_id">
                                        <option value="" selected>— None (top-level) —</option>
                                        <option value="4">Product</option>
                                        <option value="5">&nbsp;&nbsp;&nbsp;└ Features</option>
                                        <option value="6">&nbsp;&nbsp;&nbsp;└ Roadmap</option>
                                        <option value="7">Company</option>
                                        <option value="8">&nbsp;&nbsp;&nbsp;└ Announcements</option>
                                        <option value="9">Operations</option>
                                        <option value="10">Security</option>
                                        <option value="11">Tutorials</option>
                                        <option value="12">&nbsp;&nbsp;&nbsp;└ Getting Started</option>
                                    </select>
                                    <p class="mt-1 text-xs text-slate-400">This category is excluded from its own dropdown to prevent circular nesting.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Description</h5>
                            </div>
                            <div class="px-5 py-5">
                                <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                          id="description" name="description" rows="4">All things engineering &amp; software development.</textarea>
                                <p class="mt-1 text-xs text-slate-400">Some themes display this description on the category archive page.</p>
                            </div>
                        </div>

                        <!-- SEO -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">SEO</h5>
                            </div>
                            <div class="space-y-4 px-5 py-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_title">Meta Title</label>
                                    <input class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                           id="meta_title" name="meta_title" type="text"
                                           value="Engineering Articles &amp; Tutorials"
                                           maxlength="70">
                                    <p class="mt-1 flex justify-between text-xs text-slate-400">
                                        <span>Recommended: 50–60 characters.</span>
                                        <span id="meta-title-count" class="tabular-nums">35 / 70</span>
                                    </p>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-slate-700" for="meta_description">Meta Description</label>
                                    <textarea class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                                              id="meta_description" name="meta_description" rows="3"
                                              maxlength="160">Explore in-depth engineering articles covering backend, frontend, DevOps, and software architecture.</textarea>
                                    <p class="mt-1 flex justify-between text-xs text-slate-400">
                                        <span>Recommended: 120–158 characters.</span>
                                        <span id="meta-desc-count" class="tabular-nums">95 / 160</span>
