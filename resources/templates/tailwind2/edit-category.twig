                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Editing</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Engineering
                        </a>
                        <div class="my-2 border-t border-slate-100"></div>
                        <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Children</p>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 pl-5" href="#">
                            <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg> Backend
                        </a>
                        <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 pl-5" href="#">
                            <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg> Frontend
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Form content -->
            <div class="flex min-w-0 flex-col gap-5">

                <!-- Page title row -->
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                        <div class="flex items-center gap-2.5">
                            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Engineering</h1>
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">Active</span>
                        </div>
                        <p class="mt-1 text-sm text-slate-500">47 articles &nbsp;·&nbsp; 2 sub-categories &nbsp;·&nbsp; Created Jan 3, 2023</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 self-start">
                        <a href="#" class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
