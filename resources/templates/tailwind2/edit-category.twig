                                        <p id="serp-url" class="mt-0.5 truncate text-xs text-green-700">https://example.com/category/engineering</p>
                                        <p id="serp-desc" class="mt-1 text-xs text-slate-500 line-clamp-2">Explore in-depth engineering articles covering backend, frontend, DevOps, and software architecture.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Articles in this category -->
                        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                            <div class="flex items-center justify-between border-b border-slate-200 px-5 py-3">
                                <h5 class="text-sm font-semibold text-slate-700">Articles in this Category</h5>
                                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">47</span>
                            </div>
                            <div class="divide-y divide-slate-100">
                                <div class="flex items-center justify-between px-5 py-3 text-sm">
                                    <a href="#" class="font-medium text-slate-800 hover:text-emerald-700">How We Reduced API Latency by 60%</a>
