{% extends 'templates::tailwind2.auth-layout' %}

{% set page_title = 'Register' %}

{% block heading %}Create account{% endblock %}
{% block subheading %}Set up access to the admin workspace.{% endblock %}

{% block content %}
    <form method="POST" action="#" class="space-y-5 px-5 py-6 sm:px-6">
        <div>
            <label for="name" class="mb-1.5 block text-sm font-medium text-slate-700">Full name</label>
            <input id="name" name="name" type="text" autocomplete="name" required
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   placeholder="Jane Admin">
        </div>

        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-slate-700">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email" required
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   placeholder="you@example.com">
        </div>

        <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-slate-700">Password</label>
            <div class="relative">
                <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8"
                       class="w-full rounded-md border border-slate-300 px-3 py-2 pr-10 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                       placeholder="Minimum 8 characters">
                <button type="button" class="auth-password-toggle absolute inset-y-0 right-0 inline-flex items-center px-3 text-slate-400 hover:text-slate-600" data-auth-password-toggle="password" aria-label="Show password">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </button>
            </div>
            <p class="mt-1 text-xs text-slate-400">Use at least 8 characters with a mix of letters and numbers.</p>
        </div>

        <div>
            <label for="password_confirmation" class="mb-1.5 block text-sm font-medium text-slate-700">Confirm password</label>
            <input id="password_confirmation" name="password_confirmation" type="password" autocomplete="new-password" required minlength="8"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
                   placeholder="Repeat password">
        </div>

        <label class="flex items-start gap-3 text-sm text-slate-600">
            <input type="checkbox" name="terms" required class="mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500">
            <span>I agree to the terms and privacy policy.</span>
        </label>

        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Create account</button>
    </form>

    <div class="border-t border-slate-200 bg-slate-50 px-5 py-4 text-center text-sm text-slate-500 sm:px-6">
        Already have an account?
        <a href="login.twig" class="font-medium text-emerald-700 hover:text-emerald-800">Sign in</a>
    </div>
{% endblock %}
