{% extends 'admin._inc._layout' %}

{% set page_title = 'Delete Media' %}
{% set page_heading = 'Delete Media' %}
{% set active_nav = 'content' %}
{% set active_secondary_nav = 'media' %}
{% set has_secondary_sidebar = true %}
{% set media = {
    name: 'hero-banner.jpg',
    library: 'Marketing Assets',
    disk: 'Local Disk',
    path: 'uploads/marketing/hero-banner.jpg',
    mime: 'image/jpeg',
    size: '842 KB',
    dimensions: '1920 x 1080',
    used_by: 6,
    updated: 'Apr 26, 2026'
} %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="{{ route('dashboard') }}">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="media-libraries.twig">Media Libraries</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a class="hover:text-slate-800" href="media-library.twig">{{ media.library }}</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block secondary_sidebar %}
    <input id="secnav-toggle" type="checkbox">

    <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden">
        <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Section Navigation
        </span>
        <span class="secnav-chevron text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </span>
    </label>

    <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <nav class="grid grid-cols-2 gap-1 sm:grid-cols-3">
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">Libraries</a>
            <a class="flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-library.twig">View Library</a>
            <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
        </nav>
    </div>

    <aside class="hidden h-fit lg:block">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-4 py-3">
                <h5 class="text-sm font-semibold text-slate-700">Media</h5>
            </div>
            <nav class="p-2">
                <a class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-libraries.twig">Libraries</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="media-library.twig">View Library</a>
                <a class="mt-0.5 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="media-upload.twig">Upload</a>
            </nav>
        </div>
    </aside>
{% endblock %}

{% block content %}
    <div class="flex min-w-0 flex-col gap-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete Media</h1>
                <p class="mt-1 text-sm text-slate-500">Review file usage before permanently removing this asset.</p>
            </div>
            <a href="media-library.twig" class="inline-flex items-center gap-1.5 self-start rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 sm:self-auto">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Library
            </a>
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                    <p class="mt-1 text-sm text-red-700">Deleting this file may break image, download, or media references in content.</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_20rem]">
            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Media Being Deleted</h5>
                    </div>
                    <div class="grid gap-5 px-5 py-5 lg:grid-cols-[12rem_1fr]">
                        <div class="flex aspect-square items-center justify-center rounded-lg bg-sky-100 text-sky-500">
                            <svg class="h-12 w-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <dl class="divide-y divide-slate-100 text-sm">
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Name</dt><dd class="font-semibold text-slate-900">{{ media.name }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Library</dt><dd class="text-slate-700">{{ media.library }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Disk</dt><dd class="text-slate-700">{{ media.disk }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Path</dt><dd class="max-w-56 truncate font-mono text-xs text-slate-700" title="{{ media.path }}">{{ media.path }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">MIME</dt><dd class="text-slate-700">{{ media.mime }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Size</dt><dd class="font-semibold text-slate-900">{{ media.size }}</dd></div>
                            <div class="flex items-center justify-between gap-4 py-2.5"><dt class="text-slate-500">Dimensions</dt><dd class="text-slate-700">{{ media.dimensions }}</dd></div>
                        </dl>
                    </div>
                </div>

                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                    <div class="border-b border-slate-200 px-5 py-3">
                        <h5 class="text-sm font-semibold text-slate-700">Usage Impact</h5>
                    </div>
                    <div class="px-5 py-5">
                        <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3">
                            <p class="text-sm font-semibold text-amber-800">{{ media.used_by }} content references found</p>
                            <p class="mt-1 text-sm text-amber-700">Review content entries that use this file before deleting it from storage.</p>
                        </div>
                        <ul class="mt-4 divide-y divide-slate-100 text-sm">
                            <li class="flex items-center justify-between gap-4 py-2.5"><span class="text-slate-700">Homepage Hero</span><span class="text-xs text-slate-400">Entry</span></li>
                            <li class="flex items-center justify-between gap-4 py-2.5"><span class="text-slate-700">Q2 Campaign Landing Page</span><span class="text-xs text-slate-400">Entry</span></li>
                            <li class="flex items-center justify-between gap-4 py-2.5"><span class="text-slate-700">Brand Guidelines</span><span class="text-xs text-slate-400">Document</span></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-5">
                <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
                    <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                        <h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5>
                    </div>
                    <form id="delete-form" method="POST" action="#" class="px-5 py-5">
                        <input type="hidden" name="_method" value="DELETE">
                        <div class="mb-4 rounded-md bg-slate-50 px-4 py-3 text-sm text-slate-700">Select the toggle to confirm deletion of <strong>{{ media.name }}</strong>.</div>
                        <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                            <span class="text-sm font-medium text-slate-700">I understand this file will be permanently deleted</span>
                            <input class="peer sr-only" type="checkbox" name="confirm_removal" required>
                            <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:ml-1 after:mt-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                        </label>
                        <button type="submit" class="mt-5 w-full rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">Delete Media</button>
                        <a href="media-library.twig" class="mt-2 block w-full rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
