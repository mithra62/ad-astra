{% extends 'templates::tailwind2.layout' %}

{% set page_title = 'Delete Item' %}
{% set page_heading = 'Delete Item' %}

{% block breadcrumbs %}
    <nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm">
        <a class="hover:text-slate-800" href="home.twig">Dashboard</a>
        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-red-600">Delete</span>
    </nav>
{% endblock %}

{% block content %}
    <div class="mx-auto flex w-full max-w-xl flex-col gap-5">
        <div>
            <h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Delete Item</h1>
            <p class="mt-1 text-sm text-slate-500">Confirm before permanently deleting this item.</p>
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                <div>
                    <p class="text-sm font-semibold text-red-800">This action cannot be undone.</p>
                    <p class="mt-1 text-sm text-red-700">Deleting this item will permanently remove it.</p>
                </div>
            </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-red-200 bg-white shadow-sm">
            <div class="border-b border-red-100 bg-red-50 px-5 py-3">
                <h5 class="text-sm font-semibold text-red-800">Confirm Deletion</h5>
            </div>
            <form method="POST" action="#" class="px-5 py-5">
                <input type="hidden" name="_method" value="DELETE">
                <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
                    <span class="text-sm font-medium text-slate-700">I understand this item will be permanently deleted</span>
                    <input class="peer sr-only" type="checkbox" name="confirm_delete" required>
                    <span class="h-6 w-11 shrink-0 rounded-full bg-slate-300 after:mt-1 after:ml-1 after:block after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition after:content-[''] peer-checked:bg-red-600 peer-checked:after:translate-x-5 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-red-500"></span>
                </label>
                <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-end">
                    <a href="#" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Cancel</a>
                    <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">Delete Item</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
