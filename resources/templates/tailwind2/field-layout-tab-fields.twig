<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title>Tab Fields</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <style>
        .nav-group input[type="checkbox"] { display: none; }
        .nav-group input[type="checkbox"]:checked ~ .nav-subitems { display: block; }
        .nav-group input[type="checkbox"]:checked ~ label .nav-chevron { transform: rotate(90deg); }
        .nav-subitems { display: none; }
        .nav-chevron { transition: transform 0.15s ease; display: inline-block; }
        #sidebar-toggle { display: none; }
        #sidebar-toggle:checked ~ .app-shell #primary-sidebar { transform: translateX(0); }
        #sidebar-toggle:checked ~ .sidebar-overlay { display: block; }
        #secnav-toggle { display: none; }
        #secnav-toggle:checked ~ .app-shell #secondary-nav-panel { display: block; }
        #secnav-toggle:checked ~ .app-shell .secnav-chevron { transform: rotate(180deg); }
        .secnav-chevron { transition: transform 0.15s ease; display: inline-block; }
        .drag-handle { cursor: grab; }
        .drag-handle:active { cursor: grabbing; }
        .sortable-ghost { opacity: 0.45; background: #f0fdf4; }
        .drop-zone-highlight { outline: 2px dashed #6ee7b7; outline-offset: -8px; }
    </style>
</head>
<body class="min-h-screen bg-slate-100 text-slate-950 antialiased">
<input id="sidebar-toggle" type="checkbox">
<input id="secnav-toggle" type="checkbox">
<label for="sidebar-toggle" class="sidebar-overlay fixed inset-0 z-20 hidden bg-slate-900/40" aria-hidden="true"></label>
<div class="app-shell min-h-screen lg:grid lg:grid-cols-[17rem_1fr]">
    <aside id="primary-sidebar" class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full overflow-y-auto border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200 lg:relative lg:inset-auto lg:z-auto lg:w-auto lg:translate-x-0 lg:transition-none">
        <div class="mb-4 flex items-center justify-between lg:block"><a class="text-lg font-semibold tracking-tight" href="#">Admin</a><label for="sidebar-toggle" class="cursor-pointer rounded-md p-1 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Close menu"><svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></label></div>
        <nav class="mt-2 space-y-1 text-sm font-medium lg:mt-8"><a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="home.twig">Dashboard</a><div class="nav-group"><input id="nav-content" type="checkbox" checked><label for="nav-content" class="flex cursor-pointer items-center justify-between rounded-md bg-emerald-50 px-3 py-2 text-emerald-700"><span>Content</span><span class="nav-chevron"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span></label><ul class="nav-subitems ml-3 mt-1 space-y-0.5 border-l border-slate-200 pl-3"><li><a class="block rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100" href="#">Articles</a></li><li><a class="block rounded-md bg-emerald-50 px-3 py-1.5 font-semibold text-emerald-700" href="edit-field-layout.twig">Field Layouts</a></li></ul></div><a class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100" href="#">Settings</a></nav>
    </aside>
    <div class="flex min-w-0 flex-col">
        <div class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6"><div class="flex items-center gap-3"><label for="sidebar-toggle" class="cursor-pointer rounded-md p-1.5 text-slate-500 hover:bg-slate-100 lg:hidden" aria-label="Open menu"><svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></label><div><h4 class="text-sm font-semibold text-slate-800 sm:text-base">Tab Fields</h4><nav class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500 sm:text-sm"><a class="hover:text-slate-800" href="#">Dashboard</a><svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg><a class="hover:text-slate-800" href="edit-field-layout.twig">Article Layout</a><svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg><span class="text-slate-800">Content Fields</span></nav></div></div></div>
        <label for="secnav-toggle" class="flex cursor-pointer items-center justify-between border-b border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 lg:hidden"><span>Section Navigation</span><span class="secnav-chevron text-slate-400"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span></label>
        <div id="secondary-nav-panel" class="hidden border-b border-slate-200 bg-white px-4 py-3 lg:hidden"><nav class="grid grid-cols-2 gap-1 sm:grid-cols-3"><a class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="edit-field-layout.twig">Layout</a><a class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-field-layout-tab.twig">New Tab</a><a class="rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="field-layout-tab-fields.twig">Tab Fields</a></nav></div>
        <div class="flex flex-1 gap-6 p-4 sm:p-6 lg:grid lg:grid-cols-[14rem_1fr]">
            <aside class="hidden h-fit lg:block"><div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"><div class="border-b border-slate-200 px-4 py-3"><h5 class="text-sm font-semibold text-slate-700">Article Layout</h5></div><nav class="p-2"><a class="block rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="edit-field-layout.twig">Layout</a><a class="mt-0.5 block rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="create-field-layout-tab.twig">New Tab</a><a class="mt-0.5 block rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="field-layout-tab-fields.twig">Content Fields</a><div class="my-2 border-t border-slate-100"></div><p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Tabs</p><a class="block rounded-md bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-700" href="#">Content</a><a class="mt-0.5 block rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">SEO</a><a class="mt-0.5 block rounded-md px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50" href="#">Advanced</a></nav></div></aside>
            <div class="flex min-w-0 flex-col gap-5">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"><div><h1 class="text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Content Tab Fields</h1><p class="mt-1 text-sm text-slate-500">Drag fields between columns and reorder the assigned fields for this tab.</p></div><div class="flex flex-wrap gap-2"><button type="button" id="reset-btn" class="hidden rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">Reset</button><button type="button" id="save-btn" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">Save Field Order</button></div></div>
                <div id="toast" class="hidden rounded-lg border px-4 py-3 text-sm shadow-sm"></div>
                <div class="grid grid-cols-1 gap-5 xl:grid-cols-[22rem_1fr]">
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3"><div class="flex items-center justify-between"><div><h5 class="text-sm font-semibold text-slate-700">Available Fields</h5><p class="mt-0.5 text-xs text-slate-500">Drag fields into the tab.</p></div><span id="available-count" class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">5</span></div></div>
                        <div class="border-b border-slate-100 px-5 py-3"><input id="field-search" type="search" placeholder="Filter fields..." class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"></div>
                        <ul id="available-fields" class="min-h-[16rem] divide-y divide-slate-100 p-2">
                            {% set available = [
                                {name:'Subtitle', handle:'subtitle', type:'Plain Text'},
                                {name:'Featured Image', handle:'featured_image', type:'Asset'},
                                {name:'Summary', handle:'summary', type:'Textarea'},
                                {name:'Related Articles', handle:'related_articles', type:'Entries'},
                                {name:'Canonical URL', handle:'canonical_url', type:'URL'}
                            ] %}
                            {% for field in available %}
                            <li class="field-row flex items-center gap-3 rounded-md px-3 py-3 hover:bg-slate-50" data-name="{{ field.name|lower }} {{ field.handle|lower }}">
                                <span class="drag-handle shrink-0 text-slate-300"><svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg></span>
                                <div class="min-w-0 flex-1"><p class="truncate text-sm font-medium text-slate-900">{{ field.name }}</p><p class="truncate font-mono text-xs text-slate-400">{{ field.handle }} / {{ field.type }}</p></div>
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 px-5 py-3"><div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"><div><h5 class="text-sm font-semibold text-slate-700">Assigned to Content</h5><p class="mt-0.5 text-xs text-slate-500">Order here controls how fields render on the tab.</p></div><span id="assigned-count" class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">6 assigned</span></div></div>
                        <ul id="assigned-fields" class="min-h-[24rem] divide-y divide-slate-100 p-2">
                            {% set assigned = [
                                {name:'Title', handle:'title', type:'Plain Text', required:true},
                                {name:'Slug', handle:'slug', type:'Plain Text', required:true},
                                {name:'Body', handle:'body', type:'Rich Text', required:false},
                                {name:'Excerpt', handle:'excerpt', type:'Textarea', required:false},
                                {name:'Category', handle:'category', type:'Relation', required:true},
                                {name:'Tags', handle:'tags', type:'Tags', required:false}
                            ] %}
                            {% for field in assigned %}
                            <li class="field-row flex items-center gap-3 rounded-md px-3 py-3 hover:bg-slate-50" data-name="{{ field.name|lower }} {{ field.handle|lower }}">
                                <span class="drag-handle shrink-0 text-slate-300"><svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg></span>
                                <span class="position-badge inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-600">{{ loop.index }}</span>
                                <div class="min-w-0 flex-1"><p class="truncate text-sm font-medium text-slate-900">{{ field.name }}</p><p class="truncate font-mono text-xs text-slate-400">{{ field.handle }} / {{ field.type }}</p></div>
                                {% if field.required %}<span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Required</span>{% endif %}
                                <button type="button" class="remove-field rounded p-1 text-slate-400 hover:bg-red-50 hover:text-red-600" title="Remove from tab"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                            </li>
                            {% endfor %}
                        </ul>
                        <div class="border-t border-slate-100 bg-slate-50 px-5 py-3 text-xs text-slate-500">Tip: drag fields back to Available Fields to remove them from this tab.</div>
                    </div>
                </div>
            </div>
        </div>
        <footer class="mt-auto border-t border-slate-200 bg-white px-4 py-3 sm:px-6"><div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between"><p class="text-xs text-slate-400">&copy; 2026 Admin &mdash; All rights reserved.</p><nav class="flex items-center gap-4 text-xs text-slate-400"><a class="hover:text-slate-600" href="#">Documentation</a><a class="hover:text-slate-600" href="#">Support</a><a class="hover:text-slate-600" href="#">Privacy</a><span class="text-slate-300">|</span><span>v1.0.0</span></nav></div></footer>
    </div>
</div>
<script>
(function () {
    var assigned = document.getElementById('assigned-fields');
    var available = document.getElementById('available-fields');
    var resetBtn = document.getElementById('reset-btn');
    var toast = document.getElementById('toast');
    var original = assigned.innerHTML;

    function refresh() {
        assigned.querySelectorAll('.field-row').forEach(function (row, index) {
            var badge = row.querySelector('.position-badge');
            if (!badge) {
                badge = document.createElement('span');
                badge.className = 'position-badge inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-600';
                row.insertBefore(badge, row.children[1]);
            }
            badge.textContent = index + 1;
        });
        available.querySelectorAll('.position-badge').forEach(function (badge) { badge.remove(); });
        document.getElementById('assigned-count').textContent = assigned.querySelectorAll('.field-row').length + ' assigned';
        document.getElementById('available-count').textContent = available.querySelectorAll('.field-row').length;
        resetBtn.classList.remove('hidden');
    }

    [assigned, available].forEach(function (list) {
        Sortable.create(list, {
            group: 'fields',
            handle: '.drag-handle',
            animation: 150,
            ghostClass: 'sortable-ghost',
            onStart: function () { assigned.classList.add('drop-zone-highlight'); available.classList.add('drop-zone-highlight'); },
            onEnd: function () { assigned.classList.remove('drop-zone-highlight'); available.classList.remove('drop-zone-highlight'); refresh(); }
        });
    });

    assigned.addEventListener('click', function (event) {
        var button = event.target.closest('.remove-field');
        if (!button) return;
        available.appendChild(button.closest('.field-row'));
        refresh();
    });

    document.getElementById('field-search').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        available.querySelectorAll('.field-row').forEach(function (row) {
            row.style.display = !q || (row.dataset.name || '').indexOf(q) !== -1 ? '' : 'none';
        });
    });

    resetBtn.addEventListener('click', function () {
        assigned.innerHTML = original;
        refresh();
        showToast('Field order reset.');
    });

    document.getElementById('save-btn').addEventListener('click', function () {
        original = assigned.innerHTML;
        resetBtn.classList.add('hidden');
        showToast('Field layout saved.');
    });

    function showToast(message) {
        toast.className = 'rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800 shadow-sm';
        toast.textContent = message;
        setTimeout(function () { toast.classList.add('hidden'); }, 4000);
    }
})();
</script>
</body>
</html>
